<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Login | RTS</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* ===== ANIMATION KEYFRAMES ===== */
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            33% { transform: translateY(-10px) rotate(120deg); }
            66% { transform: translateY(5px) rotate(240deg); }
        }

        @keyframes floatSlow {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-15px) scale(1.05); }
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.05); }
        }

        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        @keyframes glow {
            0%, 100% { 
                box-shadow: 0 0 20px rgba(37, 99, 235, 0.3),
                            0 0 40px rgba(124, 58, 237, 0.2),
                            0 0 60px rgba(6, 182, 212, 0.1);
            }
            50% { 
                box-shadow: 0 0 30px rgba(37, 99, 235, 0.5),
                            0 0 60px rgba(124, 58, 237, 0.3),
                            0 0 90px rgba(6, 182, 212, 0.2);
            }
        }

        @keyframes logoReveal {
            0% { 
                transform: scale(0) rotate(-180deg);
                opacity: 0;
                filter: blur(10px);
            }
            60% { 
                transform: scale(1.2) rotate(10deg);
                opacity: 1;
                filter: blur(0);
            }
            80% { 
                transform: scale(0.95) rotate(-5deg);
            }
            100% { 
                transform: scale(1) rotate(0);
                opacity: 1;
                filter: blur(0);
            }
        }

        @keyframes textReveal {
            0% { 
                transform: translateY(20px);
                opacity: 0;
                letter-spacing: 20px;
            }
            60% { 
                transform: translateY(0);
                opacity: 1;
                letter-spacing: normal;
            }
            100% { 
                transform: translateY(0);
                opacity: 1;
                letter-spacing: normal;
            }
        }

        @keyframes orbit {
            0% { transform: rotate(0deg) translateX(150px) rotate(0deg); }
            100% { transform: rotate(360deg) translateX(150px) rotate(-360deg); }
        }

        @keyframes orbitReverse {
            0% { transform: rotate(0deg) translateX(100px) rotate(0deg); }
            100% { transform: rotate(-360deg) translateX(100px) rotate(360deg); }
        }

        @keyframes particleMove {
            0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
            100% { transform: translate(var(--tx), var(--ty)) rotate(360deg); opacity: 0; }
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @keyframes logoRotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @keyframes widthExpand {
            from { width: 0; }
            to { width: 200px; }
        }

        @keyframes heightExpand {
            from { height: 0; }
            to { height: 200px; }
        }

        @keyframes rotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== RESET AND BASE STYLES ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow-x: hidden;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        /* ===== CONTAINER ===== */
        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 16px;
        }

        /* ===== CARD LAYOUT ===== */
        .card {
            display: grid;
            grid-template-columns: 1fr;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            width: 100%;
            min-height: auto;
            animation: fadeIn 0.6s ease-out;
        }

        /* ===== LEFT SECTION - FOR DESKTOP ===== */
        .left-section {
            display: none;
            background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
            background-size: 400% 400%;
            padding: 40px;
            color: white;
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: gradientShift 10s ease infinite;
        }

        /* Animated Background Elements */
        .animated-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
        }

        .orbiting-circle {
            position: absolute;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            animation: orbit 15s linear infinite;
            top: 50%;
            left: 50%;
            transform-origin: center;
        }

        .orbiting-circle:nth-child(2) {
            width: 15px;
            height: 15px;
            background: rgba(255, 255, 255, 0.15);
            animation: orbitReverse 20s linear infinite;
            animation-delay: -5s;
        }

        .orbiting-circle:nth-child(3) {
            width: 25px;
            height: 25px;
            background: rgba(255, 255, 255, 0.08);
            animation: orbit 25s linear infinite;
            animation-delay: -10s;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            animation: particleMove 3s linear infinite;
        }

        /* Logo Container */
        .logo-container {
            position: relative;
            z-index: 2;
            text-align: center;
            width: 100%;
            margin-bottom: 30px;
        }

        .logo-main {
            width: 180px;
            height: 180px;
            margin: 0 auto 30px;
            position: relative;
            animation: logoReveal 1.5s cubic-bezier(0.68, -0.55, 0.265, 1.55) both,
                       glow 3s ease-in-out infinite 1.5s;
        }

        .logo-circle {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.6));
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            border: 3px solid rgba(255, 255, 255, 0.3);
            box-shadow: 
                inset 0 0 30px rgba(255, 255, 255, 0.4),
                0 10px 30px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
        }

        .logo-circle::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent 30%,
                rgba(255, 255, 255, 0.1) 50%,
                transparent 70%
            );
            animation: shimmer 4s infinite linear;
            z-index: 1;
        }

        /* Logo Image Styles */
        .logo-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 50%;
            position: relative;
            z-index: 2;
            animation: logoRotate 20s linear infinite;
            transition: all 0.3s ease;
            padding: 15px;
            background: rgba(255, 255, 255, 0.8);
        }

        /* Logo Lines */
        .logo-line {
            position: absolute;
            background: rgba(255, 255, 255, 0.3);
        }

        .line-horizontal {
            width: 200px;
            height: 2px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: widthExpand 1s ease-out 0.8s both;
        }

        .line-vertical {
            width: 2px;
            height: 200px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: heightExpand 1s ease-out 1s both;
        }

        /* Logo Title Sections */
        .logo-title-container {
            margin-top: 20px;
            width: 100%;
            position: relative;
            z-index: 2;
        }

        .logo-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 5px;
            opacity: 0;
            animation: textReveal 0.8s ease-out forwards;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .logo-title:nth-child(1) {
            animation-delay: 1.2s;
            color: white;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
        }

        .logo-title:nth-child(2) {
            animation-delay: 1.4s;
            color: #e0e7ff;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
        }

        .logo-title:nth-child(3) {
            animation-delay: 1.6s;
            color: #e0e7ff;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
        }

        .logo-acronym {
            font-size: 2.5rem;
            font-weight: 900;
            margin: 15px 0;
            color: white;
            opacity: 0;
            animation: textReveal 0.8s ease-out 3.8s forwards;
            text-shadow: 
                0 0 20px rgba(255, 255, 255, 0.5),
                0 0 40px rgba(37, 99, 235, 0.3);
            position: relative;
            display: inline-block;
        }

        .logo-acronym::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 3px;
            background: linear-gradient(90deg, transparent, white, transparent);
            animation: shimmer 2s infinite linear;
        }

        .logo-subtitle {
            font-size: 1.2rem;
            font-weight: 600;
            color: #fbbf24;
            opacity: 0;
            animation: textReveal 0.8s ease-out 2s forwards;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 10px;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        }

        /* Floating Elements */
        .floating-element {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            animation: float 20s infinite linear;
            z-index: 1;
        }

        .floating-1 {
            width: 60px;
            height: 60px;
            top: 20%;
            left: 15%;
            animation-delay: 0s;
            background: radial-gradient(circle, rgba(255,255,255,0.2), transparent);
        }

        .floating-2 {
            width: 80px;
            height: 80px;
            bottom: 20%;
            right: 15%;
            animation-delay: -5s;
            animation-duration: 25s;
            background: radial-gradient(circle, rgba(255,255,255,0.15), transparent);
        }

        /* Decorative Corner Elements */
        .corner-decoration {
            position: absolute;
            width: 80px;
            height: 80px;
            border: 2px solid rgba(255, 255, 255, 0.1);
            animation: rotate 20s linear infinite;
        }

        .corner-tl {
            top: -40px;
            left: -40px;
            border-radius: 20px;
            border-top: 2px solid rgba(255, 255, 255, 0.3);
            border-left: 2px solid rgba(255, 255, 255, 0.3);
        }

        .corner-br {
            bottom: -40px;
            right: -40px;
            border-radius: 20px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.3);
            border-right: 2px solid rgba(255, 255, 255, 0.3);
        }

        /* Welcome Text */
        .welcome-text {
            position: relative;
            z-index: 2;
            margin-top: 20px;
        }

        .welcome-text h1 {
            font-size: 2rem;
            margin-bottom: 10px;
            opacity: 0;
            animation: textReveal 0.8s ease-out 3.2s forwards;
        }

        .welcome-text p {
            opacity: 0.9;
            line-height: 1.5;
            opacity: 0;
            animation: textReveal 0.8s ease-out 2.4s forwards;
        }

        /* Simple logo style (for compatibility) */
        .simple-logo {
            width: 100px;
            height: 100px;
            margin: 0 auto 20px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: bold;
            color: white;
        }

        /* ===== RIGHT SECTION - FORM ===== */
        .right-section {
            padding: 40px 30px;
            width: 100%;
        }

        /* Form Header */
        .form-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .form-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 8px;
        }

        .form-subtitle {
            color: #6b7280;
            font-size: 0.95rem;
        }

        /* Form Styles */
        .form-group {
            margin-bottom: 20px;
            width: 100%;
        }

        .form-label {
            display: block;
            margin-bottom: 6px;
            font-weight: 500;
            color: #374151;
            font-size: 0.9rem;
        }

        .form-input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            font-size: 16px;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.2s;
            background: white;
        }

        .form-input:focus {
            outline: none;
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .password-container {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #6b7280;
            cursor: pointer;
            padding: 4px;
        }

        .remember-forgot {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 20px 0;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .remember-me input {
            width: 16px;
            height: 16px;
        }

        .forgot-password {
            color: #2563eb;
            text-decoration: none;
            font-size: 0.9rem;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }

        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(37, 99, 235, 0.2);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-submit::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent 30%,
                rgba(255, 255, 255, 0.2) 50%,
                transparent 70%
            );
            animation: shimmer 3s infinite linear;
            z-index: 1;
            pointer-events: none;
        }

        .signup-link-container {
            text-align: center;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
            color: #6b7280;
            font-size: 0.9rem;
        }

        .signup-link {
            color: #2563eb;
            font-weight: 600;
            text-decoration: none;
            margin-left: 4px;
            transition: color 0.2s;
        }

        .signup-link:hover {
            text-decoration: underline;
        }

        /* =========================================== */
        /* RESPONSIVE BREAKPOINTS */
        /* =========================================== */

        /* Tablet and above (768px+) */
        @media (min-width: 768px) {
            .card {
                grid-template-columns: 1fr 1fr;
                min-height: 500px;
            }
            
            .left-section {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
            }
            
            .right-section {
                padding: 50px 40px;
            }
            
            .form-title {
                font-size: 2rem;
            }

            .logo-main {
                width: 150px;
                height: 150px;
            }

            .logo-title {
                font-size: 1.3rem;
            }

            .logo-acronym {
                font-size: 2.2rem;
            }

            .logo-subtitle {
                font-size: 1.1rem;
            }

            .welcome-text h1 {
                font-size: 1.8rem;
            }
        }

        /* Large Desktop (1024px+) */
        @media (min-width: 1024px) {
            .card {
                min-height: 600px;
            }
            
            .logo-main {
                width: 180px;
                height: 180px;
            }
            
            .right-section {
                padding: 60px 50px;
            }
            
            .form-title {
                font-size: 2.2rem;
            }

            .logo-title {
                font-size: 1.5rem;
            }

            .logo-acronym {
                font-size: 2.5rem;
            }

            .logo-subtitle {
                font-size: 1.2rem;
            }

            .welcome-text h1 {
                font-size: 2rem;
            }
        }

        /* Mobile Landscape */
        @media (max-height: 500px) and (orientation: landscape) {
            body {
                padding: 10px;
                align-items: flex-start;
            }
            
            .card {
                max-height: 90vh;
                overflow-y: auto;
            }
            
            .right-section {
                padding: 20px;
            }

            .logo-main {
                width: 100px;
                height: 100px;
                margin-bottom: 15px;
            }
        }

        /* Very Small Mobile */
        @media (max-width: 360px) {
            .right-section {
                padding: 30px 20px;
            }
            
            .form-title {
                font-size: 1.5rem;
            }
            
            .form-input {
                padding: 10px 14px;
                font-size: 15px;
            }
            
            .btn-submit {
                padding: 12px;
                font-size: 15px;
            }

            .logo-main {
                width: 120px;
                height: 120px;
            }

            .logo-title {
                font-size: 1.1rem;
            }

            .logo-acronym {
                font-size: 2rem;
            }

            .logo-subtitle {
                font-size: 1rem;
            }
        }

        /* Fix for iOS Safari */
        input, select, textarea, button {
            -webkit-appearance: none;
            border-radius: 0;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"],
        input[type="tel"] {
            border-radius: 8px;
        }

        /* Prevent zoom on focus in iOS */
        @media screen and (max-width: 768px) {
            input, select, textarea {
                font-size: 16px !important;
            }
        }

        /* Touch Device Optimizations */
        @media (hover: none) and (pointer: coarse) {
            .btn-submit:hover {
                transform: none;
            }
            
            .btn-submit:active {
                transform: scale(0.98);
            }
            
            .logo-circle:hover {
                transform: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <!-- Left Section - Only visible on tablet/desktop -->
            <div class="left-section">
                <!-- Animated Background -->
                <div class="animated-bg">
                    <!-- Orbits will be added by JavaScript -->
                </div>
                
                <!-- Floating Elements -->
                <div class="floating-element floating-1"></div>
                <div class="floating-element floating-2"></div>
                
                <!-- Corner Decorations -->
                <div class="corner-decoration corner-tl"></div>
                <div class="corner-decoration corner-br"></div>
                
                <!-- Animated Logo -->
                <div class="logo-container">
                    <!-- Animated Circle Logo -->
                    <div class="logo-main">
                        <div class="logo-circle">
                            <img src="/img/rid-logo.png" alt="RID Logo" class="logo-image">
                        </div>
                        <!-- Animated Lines -->
                        <div class="logo-line line-horizontal"></div>
                        <div class="logo-line line-vertical"></div>
                    </div>
                    
                    <!-- Logo Titles -->
                    <div class="logo-title-container">
                        <h1 class="logo-title">RESEARCH</h1>
                        <h1 class="logo-title">INNOVATION</h1>
                        <h1 class="logo-title">DISCOVERY</h1>
                        <div class="logo-acronym">RID</div>
                        <h2 class="logo-subtitle">BHARAT</h2>
                    </div>
                </div>

                <!-- Welcome Text -->
                <div class="welcome-text">
                    <h1>Welcome Back</h1>
                    <p>Sign in to access your Research Innovation & Discovery account</p>
                </div>
            </div>

            <!-- Right Section - Form -->
            <div class="right-section">
                <div class="form-header">
                    <h1 class="form-title">Login</h1>
                    <p class="form-subtitle">Enter your credentials to continue</p>
                </div>
                
                <form id="loginForm" method="POST" action="/rts/login">

                    <!-- Email -->
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input 
                            type="email" 
                            id="email" 
                            name="email"
                            class="form-input"
                            placeholder="you@example.com"
                            required
                            autocomplete="email"
                        >
                    </div>
                    
                    <!-- Password -->
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="password-container">
                            <input 
                                type="password" 
                                id="password" 
                                name="password"
                                class="form-input"
                                placeholder="••••••••"
                                required
                                autocomplete="current-password"
                            >
                            <button type="button" class="toggle-password" id="togglePassword">
                                <span class="material-icons" style="font-size: 20px;">visibility</span>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Remember Me & Forgot Password -->
                    <div class="remember-forgot">
                        <div class="remember-me">
                            <input type="checkbox" id="remember" name="remember">
                            <label for="remember" style="font-size: 0.9rem;">Remember me</label>
                        </div>
                        <a href="/rts/forgot-password" class="forgot-password">
Forgot Password?</a>
                    </div>
                    
                    <!-- Submit Button -->
                    <button type="submit" class="btn-submit" id="submitBtn">
                        Sign In
                    </button>
                    
                    <!-- Sign Up Link -->
                    <div class="signup-link-container">
                        <span>Don't have an account?</span>
                       <a href="/rts/register" class="signup-link">Create Account</a>

                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // ===== ANIMATION INITIALIZATION =====
            function initAnimations() {
                createParticles();
                addLogoInteractions();
                createOrbits();
            }

            function createParticles() {
                const animatedBg = document.querySelector('.animated-bg');
                if (!animatedBg) return;
                
                // Create multiple particles
                for (let i = 0; i < 12; i++) {
                    const particle = document.createElement('div');
                    particle.className = 'particle';
                    
                    // Random position
                    const x = Math.random() * 100;
                    const y = Math.random() * 100;
                    
                    // Random movement
                    const tx = (Math.random() - 0.5) * 120;
                    const ty = (Math.random() - 0.5) * 120;
                    
                    // Set CSS custom properties
                    particle.style.setProperty('--tx', `${tx}px`);
                    particle.style.setProperty('--ty', `${ty}px`);
                    
                    // Random size and opacity
                    const size = 2 + Math.random() * 3;
                    particle.style.width = `${size}px`;
                    particle.style.height = `${size}px`;
                    particle.style.opacity = 0.2 + Math.random() * 0.3;
                    
                    // Position
                    particle.style.left = `${x}%`;
                    particle.style.top = `${y}%`;
                    
                    // Random animation delay
                    particle.style.animationDelay = `${Math.random() * 3}s`;
                    particle.style.animationDuration = `${2 + Math.random() * 2}s`;
                    
                    animatedBg.appendChild(particle);
                }
            }

            function createOrbits() {
                const animatedBg = document.querySelector('.animated-bg');
                if (!animatedBg) return;
                
                // Remove existing orbits if any
                document.querySelectorAll('.orbiting-circle').forEach(el => el.remove());
                
                // Create orbit circles
                const orbit1 = document.createElement('div');
                orbit1.className = 'orbiting-circle';
                
                const orbit2 = document.createElement('div');
                orbit2.className = 'orbiting-circle';
                
                const orbit3 = document.createElement('div');
                orbit3.className = 'orbiting-circle';
                
                animatedBg.appendChild(orbit1);
                animatedBg.appendChild(orbit2);
                animatedBg.appendChild(orbit3);
            }

            function addLogoInteractions() {
                const logoCircle = document.querySelector('.logo-circle');
                const logoImage = document.querySelector('.logo-image');
                
                if (!logoCircle || !logoImage) return;
                
                // Hover effect on logo
                logoCircle.addEventListener('mouseenter', () => {
                    logoCircle.style.transform = 'scale(1.05)';
                    logoCircle.style.boxShadow = 
                        'inset 0 0 40px rgba(255, 255, 255, 0.6), 0 15px 40px rgba(0, 0, 0, 0.3)';
                    
                    // Image effects
                    logoImage.style.filter = 'brightness(1.2)';
                    logoImage.style.transform = 'scale(1.1)';
                });
                
                logoCircle.addEventListener('mouseleave', () => {
                    logoCircle.style.transform = 'scale(1)';
                    logoCircle.style.boxShadow = 
                        'inset 0 0 30px rgba(255, 255, 255, 0.4), 0 10px 30px rgba(0, 0, 0, 0.2)';
                    
                    // Reset image effects
                    logoImage.style.filter = 'brightness(1)';
                    logoImage.style.transform = 'scale(1)';
                });
                
                // Click effect - change rotation speed
                logoCircle.addEventListener('click', () => {
                    if (logoImage.style.animationDuration === '2s') {
                        logoImage.style.animationDuration = '20s';
                        logoCircle.style.boxShadow = '0 0 20px rgba(255, 255, 255, 0.5)';
                    } else {
                        logoImage.style.animationDuration = '2s';
                        logoCircle.style.boxShadow = '0 0 40px rgba(255, 255, 255, 0.8)';
                    }
                });
                
                // Add sparkle effect on hover over acronym
                const logoAcronym = document.querySelector('.logo-acronym');
                if (logoAcronym) {
                    logoAcronym.addEventListener('mouseenter', () => {
                        logoAcronym.style.textShadow = 
                            '0 0 30px rgba(255, 255, 255, 0.8), 0 0 60px rgba(37, 99, 235, 0.5)';
                    });
                    
                    logoAcronym.addEventListener('mouseleave', () => {
                        logoAcronym.style.textShadow = 
                            '0 0 20px rgba(255, 255, 255, 0.5), 0 0 40px rgba(37, 99, 235, 0.3)';
                    });
                }
            }

            // ===== FORM FUNCTIONALITY =====
            const loginForm = document.getElementById('loginForm');
            const togglePassword = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('password');
            const submitBtn = document.getElementById('submitBtn');

            // Toggle password visibility
            togglePassword.addEventListener('click', function() {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                this.innerHTML = type === 'password' 
                    ? '<span class="material-icons" style="font-size: 20px;">visibility</span>'
                    : '<span class="material-icons" style="font-size: 20px;">visibility_off</span>';
            });

            // Form validation
            function validateForm() {
                const email = document.getElementById('email').value;
                const password = document.getElementById('password').value;
                
                // Basic email validation
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                const isEmailValid = emailRegex.test(email);
                
                // Basic password validation (at least 6 chars)
                const isPasswordValid = password.length >= 6;
                
                // Update UI
                const emailInput = document.getElementById('email');
                const passwordInput = document.getElementById('password');
                
                if (email) {
                    emailInput.style.borderColor = isEmailValid ? '#10b981' : '#dc2626';
                }
                
                if (password) {
                    passwordInput.style.borderColor = isPasswordValid ? '#10b981' : '#dc2626';
                }
                
                return isEmailValid && isPasswordValid;
            }

            // Real-time validation
            document.getElementById('email').addEventListener('input', validateForm);
            document.getElementById('password').addEventListener('input', validateForm);

            // Form submission
            loginForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                if (!validateForm()) {
                    alert('Please enter valid email and password (min 6 characters)');
                    return;
                }
                
                // Disable button and show loading
                submitBtn.disabled = true;
                submitBtn.textContent = 'Signing in...';
                
                try {
                    const formData = new FormData(this);
                    const data = Object.fromEntries(formData.entries());
                    
                    const response = await fetch('/rts/login', {

                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data)
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        // Show success message
                        alert('Login successful! Redirecting...');
                        window.location.href = result.redirect || '/rts/dashboard';

                    } else {
                        alert(result.message || 'Login failed');
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Sign In';
                    }
                } catch (error) {
                    console.error('Login error:', error);
                    alert('Network error. Please try again.');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Sign In';
                }
            });

            // ===== INITIALIZE ANIMATIONS =====
            // Only initialize if left section exists (desktop view)
            if (window.innerWidth >= 768) {
                initAnimations();
            }

            // Reinitialize on window resize
            window.addEventListener('resize', function() {
                if (window.innerWidth >= 768) {
                    const animatedBg = document.querySelector('.animated-bg');
                    if (animatedBg && !animatedBg.querySelector('.particle')) {
                        initAnimations();
                    }
                }
            });

            // Focus on email input
            setTimeout(() => {
                document.getElementById('email').focus();
            }, 300);
        });
    </script>
</body>
</html>