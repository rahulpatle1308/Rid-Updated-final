                        subject = 'cgl';
                        subjectClass = 'cgl-text';
                        subjectName = 'CGL';
                    } else if(i <= 60) { 
                        subject = 'cpo';
                        subjectClass = 'cpo-text';
                        subjectName = 'CPO';
                    } else if(i <= 90) { 
                        subject = 'pree';
                        subjectClass = 'pree-text';
                        subjectName = 'PREE';
                    } else if(i <= 120) { 
                        subject = 'cpo-main';
                        subjectClass = 'cpo-main-text';
                        subjectName = 'CPO Main';
                    } 
                %>
                    <div class="test-item" data-subject="<%= subject %>">
                        <div class="test-header">
                            <h3>Group-C : <%= i %></h3>
                        </div>

                        <div class="test-action">
