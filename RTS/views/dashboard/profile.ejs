<body>
    <%
        // ===== GLOBAL VARIABLES - DEFINED ONCE AT TOP =====
        // Tests count
        const testsCount = typeof totalTests !== 'undefined' ? totalTests : 
                          (user?.totalTestsAttempted || user?.testHistory?.length || 0);
        
        // Target for platinum certificate
        const certificateTarget = 50;
        const progressPercent = Math.min(Math.round((testsCount / certificateTarget) * 100), 100);
        
        // Average score
        const avgScore = typeof averageScore !== 'undefined' ? averageScore : 
                        (user?.averageScore || 0);
        
        // Best score
        let bestScore = 0;
        if (user?.testHistory?.length > 0) {
            const scores = user.testHistory
                .filter(t => t.percentage || t.resultId?.percentage)
                .map(t => t.percentage || t.resultId?.percentage || 0);
            if (scores.length > 0) {
                bestScore = Math.max(...scores);
            }
        }

        // Total correct answers
        let totalCorrect = 0;
        let totalQuestions = 0;
        if (user?.testHistory?.length > 0) {
            user.testHistory.forEach(t => {
                const score = t.score || t.resultId?.correct || 0;
                const total = t.totalQuestions || t.resultId?.totalQuestions || 0;
                totalCorrect += score;
                totalQuestions += total;
            });
        }
        
        // Achievement status
        const bronzeUnlocked = testsCount >= 10;
        const silverUnlocked = testsCount >= 25;
        const goldUnlocked = testsCount >= 50;
        const achievementsUnlocked = [bronzeUnlocked, silverUnlocked, goldUnlocked].filter(Boolean).length;
        
        // Rank
        const userRank = typeof rank !== 'undefined' ? rank : 1;
        
        // Certificate eligibility
        const isEligibleForCertificate = testsCount >= certificateTarget;
        const testsRemainingForCertificate = Math.max(certificateTarget - testsCount, 0);
        
        // Next achievement target
        let nextTarget = 50;
        let nextAchievementName = "Gold";
        if (testsCount < 10) {
            nextTarget = 10;
            nextAchievementName = "Bronze";
        } else if (testsCount < 25) {
            nextTarget = 25;
            nextAchievementName = "Silver";
        } else if (testsCount < 50) {
            nextTarget = 50;
            nextAchievementName = "Gold";
        }
        const nextProgress = Math.min(Math.round((testsCount / nextTarget) * 100), 100);
    %>

