<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>
        <%= title || 'My Profile' %> | RID Bharat
    </title>

    <!-- Fonts & Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

    <style>
        /* ===== RESET & GLOBAL ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(145deg, #f8fafc 0%, #f1f5f9 100%);
            color: #0f172a;
            line-height: 1.5;
            min-height: 100vh;
            padding: 20px;
            overflow-x: hidden;
            width: 100%;
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            width: 100%;
            overflow: hidden;
        }

        /* ===== TOGGLE BUTTON ===== */
        .toggle-btn {
            display: none;
            position: fixed;
            bottom: 25px;
            right: 25px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: white;
            border: none;
            border-radius: 50%;
            font-size: 1.6rem;
            cursor: pointer;
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.5);
            z-index: 9999;
            align-items: center;
            justify-content: center;
            border: 3px solid white;
            transition: all 0.3s ease;
        }

        .toggle-btn:hover {
            transform: scale(1.1);
        }

        .toggle-btn i {
            transition: transform 0.3s ease;
        }

        .toggle-btn.active i {
            transform: rotate(180deg);
        }

        .overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(5px);
            z-index: 9998;
        }

        .overlay.active {
            display: block;
        }

        /* ===== DASHBOARD GRID ===== */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 24px;
            width: 100%;
        }

        /* ===== LEFT COLUMN ===== */
        .user-sidebar {
            background: #ffffff;
            border-radius: 32px;
            padding: 24px;
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(226, 232, 240, 0.6);
            height: fit-content;
            position: sticky;
            top: 20px;
            width: 100%;
        }

        .profile-photo-section {
            text-align: center;
            margin-bottom: 20px;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .avatar-mega {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 3rem;
            font-weight: 600;
            margin: 0 auto 12px;
            border: 4px solid #ffffff;
            box-shadow: 0 20px 30px -8px rgba(37, 99, 235, 0.3);
            aspect-ratio: 1;
        }

        .online-indicator-large {
            position: absolute;
            bottom: 20px;
            right: calc(50% - 60px);
            width: 16px;
            height: 16px;
            background: #10b981;
            border: 3px solid #ffffff;
            border-radius: 50%;
        }

        .edit-photo-btn-large {
            position: absolute;
            bottom: 20px;
            right: calc(50% - 72px);
            width: 36px;
            height: 36px;
            background: #2563eb;
            border: 3px solid #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            text-decoration: none;
            font-size: 1rem;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }

        .user-title {
            text-align: center;
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e2e8f0;
        }

        .user-title h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
            word-break: break-word;
        }

        .badge-wrapper {
            display: flex;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .role-badge {
            background: #f1f5f9;
            color: #334155;
            padding: 6px 16px;
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.75rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .verified-badge-large {
            background: rgba(16, 185, 129, 0.1);
            color: #059669;
            padding: 6px 16px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .user-info-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 24px;
        }

        .info-row {
            display: flex;
            align-items: center;
            padding: 12px 14px;
            background: #f8fafc;
            border-radius: 18px;
            width: 100%;
        }

        .info-icon {
            width: 36px;
            height: 36px;
            background: rgba(37, 99, 235, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2563eb;
            font-size: 1rem;
            margin-right: 12px;
            flex-shrink: 0;
        }

        .info-content {
            flex: 1;
            min-width: 0;
        }

        .info-label {
            font-size: 0.6rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
            font-weight: 600;
        }

        .info-value {
            font-weight: 600;
            color: #1e293b;
            font-size: 0.8rem;
            word-break: break-word;
        }

        .edit-profile-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: #ffffff;
            border: none;
            border-radius: 100px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            text-decoration: none;
            box-shadow: 0 8px 20px -4px rgba(37, 99, 235, 0.3);
        }

        /* ===== RIGHT COLUMN ===== */
        .main-content {
            display: flex;
            flex-direction: column;
            gap: 24px;
            width: 100%;
            min-width: 0;
        }

        .welcome-rank-wrapper {
            display: grid;
            grid-template-columns: 1fr 260px;
            gap: 24px;
            width: 100%;
        }

        .welcome-banner {
            background: #ffffff;
            border-radius: 32px;
            padding: 24px 28px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-shadow: 0 12px 30px -8px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(226, 232, 240, 0.6);
            width: 100%;
        }

        .welcome-text h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 6px;
            word-break: break-word;
        }

        .welcome-text h2 .welcome-part {
            display: inline;
        }

        .welcome-text p {
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            font-size: 0.9rem;
        }

        .rank-top-card {
            background: linear-gradient(135deg, #1e1b4b, #312e81);
            border-radius: 32px;
            padding: 24px;
            color: #ffffff;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-shadow: 0 20px 30px -8px rgba(49, 46, 129, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 100%;
        }

        .rank-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
        }

        .rank-header i {
            font-size: 1.6rem;
            color: #fbbf24;
        }

        .rank-header h3 {
            font-size: 1rem;
            font-weight: 600;
            text-transform: uppercase;
            opacity: 0.9;
        }

        .rank-number-large {
            font-size: 2.4rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 4px;
            word-break: break-word;
        }

        .rank-label {
            color: #cbd5e1;
            font-size: 0.75rem;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .stats-strip {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            width: 100%;
        }

        .stat-horizontal-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 18px 16px;
            display: flex;
            align-items: center;
            gap: 14px;
            border: 1px solid rgba(226, 232, 240, 0.6);
            box-shadow: 0 8px 20px -4px rgba(0, 0, 0, 0.02);
            width: 100%;
            min-width: 0;
        }

        .stat-horizontal-icon {
            width: 48px;
            height: 48px;
            background: rgba(37, 99, 235, 0.1);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2563eb;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .stat-horizontal-content {
            min-width: 0;
            flex: 1;
        }

        .stat-horizontal-content h3 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #0f172a;
            line-height: 1.2;
            margin-bottom: 4px;
            word-break: break-word;
        }

        .stat-horizontal-content p {
            color: #64748b;
            font-size: 0.7rem;
            font-weight: 500;
            text-transform: uppercase;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ===== ACHIEVEMENTS SECTION - FIXED WIDTH ===== */
        .achievements-row {
            display: flex;
            gap: 20px;
            width: 100%;
            flex-wrap: wrap;
        }

        .achievements-full-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 20px;
            flex: 1;
            min-width: 280px;
            max-width: calc(50% - 10px);
            border: 1px solid rgba(226, 232, 240, 0.6);
            box-shadow: 0 12px 30px -8px rgba(0, 0, 0, 0.05);
        }

        .achievements-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .achievements-header h2 {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .achievements-header h2 i {
            color: #f59e0b;
            font-size: 1.1rem;
        }

        .achievements-header span {
            background: #f1f5f9;
            padding: 4px 12px;
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.7rem;
            color: #475569;
            white-space: nowrap;
        }

        .achievement-progress {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #e2e8f0;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.7rem;
            color: #64748b;
            margin-bottom: 6px;
            font-weight: 500;
            flex-wrap: wrap;
            gap: 5px;
        }

        .progress-bar-container {
            width: 100%;
            height: 8px;
            background: #f1f5f9;
            border-radius: 100px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #f59e0b, #fbbf24);
            border-radius: 100px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 8px;
            color: white;
            font-size: 0.5rem;
            font-weight: 600;
            white-space: nowrap;
        }

        .certificate-download-card {
            background: linear-gradient(135deg, #1e1b4b, #312e81);
            border-radius: 20px;
            padding: 14px;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-top: 12px;
            width: 100%;
            flex-wrap: wrap;
        }

        .certificate-info {
            display: flex;
            align-items: center;
            gap: 10px;
            flex: 1;
            min-width: 200px;
        }

        .certificate-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: #fbbf24;
            flex-shrink: 0;
        }

        .certificate-text {
            min-width: 0;
            flex: 1;
        }

        .certificate-text h4 {
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .certificate-text p {
            color: #cbd5e1;
            font-size: 0.6rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .certificate-download-btn {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #ffffff;
            padding: 8px 14px;
            border-radius: 100px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            box-shadow: 0 8px 16px -4px rgba(245, 158, 11, 0.3);
            white-space: nowrap;
            font-size: 0.7rem;
            border: none;
            cursor: pointer;
        }

        .certificate-download-btn.locked {
            background: #475569;
            box-shadow: none;
            cursor: not-allowed;
            opacity: 0.7;
        }

        .technical-card {
            background: linear-gradient(135deg, #0f172a, #1e293b);
        }

        .technical-card .achievements-header h2 {
            color: white;
        }

        .technical-card .achievements-header span {
            background: rgba(255, 255, 255, 0.15);
            color: #e2e8f0;
        }

        .technical-icon {
            text-align: center;
            margin: 16px 0;
            padding: 16px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
        }

        .technical-icon i {
            font-size: 2.5rem;
            color: #fbbf24;
            margin-bottom: 8px;
            display: block;
        }

        .technical-icon h3 {
            color: white;
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .technical-icon p {
            color: #94a3b8;
            font-size: 0.7rem;
        }

        /* ===== CONTENT CARDS ===== */
        .content-card {
            background: #ffffff;
            border-radius: 32px;
            padding: 24px;
            box-shadow: 0 12px 30px -8px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(226, 232, 240, 0.6);
            width: 100%;
            overflow: hidden;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .card-header h2 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-header a {
            color: #2563eb;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: #f1f5f9;
            border-radius: 100px;
            white-space: nowrap;
        }

        .filter-buttons {
            display: flex;
            gap: 4px;
            background: #f1f5f9;
            padding: 4px;
            border-radius: 100px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 6px 16px;
            border-radius: 100px;
            border: none;
            font-weight: 600;
            font-size: 0.75rem;
            cursor: pointer;
            background: transparent;
            color: #64748b;
            white-space: nowrap;
        }

        .filter-btn.active {
            background: #ffffff;
            color: #2563eb;
            box-shadow: 0 4px 8px -2px rgba(0, 0, 0, 0.05);
        }

        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            width: 100%;
            margin: 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 600px;
        }

        th {
            text-align: left;
            padding: 14px 10px;
            background: #f8fafc;
            color: #475569;
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        td {
            padding: 14px 10px;
            border-bottom: 1px solid #f1f5f9;
            color: #1e293b;
            font-size: 0.85rem;
        }

        .subject-tag {
            background: rgba(37, 99, 235, 0.1);
            color: #2563eb;
            padding: 4px 12px;
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.7rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .score-badge {
            background: #dcfce7;
            color: #059669;
            padding: 4px 12px;
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.7rem;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            white-space: nowrap;
        }

        .chart-container {
            height: 220px;
            position: relative;
            width: 100%;
        }

        canvas {
            max-width: 100%;
            height: auto !important;
        }

        .logout-btn {
            padding: 12px 24px;
            background: white;
            color: #ef4444;
            border-radius: 100px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid #fee2e2;
            transition: all 0.3s ease;
        }

        .logout-btn:hover {
            background: #fef2f2;
            border-color: #fecaca;
        }

        /* ===== MODAL ===== */
        .modal {
            display: none;
            position: fixed;
            z-index: 10000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
        }

        .modal-content {
            background: #ffffff;
            margin: 40px auto;
            padding: 28px;
            border-radius: 40px;
            width: 90%;
            max-width: 1200px;
            max-height: 85vh;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.3);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid #e2e8f0;
        }

        .modal-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
        }

        .close-modal {
            font-size: 1.8rem;
            font-weight: 600;
            color: #64748b;
            cursor: pointer;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: #f1f5f9;
        }

        .test-stats-summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
            padding: 20px;
            background: #f8fafc;
            border-radius: 24px;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
        }

        .stat-details h4 {
            font-size: 0.7rem;
            color: #64748b;
            margin-bottom: 4px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .stat-details p {
            font-size: 1.3rem;
            font-weight: 700;
            color: #0f172a;
            line-height: 1;
        }

        /* ===== RESPONSIVE FIXES ===== */
        @media screen and (max-width: 1280px) {
            .stats-strip {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media screen and (max-width: 1024px) {
            .toggle-btn {
                display: flex;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .user-sidebar {
                position: fixed;
                left: -350px;
                top: 0;
                width: 320px;
                max-width: 85%;
                height: 100vh;
                z-index: 10000;
                border-radius: 0 30px 30px 0;
                transition: left 0.3s ease;
                overflow-y: auto;
                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
                margin: 0;
                padding: 25px;
            }

            .user-sidebar.active {
                left: 0;
            }

            .achievements-full-card {
                max-width: 100%;
            }
        }

        @media screen and (max-width: 900px) {
            body {
                padding: 15px;
            }

            .welcome-rank-wrapper {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .welcome-banner {
                padding: 20px;
            }

            .welcome-text h2 {
                font-size: 1.2rem;
            }

            .welcome-text h2 .welcome-part {
                display: none;
            }

            .rank-top-card {
                padding: 20px;
            }

            .rank-number-large {
                font-size: 2rem;
            }

            .stats-strip {
                gap: 12px;
            }

            .stat-horizontal-card {
                padding: 15px;
            }

            .achievements-full-card {
                min-width: 100%;
                max-width: 100%;
            }
        }

        @media screen and (max-width: 600px) {
            body {
                padding: 12px;
            }

            .stats-strip {
                grid-template-columns: 1fr;
            }

            .certificate-download-card {
                flex-direction: column;
                align-items: flex-start;
            }

            .certificate-download-btn {
                width: 100%;
                justify-content: center;
            }

            .certificate-info {
                width: 100%;
            }

            .test-stats-summary {
                grid-template-columns: 1fr;
            }

            .modal-content {
                padding: 20px;
                width: 95%;
            }

            .toggle-btn {
                width: 50px;
                height: 50px;
                font-size: 1.3rem;
                bottom: 15px;
                right: 15px;
            }
        }
    </style>
</head>

<body>
    <button class="toggle-btn" id="toggleSidebar" onclick="toggleSidebar()">
        <i class="fas fa-chevron-right"></i>
    </button>

    <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

    <% const testsCount=typeof totalTests !=='undefined' ? totalTests : (user?.totalTestsAttempted ||
        user?.testHistory?.length || 0); const certificateTarget=50; const avgScore=typeof averageScore !=='undefined' ?
        averageScore : (user?.averageScore || 0); let bestScore=0; if (user?.testHistory?.length> 0) {
        const scores = user.testHistory
        .filter(t => t.percentage || t.resultId?.percentage)
        .map(t => t.percentage || t.resultId?.percentage || 0);
        if (scores.length > 0) {
        bestScore = Math.max(...scores);
        }
        }

        let totalCorrect = 0;
        let totalQuestions = 0;
        if (user?.testHistory?.length > 0) {
        user.testHistory.forEach(t => {
        const score = t.score || t.resultId?.correct || 0;
        const total = t.totalQuestions || t.resultId?.totalQuestions || 0;
        totalCorrect += score;
        totalQuestions += total;
        });
        }

        const achievementsUnlocked = [testsCount >= 10, testsCount >= 25, testsCount >= 50].filter(Boolean).length;
        const userRank = typeof rank !== 'undefined' ? rank : 1;
        const isEligibleForCertificate = testsCount >= certificateTarget;
        const testsRemainingForCertificate = Math.max(certificateTarget - testsCount, 0);

        let nextTarget = testsCount < 50 ? 50 : testsCount < 25 ? 25 : 50; let nextAchievementName=testsCount < 10
            ? "Bronze" : testsCount < 25 ? "Silver" : "Gold" ; const nextProgress=Math.min(Math.round((testsCount /
            nextTarget) * 100), 100); const technicalTestsCompleted=typeof techCount !=='undefined' ? techCount : 0;
            const technicalTestsTotal=50; const technicalProgress=Math.round( (technicalTestsCompleted /
            technicalTestsTotal) * 100 ); const isTechUnlocked=technicalTestsCompleted>= technicalTestsTotal;
            const techRemaining = technicalTestsTotal - technicalTestsCompleted;

            %>

            <div class="container">
                <div class="dashboard-grid">

                    <!-- LEFT COLUMN -->
                    <div class="user-sidebar" id="sidebar">
                        <div class="profile-photo-section">
                            <% if (user?.profilePhoto) { %>
                                <img src="<%= user.profilePhoto %>" alt="<%= user.fullName %>" class="avatar-mega"
                                    loading="lazy">
                                <% } else { %>
                                    <div class="avatar-mega">
                                        <%= user?.initials || (user?.name ? user.name.charAt(0).toUpperCase() : 'U' ) %>
                                    </div>
                                    <% } %>
                                        <span class="online-indicator-large"></span>
                                        <a href="/profile/edit" class="edit-photo-btn-large">
                                            <i class="fas fa-camera"></i>
                                        </a>
                        </div>

                        <div class="user-title">
                            <h1>
                                <%= user?.name || 'User' %>
                            </h1>
                            <div class="badge-wrapper">
                                <span class="role-badge">
                                    <i class="fas fa-graduation-cap"></i>
                                    <%= user?.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : 'Student'
                                        %>
                                </span>
                                <span class="verified-badge-large">
                                    <i class="fas fa-check-circle"></i> Verified
                                </span>
                            </div>
                        </div>

                        <div class="user-info-grid">
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-envelope"></i></div>
                                <div class="info-content">
                                    <div class="info-label">Email</div>
                                    <div class="info-value">
                                        <%= user?.email || 'email@example.com' %>
                                    </div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                                <div class="info-content">
                                    <div class="info-label">Mobile</div>
                                    <div class="info-value">
                                        <%= user.phone || 'Not Provided' %>
                                    </div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-cake-candles"></i></div>
                                <div class="info-content">
                                    <div class="info-label">DOB</div>
                                    <div class="info-value">
                                        <% if (user?.dob) { %>
                                            <%= new Date(user.dob).toLocaleDateString('en-IN', { day: 'numeric' ,
                                                month: 'short' , year: 'numeric' }) %>
                                                <% } else { %>15 Jan 2000<% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                                <div class="info-content">
                                    <div class="info-label">Location</div>
                                    <div class="info-value">
                                        <%= user?.district || 'Mumbai' %>, <%= user?.state || 'Maharashtra' %>
                                    </div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-calendar-alt"></i></div>
                                <div class="info-content">
                                    <div class="info-label">Joined</div>
                                    <div class="info-value">
                                        <% if (user?.createdAt) { %>
                                            <%= new Date(user.createdAt).toLocaleDateString('en-IN', { month: 'short' ,
                                                year: 'numeric' }) %>
                                                <% } else { %>Mar 2024<% } %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <a href="/rts/profile/edit" style="text-decoration: none;">
                            <button class="edit-profile-btn">
                                <i class="fas fa-edit"></i> Edit Profile
                                <i class="fas fa-arrow-right"></i>
                            </button>
                        </a>
                    </div>

                    <!-- RIGHT COLUMN -->
                    <div class="main-content">

                        <!-- Welcome + Rank -->
                        <div class="welcome-rank-wrapper">
                            <div class="welcome-banner">
                                <div class="welcome-text">
                                    <h2>
                                        <span class="welcome-part">Welcome </span>
                                        <%= user?.name || 'User' %>  👋
                                    </h2>
                                    <p>
                                        <i class="fas fa-chart-line" style="color: #2563eb;"></i>
                                        <% if (avgScore>= 75) { %>
                                            Excellent performance! 🌟
                                            <% } else if (avgScore>= 50) { %>
                                                Good progress! 📈
                                                <% } else { %>
                                                    Start your journey! 🚀
                                                    <% } %>
                                    </p>
                                </div>
                            </div>
                            <div class="rank-top-card">
                                <div class="rank-header">
                                    <i class="fas fa-crown"></i>
                                    <h3>Your Rank</h3>
                                </div>
                                <div class="rank-number-large">
                                    <%= userRank %>
                                </div>
                                <div class="rank-label">
                                    <i class="fas fa-trophy"></i>
                                    <% if (userRank <=10) { %>
                                        Top 1% Performer
                                        <% } else if (userRank <=50) { %>
                                            Top 5% Performer
                                            <% } else if (userRank <=100) { %>
                                                Top 10% Performer
                                                <% } else { %>
                                                    Keep climbing! 🧗
                                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <!-- Stats Strip -->
                        <div class="stats-strip">
                            <div class="stat-horizontal-card">
                                <div class="stat-horizontal-icon"><i class="fas fa-file-alt"></i></div>
                                <div class="stat-horizontal-content">
                                    <h3>
                                        <%= testsCount %>
                                    </h3>
                                    <p>Total Tests</p>
                                </div>
                            </div>
                            <div class="stat-horizontal-card">
                                <div class="stat-horizontal-icon"><i class="fas fa-star"></i></div>
                                <div class="stat-horizontal-content">
                                    <h3>
                                        <%= bestScore %>%
                                    </h3>
                                    <p>Best Score</p>
                                </div>
                            </div>
                            <div class="stat-horizontal-card">
                                <div class="stat-horizontal-icon"><i class="fas fa-chart-line"></i></div>
                                <div class="stat-horizontal-content">
                                    <h3>
                                        <%= avgScore %>%
                                    </h3>
                                    <p>Avg. Score</p>
                                </div>
                            </div>
                            <div class="stat-horizontal-card">
                                <div class="stat-horizontal-icon"><i class="fas fa-medal"></i></div>
                                <div class="stat-horizontal-content">
                                    <h3>
                                        <%= achievementsUnlocked %>
                                    </h3>
                                    <p>Achievements</p>
                                </div>
                            </div>
                        </div>

                        <!-- ACHIEVEMENTS ROW - FIXED -->
                        <div class="achievements-row">

                            <!-- LEFT CARD - ACHIEVEMENTS -->
                            <div class="achievements-full-card">
                                <div class="achievements-header">
                                    <h2><i class="fas fa-medal"></i> Achievements</h2>
                                    <span>Level <%= Math.floor(testsCount / 10) + 1 %></span>
                                </div>

                                <% if (testsCount < 50) { %>
                                    <div class="achievement-progress">
                                        <div class="progress-label">
                                            <span>Progress to <%= nextAchievementName %></span>
                                            <span>
                                                <%= testsCount %> / <%= nextTarget %>
                                            </span>
                                        </div>
                                        <div class="progress-bar-container">
                                            <div class="progress-fill" style="width: <%= nextProgress %>%;">
                                                <%= nextProgress %>%
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>

                                        <div class="certificate-download-card">
    <div class="certificate-info">
        <div class="certificate-icon">
            <i class="fas fa-certificate"></i>
        </div>
        <div class="certificate-text">
            <h4>Platinum Certificate</h4>
            <p>
                <% if (isEligibleForCertificate) { %>
                    🎉 Completed 50 tests!
                <% } else { %>
                    <%= testsRemainingForCertificate %> tests to go
                <% } %>
            </p>
        </div>
    </div>
    <% if (isEligibleForCertificate) { %>
        <a href="/rts/certificate/platinum" class="certificate-download-btn">
            Download Certificate
        </a>
    <% } else { %>
        <button class="certificate-download-btn locked">
            Complete 50 Tests to Unlock
        </button>
    <% } %>
</div>
                            </div>

                            <!-- RIGHT CARD - TECHNICAL CERTIFICATE -->
                            <div class="achievements-full-card technical-card">
                                <div class="achievements-header">
                                    <h2><i class="fas fa-code"></i> Tech-Interview</h2>
                                    <span>Certificate</span>
                                </div>


                                <div class="achievement-progress">
                                    <div class="progress-label">
                                        <span style="color: #cbd5e1;">Progress</span>
                                        <span style="color: #fbbf24;">
                                            <%= technicalTestsCompleted %> / <%= technicalTestsTotal %>
                                        </span>
                                    </div>
                                    <div class="progress-bar-container" style="background: rgba(255,255,255,0.2);">
                                        <div class="progress-fill"
                                            style="width: <%= technicalProgress %>%; background: linear-gradient(90deg, #fbbf24, #f59e0b);">
                                            <%= technicalProgress %>%
                                        </div>
                                    </div>
                                </div>

                                <div class="certificate-download-card"
                                    style="background: linear-gradient(135deg, #1e293b, #0f172a);">
                                    <div class="certificate-info">
                                        <div class="certificate-icon" style="background: rgba(251, 191, 36, 0.2);">
                                            <i class="fas fa-certificate" style="color: #fbbf24;"></i>
                                        </div>
                                        <div class="certificate-text">
                                            <h4 style="color: white;">Certificate</h4>
                                            <p style="color: #94a3b8;">
                                                <% if (technicalTestsCompleted>= technicalTestsTotal) { %>
                                                    🎉 Certificate ready!
                                                    <% } else { %>
                                                        <%= techRemaining %> tests left
                                                            <% } %>
                                            </p>
                                        </div>
                                    </div>
                                    <% if (isTechUnlocked) { %>
                                        <a href="/rts/certificate/technical" class="certificate-download-btn">
                                            Download
                                        </a>
                                        <% } else { %>
                                            <button class="certificate-download-btn locked">
                                                Locked
                                            </button>
                                            <% } %>
                                </div>
                            </div>
                        </div>

                       

                        <!-- Test History -->
                        <div class="content-card">
                            <div class="card-header">
                                <h2><i class="fas fa-clock-rotate-left"></i> Recent Tests</h2>
                                <a href="javascript:void(0)" onclick="openTestHistoryModal()">
                                    View All <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>

                            <div class="table-responsive">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Subject</th>
                                            <th>Set</th>
                                            <th>Score</th>
                                            <th>%</th>
                                            <th>Date</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (user?.testHistory && user.testHistory.length> 0) {
                                            const recentTests = [...user.testHistory]
                                            .filter(t => t.resultId || t.percentage)
                                            .sort((a, b) => new Date(b.date || b.createdAt || 0) - new Date(a.date ||
                                            a.createdAt || 0))
                                            .slice(0, 5);
                                            recentTests.forEach(t => {
                                            const res = t.resultId || {};
                                            %>
                                            <tr>
                                                <td>
                                                    <span class="subject-tag">
                                                        <i class="fas fa-code"></i>
                                                        <%= t.subject || res.subject || 'HTML' %>
                                                    </span>
                                                </td>
                                                <td><strong>Set <%= t.setNo || res.setNo || 1 %></strong></td>
                                                <td>
                                                    <%= t.score || res.correct || 0 %>/<%= t.totalQuestions ||
                                                            res.totalQuestions || 0 %>
                                                </td>
                                                <td><span class="score-badge">
                                                        <i class="fas fa-percent"></i>
                                                        <%= Math.round(t.percentage || res.percentage || 0) %>%
                                                    </span></td>
                                                <td>
                                                    <%= t.date || res.createdAt ? new Date(t.date ||
                                                        res.createdAt).toLocaleDateString('en-IN', { day: 'numeric' ,
                                                        month: 'short' }) : 'N/A' %>
                                                </td>
                                                <td>
                                                    <% if (t.resultId?._id) { %>
                                                        <a href="/rts/quiz/<%= t.category || 'technical' %>/<%= t.subject || res.subject %>/<%= t.setNo || res.setNo %>/result/<%= t.resultId._id %>"
                                                            style="background:#2563eb; color:white; padding:6px 16px; border-radius:100px; text-decoration:none; font-size:0.7rem;">
                                                            <i class="fas fa-eye"></i> View
                                                        </a>
                                                        <% } else { %>—<% } %>
                                                </td>
                                            </tr>
                                            <% }); } else { %>
                                                <tr>
                                                    <td colspan="6" style="text-align:center; padding:40px;">
                                                        <i class="fas fa-clipboard-list"
                                                            style="font-size:2.5rem; color:#cbd5e1;"></i>
                                                        <h3>No Tests Yet</h3>
                                                        <a href="/technical-coding" class="start-test-btn">
                                                            <i class="fas fa-play"></i> Start First Test
                                                        </a>
                                                    </td>
                                                </tr>
                                                <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Logout -->
                        <div style="display: flex; justify-content: flex-end;">
                            <a href="/login" onclick="return confirm('Are you sure?')" class="logout-btn">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL -->
            <div id="testHistoryModal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2>Complete Test History</h2>
                        <span class="close-modal" onclick="closeTestHistoryModal()">&times;</span>
                    </div>

                    <div class="test-stats-summary">
                        <div class="stat-item">
                            <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
                            <div class="stat-details">
                                <h4>Total Tests</h4>
                                <p>
                                    <%= testsCount %>
                                </p>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon"><i class="fas fa-star"></i></div>
                            <div class="stat-details">
                                <h4>Best Score</h4>
                                <p>
                                    <%= bestScore %>%
                                </p>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                            <div class="stat-details">
                                <h4>Avg. Score</h4>
                                <p>
                                    <%= avgScore %>%
                                </p>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                            <div class="stat-details">
                                <h4>Correct</h4>
                                <p>
                                    <%= totalCorrect %>/<%= totalQuestions %>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table>
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Subject</th>
                                    <th>Set</th>
                                    <th>Score</th>
                                    <th>%</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (user?.testHistory && user.testHistory.length> 0) {
                                    const allTests = [...user.testHistory]
                                    .filter(t => t.resultId || t.percentage)
                                    .sort((a, b) => new Date(b.date || b.createdAt || 0) - new Date(a.date ||
                                    a.createdAt || 0));
                                    allTests.forEach((t, idx) => {
                                    const res = t.resultId || {};
                                    %>
                                    <tr>
                                        <td>#<%= idx + 1 %>
                                        </td>
                                        <td>
                                            <%= t.subject || res.subject || 'HTML' %>
                                        </td>
                                        <td>Set <%= t.setNo || res.setNo || 1 %>
                                        </td>
                                        <td>
                                            <%= t.score || res.correct || 0 %>/<%= t.totalQuestions ||
                                                    res.totalQuestions || 0 %>
                                        </td>
                                        <td>
                                            <%= Math.round(t.percentage || res.percentage || 0) %>%
                                        </td>
                                        <td>
                                            <%= t.date || res.createdAt ? new Date(t.date ||
                                                res.createdAt).toLocaleDateString('en-IN', { day: 'numeric' ,
                                                month: 'short' }) : 'N/A' %>
                                        </td>
                                        <td>
                                            <a
                                                href="/quiz/<%= t.category || 'technical' %>/<%= (t.subject || 'HTML') %>/test-<%= t.setNo || 1 %>/result/<%= t.resultId?._id || t.resultId %>">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); } else { %>
                                        <tr>
                                            <td colspan="7" style="text-align:center;">No History Found</td>
                                        </tr>
                                        <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <script>
                // Chart
                document.addEventListener('DOMContentLoaded', function () {
                    const ctx = document.getElementById('performanceChart').getContext('2d');
                    let labels = [], scores = [];
            
            <% if (user?.testHistory && user.testHistory.length > 0) {
                        const last7Tests = [...user.testHistory]
                            .filter(t => t.percentage || t.resultId?.percentage)
                            .sort((a, b) => new Date(a.date || a.createdAt || 0) - new Date(b.date || b.createdAt || 0))
                            .slice(-7); 
            %>
                            labels = <% - JSON.stringify(last7Tests.map((t, i) => `Test ${i + 1}`)) %>;
                        scores = <% - JSON.stringify(last7Tests.map(t => Math.round(t.percentage || t.resultId?.percentage || 0))) %>;
            <% } else { %>
                        labels =['No Data'];
                        scores = [0];
            <% } %>

                        new Chart(ctx, {
                            type: 'line',
                            data: {
                                labels: labels,
                                datasets: [{
                                    data: scores,
                                    borderColor: '#2563eb',
                                    backgroundColor: 'rgba(37, 99, 235, 0.1)',
                                    borderWidth: 3,
                                    tension: 0.3,
                                    fill: true
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: { legend: { display: false } },
                                scales: { y: { beginAtZero: true, max: 100 } }
                            }
                        });
                });

                // Toggle
                function toggleSidebar() {
                    const sidebar = document.getElementById('sidebar');
                    const overlay = document.getElementById('overlay');
                    const toggleBtn = document.getElementById('toggleSidebar');

                    sidebar.classList.toggle('active');
                    overlay.classList.toggle('active');
                    toggleBtn.classList.toggle('active');

                    const icon = toggleBtn.querySelector('i');
                    if (sidebar.classList.contains('active')) {
                        icon.classList.remove('fa-chevron-right');
                        icon.classList.add('fa-chevron-left');
                    } else {
                        icon.classList.remove('fa-chevron-left');
                        icon.classList.add('fa-chevron-right');
                    }
                }

                function closeSidebar() {
                    const sidebar = document.getElementById('sidebar');
                    const overlay = document.getElementById('overlay');
                    const toggleBtn = document.getElementById('toggleSidebar');

                    sidebar.classList.remove('active');
                    overlay.classList.remove('active');
                    toggleBtn.classList.remove('active');

                    toggleBtn.querySelector('i').className = 'fas fa-chevron-right';
                }

                // Modal
                function openTestHistoryModal() {
                    document.getElementById('testHistoryModal').style.display = 'block';
                    document.body.style.overflow = 'hidden';
                }

                function closeTestHistoryModal() {
                    document.getElementById('testHistoryModal').style.display = 'none';
                    document.body.style.overflow = 'auto';
                }

                window.onclick = function (e) {
                    const modal = document.getElementById('testHistoryModal');
                    if (e.target == modal) closeTestHistoryModal();
                }

                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') {
                        closeTestHistoryModal();
                        closeSidebar();
                    }
                });

                // Filter buttons
                document.querySelectorAll('.filter-btn').forEach(btn => {
                    btn.addEventListener('click', function () {
                        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                        this.classList.add('active');
                    });
                });
            </script>
</body>

</html>