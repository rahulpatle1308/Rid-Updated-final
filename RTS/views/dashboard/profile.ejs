<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title || 'My Profile' %> | RID Bharat</title>
    
    <!-- Fonts & Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    
    <style>
        /* ===== RESET & GLOBAL ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(145deg, #f6f8fd 0%, #f1f5f9 100%);
            color: #0b1c38;
            line-height: 1.5;
            min-height: 100vh;
            padding: clamp(15px, 3vw, 30px) clamp(10px, 4vw, 20px);
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            width: 100%;
        }

        /* ===== ANIMATIONS ===== */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== 2-COLUMN LAYOUT ===== */
        .dashboard-grid {
            display: grid;
            grid-template-columns: minmax(300px, 380px) 1fr;
            gap: clamp(16px, 2vw, 28px);
            animation: fadeIn 0.8s ease-out;
        }

        /* ===== LEFT COLUMN - USER CARD ===== */
        .user-sidebar {
            background: #ffffff;
            border-radius: 40px;
            padding: clamp(20px, 3vw, 30px);
            box-shadow: 0 20px 35px -8px rgba(0, 20, 40, 0.06);
            border: 1px solid rgba(37, 99, 235, 0.04);
            height: fit-content;
            position: sticky;
            top: clamp(15px, 3vw, 30px);
            transition: all 0.3s ease;
            width: 100%;
        }

        .user-sidebar:hover {
            box-shadow: 0 30px 45px -12px rgba(37, 99, 235, 0.12);
            border-color: rgba(37, 99, 235, 0.1);
        }

        /* Profile Photo Section */
        .profile-photo-section {
            text-align: center;
            margin-bottom: 25px;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .avatar-mega {
            width: clamp(90px, 20vw, 140px);
            height: clamp(90px, 20vw, 140px);
            border-radius: 50%;
            object-fit: cover;
            background: linear-gradient(145deg, #2563eb, #4f46e5);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: clamp(2rem, 8vw, 3.5rem);
            font-weight: 600;
            margin: 0 auto 15px;
            border: 4px solid #ffffff;
            box-shadow: 0 20px 40px rgba(37, 99, 235, 0.25);
            transition: all 0.3s ease;
            aspect-ratio: 1;
        }

        .avatar-mega:hover {
            transform: scale(1.03);
            box-shadow: 0 25px 50px rgba(37, 99, 235, 0.35);
        }

        .online-indicator-large {
            position: absolute;
            bottom: 20px;
            right: calc(50% - clamp(40px, 10vw, 70px));
            width: clamp(14px, 3vw, 22px);
            height: clamp(14px, 3vw, 22px);
            background: #10b981;
            border: 3px solid #ffffff;
            border-radius: 50%;
        }

        .edit-photo-btn-large {
            position: absolute;
            bottom: 20px;
            right: calc(50% - clamp(48px, 12vw, 80px));
            width: clamp(32px, 6vw, 42px);
            height: clamp(32px, 6vw, 42px);
            background: #2563eb;
            border: 3px solid #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
        }

        .edit-photo-btn-large:hover {
            background: #1d4ed8;
            transform: rotate(15deg) scale(1.1);
        }

        /* User Title & Badges */
        .user-title {
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 25px;
            border-bottom: 2px dashed #f1f5f9;
        }

        .user-title h1 {
            font-size: clamp(1.3rem, 5vw, 2rem);
            font-weight: 800;
            color: #0b1c38;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
            word-break: break-word;
        }

        .badge-wrapper {
            display: flex;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .role-badge {
            background: linear-gradient(145deg, #f1f5f9, #e2e8f0);
            color: #1e293b;
            padding: 8px 22px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid #ffffff;
        }

        .verified-badge-large {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            padding: 8px 22px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        /* ===== USER INFO GRID - LEFT SIDE DATA ===== */
        .user-info-grid {
            display: flex;
            flex-direction: column;
            gap: clamp(12px, 2vw, 16px);
            margin-bottom: 30px;
        }

        .info-row {
            display: flex;
            align-items: center;
            padding: clamp(12px, 2vw, 14px) clamp(14px, 2vw, 18px);
            background: #fafcff;
            border-radius: 22px;
            transition: all 0.3s ease;
            border: 1px solid rgba(0,0,0,0.02);
            width: 100%;
        }

        .info-row:hover {
            background: #ffffff;
            border-color: rgba(37, 99, 235, 0.1);
            transform: translateX(8px);
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.06);
        }

        .info-icon {
            width: clamp(36px, 6vw, 48px);
            height: clamp(36px, 6vw, 48px);
            background: linear-gradient(145deg, rgba(37, 99, 235, 0.1), rgba(79, 70, 229, 0.1));
            border-radius: clamp(14px, 3vw, 18px);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2563eb;
            font-size: clamp(0.9rem, 4vw, 1.2rem);
            margin-right: clamp(12px, 2vw, 16px);
            flex-shrink: 0;
        }

        .info-content {
            flex: 1;
            min-width: 0;
        }

        .info-label {
            font-size: 0.7rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 3px;
        }

        .info-value {
            font-weight: 700;
            color: #1e293b;
            font-size: clamp(0.85rem, 2.5vw, 1rem);
            display: flex;
            align-items: center;
            gap: 8px;
            word-break: break-word;
        }

        /* Edit Profile Button */
        .edit-profile-btn {
            width: 100%;
            padding: clamp(14px, 2.5vw, 16px);
            background: linear-gradient(145deg, #2563eb, #4f46e5);
            color: #ffffff;
            border: none;
            border-radius: 50px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: clamp(0.9rem, 2.5vw, 1rem);
            text-decoration: none;
        }

        .edit-profile-btn:hover {
            background: linear-gradient(145deg, #1d4ed8, #4f46e5);
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
        }

        /* ===== RIGHT COLUMN ===== */
        .main-content {
            display: flex;
            flex-direction: column;
            gap: clamp(20px, 2.5vw, 28px);
            width: 100%;
        }

        /* Welcome + Rank Wrapper */
        .welcome-rank-wrapper {
            display: grid;
            grid-template-columns: 1fr minmax(200px, 280px);
            gap: clamp(16px, 2vw, 20px);
            align-items: stretch;
        }

        .welcome-banner {
            background: #ffffff;
            border-radius: 32px;
            padding: clamp(20px, 3vw, 28px) clamp(24px, 3vw, 32px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.02);
            border: 1px solid rgba(37, 99, 235, 0.04);
            width: 100%;
        }

        .welcome-text h2 {
            font-size: clamp(1.2rem, 4vw, 1.6rem);
            font-weight: 700;
            color: #0b1c38;
            margin-bottom: 8px;
            word-break: break-word;
        }

        .welcome-text p {
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        /* Rank Card */
        .rank-top-card {
            background: linear-gradient(145deg, #1e1b4b, #312e81);
            border-radius: 32px;
            padding: clamp(20px, 3vw, 28px);
            color: #ffffff;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-shadow: 0 15px 30px rgba(49, 46, 129, 0.2);
            border: 1px solid rgba(255,255,255,0.1);
            width: 100%;
        }

        .rank-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
        }

        .rank-header i {
            font-size: 1.8rem;
            color: #fbbf24;
        }

        .rank-header h3 {
            font-size: clamp(1rem, 3vw, 1.2rem);
            font-weight: 700;
        }

        .rank-number-large {
            font-size: clamp(2rem, 8vw, 2.8rem);
            font-weight: 800;
            line-height: 1;
            margin-bottom: 5px;
            position: relative;
            z-index: 1;
            word-break: break-word;
        }

        .rank-label {
            color: #cbd5e1;
            font-size: 0.85rem;
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        /* Stats Strip - 4 Cards Horizontal */
        .stats-strip {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: clamp(12px, 1.5vw, 20px);
            width: 100%;
        }

        .stat-horizontal-card {
            background: #ffffff;
            border-radius: 24px;
            padding: clamp(16px, 2vw, 22px);
            display: flex;
            align-items: center;
            gap: clamp(12px, 1.5vw, 18px);
            transition: all 0.3s ease;
            border: 1px solid rgba(0,0,0,0.02);
            box-shadow: 0 10px 25px rgba(0,0,0,0.02);
            width: 100%;
        }

        .stat-horizontal-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 45px -12px rgba(37, 99, 235, 0.12);
            border-color: rgba(37, 99, 235, 0.1);
        }

        .stat-horizontal-icon {
            width: clamp(44px, 8vw, 60px);
            height: clamp(44px, 8vw, 60px);
            background: linear-gradient(145deg, rgba(37, 99, 235, 0.1), rgba(79, 70, 229, 0.1));
            border-radius: clamp(16px, 3vw, 20px);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2563eb;
            font-size: clamp(1.3rem, 4vw, 1.8rem);
            flex-shrink: 0;
        }

        .stat-horizontal-content {
            min-width: 0;
        }

        .stat-horizontal-content h3 {
            font-size: clamp(1.3rem, 5vw, 1.8rem);
            font-weight: 800;
            color: #1e293b;
            line-height: 1;
            margin-bottom: 5px;
            word-break: break-word;
        }

        .stat-horizontal-content p {
            color: #64748b;
            font-size: clamp(0.75rem, 2vw, 0.85rem);
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ===== ACHIEVEMENTS SECTION ===== */
        .achievements-full-card {
            background: #ffffff;
            border-radius: 32px;
            padding: clamp(20px, 3vw, 28px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.02);
            border: 1px solid rgba(37, 99, 235, 0.04);
            width: 100%;
        }

        .achievements-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .achievements-header h2 {
            font-size: clamp(1.1rem, 3vw, 1.3rem);
            font-weight: 700;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .achievements-header h2 i {
            color: #fbbf24;
        }

        /* Progress Bar */
        .achievement-progress {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 8px;
            flex-wrap: wrap;
            gap: 5px;
        }

        .progress-bar-container {
            width: 100%;
            height: 10px;
            background: #f1f5f9;
            border-radius: 20px;
            overflow: hidden;
            margin-bottom: 25px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #fbbf24, #f59e0b);
            border-radius: 20px;
            transition: width 0.8s ease;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 10px;
            color: white;
            font-size: 0.7rem;
            font-weight: 700;
        }

        /* Certificate Download Card */
        .certificate-download-card {
            background: linear-gradient(145deg, #1e1b4b, #312e81);
            border-radius: 24px;
            padding: clamp(20px, 3vw, 25px);
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 20px;
            width: 100%;
        }

        .certificate-info {
            display: flex;
            align-items: center;
            gap: clamp(12px, 2vw, 18px);
            flex: 1;
            min-width: min(100%, 300px);
        }

        .certificate-icon {
            width: clamp(50px, 8vw, 60px);
            height: clamp(50px, 8vw, 60px);
            background: rgba(255,255,255,0.15);
            border-radius: clamp(14px, 3vw, 18px);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: clamp(1.6rem, 4vw, 2rem);
            color: #fbbf24;
            flex-shrink: 0;
        }

        .certificate-text h4 {
            font-size: clamp(1rem, 3vw, 1.2rem);
            font-weight: 700;
            margin-bottom: 5px;
            word-break: break-word;
        }

        .certificate-text p {
            color: #cbd5e1;
            font-size: clamp(0.75rem, 2vw, 0.85rem);
            word-break: break-word;
        }

        .certificate-download-btn {
            background: linear-gradient(145deg, #fbbf24, #f59e0b);
            color: #ffffff;
            padding: clamp(12px, 2vw, 14px) clamp(20px, 3vw, 28px);
            border-radius: 50px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            white-space: nowrap;
        }

        .certificate-download-btn:hover {
            background: linear-gradient(145deg, #f59e0b, #d97706);
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.3);
        }

        .certificate-download-btn.locked {
            background: #64748b;
            pointer-events: none;
            opacity: 0.7;
            box-shadow: none;
        }

        .certificate-download-btn.locked:hover {
            transform: none;
        }

        /* Content Cards */
        .content-card {
            background: #ffffff;
            border-radius: 32px;
            padding: clamp(20px, 3vw, 28px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.02);
            border: 1px solid rgba(37, 99, 235, 0.04);
            width: 100%;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .card-header h2 {
            font-size: clamp(1.1rem, 3vw, 1.3rem);
            font-weight: 700;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        /* Filter Buttons */
        .filter-buttons {
            display: flex;
            gap: 8px;
            background: #f1f5f9;
            padding: 5px;
            border-radius: 50px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 8px 18px;
            border-radius: 50px;
            border: none;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.3s ease;
            background: transparent;
            color: #64748b;
        }

        .filter-btn.active {
            background: #ffffff;
            color: #2563eb;
            box-shadow: 0 5px 12px rgba(0,0,0,0.03);
        }

        .filter-btn:hover {
            background: #ffffff;
            color: #2563eb;
        }

        /* Table Styles */
        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            margin: 0 -5px;
            padding: 0 5px;
            width: 100%;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 600px;
        }

        th {
            text-align: left;
            padding: 16px 12px;
            background: #f8fafd;
            color: #475569;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        td {
            padding: 16px 12px;
            border-bottom: 1px solid #f1f5f9;
            color: #1e293b;
            font-size: 0.95rem;
        }

        tr:hover td {
            background: #f8fafc;
        }

        .subject-tag {
            background: rgba(37, 99, 235, 0.1);
            color: #2563eb;
            padding: 6px 16px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .score-badge {
            background: #dcfce7;
            color: #16a34a;
            padding: 6px 16px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
        }

        /* Chart Container */
        .chart-container {
            height: 280px;
            position: relative;
            width: 100%;
        }

        canvas {
            max-width: 100%;
            height: auto !important;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: #94a3b8;
        }

        .empty-state i {
            font-size: 2.5rem;
            margin-bottom: 15px;
            color: #cbd5e1;
        }

        .empty-state h3 {
            margin-bottom: 10px;
            color: #1e293b;
        }

        .empty-state p {
            margin-bottom: 20px;
        }

        .start-test-btn {
            display: inline-block;
            padding: 12px 30px;
            background: #2563eb;
            color: #ffffff;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .start-test-btn:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
        }

        /* ===== MODAL STYLES FOR FULL TEST HISTORY ===== */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            animation: fadeIn 0.3s ease;
        }

        .modal-content {
            background: #ffffff;
            margin: 30px auto;
            padding: 30px;
            border-radius: 40px;
            width: 90%;
            max-width: 1200px;
            max-height: 80vh;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 2px dashed #f1f5f9;
        }

        .modal-header h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #0b1c38;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .modal-header h2 i {
            color: #2563eb;
        }

        .close-modal {
            font-size: 2rem;
            font-weight: 700;
            color: #64748b;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: #f1f5f9;
        }

        .close-modal:hover {
            color: #ef4444;
            background: #fee2e2;
            transform: rotate(90deg);
        }

        .modal-table-responsive {
            overflow-x: auto;
            width: 100%;
        }

        .modal-table {
            width: 100%;
            border-collapse: collapse;
        }

        .modal-table th {
            background: #f8fafd;
            padding: 16px 12px;
            text-align: left;
            font-size: 0.9rem;
            color: #475569;
            font-weight: 600;
            text-transform: uppercase;
        }

        .modal-table td {
            padding: 16px 12px;
            border-bottom: 1px solid #f1f5f9;
            color: #1e293b;
        }

