                                <i class="fas fa-lock"></i>
                                Locked
                            </button>
                        <% } %>
                    </div>
                </div>
                </div>
                

                <!-- Performance Chart Card -->
                <div class="content-card">
                    <div class="card-header">
                        <h2>
                            <i class="fas fa-chart-area" style="color: #2563eb;"></i>
                            Performance Trend
                        </h2>
                        <div class="filter-buttons">
                            <button class="filter-btn active">All</button>
                            <button class="filter-btn">Recent</button>
                            <button class="filter-btn">Best</button>
                        </div>
                    </div>
                    <div style="height: 280px; position: relative;">
                        <canvas id="performanceChart"></canvas>
                    </div>
                </div>

                <!-- Test History Card -->
                <div class="content-card">
                    <div class="card-header">
                        <h2>
                            <i class="fas fa-clock-rotate-left" style="color: #2563eb;"></i>
                            Recent Tests
                        </h2>
                        <a href="javascript:void(0)" onclick="openTestHistoryModal()" style="color: #2563eb; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 8px;">
                            View All <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="table-responsive">
                        <table>
                            <thead>
                                <tr>
                                    <th>Subject</th>
                                    <th>Set</th>
                                    <th>Score</th>
                                    <th>Percentage</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (user?.testHistory && user.testHistory.length > 0) { %>
                                    <% 
                                        const recentTests = [...user.testHistory]
                                            .filter(t => t.resultId || t.percentage)
                                            .sort((a, b) => {
                                                const dateA = a.date || a.createdAt || a.resultId?.createdAt || 0;
                                                const dateB = b.date || b.createdAt || b.resultId?.createdAt || 0;
                                                return new Date(dateB) - new Date(dateA);
                                            })
                                            .slice(0, 5);
                                    %>
                                    <% recentTests.forEach(t => { 
                                        const result = t.resultId || {};
                                        const subject = t.subject || result.subject || 'HTML';
                                        const setNo = t.setNo || result.setNo || 1;
                                        const score = t.score || result.correct || 0;
                                        const totalQ = t.totalQuestions || result.totalQuestions || 0;
                                        const percentage = t.percentage || result.percentage || 0;
                                        const testDate = t.date || result.createdAt || t.createdAt;
                                    %>
                                    <tr>
                                        <td>
                                            <span class="subject-tag">
                                                <i class="fas fa-code"></i> <%= subject %>
                                            </span>
                                        </td>
                                        <td><strong>Set <%= setNo %></strong></td>
                                        <td><%= score %>/<%= totalQ %></td>
                                        <td>
                                            <span class="score-badge">
                                                <%= Math.round(percentage) %>%
                                                <% if (percentage >= 90) { %>
                                                    <i class="fas fa-crown" style="color: #fbbf24;"></i>
                                                <% } %>
                                            </span>
                                        </td>
                                        <td style="color: #64748b; font-size: 0.85rem;">
                                            <i class="fas fa-calendar"></i> 
                                            <%= testDate ? new Date(testDate).toLocaleDateString('en-IN', { 
                                                day: 'numeric', 
                                                month: 'short',
                                                year: 'numeric'
                                            }) : 'N/A' %>
                                        </td>
                                        <td>
                                            <% if (t.resultId?._id) { %>
                                                <a href="/quiz/<%= t.category || 'technical' %>/<%= subject %>/<%= setNo %>/result/<%= t.resultId._id %>" 
   style="display: inline-flex; align-items: center; gap: 6px; background: #2563eb; color: white; padding: 8px 16px; border-radius: 30px; text-decoration: none; font-size: 0.8rem; font-weight: 600;">
   <i class="fas fa-eye"></i> View Result
</a>

                                            <% } else { %>
                                                <span style="color: #94a3b8;">—</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" style="text-align: center; padding: 50px 20px; color: #94a3b8;">
                                            <i class="fas fa-clipboard-list" style="font-size: 2.5rem; margin-bottom: 15px; color: #cbd5e1;"></i>
                                            <h3 style="margin-bottom: 10px; color: #1e293b;">No Tests Attempted Yet</h3>
                                            <p style="margin-bottom: 20px;">Start your learning journey today!</p>
                                            <a href="/technical-coding" class="start-test-btn">
                                                <i class="fas fa-play"></i> Start First Test
                                            </a>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Quick Actions - Logout Only -->
                <div style="display: flex; gap: 15px; justify-content: flex-end; flex-wrap: wrap;">
                    <a href="/login" onclick="return confirm('Are you sure you want to logout?')" 
                       style="padding: 14px 28px; background: white; color: #ef4444; border-radius: 50px; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 10px; border: 1px solid #fee2e2;">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== FULL TEST HISTORY MODAL ===== -->
    <div id="testHistoryModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>
                    <i class="fas fa-clock-rotate-left"></i>
                    Complete Test History
                </h2>
                <span class="close-modal" onclick="closeTestHistoryModal()">&times;</span>
            </div>

            <!-- Test Statistics Summary -->
            <div class="test-stats-summary">
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div class="stat-details">
                        <h4>Total Tests</h4>
                        <p><%= testsCount %></p>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <div class="stat-details">
                        <h4>Best Score</h4>
                        <p><%= bestScore %>%</p>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="stat-details">
                        <h4>Average Score</h4>
                        <p><%= avgScore %>%</p>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-details">
                        <h4>Correct Answers</h4>
                        <p><%= totalCorrect %>/<%= totalQuestions %></p>
                    </div>
                </div>
            </div>

            <!-- Full Test History Table -->
            <div class="modal-table-responsive">
                <table class="modal-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Subject</th>
                            <th>Set</th>
                            <th>Score</th>
                            <th>Percentage</th>
                            <th>Date & Time</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (user?.testHistory && user.testHistory.length > 0) { %>
                            <% 
                                const allTests = [...user.testHistory]
                                    .filter(t => t.resultId || t.percentage)
                                    .sort((a, b) => {
                                        const dateA = a.date || a.createdAt || a.resultId?.createdAt || 0;
                                        const dateB = b.date || b.createdAt || b.resultId?.createdAt || 0;
                                        return new Date(dateB) - new Date(dateA);
                                    });
                            %>
                            <% allTests.forEach((t, index) => { 
                                const result = t.resultId || {};
                                const subject = t.subject || result.subject || 'HTML';
                                const setNo = t.setNo || result.setNo || 1;
                                const score = t.score || result.correct || 0;
                                const totalQ = t.totalQuestions || result.totalQuestions || 0;
                                const percentage = t.percentage || result.percentage || 0;
                                const testDate = t.date || result.createdAt || t.createdAt;
                            %>
                            <tr>
                                <td style="font-weight: 600; color: #2563eb;">#<%= index + 1 %></td>
                                <td>
                                    <span class="subject-tag">
                                        <i class="fas fa-code"></i> <%= subject %>
                                    </span>
                                </td>
                                <td><strong>Set <%= setNo %></strong></td>
                                <td><%= score %>/<%= totalQ %></td>
                                <td>
                                    <span class="score-badge">
                                        <%= Math.round(percentage) %>%
                                        <% if (percentage >= 90) { %>
                                            <i class="fas fa-crown" style="color: #fbbf24;"></i>
                                        <% } else if (percentage >= 75) { %>
                                            <i class="fas fa-star" style="color: #fbbf24;"></i>
                                        <% } else if (percentage >= 50) { %>
                                            <i class="fas fa-check" style="color: #16a34a;"></i>
                                        <% } %>
                                    </span>
                                </td>
                                <td style="color: #64748b;">
                                    <i class="fas fa-calendar"></i> 
                                    <%= testDate ? new Date(testDate).toLocaleDateString('en-IN', { 
                                        day: 'numeric', 
                                        month: 'short',
                                        year: 'numeric'
                                    }) : 'N/A' %>
                                    <br>
                                    <small style="color: #94a3b8;">
                                        <i class="fas fa-clock"></i>
                                        <%= testDate ? new Date(testDate).toLocaleTimeString('en-IN', { 
                                            hour: '2-digit', 
                                            minute: '2-digit'
                                        }) : '' %>
                                    </small>
                                </td>
                                <td>
                                    <% if (t.resultId?._id) { %>
                                      <a href="/quiz/<%= t.category || 'technical' %>/<%= subject %>/<%= setNo %>/result/<%= t.resultId._id %>"></a>
 
                                           style="display: inline-flex; align-items: center; gap: 6px; background: #2563eb; color: white; padding: 8px 16px; border-radius: 30px; text-decoration: none; font-size: 0.8rem; font-weight: 600; transition: all 0.3s ease;"
                                           onmouseover="this.style.background='#1d4ed8'; this.style.transform='translateY(-2px)';"
                                           onmouseout="this.style.background='#2563eb'; this.style.transform='translateY(0)';">
                                            <i class="fas fa-eye"></i> View Result
                                        </a>
                                    <% } else { %>
                                        <span style="color: #94a3b8; padding: 8px 16px; background: #f1f5f9; border-radius: 30px; font-size: 0.8rem;">
                                            <i class="fas fa-ban"></i> No Result
                                        </span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" style="text-align: center; padding: 60px 20px;">
                                    <i class="fas fa-clipboard-list" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 20px;"></i>
                                    <h3 style="color: #1e293b; margin-bottom: 10px;">No Test History Found</h3>
                                    <p style="color: #64748b; margin-bottom: 20px;">You haven't attempted any tests yet.</p>
                                    <a href="/technical-coding" class="start-test-btn" onclick="closeTestHistoryModal()">
                                        <i class="fas fa-play"></i> Start Your First Test
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // ===== PERFORMANCE CHART =====
        document.addEventListener('DOMContentLoaded', function() {
            try {
                const ctx = document.getElementById('performanceChart').getContext('2d');
                
                // Get chart data from EJS
                let chartLabels = [];
                let chartScores = [];
                
                <% if (user?.testHistory && user.testHistory.length > 0) { %>
                    <% 
                        const last7Tests = [...user.testHistory]
                            .filter(t => t.percentage || t.resultId?.percentage)
                            .sort((a, b) => {
                                const dateA = a.date || a.createdAt || a.resultId?.createdAt || 0;
                                const dateB = b.date || b.createdAt || b.resultId?.createdAt || 0;
                                return new Date(dateA) - new Date(dateB);
                            })
                            .slice(-7);
                    %>
                    chartLabels = <%- JSON.stringify(last7Tests.map((t, i) => {
                        const date = new Date(t.date || t.createdAt || t.resultId?.createdAt || Date.now());
                        return `Test ${i+1} (${date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })})`;
                    })) %>;
                    chartScores = <%- JSON.stringify(last7Tests.map(t => 
                        Math.round(t.percentage || t.resultId?.percentage || 0)
                    )) %>;
                <% } else { %>
                    chartLabels = ['No Data'];
                    chartScores = [0];
                <% } %>

                const gradient = ctx.createLinearGradient(0, 0, 0, 280);
                gradient.addColorStop(0, 'rgba(37, 99, 235, 0.2)');
                gradient.addColorStop(1, 'rgba(37, 99, 235, 0.0)');

                window.performanceChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: chartLabels,
                        datasets: [{
                            label: 'Score Percentage',
                            data: chartScores,
                            borderColor: '#2563eb',
                            backgroundColor: gradient,
                            borderWidth: 3,
                            pointBackgroundColor: '#2563eb',
                            pointBorderColor: 'white',
                            pointBorderWidth: 2,
                            pointRadius: 5,
                            pointHoverRadius: 8,
                            tension: 0.3,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 6,
                                    font: { size: 12, weight: '600' }
                                }
                            },
                            tooltip: {
                                backgroundColor: '#0f172a',
                                titleColor: 'white',
                                bodyColor: '#e2e8f0',
                                padding: 12,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function(context) {
                                        return ` Score: ${context.parsed.y}%`;
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 100,
                                grid: { color: 'rgba(0, 0, 0, 0.03)' },
                                ticks: {
                                    callback: function(value) {
                                        return value + '%';
                                    },
                                    stepSize: 20
                                }
                            },
                            x: {
                                grid: { display: false }
                            }
                        }
                    }
                });
            } catch (error) {
                console.error('Chart initialization error:', error);
            }
        });

        // ===== TEST HISTORY MODAL FUNCTIONS =====
        function openTestHistoryModal() {
            document.getElementById('testHistoryModal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeTestHistoryModal() {
            document.getElementById('testHistoryModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('testHistoryModal');
            if (event.target == modal) {
                closeTestHistoryModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeTestHistoryModal();
            }
        });
    </script>
</body>
</html>