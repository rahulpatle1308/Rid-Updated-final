<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>Coming Soon | Tic Tac Toe vs Computer</title>
  <link rel="icon" type="image/png" href="/assets/signup.png">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(145deg, #0a0c12 0%, #12151f 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Segoe UI', system-ui, -apple-system, 'Inter', 'Poppins', 'Helvetica Neue', sans-serif;
      overflow-x: hidden;
      position: relative;
      padding: 2rem 1rem;
    }

    /* subtle animated particles */
    body::before {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      background-image: radial-gradient(rgba(255, 105, 180, 0.08) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      animation: floatBg 20s linear infinite;
    }

    @keyframes floatBg {
      0% {
        background-position: 0 0;
      }
      100% {
        background-position: 80px 80px;
      }
    }

    .main-wrapper {
      max-width: 700px;
      width: 100%;
      z-index: 2;
    }

    /* coming soon text */
    .coming-soon-text {
      font-size: clamp(2rem, 7vw, 4rem);
      font-weight: 800;
      letter-spacing: 0.08em;
      margin-bottom: 2rem;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.1em;
    }

    .char {
      display: inline-block;
      opacity: 0;
      transform: translateY(-80px);
      animation: dropFromTop 0.5s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
      background: linear-gradient(135deg, #FF6B9D, #C084FC, #60A5FA);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      text-shadow: 0 0 20px rgba(192, 132, 252, 0.3);
      text-transform: uppercase;
    }

    .char:nth-child(1) { animation-delay: 0.05s; }
    .char:nth-child(2) { animation-delay: 0.10s; }
    .char:nth-child(3) { animation-delay: 0.15s; }
    .char:nth-child(4) { animation-delay: 0.20s; }
    .char:nth-child(5) { animation-delay: 0.25s; }
    .char:nth-child(6) { animation-delay: 0.30s; }
    .char:nth-child(7) { animation-delay: 0.35s; }
    .char:nth-child(8) { animation-delay: 0.42s; }
    .char:nth-child(9) { animation-delay: 0.47s; }
    .char:nth-child(10) { animation-delay: 0.52s; }
    .char:nth-child(11) { animation-delay: 0.57s; }

    @keyframes dropFromTop {
      0% {
        opacity: 0;
        transform: translateY(-80px);
        filter: blur(6px);
      }
      40% {
        opacity: 0.8;
        transform: translateY(5px);
      }
      70% {
        transform: translateY(-2px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
      }
    }

    /* Game Section */
    .game-section {
      background: rgba(15, 20, 30, 0.6);
      backdrop-filter: blur(10px);
      border-radius: 2rem;
      padding: 1.5rem;
      margin-top: 1rem;
      border: 1px solid rgba(255, 107, 157, 0.2);
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.4);
      animation: fadeInUp 0.8s ease forwards;
      animation-delay: 0.7s;
      opacity: 0;
      transform: translateY(20px);
    }

    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .game-title {
      text-align: center;
      font-size: 1.2rem;
      font-weight: 600;
      color: #FF6B9D;
      letter-spacing: 1px;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .mode-selector {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 1.2rem;
    }

    .mode-btn {
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 107, 157, 0.3);
      padding: 0.5rem 1.2rem;
      border-radius: 60px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      color: #e2e8f0;
      font-family: inherit;
    }

    .mode-btn.active {
      background: linear-gradient(135deg, #FF6B9D, #C084FC);
      border-color: transparent;
      color: white;
    }

    .mode-btn:hover {
      background: rgba(255, 107, 157, 0.3);
    }

    .status {
      text-align: center;
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      padding: 0.6rem;
      border-radius: 60px;
      background: rgba(0, 0, 0, 0.3);
      color: #e2e8f0;
    }

    .board {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      max-width: 320px;
      margin: 0 auto 1.5rem;
    }

    .cell {
      aspect-ratio: 1 / 1;
      background: rgba(20, 25, 40, 0.8);
      border-radius: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.2s ease;
      border: 1px solid rgba(255, 107, 157, 0.3);
      color: white;
      box-shadow: 0 8px 12px rgba(0, 0, 0, 0.2);
    }

    .cell:hover {
      background: rgba(79, 70, 229, 0.3);
      border-color: #FF6B9D;
      transform: scale(1.02);
    }

    .cell.X {
      color: #FF6B9D;
      text-shadow: 0 0 12px #FF6B9D;
    }

    .cell.O {
      color: #60A5FA;
      text-shadow: 0 0 12px #60A5FA;
    }

    .reset-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: linear-gradient(135deg, #FF6B9D, #C084FC);
      border: none;
      padding: 0.8rem 2rem;
      font-size: 1rem;
      font-weight: 700;
      color: white;
      border-radius: 60px;
      cursor: pointer;
      margin: 0 auto 0.5rem;
      transition: all 0.2s;
      font-family: inherit;
      width: fit-content;
    }

    .reset-btn:hover {
      transform: scale(1.02);
      box-shadow: 0 5px 15px rgba(255, 107, 157, 0.4);
    }

    /* Celebration Modal */
    .celebration-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .celebration-overlay.show {
      opacity: 1;
      visibility: visible;
    }

    .celebration-card {
      background: linear-gradient(145deg, #1a1f2e, #0f1119);
      border-radius: 2.5rem;
      padding: 2rem 2.5rem;
      text-align: center;
      border: 2px solid rgba(255, 107, 157, 0.6);
      box-shadow: 0 0 60px rgba(255, 107, 157, 0.4);
      transform: scale(0.8);
      animation: popIn 0.5s cubic-bezier(0.34, 1.3, 0.64, 1) forwards;
      max-width: 400px;
      margin: 1rem;
    }

    @keyframes popIn {
      0% {
        transform: scale(0.6);
        opacity: 0;
      }
      80% {
        transform: scale(1.05);
      }
      100% {
        transform: scale(1);
        opacity: 1;
      }
    }

    .celebration-card h2 {
      font-size: 2.5rem;
      font-weight: 800;
      background: linear-gradient(135deg, #FF6B9D, #C084FC, #60A5FA);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      margin-bottom: 0.8rem;
    }

    .celebration-card p {
      font-size: 1.3rem;
      color: #e2e8f0;
      margin: 0.5rem 0 1.5rem;
    }

    .winner-name {
      font-size: 2rem;
      font-weight: 800;
      color: #FF6B9D;
      text-shadow: 0 0 15px #FF6B9D;
    }

    .draw-emoji {
      font-size: 3rem;
      margin-bottom: 0.5rem;
    }

    .celebration-btn {
      background: linear-gradient(135deg, #FF6B9D, #C084FC);
      border: none;
      padding: 0.7rem 1.8rem;
      font-size: 1rem;
      font-weight: 700;
      color: white;
      border-radius: 60px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .celebration-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 5px 20px rgba(255, 107, 157, 0.5);
    }

    .confetti {
      position: fixed;
      width: 10px;
      height: 10px;
      position: absolute;
      animation: fall 3s linear forwards;
      z-index: 1001;
      pointer-events: none;
    }

    @keyframes fall {
      0% {
        transform: translateY(-100vh) rotate(0deg);
        opacity: 1;
      }
      100% {
        transform: translateY(100vh) rotate(360deg);
        opacity: 0;
      }
    }

    .winner-msg {
      text-align: center;
      margin-top: 1rem;
      font-size: 0.9rem;
      color: #C084FC;
    }

    .glow-line {
      width: 140px;
      height: 3px;
      background: linear-gradient(90deg, transparent, #FF6B9D, #C084FC, #60A5FA, transparent);
      margin: 1.5rem auto 0;
      border-radius: 4px;
      opacity: 0;
      animation: lineGlow 1.8s ease-in-out infinite alternate, fadeInLine 1s ease forwards;
      animation-delay: 0.7s;
    }

    @keyframes lineGlow {
      0% {
        opacity: 0.4;
        width: 100px;
      }
      100% {
        opacity: 1;
        width: 180px;
      }
    }

    @keyframes fadeInLine {
      0% {
        opacity: 0;
      }
      100% {
        opacity: 1;
      }
    }

    .particle {
      position: absolute;
      background: rgba(255, 107, 157, 0.5);
      border-radius: 50%;
      pointer-events: none;
      animation: floatParticle 8s infinite ease-in-out;
      z-index: 1;
    }

    @keyframes floatParticle {
      0%, 100% {
        transform: translateY(0) translateX(0);
        opacity: 0.3;
      }
      50% {
        transform: translateY(-30px) translateX(20px);
        opacity: 0.8;
      }
    }

    @media (max-width: 500px) {
      .board {
        gap: 8px;
        max-width: 280px;
      }
      .cell {
        font-size: 2.2rem;
        border-radius: 1rem;
      }
      .celebration-card h2 {
        font-size: 1.8rem;
      }
      .mode-selector {
        gap: 0.5rem;
      }
      .mode-btn {
        padding: 0.4rem 1rem;
        font-size: 0.75rem;
      }
    }
  </style>
</head>
<body>
  <div class="main-wrapper">
    <div class="coming-soon-text" id="comingSoonText"></div>
    
    <div class="game-section">
      <div class="game-title">
        <i class="fas fa-gamepad"></i>
        <span>✦ TIC TAC TOE ✦</span>
        <i class="fas fa-microchip"></i>
      </div>
      
      <div class="mode-selector">
        <button class="mode-btn active" data-mode="easy">😊 Easy</button>
        <button class="mode-btn" data-mode="hard">🤖 Hard</button>
      </div>
      
      <div class="status" id="statusMsg">Your turn (X)</div>
      <div class="board" id="board"></div>
      <button class="reset-btn" id="resetGame">
        <i class="fas fa-undo-alt"></i> New Game
      </button>
      <div class="winner-msg" id="winnerMsg"></div>
    </div>
    
    <div class="glow-line"></div>
  </div>

  <!-- Celebration Modal -->
  <div id="celebrationOverlay" class="celebration-overlay">
    <div class="celebration-card">
      <div id="celebrationContent"></div>
      <button class="celebration-btn" id="closeCelebration">
        <i class="fas fa-play"></i> Play Again
      </button>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/js/all.min.js"></script>
  <script>
    // ==================== COMING SOON ANIMATION ====================
    (function() {
      const mainText = "COMING SOON";
      const container = document.getElementById('comingSoonText');
      if (container) {
        container.innerHTML = '';
        for (let i = 0; i < mainText.length; i++) {
          const charSpan = document.createElement('span');
          charSpan.className = 'char';
          const char = mainText[i];
          charSpan.textContent = char === ' ' ? '\u00A0' : char;
          if (char === ' ') charSpan.style.width = '0.5em';
          container.appendChild(charSpan);
        }
      }
      function createParticles() {
        for (let i = 0; i < 28; i++) {
          const particle = document.createElement('div');
          particle.classList.add('particle');
          const size = Math.random() * 6 + 2;
          particle.style.width = `${size}px`;
          particle.style.height = `${size}px`;
          particle.style.left = `${Math.random() * 100}%`;
          particle.style.top = `${Math.random() * 100}%`;
          particle.style.animationDelay = `${Math.random() * 5}s`;
          particle.style.animationDuration = `${Math.random() * 6 + 4}s`;
          particle.style.background = `radial-gradient(circle, rgba(255, ${Math.floor(100 + Math.random() * 100)}, 180, 0.6), rgba(192, 132, 252, 0.2))`;
          document.body.appendChild(particle);
        }
      }
      createParticles();
    })();

    // ==================== TIC TAC TOE VS COMPUTER ====================
    let board = ['', '', '', '', '', '', '', '', ''];
    let gameActive = true;
    let currentPlayer = 'X'; // X is always the user
    let computerPlayer = 'O';
    let difficulty = 'easy'; // 'easy' or 'hard'
    
    const winPatterns = [
      [0, 1, 2], [3, 4, 5], [6, 7, 8],
      [0, 3, 6], [1, 4, 7], [2, 5, 8],
      [0, 4, 8], [2, 4, 6]
    ];
    
    const statusMsg = document.getElementById('statusMsg');
    const winnerMsgDiv = document.getElementById('winnerMsg');
    const resetBtn = document.getElementById('resetGame');
    const boardContainer = document.getElementById('board');
    const celebrationOverlay = document.getElementById('celebrationOverlay');
    const celebrationContent = document.getElementById('celebrationContent');
    const closeCelebrationBtn = document.getElementById('closeCelebration');
    const modeBtns = document.querySelectorAll('.mode-btn');
    
    // Create board UI
    function createBoard() {
      boardContainer.innerHTML = '';
      for (let i = 0; i < 9; i++) {
        const cell = document.createElement('div');
        cell.classList.add('cell');
        if (board[i] === 'X') cell.classList.add('X');
        if (board[i] === 'O') cell.classList.add('O');
        cell.textContent = board[i];
        cell.dataset.index = i;
        cell.addEventListener('click', () => handleUserMove(i));
        boardContainer.appendChild(cell);
      }
    }
    
    function updateBoardUI() {
      const cells = document.querySelectorAll('.cell');
      cells.forEach((cell, idx) => {
        cell.textContent = board[idx];
        cell.classList.remove('X', 'O');
        if (board[idx] === 'X') cell.classList.add('X');
        if (board[idx] === 'O') cell.classList.add('O');
      });
    }
    
    function checkWinner() {
      for (let pattern of winPatterns) {
        const [a, b, c] = pattern;
        if (board[a] && board[a] === board[b] && board[a] === board[c]) {
          return board[a];
        }
      }
      return null;
    }
    
    function isDraw() {
      return board.every(cell => cell !== '');
    }
    
    function showCelebration(result, winner = null) {
      if (result === 'win') {
        if (winner === 'X') {
          celebrationContent.innerHTML = `
            <h2>🎉 CONGRATULATIONS! 🎉</h2>
            <p>You <span class="winner-name">WIN</span> against computer!</p>
            <p style="font-size: 1rem; color: #94a3b8;">🏆 Amazing skills! 🏆</p>
          `;
        } else {
          celebrationContent.innerHTML = `
            <h2>🤖 COMPUTER WINS!</h2>
            <p>Computer beat you this time!</p>
            <p style="font-size: 1rem; color: #94a3b8;">Try again to defeat the AI 💪</p>
          `;
        }
      } else {
        celebrationContent.innerHTML = `
          <div class="draw-emoji">🤝</div>
          <h2 style="background: linear-gradient(135deg, #C084FC, #60A5FA); background-clip: text;">IT'S A DRAW!</h2>
          <p>Well played against the computer!</p>
          <p style="font-size: 0.95rem; color: #94a3b8;">✨ Great match! Try again ✨</p>
        `;
      }
      celebrationOverlay.classList.add('show');
      createConfetti(result === 'win' && winner === 'X' ? 120 : 80);
    }
    
    function createConfetti(count = 100) {
      const colors = ['#FF6B9D', '#C084FC', '#60A5FA', '#FFB347', '#4ECDC4'];
      for (let i = 0; i < count; i++) {
        const confetti = document.createElement('div');
        confetti.classList.add('confetti');
        confetti.style.left = Math.random() * 100 + '%';
        confetti.style.width = Math.random() * 8 + 4 + 'px';
        confetti.style.height = Math.random() * 8 + 4 + 'px';
        confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
        confetti.style.animationDuration = Math.random() * 2 + 2 + 's';
        confetti.style.animationDelay = Math.random() * 0.5 + 's';
        document.body.appendChild(confetti);
        setTimeout(() => {
          if (confetti && confetti.parentNode) confetti.remove();
        }, 3000);
      }
    }
    
    function checkGameStatus() {
      const winner = checkWinner();
      if (winner) {
        gameActive = false;
        if (winner === 'X') {
          statusMsg.textContent = "🎉 You win! 🎉";
          winnerMsgDiv.innerHTML = '<span style="color:#FF6B9D;">✨ You defeated the computer! ✨</span>';
          showCelebration('win', 'X');
        } else {
          statusMsg.textContent = "🤖 Computer wins! 🤖";
          winnerMsgDiv.innerHTML = '<span style="color:#60A5FA;">Computer wins. Try again!</span>';
          showCelebration('win', 'O');
        }
        return true;
      }
      
      if (isDraw()) {
        gameActive = false;
        statusMsg.textContent = "🤝 It's a draw! 🤝";
        winnerMsgDiv.innerHTML = '<span style="color:#C084FC;">Draw! Great match!</span>';
        showCelebration('draw');
        return true;
      }
      return false;
    }
    
    // Computer move logic
    function getEmptyCells() {
      return board.reduce((acc, cell, idx) => {
        if (cell === '') acc.push(idx);
        return acc;
      }, []);
    }
    
    function minimax(isMaximizing, depth = 0) {
      const winner = checkWinner();
      if (winner === 'O') return 10 - depth;
      if (winner === 'X') return depth - 10;
      if (isDraw()) return 0;
      
      const emptyCells = getEmptyCells();
      
      if (isMaximizing) {
        let bestScore = -Infinity;
        for (let idx of emptyCells) {
          board[idx] = 'O';
          let score = minimax(false, depth + 1);
          board[idx] = '';
          bestScore = Math.max(score, bestScore);
        }
        return bestScore;
      } else {
        let bestScore = Infinity;
        for (let idx of emptyCells) {
          board[idx] = 'X';
          let score = minimax(true, depth + 1);
          board[idx] = '';
          bestScore = Math.min(score, bestScore);
        }
        return bestScore;
      }
    }
    
    function getBestMove() {
      let bestScore = -Infinity;
      let bestMove = -1;
      const emptyCells = getEmptyCells();
      
      for (let idx of emptyCells) {
        board[idx] = 'O';
        let score = minimax(false);
        board[idx] = '';
        if (score > bestScore) {
          bestScore = score;
          bestMove = idx;
        }
      }
      return bestMove;
    }
    
    function getRandomMove() {
      const empty = getEmptyCells();
      if (empty.length === 0) return -1;
      return empty[Math.floor(Math.random() * empty.length)];
    }
    
    async function computerMove() {
      if (!gameActive || currentPlayer !== computerPlayer) return;
      
      statusMsg.textContent = "🤖 Computer is thinking...";
      
      // Small delay for better UX
      await new Promise(resolve => setTimeout(resolve, 300));
      
      let move;
      if (difficulty === 'easy') {
        move = getRandomMove();
      } else {
        move = getBestMove();
      }
      
      if (move !== -1 && gameActive && board[move] === '') {
        board[move] = computerPlayer;
        updateBoardUI();
        
        if (!checkGameStatus()) {
          currentPlayer = 'X';
          statusMsg.textContent = "Your turn (X)";
        }
      }
    }
    
    function handleUserMove(index) {
      if (!gameActive || currentPlayer !== 'X' || board[index] !== '') return;
      
      board[index] = 'X';
      updateBoardUI();
      
      if (!checkGameStatus()) {
        currentPlayer = 'O';
        statusMsg.textContent = "🤖 Computer's turn...";
        computerMove();
      }
    }
    
    function resetGame() {
      board = ['', '', '', '', '', '', '', '', ''];
      gameActive = true;
      currentPlayer = 'X';
      statusMsg.textContent = "Your turn (X)";
      winnerMsgDiv.innerHTML = '';
      updateBoardUI();
      createBoard();
    }
    
    function changeDifficulty(level) {
      difficulty = level;
      resetGame();
    }
    
    // Event listeners
    resetBtn.addEventListener('click', resetGame);
    closeCelebrationBtn.addEventListener('click', () => {
      celebrationOverlay.classList.remove('show');
      resetGame();
    });
    
    celebrationOverlay.addEventListener('click', (e) => {
      if (e.target === celebrationOverlay) {
        celebrationOverlay.classList.remove('show');
        resetGame();
      }
    });
    
    modeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        modeBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        changeDifficulty(btn.dataset.mode);
      });
    });
    
    // Initialize game
    createBoard();
  </script>
</body>
</html>