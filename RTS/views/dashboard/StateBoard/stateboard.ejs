<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <%= typeof title !== 'undefined' ? title : 'Technical & Coding Courses' %>
    <link rel="icon" type="image/png" href="/assets/signup.png">
    <!-- External CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined">
    <link rel="stylesheet" href="./css/header.css">
    <link rel="stylesheet" href="./css/sidebar.css">
    <link rel="stylesheet" href="./css/technical.css">
    <link rel="stylesheet" href="./css/footer.css">
    <link rel="stylesheet" href="./css/responsive.css">
</head>

<body>
    <!-- Header -->
    <%- include('../partials/header') %>
    
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>
    
    <!-- Main Content -->
    <main>
        
       <section class="courses-section">
    <div class="courses-container">
        <!-- Course 1: UP BOARD -->
        <div class="course-card" data-course-id="UP BOARD" data-course-name="UP BOARD">
            <!-- VISIT COUNT - LEFT SIDE (Without eye icon) -->
            <div class="visit-count">
                <span class="count">0</span>
                <span class="visits-text">visits</span>
            </div>
            <!-- BADGE - RIGHT SIDE -->
            <span class="badge-left update-badge">UPDATED</span>
            
            <div class="course-header">
                <div class="card-icon">
                    <i class="fa-brands fa-html5"></i>
                </div>
                <h3>UP BOARD</h3>
            </div>
            <div class="course-content">
                <div class="marquee">
                    <p>All Test <span>Series</span></p>
                </div>
                <div class="btn-container">
                   <a href="/rts/upboard/purchase" class="btn track-visit">Open Now</a>
                </div>
            </div>
        </div>

        <!-- Course 2:BIHAR BOARD -->
        <div class="course-card" data-course-id="BIHAR BOARD" data-course-name="BIHAR BOARD">
            <!-- VISIT COUNT - LEFT SIDE (Without eye icon) -->
            <div class="visit-count">
                <span class="count">0</span>
                <span class="visits-text">visits</span>
            </div>
            <!-- BADGE - RIGHT SIDE -->
            <span class="badge-left new-badge">UPDATED</span>
            
            <div class="course-header">
                <div class="card-icon">
                    <i class="fa-brands fa-css3-alt"></i>
                </div>
                <h3>BIHAR BOARD</h3>
            </div>
            <div class="course-content">
                <div class="marquee">
                    <p>All Test <span>Series</span></p>
                </div>
                <div class="btn-container">
                    <a href="/rts/biharboard/purchase" class="btn track-visit">Open Now</a>
                </div>
            </div>
        </div>

        <!-- Course 3: MP BOARD -->
        <div class="course-card" data-course-id="MP BOARD" data-course-name="MP BOARD">
            <!-- VISIT COUNT - LEFT SIDE (Without eye icon) -->
            <div class="visit-count">
                <span class="count">0</span>
                <span class="visits-text">visits</span>
            </div>
            <!-- BADGE - RIGHT SIDE -->
            <span class="badge-left hot-badge">UPDATED</span>
            
            <div class="course-header">
                <div class="card-icon">
                    <i class="fa-brands fa-js"></i>
                </div>
                <h3>MP BOARD</h3>
            </div>
            <div class="course-content">
                <div class="marquee">
                    <p>All Test <span>Series</span></p>
                </div>
                <div class="btn-container">
                    <a href="/rts/mpboard/purchase" class="btn track-visit">Open Now</a>
                </div>
            </div>
        </div>

        <!-- Course 4: PUNJAB BOARD< -->
        <div class="course-card" data-course-id="PUNJAB BOARD" data-course-name="PUNJAB BOARD">
            <!-- VISIT COUNT - LEFT SIDE (Without eye icon) -->
            <div class="visit-count">
                <span class="count">0</span>
                <span class="visits-text">visits</span>
            </div>
            <!-- BADGE - RIGHT SIDE -->
            <span class="badge-left update-badge">UPDATED</span>
            
            <div class="course-header">
                <div class="card-icon">
                    <i class="fa-brands fa-python"></i>
                </div>
                <h3>PUNJAB BOARD</h3>
            </div>
            <div class="course-content">
                <div class="marquee">
                    <p>All Test <span>Series</span></p>
                </div>
                <div class="btn-container">
                    <a href="/rts/punjab-board/purchase" class="btn track-visit">Open Now</a>
                </div>
            </div>
        </div>

       
    </div>
</section>
    </main>
    
    <!-- Footer -->
    <%- include('../partials/footer') %>

    
    <script src="/rts/js/visit-counter.js"></script>
    <script src="/rts/js/banner-slider.js"></script>
    <script src="/rts/js/search-filter.js"></script>
    <script src="/rts/js/ui-handlers.js"></script>
    <script src="/rts/js/dashboard.js"></script>
    
    <!-- Ionicons for footer icons -->
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
</body>
</html>