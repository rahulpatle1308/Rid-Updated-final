    <main>
        <!-- Subject Tabs Section -->
        <section class="description-section" aria-labelledby="tests-title">
            <h2 class="section-title" id="tests-title">Primary-Teacher TEST's</h2>
            
            <!-- Subject Tabs -->
            <div class="subject-tabs">
                <button class="tab-btn active" data-subject="all" onclick="filterTests('all')">All Tests</button>
                <button class="tab-btn" data-subject="child" onclick="filterTests('child')">Child</button>
                <button class="tab-btn" data-subject="english" onclick="filterTests('english')">English</button>
                <button class="tab-btn" data-subject="environment" onclick="filterTests('environment')">Environment</button>
                <button class="tab-btn" data-subject="hindi" onclick="filterTests('hindi')">Hindi</button>
                <button class="tab-btn" data-subject="math" onclick="filterTests('math')">Mathematics</button>
            </div>

            <!-- Test Cards Grid -->
            <div class="test-grid" id="testGrid">
                <% const totalTests = 15; %>
                <% for(let i = 1; i <= totalTests; i++) { 
                    let subject = '';
                    let subjectClass = '';
                    let subjectName = '';
                    
                    if(i <= 3) { 
                        subject = 'child';
                        subjectClass = 'child-text';
                        subjectName = 'Child ';
                    } else if(i <= 6) { 
                        subject = 'english';
                        subjectClass = 'english-text';
                        subjectName = 'English';
                    } else if(i <= 9) { 
                        subject = 'environment';
                        subjectClass = 'environment-text';
                        subjectName = 'Environment';
                    } else if(i <= 12) { 
                        subject = 'hindi';
                        subjectClass = 'hindi-text';
                        subjectName = 'Hindi';
                    } else if(i <= 15) { 
                        subject = 'math';
                        subjectClass = 'math-text';
                        subjectName = 'Mathematics';
                    } 
                %>
                    <div class="test-item" data-subject="<%= subject %>">
                        <div class="test-header">
                            <h3>Primary-Teacher Test : <%= i %></h3>
                        </div>

                        <div class="test-action">
                            <a href="/rts/quiz/BPSC/Primary-Teacher/<%= i %>">
                                <button class="start-button">Start Test</button>
                            </a>
                            <div class="special-text <%= subjectClass %>"><%= subjectName %></div>
                        </div>
                    </div>
                <% } %>
            </div>
        </section>
    </main>

