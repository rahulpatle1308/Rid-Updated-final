<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"><br><br>
   <%= typeof title !== 'undefined' ? title : 'Technical & Coding Courses' %>
    
    <!-- External CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined">
    <link rel="stylesheet" href="./css/header.css">
    <link rel="stylesheet" href="./css/sidebar.css">
    <link rel="stylesheet" href="./css/technical.css">
    <link rel="stylesheet" href="./css/footer.css">
    <link rel="stylesheet" href="./css/responsive.css">
</head>

<body>
    <!-- Header -->
    <%- include('../partials/header') %>  
    
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>
   
    <!-- Main Content -->
    <main>
       
       <section class="courses-section">
    <div class="courses-container">
        <!-- Course 1: RRB NTPC -->
        <div class="course-card" data-course-id="RRB NTPC" data-course-name="RRB NTPC">
            <!-- VISIT COUNT - LEFT SIDE (Without eye icon) -->
            <div class="visit-count">
                <span class="count">0</span>
                <span class="visits-text">visits</span>
            </div>
            <!-- BADGE - RIGHT SIDE -->
            <span class="badge-left update-badge">UPDATED</span>
            
            <div class="course-header">
                <div class="card-icon">
                    <i class="fa-brands fa-html5"></i>
                </div>
                <h3>RRB NTPC</h3>
            </div>
            <div class="course-content">
                <div class="marquee">
                    <p>All Test <span>Series</span></p>
                </div>
                <div class="btn-container">
                   <a href="/html/purchase" class="btn track-visit">Open Now</a>
                </div>
            </div>
        </div>
      <!-- Course 2: RRB Group D -->
        <div class="course-card" data-course-id="RRB Group D" data-course-name="RRB Group D">
            <!-- VISIT COUNT - LEFT SIDE (Without eye icon) -->
            <div class="visit-count">
                <span class="count">0</span>
                <span class="visits-text">visits</span>
            </div>
            <!-- BADGE - RIGHT SIDE -->
            <span class="badge-left update-badge">UPDATED</span>
            
            <div class="course-header">
                <div class="card-icon">
                    <i class="fa-brands fa-html5"></i>
                </div>
                <h3>RRB Group D</h3>
            </div>
            <div class="course-content">
                <div class="marquee">
                    <p>All Test <span>Series</span></p>
                </div>
                <div class="btn-container">
                   <a href="/html/purchase" class="btn track-visit">Open Now</a>
                </div>
            </div>
        </div>
    
    </div>
</section>
    </main>
    
    <!-- Footer -->
    <%- include('../partials/footer') %>

    
    <script src="/js/visit-counter.js"></script>
    <script src="/js/banner-slider.js"></script>
    <script src="/js/search-filter.js"></script>
    <script src="/js/ui-handlers.js"></script>
    <script src="/js/dashboard.js"></script>
    
    <!-- Ionicons for footer icons -->
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
</body>
</html>