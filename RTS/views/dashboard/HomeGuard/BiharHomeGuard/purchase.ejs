<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'HTML Test Series' %></title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined">
  <link rel="stylesheet" href="/css/purchase.css">
  <link rel="stylesheet" href="/css/header.css">
 <style>
 /* ==================== CSS VARIABLES ==================== */
:root {
    /* Background Colors */
    --bg-footer: #f4f1f1;
    --bg-copyright: #f4f1f1;
    --bg-footer-overlay: rgba(244, 241, 241, 0.9);
    
    /* Text Colors */
    --text-primary: #212529;
    --text-secondary: #6c757d;
    --text-link: #0a66c2;
    --text-hover: #084e94;
    --text-grey: #808080;
    --text-dark: #140b0b;
    --text-white: #ffffff;
    
    /* Font Settings */
    --font-family-primary: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    --font-family-heading: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    
    /* Font Weights */
    --font-normal: 400;
    --font-medium: 500;
    --font-semibold: 600;
    --font-bold: 700;
    
    /* Line Heights */
    --line-height-tight: 1.2;
    --line-height-normal: 1.5;
    --line-height-loose: 1.8;
}

/* Dark Mode Colors */
body.dark-mode {
    --bg-footer: #2d2d2d;
    --bg-copyright: #404040;
    --bg-footer-overlay: rgba(45, 45, 45, 0.95);
    --text-primary: #ffffff;
    --text-secondary: #e0e0e0;
    --text-link: #6ea8fe;
    --text-hover: #8bb9fe;
    --text-grey: #c0c0c0;
    --text-dark: #f0f0f0;
}

/* ==================== FOOTER STYLING ==================== */
.footer {
    height: fit-content;
    width: 100%;
    margin-left: 0;
    padding: 64px 32px;
    background: linear-gradient(var(--bg-footer-overlay), var(--bg-footer-overlay)), url('/image_all/footer overlay.png') no-repeat center;
    align-items: start;
    color: var(--text-dark);
    background-size: cover;
    background-attachment: scroll;
    overflow-x: hidden;
    box-sizing: border-box;
    background-color: var(--bg-footer);
    font-family: var(--font-family-primary);
}

footer {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    align-items: start;
    gap: 40px;
    max-width: 1400px;
    margin: 0 auto;
}

/* Left Section */
footer .left {
    display: flex;
    flex-direction: column;
    gap: 24px;
    flex: 1 1 300px;
    min-width: 280px;
}

footer .left img {
    width: 100%;
    max-width: 330px;
    height: auto;
}

footer .left p {
    font-size: 14px;
    line-height: var(--line-height-loose);
    color: var(--text-link);
    font-family: var(--font-family-primary);
    font-weight: var(--font-normal);
    margin: 0;
}

footer .left a {
    font-size: 14px;
    text-decoration: none;
    color: var(--text-link);
    font-family: var(--font-family-primary);
    font-weight: var(--font-medium);
    transition: color 0.3s ease;
}

footer .left a:hover {
    color: var(--text-hover);
    text-decoration: underline;
}

/* Links Sections */
footer .links-head,
.links-social {
    flex: 1 1 200px;
    min-width: 200px;
}

footer .links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
}

.links-head h3,
.links-social h3 {
    text-transform: uppercase;
    font-size: 16px;
    font-weight: var(--font-semibold);
    margin-bottom: 16px;
    color: var(--text-primary);
    font-family: var(--font-family-heading);
    letter-spacing: 0.5px;
}

.links-head .links-1,
.links-2,
.links-3,
.links-social .links-1,
.links-2 {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.links-head a,
.links-social a {
    text-decoration: none;
    color: var(--text-grey);
    transition: 0.3s ease-in-out;
    font-size: 14px;
    font-family: var(--font-family-primary);
    font-weight: var(--font-normal);
    line-height: var(--line-height-loose);
}

.links-head a:hover,
.links-social a:hover {
    color: var(--text-link);
    text-decoration: underline;
}

.links-social .links a {
    display: flex;
    align-items: center;
    gap: 8px;
}

.links-social .links a i {
    font-size: 18px;
    color: var(--text-link);
}

/* Copyright Section */
.copyrightsection {
    width: 100%;
    margin-left: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 32px;
    background: var(--bg-copyright);
    color: var(--text-dark);
    overflow-x: hidden;
    margin-top: 5px;
    box-sizing: border-box;
    flex-wrap: wrap;
    gap: 16px;
    font-family: var(--font-family-primary);
}

.copyrightsection p,
.copyrightsection a {
    font-size: 12px;
    margin: 0;
    font-family: var(--font-family-primary);
}

.copyrightsection p {
    color: var(--text-secondary);
    font-weight: var(--font-normal);
}

.copyrightsection .link {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
}

.copyrightsection .link a {
    text-decoration: none;
    color: var(--text-grey);
    transition: 0.3s;
    white-space: nowrap;
    font-weight: var(--font-medium);
}

.copyrightsection .link a:hover {
    color: var(--text-link);
}

.about-text {
    margin-top: 20px;
    color: var(--text-secondary);
    font-size: 14px;
    line-height: var(--line-height-loose);
    font-family: var(--font-family-primary);
}

/* ==================== MEDIA QUERIES ==================== */

/* Tablet Devices (768px to 1024px) */
@media screen and (max-width: 1024px) {
    .footer {
        padding: 48px 24px;
        background-color: var(--bg-footer);
    }
    
    footer .left {
        flex: 1 1 250px;
    }
    
    footer .left img {
        max-width: 280px;
    }
    
    .copyrightsection {
        padding: 16px 24px;
        background: var(--bg-copyright);
    }
    
    .links-head h3,
    .links-social h3 {
        font-size: 15.5px;
    }
}

/* Mobile Devices (up to 767px) */
@media screen and (max-width: 767px) {
    .footer {
        padding: 40px 20px;
        background-attachment: scroll;
        background-size: cover;
        background-color: var(--bg-footer);
    }
    
    footer {
        flex-direction: column;
        gap: 40px;
    }
    
    footer .left {
        max-width: 100%;
        width: 100%;
    }
    
    footer .left img {
        max-width: 250px;
    }
    
    footer .links-head,
    .links-social {
        max-width: 100%;
        width: 100%;
    }
    
    footer .links {
        gap: 30px;
    }
    
    .links-head h3,
    .links-social h3 {
        font-size: 15px;
        margin-bottom: 14px;
        font-family: var(--font-family-heading);
    }
    
    .links-head a,
    .links-social a,
    footer .left p,
    footer .left a {
        font-size: 13px;
        line-height: var(--line-height-loose);
    }
    
    /* Copyright section mobile */
    .copyrightsection {
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 16px 20px;
        gap: 12px;
        background: var(--bg-copyright);
    }
    
    .copyrightsection .link {
        justify-content: center;
        gap: 16px;
    }
    
    .copyrightsection .link a {
        font-size: 11px;
    }
    
    .copyrightsection p {
        font-size: 11px;
    }
}

/* Small Mobile Devices (up to 480px) */
@media screen and (max-width: 480px) {
    .footer {
        padding: 32px 16px;
        background-color: var(--bg-footer);
    }
    
    footer {
        gap: 32px;
    }
    
    footer .left img {
        max-width: 200px;
    }
    
    footer .links {
        flex-direction: column;
        gap: 20px;
    }
    
    .links-head h3,
    .links-social h3 {
        font-size: 14px;
        margin-bottom: 12px;
    }
    
    .links-head a,
    .links-social a {
        font-size: 13px;
    }
    
    .copyrightsection {
        background: var(--bg-copyright);
    }
    
    .copyrightsection .link {
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
    }
    
    .copyrightsection .link a {
        white-space: normal;
        font-size: 11px;
    }
    
    .copyrightsection p {
        font-size: 11px;
    }
    
    .about-text {
        font-size: 13px;
    }
}

/* Landscape Mode for Mobile */
@media screen and (max-width: 896px) and (orientation: landscape) {
    .footer {
        padding: 40px 24px;
        background-color: var(--bg-footer);
    }
    
    footer {
        flex-direction: row;
        flex-wrap: wrap;
    }
    
    footer .left {
        flex: 1 1 100%;
    }
    
    footer .links-head,
    .links-social {
        flex: 1 1 200px;
    }
}

/* Dark Mode Support */
@media (prefers-color-scheme: dark) {
    body.dark-mode .footer {
        background: linear-gradient(var(--bg-footer-overlay), var(--bg-footer-overlay)), url('/image_all/footer overlay.png') no-repeat center;
        background-size: cover;
    }
    
    body.dark-mode .copyrightsection {
        background: var(--bg-copyright);
    }
    
    body.dark-mode .links-head a,
    body.dark-mode .links-social a {
        color: var(--text-grey);
    }
    
    body.dark-mode footer .left p {
        color: var(--text-link);
    }
}

/* High Resolution Screens */
@media (min-width: 1920px) {
    .footer {
        padding: 80px 40px;
    }
    
    footer .left p,
    footer .left a,
    .links-head a,
    .links-social a {
        font-size: 16px;
    }
    
    .links-head h3,
    .links-social h3 {
        font-size: 18px;
    }
    
    .copyrightsection p,
    .copyrightsection a {
        font-size: 14px;
    }
    
    .about-text {
        font-size: 16px;
    }
}
 </style> 
 

</head>

