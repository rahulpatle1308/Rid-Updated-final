  <script>
// ==================== MOBILE MENU TOGGLE FUNCTIONALITY ====================
document.addEventListener('DOMContentLoaded', function() {
    
    // Get all required elements
    const menuToggle = document.getElementById('menuToggle');
    const mobileNav = document.getElementById('mobileNav');
    const overlay = document.getElementById('mobileMenuOverlay');
    const closeBtn = document.querySelector('.mobile-close-btn');
    const header = document.querySelector('.main-header');
    const body = document.body;
    
    // Check if elements exist
    if (!menuToggle || !mobileNav || !overlay) {
        console.error('Mobile menu elements not found!');
        return;
    }
    
    // Function to open menu
    function openMenu() {
        mobileNav.classList.add('active');
        overlay.classList.add('active');
        menuToggle.classList.add('active');
        header.classList.add('menu-open');
        body.classList.add('menu-open');
        menuToggle.setAttribute('aria-expanded', 'true');
        menuToggle.innerHTML = '<i class="fas fa-times"></i>'; // Change to close icon
        
        // Prevent body scroll
        body.style.overflow = 'hidden';
    }
    
    // Function to close menu
    function closeMenu() {
        mobileNav.classList.remove('active');
        overlay.classList.remove('active');
        menuToggle.classList.remove('active');
        header.classList.remove('menu-open');
        body.classList.remove('menu-open');
        menuToggle.setAttribute('aria-expanded', 'false');
        menuToggle.innerHTML = '<i class="fas fa-bars"></i>'; // Change back to hamburger
        
        // Restore body scroll
        body.style.overflow = '';
    }
    
    // Toggle menu on button click
    menuToggle.addEventListener('click', function(e) {
        e.stopPropagation();
        const isOpen = mobileNav.classList.contains('active');
        
        if (isOpen) {
            closeMenu();
        } else {
            openMenu();
        }
    });
    
    // Close menu when clicking overlay
    overlay.addEventListener('click', closeMenu);
    
    // Close menu when clicking close button (if exists)
    if (closeBtn) {
        closeBtn.addEventListener('click', closeMenu);
    }
    
    // Close menu on escape key press
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && mobileNav.classList.contains('active')) {
            closeMenu();
        }
    });
    
    // Prevent menu from closing when clicking inside mobile nav
    mobileNav.addEventListener('click', function(e) {
        e.stopPropagation();
    });
    
    // Handle window resize - close menu on desktop
    window.addEventListener('resize', function() {
        if (window.innerWidth > 992 && mobileNav.classList.contains('active')) {
            closeMenu();
        }
    });
    
    // ==================== FONT SIZE CONTROLS ====================
    const increaseBtn = document.getElementById('increaseFont');
    const resetBtn = document.getElementById('resetFont');
    const decreaseBtn = document.getElementById('decreaseFont');
    
    let currentFontSize = 16; // base font size in pixels
    const minFontSize = 12;
    const maxFontSize = 24;
    
    function setBodyFontSize(size) {
        document.body.style.fontSize = size + 'px';
        // Store in localStorage for persistence
        localStorage.setItem('preferredFontSize', size);
    }
    
    if (increaseBtn) {
        increaseBtn.addEventListener('click', function() {
            currentFontSize = Math.min(maxFontSize, currentFontSize + 2);
            setBodyFontSize(currentFontSize);
        });
    }
    
    if (decreaseBtn) {
        decreaseBtn.addEventListener('click', function() {
            currentFontSize = Math.max(minFontSize, currentFontSize - 2);
            setBodyFontSize(currentFontSize);
        });
    }
    
    if (resetBtn) {
        resetBtn.addEventListener('click', function() {
            currentFontSize = 16;
            document.body.style.fontSize = '';
            localStorage.removeItem('preferredFontSize');
        });
    }
    
    // Load saved font size preference
    const savedFontSize = localStorage.getItem('preferredFontSize');
    if (savedFontSize) {
        currentFontSize = parseInt(savedFontSize);
        document.body.style.fontSize = currentFontSize + 'px';
    }
    
    // ==================== ACTIVE LINK HIGHLIGHTING ====================
    const currentPath = window.location.pathname;
    
    // Desktop menu active link
    document.querySelectorAll('.desktop-menu-link').forEach(link => {
        const href = link.getAttribute('href');
        if (href === currentPath) {
            link.classList.add('active');
            // Optional: Add active state styling
            link.style.backgroundColor = '#e6f0ff';
            link.style.color = 'var(--maintheme)';
        }
    });
    
    // Mobile menu active link
    document.querySelectorAll('.mobile-menu-link').forEach(link => {
        const href = link.getAttribute('href');
        if (href === currentPath) {
            link.classList.add('active');
            // Optional: Add active state styling
            link.style.backgroundColor = '#f0f7ff';
            link.style.borderLeft = '3px solid var(--maintheme)';
        }
    });
    
    // ==================== TOUCH EVENT HANDLING (for mobile) ====================
    let touchStartX = 0;
    let touchEndX = 0;
    
    // Swipe to close menu on mobile
    if ('ontouchstart' in window) {
        mobileNav.addEventListener('touchstart', function(e) {
            touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });
        
        mobileNav.addEventListener('touchend', function(e) {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipe();
        }, { passive: true });
    }
    
    function handleSwipe() {
        const swipeThreshold = 100;
        const swipeDistance = touchEndX - touchStartX;
        
        // If swipe left more than threshold, close menu
        if (swipeDistance < -swipeThreshold && mobileNav.classList.contains('active')) {
            closeMenu();
        }
    }
    
 
    
});
</script>
