<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advanced Admin Dashboard - RID Platform</title>
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
    <link rel="stylesheet" href="/css/Admin-css/admin.css">
   
</head>

<body>
    <!-- Preloader -->
    <div class="preloader" id="preloader">
        <div class="preloader-logo">
            <i class="fas fa-graduation-cap fa-3x" style="color: #003366;"></i>
        </div>
        <div class="preloader-text">RID Admin Panel</div>
        <div class="loader"></div>
    </div>

    <!-- Header -->
    <header>
        <div class="header">
            <div class="web-text">
                <p><i class="fas fa-globe"></i> <span>RID Platform v3.0</span></p>
                <p><i class="fas fa-phone"></i> <span>+91- 9202707903</span></p>
                <p><i class="fas fa-envelope"></i> <span>ridorg.in@gmail.com</span></p>
            </div>
            <div class="right-text">
                <a href="#" class="link" id="themeToggle">
                    <i class="fas fa-moon"></i>
                    <span>Dark Mode</span>
                </a>
                <a href="#" class="link" id="fullscreenToggle">
                    <i class="fas fa-expand"></i>
                    <span>Fullscreen</span>
                </a>
                <a href="#" class="link notification-link">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                    <span class="notification-badge">5</span>
                </a>
                <div class="user-profile" id="userProfile">
                    <div class="user-avatar">
                        <%= admin ? admin.name.charAt(0).toUpperCase() : 'A' %>
                    </div>
                    <div class="user-info">
                        <div class="user-name">
                            <%= admin ? admin.name : 'Admin' %>
                        </div>
                        <div class="user-role">
                            <%= admin ? admin.role : '' %>
                        </div>
                    </div>
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>
        </div>

        <div class="lower-header">
            <div class="logo">
                <img src="../assets/final_logo.svg" alt="RID Logo">
                <div class="logo-text">Research Innovation & Discovery</div>
            </div>
            <div class="header-controls">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" id="globalSearch" placeholder="Search users, certificates, books...">
                </div>
                <div class="quick-actions">
                    <button class="quick-btn" onclick="showModal('newUserModal')">
                        <i class="fas fa-user-plus"></i> New User
                    </button>
                    <button class="quick-btn" onclick="createOfferLetter()">
                        <i class="fas fa-file-signature"></i> Create Offer Letter
                    </button>
                    <button class="quick-btn" onclick="ShowUploadBook()">
                        <i class="fas fa-book"></i> Add Book
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Menu Toggle -->
    <span class="menu-icon" onclick="toggleSidebar()">
        <i class="fas fa-bars"></i>
    </span>

    <!-- Sidebar -->
    <div class="side-bar" id="sidebar">
        <div class="div1">
            <h2>Dashboard</h2>
            <button class="active" onclick="showDashboard()">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </button>
            <button onclick="showAnalytics()">
                <i class="fas fa-chart-line"></i>
                <span>Analytics</span>
                <span class="badge">New</span>
            </button>

            <h2>User Management</h2>
            <button onclick="showTotalList()">
                <i class="fas fa-users"></i>
                <span>All Users</span>
            </button>
            <button onclick="showRoleManagement()">
                <i class="fas fa-user-tag"></i>
                <span>Role Management</span>
            </button>
            <button onclick="showUserGroups()">
                <i class="fas fa-layer-group"></i>
                <span>User Groups</span>
            </button>
            <button onclick="showPermissionManager()">
                <i class="fas fa-shield-alt"></i>
                <span>Permissions</span>
            </button>

            <h2>Content Management</h2>
            <button onclick="uploadcertificate()">
                <i class="fas fa-certificate"></i>
                <span>Certificates</span>
            </button>
            <button onclick="ShowUploadBook()">
                <i class="fas fa-book"></i>
                <span>E-Books</span>
            </button>
            <button onclick="showContentLibrary()">
                <i class="fas fa-photo-video"></i>
                <span>Media Library</span>
            </button>
            <button onclick="showBlogManager()">
                <i class="fas fa-blog"></i>
                <span>Blog Posts</span>
            </button>

            <h2>Advanced Features</h2>
            <button onclick="showWorkflowManager()">
                <i class="fas fa-sitemap"></i>
                <span>Workflows</span>
            </button>
            <button onclick="showAutomationRules()">
                <i class="fas fa-robot"></i>
                <span>Automation</span>
            </button>
            <button onclick="showApiManager()">
                <i class="fas fa-code"></i>
                <span>API Manager</span>
            </button>
            <button onclick="showIntegrations()">
                <i class="fas fa-plug"></i>
                <span>Integrations</span>
            </button>

            <h2>System Tools</h2>
            <button onclick="showAuditLogs()">
                <i class="fas fa-clipboard-list"></i>
                <span>Audit Logs</span>
            </button>
            <button onclick="showBackupManager()">
                <i class="fas fa-database"></i>
                <span>Backup & Restore</span>
            </button>
            <button onclick="showSystemSettings()">
                <i class="fas fa-cogs"></i>
                <span>System Settings</span>
            </button>
            <button onclick="showEmailTemplates()">
                <i class="fas fa-envelope"></i>
                <span>Email Templates</span>
            </button>
        </div>

        <div style="padding: 20px; border-top: 1px solid rgba(255,255,255,0.1);">
            <button id="logout-btn" style="background: rgba(244, 67, 54, 0.2); color: #ff6b6b;">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <!-- Dashboard Content -->
        <div id="dashboardContent">
            <div class="dashboard-header mb-30">
                <h1 style="color: var(--primary-color); margin-bottom: 10px;">Welcome back, Admin!</h1>
                <p style="color: #666;">Here's what's happening with your platform today.</p>
            </div>

            <!-- Quick Stats -->
            <div class="dashboard-grid">
                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="stat-trend trend-up">
                            <i class="fas fa-arrow-up"></i>
                            <span>12%</span>
                        </div>
                    </div>
                    <div class="stat-value" id="totalUsers">1,847</div>
                    <div class="stat-label">Total Users Registered</div>
                    <div class="stat-progress">
                        <div class="progress-bar" style="width: 75%;"></div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #2196f3 0%, #0d47a1 100%);">
                            <i class="fas fa-certificate"></i>
                        </div>
                        <div class="stat-trend trend-up">
                            <i class="fas fa-arrow-up"></i>
                            <span>8%</span>
                        </div>
                    </div>
                    <div class="stat-value" id="totalCertificates">892</div>
                    <div class="stat-label">Certificates Issued</div>
                    <div class="stat-progress">
                        <div class="progress-bar" style="width: 60%;"></div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #ff9800 0%, #ef6c00 100%);">
                            <i class="fas fa-book"></i>
                        </div>
                        <div class="stat-trend trend-up">
                            <i class="fas fa-arrow-up"></i>
                            <span>5%</span>
                        </div>
                    </div>
                    <div class="stat-value" id="totalBooks">156</div>
                    <div class="stat-label">E-Books Available</div>
                    <div class="stat-progress">
                        <div class="progress-bar" style="width: 45%;"></div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-header">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #9c27b0 0%, #6a1b9a 100%);">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="stat-trend trend-up">
                            <i class="fas fa-arrow-up"></i>
                            <span>23%</span>
                        </div>
                    </div>
                    <div class="stat-value">₹ 2,45,670</div>
                    <div class="stat-label">Total Revenue</div>
                    <div class="stat-progress">
                        <div class="progress-bar" style="width: 85%;"></div>
                    </div>
                </div>
            </div>

            <!-- Charts Section -->
            <div class="charts-container mb-30">
                <div class="chart-card">
                    <div class="chart-header">
                        <h3 class="chart-title">User Growth</h3>
                        <div class="chart-actions">
                            <button class="chart-btn">Daily</button>
                            <button class="chart-btn active">Weekly</button>
                            <button class="chart-btn">Monthly</button>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas id="userGrowthChart"></canvas>
                    </div>
                </div>

                <div class="chart-card">
                    <div class="chart-header">
                        <h3 class="chart-title">Resource Distribution</h3>
                        <div class="chart-actions">
                            <button class="chart-btn">View Details</button>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas id="resourceChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Recent Activity & Calendar -->
            <div class="d-flex gap-20 mb-30" style="flex-wrap: wrap;">
                <div class="activity-feed" style="flex: 1; min-width: 300px;">
                    <div class="activity-header">
                        <h3>Recent Activity</h3>
                        <button class="chart-btn">View All</button>
                    </div>
                    <div class="activity-list" id="activityList">
                        <!-- Activity items will be populated here -->
                    </div>
                </div>

                <div class="calendar-widget" style="flex: 1; min-width: 300px;">
                    <div class="calendar-header">
                        <h3>Calendar</h3>
                        <div class="chart-actions">
                            <button class="chart-btn"><i class="fas fa-chevron-left"></i></button>
                            <span style="padding: 0 15px;">March 2024</span>
                            <button class="chart-btn"><i class="fas fa-chevron-right"></i></button>
                        </div>
                    </div>
                    <div class="calendar-grid" id="calendarGrid">
                        <!-- Calendar will be populated here -->
                    </div>
                </div>
            </div>

            <!-- Recent Users Table -->
            <div class="data-table-container">
                <div class="table-header">
                    <h3>Recent Users</h3>
                    <div class="table-tools">
                        <div class="table-filter">
                            <select class="filter-select">
                                <option>All Roles</option>
                                <option>Admin</option>
                                <option>Teacher</option>
                                <option>Student</option>
                            </select>
                            <select class="filter-select">
                                <option>All Status</option>
                                <option>Active</option>
                                <option>Pending</option>
                                <option>Inactive</option>
                            </select>
                        </div>
                        <div class="table-search">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" placeholder="Search users...">
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="data-table" id="recentUsersTable">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Join Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="recentUsersBody">
                            <!-- Users will be populated here -->
                        </tbody>
                    </table>
                </div>
                <div class="pagination">
                    <button class="pagination-btn active">1</button>
                    <button class="pagination-btn">2</button>
                    <button class="pagination-btn">3</button>
                    <button class="pagination-btn">Next</button>
                </div>
            </div>
        </div>

        <!-- Other sections will be dynamically loaded here -->
        <div id="dynamicContent"></div>
    </div>

    <!-- Dark Mode Toggle -->
    <div class="dark-mode-toggle">
        <button class="toggle-btn" id="darkModeToggle">
            <i class="fas fa-moon"></i>
        </button>
    </div>

    <!-- Toast Container -->
    <div class="toastify-container" id="toastContainer"></div>

    <!-- Modals -->
    <div class="modal" id="newUserModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Add New User</h3>
                <button class="modal-close" onclick="closeModal('newUserModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="newUserForm">
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">First Name</label>
                            <input type="text" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Last Name</label>
                            <input type="text" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Role</label>
                            <select class="form-control form-select" required>
                                <option value="">Select Role</option>
                                <option value="admin">Administrator</option>
                                <option value="teacher">Teacher</option>
                                <option value="student">Student</option>
                                <option value="organisation">Organisation</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Gender</label>
                            <select class="form-control form-select" required>
                                <option value="">Select Gender</option>
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="action-btn btn-view" onclick="closeModal('newUserModal')">Cancel</button>
                <button class="action-btn btn-edit" type="submit" form="newUserForm">Create User</button>
            </div>
        </div>
    </div>

    <!-- Include Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.14.0/Sortable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <script>
        // Preloader
        window.addEventListener('load', function () {
            setTimeout(() => {
                document.getElementById('preloader').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('preloader').style.display = 'none';
                }, 500);
            }, 1500);
        });

        // State Management
        const state = {
            currentView: 'dashboard',
            darkMode: localStorage.getItem('darkMode') === 'true',
            sidebarOpen: window.innerWidth > 992,
            notifications: [],
            currentUser: {
                name: 'Admin User',
                role: 'super_admin',
                email: 'admin@rid.org'
            }
        };

        // Initialize
        function init() {
            // Set dark mode
            if (state.darkMode) {
                document.body.classList.add('dark-mode');
            }

            // Initialize components
            initCharts();
            initActivityFeed();
            initCalendar();
            initRecentUsers();
            initEventListeners();

            // Update UI
            updateSidebarState();
        }

        // Sidebar Management
        function toggleSidebar() {
            state.sidebarOpen = !state.sidebarOpen;
            updateSidebarState();
        }

        function updateSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');

            if (state.sidebarOpen) {
                sidebar.classList.remove('active');
                mainContent.classList.remove('full-width');
            } else {
                sidebar.classList.add('active');
                mainContent.classList.add('full-width');
            }
        }

        // Dark Mode Toggle
        function toggleDarkMode() {
            state.darkMode = !state.darkMode;
            document.body.classList.toggle('dark-mode', state.darkMode);
            localStorage.setItem('darkMode', state.darkMode);

            showToast(state.darkMode ? 'Dark mode enabled' : 'Light mode enabled', 'info');
        }

        // Fullscreen Toggle
        function toggleFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen();
            } else {
                document.exitFullscreen();
            }
        }

        // Toast Notification System
        function showToast(message, type = 'info', duration = 5000) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toastify-toast ${type}`;

            const icons = {
                success: '✓',
                error: '✗',
                warning: '⚠',
                info: 'ℹ'
            };

            toast.innerHTML = `
                <div class="toastify-content">
                    <div class="toastify-icon">${icons[type] || 'ℹ'}</div>
                    <div class="toastify-message">
                        <div class="toastify-title">${type.charAt(0).toUpperCase() + type.slice(1)}</div>
                        <div>${message}</div>
                    </div>
                    <button class="toastify-close" onclick="this.parentElement.parentElement.remove()">&times;</button>
                </div>
            `;

            container.appendChild(toast);

            // Auto remove after duration
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.style.animation = 'slideInRight 0.3s ease reverse';
                    setTimeout(() => toast.remove(), 300);
                }
            }, duration);
        }

        // Modal System
        function showModal(modalId) {
            document.getElementById(modalId).classList.add('active');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // View Navigation
        function showDashboard() {
            state.currentView = 'dashboard';
            document.getElementById('dashboardContent').style.display = 'block';
            document.getElementById('dynamicContent').innerHTML = '';
            updateSidebarActive('dashboard');
        }

        function showTotalList() {
            state.currentView = 'users';
            document.getElementById('dashboardContent').style.display = 'none';

            const content = `
                <div class="data-table-container slide-up">
                    <div class="table-header">
                        <h3>All Registered Users</h3>
                        <div class="table-tools">
                            <button class="action-btn btn-edit" onclick="exportUsers()">
                                <i class="fas fa-download"></i> Export
                            </button>
                            <button class="action-btn btn-view" onclick="showModal('newUserModal')">
                                <i class="fas fa-plus"></i> Add User
                            </button>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Registration Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="allUsersTable">
                                <!-- Users will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination">
                        <button class="pagination-btn active">1</button>
                        <button class="pagination-btn">2</button>
                        <button class="pagination-btn">3</button>
                        <button class="pagination-btn">4</button>
                        <button class="pagination-btn">5</button>
                        <button class="pagination-btn">Next</button>
                    </div>
                </div>
            `;

            document.getElementById('dynamicContent').innerHTML = content;
            loadAllUsers();
            updateSidebarActive('users');
        }

        function showAnalytics() {
            state.currentView = 'analytics';
            document.getElementById('dashboardContent').style.display = 'none';
            const content = `
                <div class="slide-up">
                    <h2 style="color: var(--primary-color); margin-bottom: 30px;">Advanced Analytics</h2>
                    
                    <div class="tabs mb-30">
                        <button class="tab-btn active" onclick="switchAnalyticsTab('overview')">Overview</button>
                        <button class="tab-btn" onclick="switchAnalyticsTab('users')">User Analytics</button>
                        <button class="tab-btn" onclick="switchAnalyticsTab('content')">Content Analytics</button>
                        <button class="tab-btn" onclick="switchAnalyticsTab('revenue')">Revenue Analytics</button>
                    </div>
                    
                    <div id="analyticsContent">
                        <div class="charts-container mb-30">
                            <div class="chart-card">
                                <h3 class="chart-title">User Engagement Metrics</h3>
                                <div class="chart-container">
                                    <canvas id="engagementChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <h3 class="chart-title">Platform Performance</h3>
                                <div class="chart-container">
                                    <canvas id="performanceChart"></canvas>
                                </div>
                            </div>
                        </div>
                        
                        <div class="data-table-container">
                            <h3>Key Metrics</h3>
                            <div class="dashboard-grid mb-30">
                                <div class="stat-card">
                                    <div class="stat-value">94.2%</div>
                                    <div class="stat-label">User Retention Rate</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value">2.3min</div>
                                    <div class="stat-label">Avg Session Duration</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value">87%</div>
                                    <div class="stat-label">Platform Uptime</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value">4.8/5</div>
                                    <div class="stat-label">User Satisfaction</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('dynamicContent').innerHTML = content;
            initAnalyticsCharts();
            updateSidebarActive('analytics');
        }

        // Chart Initialization
        function initCharts() {
            // User Growth Chart
            const userGrowthCtx = document.getElementById('userGrowthChart').getContext('2d');
            new Chart(userGrowthCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'New Users',
                        data: [65, 78, 90, 120, 150, 180],
                        borderColor: '#0a66c2',
                        backgroundColor: 'rgba(10, 102, 194, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
