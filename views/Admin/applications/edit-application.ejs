<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Application · creative UI</title>
    <!-- Font Awesome 6 (free) for clean icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Font: Inter for modern, readable type -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #f0f5fe 0%, #e9f0fa 100%);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            margin: 0;
            line-height: 1.5;
        }

        /* main card – soft floating design */
        .edit-card {
            max-width: 1000px;
            width: 100%;
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 2.5rem;
            padding: 2rem 2.5rem;
            box-shadow: 
                0 25px 50px -12px rgba(0,51,102,0.25),
                inset 0 1px 2px rgba(255,255,255,0.8);
            border: 1px solid rgba(255,255,255,0.6);
            transition: all 0.2s ease;
        }

        /* header area with icon */
        .edit-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 2.2rem;
        }

        .edit-header .icon-bg {
            background: linear-gradient(135deg, #003366, #1a4d8c);
            width: 52px;
            height: 52px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px -7px #00336660;
        }

        .edit-header .icon-bg i {
            font-size: 1.8rem;
            color: white;
        }

        .edit-header h1 {
            font-size: 2rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            background: linear-gradient(145deg, #003366, #0a4d8c);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin: 0;
        }

        .edit-header p {
            font-size: 0.95rem;
            color: #4a5a6e;
            margin-top: 4px;
            font-weight: 400;
        }

        /* form layout – responsive grid */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem 2rem;
            margin-bottom: 2.5rem;
        }

        /* field groups */
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group label {
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.02em;
            color: #1e2b3c;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-group label i {
            color: #0a66c2;
            font-size: 1rem;
            width: 1.2rem;
            text-align: center;
        }

        /* elegant input style */
        .form-group input {
            width: 100%;
            padding: 0.9rem 1.2rem;
            background: rgba(255,255,255,0.9);
            border: 2px solid #e6edf4;
            border-radius: 20px;
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
            font-weight: 500;
            color: #0b1c2e;
            transition: all 0.2s ease;
            box-shadow: 0 4px 8px rgba(0,0,0,0.02);
        }

        .form-group input:focus {
            outline: none;
            border-color: #0a66c2;
            background: white;
            box-shadow: 0 10px 20px -12px #0a66c2, 0 0 0 4px rgba(10,102,194,0.12);
        }

        .form-group input::placeholder {
            color: #9aa9b9;
            font-weight: 400;
            opacity: 0.7;
        }

        /* preserve existing values style (ejs) */
        .form-group input[value] {
            font-weight: 500;
            color: #0f2b3f;
        }

        /* action buttons row */
        .form-actions {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            border-top: 2px dashed rgba(0,51,102,0.15);
            padding-top: 2rem;
            margin-top: 0.5rem;
        }

        .btn-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        /* button styles */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 0.9rem 2rem;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1rem;
            border: none;
            cursor: pointer;
            transition: 0.15s ease;
            font-family: 'Inter', sans-serif;
            text-decoration: none;
            box-shadow: 0 8px 16px -8px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: linear-gradient(115deg, #003366, #0f5cad);
            color: white;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .btn-primary i {
            font-size: 1.1rem;
        }

        .btn-primary:hover {
            background: linear-gradient(115deg, #002244, #0a4a94);
            transform: scale(1.02);
            box-shadow: 0 16px 20px -10px #003366b3;
        }

        .btn-secondary {
            background: white;
            color: #1e3a5f;
            border: 2px solid #cddae9;
            box-shadow: none;
        }

        .btn-secondary i {
            color: #4f6f8f;
        }

        .btn-secondary:hover {
            background: #f4f9ff;
            border-color: #9bb7d4;
            transform: translateY(-2px);
        }

        /* hint / decorative element */
        .safe-note {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #2b4d71;
            font-size: 0.9rem;
            background: rgba(10,102,194,0.06);
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            border: 1px solid rgba(10,102,194,0.15);
        }

        .safe-note i {
            color: #0a66c2;
        }

        /* ---------- responsive for small devices ---------- */
        @media screen and (max-width: 700px) {
            body {
                padding: 0.8rem;
                align-items: flex-start;
            }

            .edit-card {
                padding: 1.8rem 1.5rem;
                border-radius: 2rem;
            }

            .form-grid {
                grid-template-columns: 1fr;  /* stack */
                gap: 1.2rem;
            }

            .edit-header h1 {
                font-size: 1.8rem;
            }

            .edit-header .icon-bg {
                width: 46px;
                height: 46px;
                border-radius: 16px;
            }

            .btn {
                width: 100%;
                justify-content: center;
                padding: 0.9rem 1.2rem;
            }

            .form-actions {
                flex-direction: column-reverse;
                align-items: stretch;
            }

            .btn-row {
                flex-direction: column;
                width: 100%;
            }

            .safe-note {
                justify-content: center;
                margin-bottom: 0.5rem;
            }
        }

        /* extra fine-tuning for very tiny screens */
        @media screen and (max-width: 380px) {
            .edit-card {
                padding: 1.2rem;
            }
            .edit-header {
                flex-wrap: wrap;
            }
        }

        /* preserve original form structure — no JS, only ui */
        .form-group input[type="text"],
        .form-group input[type="email"] {
            -webkit-appearance: none;
            appearance: none;
        }
    </style>
</head>
<body>
    <!-- main creative card – fully responsive, no functionality changes -->
    <div class="edit-card">
        <!-- header with icon + gradient text -->
        <div class="edit-header">
            <div class="icon-bg">
                <i class="fas fa-pen-to-square"></i>
            </div>
            <div>
                <h1>Edit application</h1>
                <p><i class="fas fa-asterisk" style="font-size: 0.4rem; vertical-align: middle; color: #0a66c2;"></i> update details below</p>
            </div>
        </div>

        <!-- form – exactly same action, method and field names (ejs preserved) -->
        <form action="/api/admin/update/<%= app._id %>" method="POST">
            <!-- two column grid (auto stacks on mobile) -->
            <div class="form-grid">
                <!-- full name -->
                <div class="form-group">
                    <label><i class="fas fa-user-circle"></i> Full name</label>
                    <input type="text" name="fullName" value="<%= app.fullName %>" placeholder="e.g. Alex Johnson" class="form-control">
                </div>

                <!-- father name -->
                <div class="form-group">
                    <label><i class="fas fa-user"></i> Father's name</label>
                    <input type="text" name="fatherName" value="<%= app.fatherName %>" placeholder="Father's name" class="form-control">
                </div>

                <!-- email -->
                <div class="form-group">
                    <label><i class="fas fa-envelope"></i> Email address</label>
                    <input type="email" name="email" value="<%= app.email %>" placeholder="name@example.com" class="form-control">
                </div>

                <!-- phone -->
                <div class="form-group">
                    <label><i class="fas fa-phone-alt"></i> Phone number</label>
                    <input type="text" name="phone" value="<%= app.phone %>" placeholder="+91 98765 43210" class="form-control">
                </div>

                <!-- course -->
                <div class="form-group">
                    <label><i class="fas fa-graduation-cap"></i> Course</label>
                    <input type="text" name="course" value="<%= app.course %>" placeholder="e.g. Computer Science" class="form-control">
                </div>

                <!-- project name -->
                <div class="form-group">
                    <label><i class="fas fa-code-branch"></i> Project name</label>
                    <input type="text" name="projectName" value="<%= app.projectName %>" placeholder="Final year project" class="form-control">
                </div>
            </div>

            <!-- action buttons (cancel is dummy, only design – no logic added) -->
            <div class="form-actions">
                <div class="safe-note">
                    <i class="fas fa-lock"></i> <span>Your data stays private</span>
                </div>
                <div class="btn-row">
                    <!-- cancel / back button – purely visual, does not submit, no js -->
                    <button type="button" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </button>
                    <!-- update submit – primary action, keeps original functionality -->
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-cloud-upload-alt"></i> Update application
                    </button>
                </div>
            </div>

            <!-- hidden fields? not needed – but we keep the form untouched -->
        </form>

        <!-- tiny footnote: pure ui, no js, fully responsive -->
        <div style="margin-top: 1.5rem; text-align: right; font-size: 0.8rem; color: #738ea8; opacity: 0.8; border-top: 1px solid rgba(0,51,102,0.1); padding-top: 1rem;">
            <i class="fas fa-mobile-alt"></i> responsive for all devices · creative design
        </div>
    </div>
    <!-- zero javascript – only css design, form functionality unchanged -->
</body>
</html>