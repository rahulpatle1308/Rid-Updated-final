<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes">
    <title>✨ Certificate Applications · Creative Admin UI</title>
    <!-- Google Font & Font Awesome for icons & modern look -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(145deg, #f9f0ff 0%, #e6f2fe 100%);
            min-height: 100vh;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: bgGlow 8s infinite alternate ease-in-out;
        }

        @keyframes bgGlow {
            0% { background: linear-gradient(145deg, #f9f0ff, #e6f2fe); }
            50% { background: linear-gradient(145deg, #ffe7f0, #d9efff); }
            100% { background: linear-gradient(145deg, #f0e7ff, #cff0fe); }
        }

        .glass-card {
            width: 100%;
            max-width: 1600px;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border-radius: 2.5rem;
            padding: 2rem 1.5rem;
            box-shadow: 0 30px 60px -20px rgba(0, 20, 80, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
            border: 1px solid rgba(255,255,255,0.5);
            transition: all 0.2s;
        }

        /* header area with title & search */
        .dashboard-header {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .title-section h2 {
            font-size: 2.2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e2b5e, #7c3aed, #c026d3);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.02em;
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
        }

        .title-section h2 i {
            background: white;
            padding: 0.6rem;
            border-radius: 1.2rem;
            font-size: 1.4rem;
            color: #7c3aed;
            box-shadow: 0 6px 12px rgba(124, 58, 237, 0.25);
        }

        .search-wrapper {
            position: relative;
            min-width: 280px;
            width: 100%;
            max-width: 420px;
        }

        .search-wrapper i {
            position: absolute;
            left: 1.2rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.2rem;
            color: #7c3aed;
            background: rgba(255,255,240,0.8);
            padding: 0.4rem;
            border-radius: 50%;
            transition: all 0.2s;
        }

        #searchInput {
            width: 100%;
            padding: 1rem 1rem 1rem 3.5rem;
            font-size: 1rem;
            font-weight: 500;
            border: none;
            border-radius: 3rem;
            background: rgba(255,255,255,0.9);
            box-shadow: 0 8px 20px -8px rgba(0,0,0,0.15), 0 0 0 2px rgba(255,255,255,0.8) inset;
            outline: none;
            transition: all 0.3s;
            color: #1e1e3f;
        }

        #searchInput::placeholder {
            color: #a0a0c0;
            font-weight: 400;
            letter-spacing: -0.2px;
        }

        #searchInput:focus {
            box-shadow: 0 10px 25px -5px #a560e8, 0 0 0 4px rgba(124, 58, 237, 0.3);
            background: white;
        }

        /* responsive table container */
        .table-responsive {
            overflow-x: auto;
            border-radius: 1.8rem;
            background: rgba(255,255,255,0.5);
            padding: 0.2rem;
            box-shadow: 0 10px 25px -10px rgba(0,0,0,0.2);
        }

        /* ----- CREATIVE TABLE ----- */
        .application-table {
            width: 100%;
            border-collapse: collapse;
            border-style: hidden;
            border-radius: 1.8rem;
            overflow: hidden;
            background: white;
            font-size: 0.95rem;
            box-shadow: 0 15px 30px -12px rgba(0,0,0,0.2);
        }

        .application-table thead tr {
            background: linear-gradient(112deg, #1f1c4e, #3b2e7c, #5b3ca0);
            background-size: 200% 200%;
            animation: gradientMove 8s ease infinite;
        }

        @keyframes gradientMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .application-table th {
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            padding: 1.2rem 0.8rem;
            white-space: nowrap;
            border-right: 1px solid rgba(255,255,255,0.15);
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
        }

        .application-table th:last-child {
            border-right: none;
        }

        .application-table td {
            padding: 1.1rem 0.8rem;
            border-bottom: 1px solid rgba(160, 140, 200, 0.2);
            background-color: rgba(255,255,255,0.8);
            color: #1e1a3a;
            font-weight: 500;
            transition: background 0.2s;
        }

        .application-table tbody tr:hover td {
            background: #fff5f9;
            box-shadow: 0 2px 0 #d8b4fe inset;
        }

        /* special colorful cell accents */
        .application-table td:nth-child(1) { /* app id */
            font-weight: 700;
            color: #303f9f;
        }
        .application-table td:nth-child(2) { /* name */
            font-weight: 600;
            color: #27496d;
        }
        .application-table td:nth-child(3) { /* type */
            background: linear-gradient(145deg, #f3e8ff, #faf5ff);
            border-radius: 40px 0 0 40px;
            font-weight: 600;
            color: #5b2e9e;
        }

        /* status badges - creative pill */
        .status-badge {
            display: inline-block;
            padding: 0.3rem 1rem;
            border-radius: 30px;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 0.02em;
            text-transform: uppercase;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.5);
            background: white;
        }

        .status-verified {
            background: linear-gradient(145deg, #22c55e, #16a34a);
            color: white;
            text-shadow: 0 1px 2px rgba(0,70,0,0.3);
            border-color: #bbf7d0;
        }

        .status-pending {
            background: linear-gradient(145deg, #f97316, #ea580c);
            color: white;
            text-shadow: 0 1px 2px rgba(120,40,0,0.3);
            border-color: #fed7aa;
        }

        /* duration chip */
        .duration-chip {
            background: #e5e4fc;
            padding: 0.2rem 1rem;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.85rem;
            color: #2c3d7b;
            display: inline-block;
            white-space: nowrap;
        }

        /* action buttons container */
        .action-cell {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            align-items: center;
        }

        .action-btn {
            border: none;
            padding: 0.5rem 0.9rem;
            border-radius: 3rem;
            font-weight: 600;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: white;
            color: #1f1a45;
            box-shadow: 0 4px 8px -4px rgba(0, 0, 0, 0.2);
            cursor: pointer;
            transition: all 0.2s ease;
            border: 1px solid rgba(255,255,255,0.8);
            text-decoration: none;
        }

        .action-btn i {
            font-size: 0.85rem;
        }

        .btn-verify {
            background: linear-gradient(145deg, #22c55e, #16a34a);
            color: white;
            border-color: #86efac;
        }
        .btn-verify:hover {
            background: linear-gradient(145deg, #16a34a, #15803d);
            transform: scale(1.03);
            box-shadow: 0 8px 12px -6px #14532d;
        }

        .btn-edit {
            background: linear-gradient(145deg, #3b82f6, #2563eb);
            color: white;
            border-color: #b1d3ff;
        }
        .btn-edit:hover {
            background: linear-gradient(145deg, #2563eb, #1d4ed8);
            transform: scale(1.03);
        }

        .btn-delete {
            background: linear-gradient(145deg, #ef4444, #dc2626);
            color: white;
            border-color: #fbc5c5;
        }
        .btn-delete:hover {
            background: linear-gradient(145deg, #dc2626, #b91c1c);
            transform: scale(1.03);
        }

        .btn-download {
            background: linear-gradient(145deg, #1e1e2f, #2d2d44);
            color: white;
            border-color: #b1b1cf;
        }
        .btn-download:hover {
            background: linear-gradient(145deg, #2d2d44, #1e1e2f);
            transform: scale(1.03);
        }

        /* delete form inline */
        .delete-form {
            display: inline;
        }

        /* no results message */
        .no-results {
            text-align: center;
            padding: 2.5rem;
            background: rgba(255,250,240,0.7);
            border-radius: 3rem;
            font-size: 1.2rem;
            font-weight: 600;
            color: #6b21a5;
            backdrop-filter: blur(4px);
            margin: 1rem 0;
        }
        .no-results i {
            font-size: 2rem;
            display: block;
            margin-bottom: 0.5rem;
            color: #c084fc;
        }

        /* responsive touches */
        @media (max-width: 700px) {
            .glass-card { padding: 1.2rem 1rem; border-radius: 2rem; }
            .title-section h2 { font-size: 1.7rem; }
            .search-wrapper { max-width: 100%; }
            .action-btn { padding: 0.4rem 0.7rem; font-size: 0.7rem; }
            .application-table th { font-size: 0.75rem; padding: 1rem 0.4rem; }
            .application-table td { padding: 0.8rem 0.4rem; font-size: 0.8rem; }
        }
        @media (max-width: 480px) {
            .action-cell { flex-direction: column; align-items: flex-start; }
        }

        /* small row animation */
        .application-table tbody tr {
            transition: all 0.1s;
        }
    </style>
</head>
<body>
    <div class="glass-card">
        <!-- header with search bar -->
        <div class="dashboard-header">
            <div class="title-section">
                <h2>
                    <i class="fas fa-certificate"></i> 
                    Certificate applications
                </h2>
            </div>
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search by name or certificate ID...">
            </div>
        </div>

        <!-- table container (scrolls on small devices) -->
        <div class="table-responsive">
            <table class="application-table" id="applicationTable">
                <thead>
                    <tr>
                        <th><i class="fas fa-id-card" style="margin-right: 6px;"></i> App ID</th>
                        <th><i class="fas fa-user-graduate" style="margin-right: 6px;"></i> Name</th>
                        <th><i class="fas fa-tag" style="margin-right: 6px;"></i> Type</th>
                        <th><i class="fas fa-circle-check" style="margin-right: 6px;"></i> Status</th>
                        <th><i class="fas fa-clock" style="margin-right: 6px;"></i> Duration</th>
                        <th><i class="fas fa-tools" style="margin-right: 6px;"></i> Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- EJS blocks: exactly as given, but we keep them for backend rendering -->
                    <% apps.forEach(app => { %>
                        <tr class="data-row">
                            <td><%= app.appId %></td>
                            <td><%= app.fullName %></td>
                            <td><%= app.certificateType %></td>
                            <td>
                                <% if(app.status === "VERIFIED") { %>
                                    <span class="status-badge status-verified"><i class="fas fa-check-circle" style="margin-right: 4px;"></i> Verified</span>
                                <% } else { %>
                                    <span class="status-badge status-pending"><i class="fas fa-hourglass-half" style="margin-right: 4px;"></i> Pending</span>
                                <% } %>
                            </td>
                            <td>
                                <span class="duration-chip"><i class="far fa-calendar-alt" style="margin-right: 4px;"></i> <%= app.duration %> <%= app.durationUnit %></span>
                            </td>
                            <td class="action-cell">
                                <% if(app.status !== "VERIFIED") { %>
                                    <a href="/api/admin/verify/<%= app._id %>" class="action-btn btn-verify" title="Verify application">
                                        <i class="fas fa-check-circle"></i> <span>Verify</span>
                                    </a>
                                <% } %>

                                <a href="/api/admin/edit/<%= app._id %>" class="action-btn btn-edit" title="Edit">
                                    <i class="fas fa-pen-to-square"></i> <span>Edit</span>
                                </a>

                                <form action="/api/admin/delete/<%= app._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this application?')" class="delete-form">
                                    <button type="submit" class="action-btn btn-delete" title="Delete">
                                        <i class="fas fa-trash-can"></i> <span>Delete</span>
                                    </button>
                                </form>

                                <% if(app.status === "VERIFIED") { %>
                                    <a href="/api/download/<%= app.appId %>" class="action-btn btn-download" title="Download certificate">
                                        <i class="fas fa-download"></i> <span>Download</span>
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- container for no-results message (dynamic) -->
        <div id="noResultsMsg" style="display: none;" class="no-results">
            <i class="fas fa-file-circle-exclamation"></i>
            No matching applications found
        </div>
    </div>

    <!-- live search script (client side) -->
    <script>
        (function() {
            const searchInput = document.getElementById('searchInput');
            const tableBody = document.getElementById('tableBody');
            const noResultsMsg = document.getElementById('noResultsMsg');
            
            // Get all rows from tbody
            const rows = Array.from(document.querySelectorAll('#tableBody .data-row'));

            function filterTable() {
                const query = searchInput.value.trim().toLowerCase();
                let anyVisible = false;

                rows.forEach(row => {
                    const cells = row.children; // td elements
                    // appId is first cell (index 0), name is second cell (index 1)
                    const appId = cells[0]?.textContent.trim().toLowerCase() || '';
                    const fullName = cells[1]?.textContent.trim().toLowerCase() || '';
                    
                    // check if query matches either appId or fullName
                    const matches = appId.includes(query) || fullName.includes(query);
                    
                    if (matches) {
                        row.style.display = ''; // show
                        anyVisible = true;
                    } else {
                        row.style.display = 'none'; // hide
                    }
                });

                // show/hide no results message
                if (!anyVisible && rows.length > 0) {
                    noResultsMsg.style.display = 'block';
                } else {
                    noResultsMsg.style.display = 'none';
                }
            }

            // add input event listener
            if (searchInput) {
                searchInput.addEventListener('input', filterTable);
            }

            // initial check in case of pre-filled search (optional)
            filterTable();

            // also if new rows are added dynamically (not needed for EJS static), 
            // but we keep reference.
        })();
    </script>

    <!-- ensure that ejs tags are not broken, and we keep original functionality. 
         the above design keeps all original links/buttons + added icons & classes. 
         no backend logic harmed. -->
</body>
</html>