<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Mobile Reader - <%= pdf.title %> | ReadVault</title>
    <link rel="icon" type="image/png" href="/assets/signup.png">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="preload" as="script" href="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-user-select: none;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            color: white;
            overflow: hidden;
        }

        .security-header {
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 0.75rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            height: 70px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-text {
            font-size: 1.2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .book-info {
            flex: 1;
            text-align: center;
        }

        .book-title {
            font-size: 1rem;
            font-weight: 500;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .security-status {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(16, 185, 129, 0.2);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            color: #10b981;
        }

        .main-container {
            margin-top: 70px;
            height: calc(100vh - 70px);
            background: #1a1a1a;
            display: flex;
            flex-direction: column;
        }

        .pdf-container {
            flex: 1;
            overflow: auto;
            background: #2d2d2d;
        }

        .canvas-container {
    display: flex;
    flex-direction: column;
    align-items: center;        /* center horizontally */
    justify-content: flex-start; /* top se start (important) */
    padding: 30px;
    min-height: 100%;
}
@media (max-width: 768px) {
    .canvas-container {
        display: block;
        align-items: center;     /* center on mobile */
        justify-content: flex-start;
    }
}

        /* HD Canvas Styles */
        .page-canvas {
            display: block;
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            border-radius: 12px;
            cursor: default;
            max-width: none !important;
            width: auto !important;
            height: auto !important;
            /* HD Rendering */
            image-rendering: -webkit-optimize-contrast;
            image-rendering: crisp-edges;
            image-rendering: pixelated;
        }

        /* Zoom Controls */
        .zoom-controls {
            position: fixed;
            right: 20px;
            bottom: 100px;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(20px);
            padding: 12px;
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 100;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .zoom-btn {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: white;
            width: 48px;
            height: 48px;
            border-radius: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            transition: all 0.2s ease;
        }

        .zoom-btn:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: scale(1.05);
        }

        .zoom-level {
            text-align: center;
            font-size: 0.85rem;
            font-weight: 600;
            padding: 8px 0;
            color: #10b981;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 8px;
        }

        /* Navigation Controls */
        .navigation-controls {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(20px);
            padding: 12px 24px;
            border-radius: 60px;
            z-index: 100;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .nav-buttons-container {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .back-btn, .nav-btn {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: white;
            padding: 10px 20px;
            border-radius: 40px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

        .back-btn:hover, .nav-btn:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateY(-2px);
        }

        .page-info {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.2), rgba(118, 75, 162, 0.2));
            padding: 8px 24px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1rem;
            min-width: 120px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .loading-state {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1a1a1a, #2d2d2d);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            z-index: 50;
        }

        .loading-spinner {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(255, 255, 255, 0.1);
            border-top: 4px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 1.5rem;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .progress-bar {
            width: 300px;
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
            margin: 1rem 0;
        }

        .progress {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transition: width 0.3s ease;
        }

        .zoom-hint, .controls-hint {
            position: fixed;
            bottom: 180px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 12px 24px;
            border-radius: 40px;
            font-size: 0.9rem;
            z-index: 1001;
            backdrop-filter: blur(10px);
            white-space: nowrap;
            animation: fadeInUp 0.3s ease;
            pointer-events: none;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateX(-50%) translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }
        }

        .security-warning {
            position: fixed;
            top: 80px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(239, 68, 68, 0.95);
            color: white;
            padding: 10px 20px;
            border-radius: 40px;
            font-size: 0.85rem;
            z-index: 1001;
            display: none;
        }
       .pdf-container {
    overflow: auto;
    cursor: grab;
}

.pdf-container:active {
    cursor: grabbing;
}

        .pdf-container::-webkit-scrollbar {
            width: 10px;
            height: 10px;
        }

        .pdf-container::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.1);
        }

        .pdf-container::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.3);
            border-radius: 5px;
        }

        @media print {
            body * { display: none !important; }
        }

        /* High DPI Screens */
        @media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
            .page-canvas {
                image-rendering: -webkit-optimize-contrast;
                image-rendering: crisp-edges;
            }
        }

        @media (max-width: 768px) {
            .security-header {
                height: 60px;
                padding: 0 1rem;
            }
            
            .logo-icon {
                width: 32px;
                height: 32px;
            }
            
            .logo-text {
                display: none;
            }
            
            .security-status span {
                display: none;
            }
            
            .main-container {
                margin-top: 60px;
                height: calc(100vh - 60px);
            }
            
            .zoom-controls {
                right: 10px;
                bottom: 80px;
                padding: 8px;
                gap: 8px;
            }
            
            .zoom-btn {
                width: 40px;
                height: 40px;
                font-size: 1rem;
            }
            
            .navigation-controls {
                padding: 8px 16px;
            }
            
            .nav-buttons-container {
                gap: 12px;
            }
            
            .back-btn span, .nav-btn span {
                display: none;
            }
            
            .back-btn i, .nav-btn i {
                margin: 0;
            }
            
            .page-info {
                padding: 6px 16px;
                font-size: 0.85rem;
                min-width: 80px;
            }
            
            .canvas-container {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="security-overlay" id="securityOverlay">
        <div class="watermark" style="display: none;">READVAULT</div>
    </div>

    <div class="security-header">
        <div class="logo">
            <div class="logo-icon">
                <i class="fas fa-book-open"></i>
            </div>
            <div class="logo-text">ReadVault</div>
        </div>
        
        <div class="book-info">
            <div class="book-title">
                <i class="fas fa-book"></i> <%= pdf.title %>
            </div>
        </div>

        <div class="security-status">
            <i class="fas fa-shield-alt"></i>
            <span>Protected</span>
        </div>
    </div>

    <div class="main-container">
        <div class="loading-state" id="loadingState">
            <div class="loading-spinner"></div>
            <div style="margin-bottom: 1rem;">Loading HD PDF Reader...</div>
            <div class="progress-bar">
                <div class="progress" id="loadingProgress" style="width: 0%"></div>
            </div>
            <div style="font-size: 0.8rem; color: #999; margin-top: 1rem;">
                High Quality • Secure Reading
            </div>
        </div>

        <div class="pdf-container" id="pdfContainer" style="display: none;">
            <div class="canvas-container" id="canvasContainer"></div>
        </div>

        <div class="zoom-controls" id="zoomControls">
            <button class="zoom-btn" id="zoomIn" title="Zoom In (Ctrl + +)">
                <i class="fas fa-search-plus"></i>
            </button>
            <button class="zoom-btn" id="zoomOut" title="Zoom Out (Ctrl + -)">
                <i class="fas fa-search-minus"></i>
            </button>
            <button class="zoom-btn" id="zoomReset" title="Reset Zoom (Ctrl + 0)">
                <i class="fas fa-expand"></i>
            </button>
            <div class="zoom-level" id="zoomLevel">100%</div>
        </div>

        <div class="navigation-controls" id="mainNavigation">
            <div class="nav-buttons-container">
                <button class="back-btn" id="backButton" title="Go Back">
                    <i class="fas fa-arrow-left"></i>
                    <span>Back</span>
                </button>
                
                <button class="nav-btn" id="prevPage" title="Previous Page">
                    <i class="fas fa-chevron-left"></i>
                    <span>Prev</span>
                </button>
                
                <div class="page-info">
                    <span id="currentPage">1</span> / <span id="totalPages">0</span>
                </div>
                
                <button class="nav-btn" id="nextPage" title="Next Page">
                    <span>Next</span>
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="security-warning" id="securityWarning">
        <i class="fas fa-shield-alt"></i> Security Action Blocked
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>
    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';

        const CONFIG = {
            logEndpoint: '<%= typeof basePath !== "undefined" ? basePath + "/api/security/log" : "/ebook/api/security/log" %>',
            pdfId: '<%= pdf._id %>',
            sessionToken: '<%= sessionToken %>',
            minZoom: 0.5,
            maxZoom: 3.0,
            zoomStep: 0.1
        };

        let pdfDoc = null;
        let currentPage = 1;
        let totalPages = 0;
        let currentScale = 1.0;
        let originalScale = 1.0;

        // HD Configuration - High Quality Rendering
        const HD_CONFIG = {
            // Get device pixel ratio for HD rendering
            devicePixelRatio: window.devicePixelRatio || 1,
            // Maximum pixel ratio for HD (limit to 2 for performance)
            maxPixelRatio: Math.min(2, window.devicePixelRatio || 1),
            // Enable image smoothing for better quality
            imageSmoothingEnabled: true,
            imageSmoothingQuality: 'high'
        };

        console.log('HD Config:', HD_CONFIG);

        // ==================== HD ZOOM FUNCTIONS ====================
        
        async function zoomIn() {
            if (currentScale < CONFIG.maxZoom) {
                let newScale = currentScale + CONFIG.zoomStep;
                newScale = Math.min(newScale, CONFIG.maxZoom);
                await applyZoom(newScale);
                showHint('HD Zoomed In: ' + Math.round(newScale * 100) + '%', 'zoom');
            } else {
                showHint('Maximum HD zoom reached', 'zoom');
            }
        }

        async function zoomOut() {
            if (currentScale > CONFIG.minZoom) {
                let newScale = currentScale - CONFIG.zoomStep;
                newScale = Math.max(newScale, CONFIG.minZoom);
                await applyZoom(newScale);
                showHint('HD Zoomed Out: ' + Math.round(newScale * 100) + '%', 'zoom');
            } else {
                showHint('Minimum zoom reached', 'zoom');
            }
        }

        async function zoomReset() {
            await applyZoom(originalScale);
            showHint('HD Zoom Reset: ' + Math.round(originalScale * 100) + '%', 'zoom');
        }

        async function applyZoom(newScale) {
    if (!pdfDoc) return;

    const container = document.getElementById("pdfContainer");

    // 👇 OLD center position nikal lo
    const prevCenterX = container.scrollLeft + container.clientWidth / 2;
    const prevCenterY = container.scrollTop + container.clientHeight / 2;

    const prevScale = currentScale;

    newScale = Math.max(CONFIG.minZoom, Math.min(newScale, CONFIG.maxZoom));
    currentScale = newScale;

    // 👇 re-render
    await renderPageHD(currentPage);

    // 👇 NEW scale ke hisaab se adjust karo
    const scaleRatio = currentScale / prevScale;

    const newScrollLeft = (prevCenterX * scaleRatio) - (container.clientWidth / 2);
    const newScrollTop = (prevCenterY * scaleRatio) - (container.clientHeight / 2);

    container.scrollLeft = newScrollLeft;
    container.scrollTop = newScrollTop;

    updateZoomDisplay();
}

        function updateZoomDisplay() {
            const zoomLevel = document.getElementById('zoomLevel');
            if (zoomLevel) {
                const percent = Math.round(currentScale * 100);
                zoomLevel.textContent = percent + '%';
                
                if (percent === 100) {
                    zoomLevel.style.color = '#10b981';
                } else if (percent > 150) {
                    zoomLevel.style.color = '#f59e0b';
                } else {
                    zoomLevel.style.color = '#ffffff';
                }
            }
        }

        // ==================== MOUSE WHEEL ZOOM ====================

        function setupMouseWheelZoom() {
            const pdfContainer = document.getElementById('pdfContainer');
            if (!pdfContainer) return;
            
            pdfContainer.addEventListener('wheel', (e) => {
                if (e.ctrlKey) {
                    e.preventDefault();
                    if (e.deltaY < 0) {
                        zoomIn();
                    } else {
                        zoomOut();
                    }
                }
            }, { passive: false });
        }

        // ==================== HD PAGE RENDERING ====================

        async function loadPDF() {
            try {
                console.log('Loading HD PDF...');
                console.log('Device Pixel Ratio:', HD_CONFIG.devicePixelRatio);
                
                const basePath = '<%= typeof basePath !== "undefined" ? basePath : "" %>';
                const streamingUrl = `${basePath}/api/stream-pdf?token=<%= sessionToken %>`;
                
                const loadingTask = pdfjsLib.getDocument({
                    url: streamingUrl,
                    withCredentials: false,
                    cMapUrl: 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/cmaps/',
                    cMapPacked: true,
                    disableAutoFetch: false,
                    disableStream: false,
                    disableRange: false,
                    // HD Settings
                    maxImageSize: -1, // No limit for HD
                    disableFontFace: false,
                    enableXfa: true
                });
                
                loadingTask.onProgress = (progress) => {
                    const percent = Math.round((progress.loaded / progress.total) * 100);
                    updateProgress(percent);
                };

                pdfDoc = await loadingTask.promise;
                totalPages = pdfDoc.numPages;
                
                console.log(`HD PDF loaded: ${totalPages} pages`);
                
                document.getElementById('totalPages').textContent = totalPages;
                document.getElementById('loadingState').style.display = 'none';
                document.getElementById('pdfContainer').style.display = 'block';
                
                originalScale = calculateOptimalScale();
                currentScale = originalScale;
                
                await renderPageHD(currentPage);
                updateZoomDisplay();
                
                logSecurityEvent('PDF_LOADED', { pageCount: totalPages });
                
            } catch (error) {
                console.error('PDF load error:', error);
                showError(error);
            }
        }

        function calculateOptimalScale() {
            const container = document.getElementById('pdfContainer');
            if (!container) return 1.0;
            
            const containerWidth = container.clientWidth - 60;
            // Standard PDF page width is around 600-800px
            const optimalScale = containerWidth / 700;
            
            return Math.max(0.6, Math.min(optimalScale, 1.5));
        }

        async function renderPageHD(pageNum) {
            try {
                console.log(`Rendering HD page ${pageNum} at scale ${currentScale}...`);
                
                const page = await pdfDoc.getPage(pageNum);
                const container = document.getElementById('canvasContainer');
                
                container.innerHTML = '';
                
                const canvas = document.createElement('canvas');
                canvas.className = 'page-canvas';
                canvas.id = `page-${pageNum}`;
                
                const ctx = canvas.getContext('2d', {
                    alpha: false,
                    desynchronized: true, // Performance optimization
                    willReadFrequently: false
                });
                
                // Get viewport with current scale
                const viewport = page.getViewport({ scale: currentScale });
                
                // HD Rendering - Use device pixel ratio for sharper text
                const pixelRatio = HD_CONFIG.maxPixelRatio;
                
                // Set canvas dimensions with pixel ratio for HD
                canvas.width = Math.floor(viewport.width * pixelRatio);
                canvas.height = Math.floor(viewport.height * pixelRatio);
                canvas.style.width = viewport.width + 'px';
                canvas.style.height = viewport.height + 'px';
                
                // Scale context for HD rendering
                ctx.scale(pixelRatio, pixelRatio);
                
                // Enable high-quality image smoothing
                ctx.imageSmoothingEnabled = HD_CONFIG.imageSmoothingEnabled;
                ctx.imageSmoothingQuality = HD_CONFIG.imageSmoothingQuality;
                
                // Better text rendering
                ctx.textRenderingOptimization = 'optimizeLegibility';
                
                container.appendChild(canvas);
                
                const renderContext = {
                    canvasContext: ctx,
                    viewport: viewport,
                    background: 'white',
                    // HD rendering options
                    enableWebGL: true,
                    renderInteractiveForms: true,
                    annotationMode: 2 // Render all annotations
                };

                await page.render(renderContext).promise;
                
                updateNavigation();
                
                // Cache page
                if (!window.pageCache) window.pageCache = {};
                window.pageCache[pageNum] = page;
                
                console.log(`HD Page ${pageNum} rendered`);
                console.log(`  - Scale: ${Math.round(currentScale * 100)}%`);
                console.log(`  - Viewport: ${Math.round(viewport.width)} x ${Math.round(viewport.height)}px`);
                console.log(`  - Canvas: ${canvas.width} x ${canvas.height}px (${pixelRatio}x HD)`);
                
            } catch (error) {
                console.error('HD Render error:', error);
                throw error;
            }
        }

        // ==================== NAVIGATION ====================

        async function goToPreviousPage() {
            if (currentPage > 1) {
                currentPage--;
                await renderPageHD(currentPage);
                document.getElementById('currentPage').textContent = currentPage;
                updateNavigation();
                logSecurityEvent('PAGE_PREV', { page: currentPage });
            }
        }

        async function goToNextPage() {
            if (currentPage < totalPages) {
                currentPage++;
                await renderPageHD(currentPage);
                document.getElementById('currentPage').textContent = currentPage;
                updateNavigation();
                logSecurityEvent('PAGE_NEXT', { page: currentPage });
            }
        }

        async function goToPage(pageNum) {
            if (pageNum >= 1 && pageNum <= totalPages && pageNum !== currentPage) {
                currentPage = pageNum;
                await renderPageHD(currentPage);
                document.getElementById('currentPage').textContent = currentPage;
                updateNavigation();
                logSecurityEvent('PAGE_JUMP', { page: pageNum });
            }
        }

        function updateNavigation() {
            const prevBtn = document.getElementById('prevPage');
            const nextBtn = document.getElementById('nextPage');
            
            if (prevBtn) prevBtn.disabled = currentPage <= 1;
            if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
        }

        // ==================== KEYBOARD SHORTCUTS ====================

        function setupKeyboardShortcuts() {
            document.addEventListener('keydown', (e) => {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
                
                switch(e.key) {
                    case 'ArrowLeft':
                        e.preventDefault();
                        goToPreviousPage();
                        break;
                        
                    case 'ArrowRight':
                        e.preventDefault();
                        goToNextPage();
                        break;
                        
                    case '+':
                    case '=':
                        if (e.ctrlKey || e.metaKey) {
                            e.preventDefault();
                            zoomIn();
                        }
                        break;
                        
                    case '-':
                        if (e.ctrlKey || e.metaKey) {
                            e.preventDefault();
                            zoomOut();
                        }
                        break;
                        
                    case '0':
                        if (e.ctrlKey || e.metaKey) {
                            e.preventDefault();
                            zoomReset();
                        }
                        break;
                        
                    case 'Escape':
                        e.preventDefault();
                        goBack();
                        break;
                        
                    case 'Home':
                        e.preventDefault();
                        goToPage(1);
                        break;
                        
                    case 'End':
                        e.preventDefault();
                        goToPage(totalPages);
                        break;
                }
            });
        }

        // ==================== BACK BUTTON ====================

        function goBack() {
            const basePath = '<%= typeof basePath !== "undefined" ? basePath : "/ebook" %>';
            window.location.href = basePath;
        }

        function setupBackButton() {
            const backButton = document.getElementById('backButton');
            if (backButton) {
                backButton.addEventListener('click', goBack);
            }
        }

        // ==================== UI HELPERS ====================

        function updateProgress(percent) {
            const progress = document.getElementById('loadingProgress');
            if (progress) {
                progress.style.width = percent + '%';
            }
        }

        function showHint(message, type = 'general') {
            const existingHint = document.querySelector('.' + type + '-hint');
            if (existingHint) existingHint.remove();
            
            const hint = document.createElement('div');
            hint.className = type + '-hint';
            hint.innerHTML = `<i class="fas fa-${type === 'zoom' ? 'search' : 'info-circle'}"></i> ${message}`;
            document.body.appendChild(hint);
            
            setTimeout(() => {
                hint.style.opacity = '0';
                hint.style.transition = 'opacity 0.3s ease';
                setTimeout(() => hint.remove(), 300);
            }, 2000);
        }

        function showError(error) {
            const loadingState = document.getElementById('loadingState');
            if (loadingState) {
                loadingState.innerHTML = `
                    <div style="text-align: center; color: #ef4444;">
                        <i class="fas fa-exclamation-triangle" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                        <div style="font-size: 1.2rem; margin-bottom: 0.5rem;">Failed to load PDF</div>
                        <div style="font-size: 0.9rem; margin-bottom: 1rem;">${error.message}</div>
                        <button onclick="location.reload()" style="padding: 12px 24px; background: linear-gradient(135deg, #667eea, #764ba2); border: none; border-radius: 40px; color: white; cursor: pointer;">
                            <i class="fas fa-redo"></i> Retry
                        </button>
                    </div>
                `;
            }
        }

        function showSecurityWarning(message) {
            const warning = document.getElementById('securityWarning');
            if (warning) {
                warning.innerHTML = `<i class="fas fa-shield-alt"></i> ${message}`;
                warning.style.display = 'block';
                setTimeout(() => {
                    warning.style.display = 'none';
                }, 2000);
            }
        }

        // ==================== SECURITY ====================

        function setupSecurity() {
            document.addEventListener('contextmenu', (e) => {
                e.preventDefault();
                showSecurityWarning('Right-click disabled');
                return false;
            });
            
            // ✅ allow drag but block text selection
document.addEventListener('selectstart', (e) => {
    if (!e.target.closest('#pdfContainer')) {
        e.preventDefault();
    }
});;
            
            document.addEventListener('dragstart', (e) => {
                e.preventDefault();
                return false;
            });
            
            window.addEventListener('beforeprint', (e) => {
                e.preventDefault();
                showSecurityWarning('Printing is disabled');
                logSecurityEvent('PRINT_ATTEMPT_BLOCKED');
                return false;
            });
            
            window.print = function() {
                showSecurityWarning('Printing is disabled');
                logSecurityEvent('PRINT_FUNCTION_BLOCKED');
                return false;
            };
            
            document.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.key === 'p') {
                    e.preventDefault();
                    showSecurityWarning('Printing is disabled');
                    logSecurityEvent('PRINT_SHORTCUT_BLOCKED');
                    return false;
                }
            });
        }

        function logSecurityEvent(eventType, details = {}) {
            if (CONFIG.logEndpoint) {
                fetch(CONFIG.logEndpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        eventType,
                        pdfId: CONFIG.pdfId,
                        details: {
                            ...details,
                            userAgent: navigator.userAgent,
                            timestamp: new Date().toISOString()
                        }
                    })
                }).catch(err => console.error('Log failed:', err));
            }
        }

        // ==================== EVENT LISTENERS ====================

        function setupEventListeners() {
            document.getElementById('prevPage').addEventListener('click', goToPreviousPage);
            document.getElementById('nextPage').addEventListener('click', goToNextPage);
            document.getElementById('backButton').addEventListener('click', goBack);
            document.getElementById('zoomIn').addEventListener('click', zoomIn);
            document.getElementById('zoomOut').addEventListener('click', zoomOut);
            document.getElementById('zoomReset').addEventListener('click', zoomReset);
            
            setupMouseWheelZoom();
            setupKeyboardShortcuts();
        }

        // ==================== RESIZE HANDLER ====================

        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                if (pdfDoc) {
                    originalScale = calculateOptimalScale();
                    if (Math.abs(currentScale - originalScale) < 0.1) {
                        currentScale = originalScale;
                        renderPageHD(currentPage);
                        updateZoomDisplay();
                    }
                }
            }, 250);
        });

        // ==================== INITIALIZATION ====================

        document.addEventListener('DOMContentLoaded', async () => {
            console.log('HD PDF Reader Initializing...');
            console.log('Screen:', window.innerWidth, 'x', window.innerHeight);
            console.log('Device Pixel Ratio:', window.devicePixelRatio);
            
            setupSecurity();
            setupEventListeners();
            setupBackButton();
                enableDragPan();  // 👈 ADD THIS
            await loadPDF();
            
            console.log('HD PDF Reader Ready!');
        });

        window.addEventListener('beforeunload', () => {
            if (pdfDoc) {
                pdfDoc.destroy().catch(() => {});
            }
            logSecurityEvent('USER_EXIT', {
                lastPage: currentPage,
                zoomLevel: currentScale
            });
        });

        function enableDragPan() {
    const container = document.getElementById("pdfContainer");

    let isDragging = false;
    let startX, startY;
    let scrollLeft, scrollTop;

    container.addEventListener("mousedown", (e) => {
        isDragging = true;
        startX = e.pageX - container.offsetLeft;
        startY = e.pageY - container.offsetTop;
        scrollLeft = container.scrollLeft;
        scrollTop = container.scrollTop;
    });

    container.addEventListener("mouseleave", () => {
        isDragging = false;
    });

    container.addEventListener("mouseup", () => {
        isDragging = false;
    });

    container.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        e.preventDefault();

        const x = e.pageX - container.offsetLeft;
        const y = e.pageY - container.offsetTop;

        const walkX = (x - startX) * 1.5;
        const walkY = (y - startY) * 1.5;

        container.scrollLeft = scrollLeft - walkX;
        container.scrollTop = scrollTop - walkY;
    });
}
    </script>
</body>
</html>

