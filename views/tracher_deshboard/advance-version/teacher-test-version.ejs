<!-- Modal for Create Test - DESKTOP + MOBILE RESPONSIVE -->
<div class="modal" id="createTestModal">
    <div class="modal-content responsive-modal">
        <div class="modal-header">
            <h2><i class="fas fa-pen-alt"></i> Create Test Questions</h2>
            <button class="close-btn" onclick="closeModal('createTestModal')">&times;</button>
        </div>
        
        <div class="modal-body responsive-modal-body">
            
            <!-- LEFT COLUMN: Added Questions -->
            <div class="left-column">
                <div class="panel-title">
                    <i class="fas fa-list"></i>
                    <span>Added Questions</span>
                    <span class="question-badge" id="questionCountBadge">0</span>
                </div>
                
                <div class="questions-container" id="questionList">
                    <div class="empty-state">
                        <i class="fas fa-question-circle"></i>
                        <p>No questions added yet.</p>
                        <small>Add your first question below 👇</small>
                    </div>
                </div>
                
                <!-- DESKTOP BUTTONS (Left Panel ke andar) - सिर्फ डेस्कटॉप पर दिखेगा -->
                <div class="desktop-buttons">
                    <button class="btn-cancel-desktop" onclick="closeModal('createTestModal')">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <button class="btn-save-desktop" id="saveQuestionsBtn">
                        <i class="fas fa-save"></i> Save All
                    </button>
                </div>
            </div>

            <!-- RIGHT COLUMN: Add New Question -->
            <div class="right-column">
                <div class="panel-title">
                    <i class="fas fa-plus-circle"></i>
                    <span>Add New Question</span>
                </div>
                
                <!-- Question Type + Marks -->
                <div class="row-2cols">
                    <div class="form-group-custom">
                        <label>Question Type</label>
                        <select id="questionType" class="custom-input">
                            <option value="multiple-choice">Multiple Choice (MCQ)</option>
                            <option value="true-false">True/False</option>
                            <option value="short-answer">Short Answer</option>
                        </select>
                    </div>
                    <div class="form-group-custom">
                        <label>Marks</label>
                        <input type="number" id="questionPoints" class="custom-input" value="1" min="1">
                    </div>
                </div>

                <!-- Write Your Question -->
                <div class="form-group-custom">
                    <label>Write Your Question</label>
                    <textarea id="questionText" class="custom-input" rows="2" placeholder="Enter your question..."></textarea>
                </div>

                <!-- Options (MCQ) -->
                <div id="optionsContainer">
                    <label>Options (For MCQ)</label>
                    <div id="optionsList" class="options-grid-custom">
                        <div class="option-row-custom">
                            <input type="radio" name="correctOption" value="0">
                            <input type="text" id="option0" class="custom-input" placeholder="Option A">
                        </div>
                        <div class="option-row-custom">
                            <input type="radio" name="correctOption" value="1">
                            <input type="text" id="option1" class="custom-input" placeholder="Option B">
                        </div>
                        <div class="option-row-custom">
                            <input type="radio" name="correctOption" value="2">
                            <input type="text" id="option2" class="custom-input" placeholder="Option C">
                        </div>
                        <div class="option-row-custom">
                            <input type="radio" name="correctOption" value="3">
                            <input type="text" id="option3" class="custom-input" placeholder="Option D">
                        </div>
                    </div>
                    <button type="button" class="add-option-custom" id="addOptionBtn">
                        <i class="fas fa-plus"></i> Add More Options
                    </button>
                </div>

                <!-- Difficulty + Translate -->
                <div class="row-2cols">
                    <div class="form-group-custom">
                        <label>Difficulty</label>
                        <select id="questionDifficulty" class="custom-input">
                            <option value="Easy">Easy</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                    </div>
                    <div class="form-group-custom">
                        <label>&nbsp;</label>
                        <button type="button" class="translate-custom" onclick="translateAuto()">
                            <i class="fas fa-language"></i> Auto Translate
                        </button>
                    </div>
                </div>

                <!-- Add Question Button -->
                <button class="add-question-custom" id="addQuestionBtn">
                    <i class="fas fa-plus"></i> Add Question to Test
                </button>
            </div>
        </div>

        <!-- MOBILE BUTTONS (सिर्फ मोबाइल पर दिखेगा - सबसे नीचे) -->
