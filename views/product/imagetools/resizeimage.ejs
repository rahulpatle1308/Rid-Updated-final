<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes"/>
<title>Resize Image – RID Bharat</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
/* ============================================================
   RESET
   ============================================================ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

/* ============================================================
   RID BHARAT CSS VARIABLES (header/footer)
   ============================================================ */
:root{
  --primary:#083d5d;--primary-dark:#062a41;--secondary:#4da8da;
  --accent:#ff6b35;--light:#f2f7fc;--dark:#333;--gray:#555;
  --light-gray:#e0e0e0;--white:#ffffff;
  --shadow:0 5px 15px rgba(0,0,0,.08);--transition:all 0.3s ease;

  /* Resize tool variables */
  --bg:#eef0f5;--surface:#ffffff;--surface2:#f4f5f9;
  --border:#dde0ea;--text:#14161f;--text-muted:#6e7491;
  --tool-accent:#4f6ef7;--accent2:#a78bfa;
  --accent-glow:rgba(79,110,247,0.16);
  --tool-shadow:0 8px 40px rgba(14,16,31,0.10);
  --radius:20px;--radius-sm:12px;
  --tool-transition:all 0.3s cubic-bezier(.4,0,.2,1);
}
[data-theme="dark"]{
  --bg:#0f1018;--surface:#181a26;--surface2:#1f2133;
  --border:#2a2d42;--text:#eef0f5;--text-muted:#7a7e9a;
  --tool-accent:#6b8aff;--accent2:#b39dfa;
  --accent-glow:rgba(107,138,255,0.18);
  --tool-shadow:0 8px 40px rgba(0,0,0,0.45);
}

/* ============================================================
   BASE BODY
   ============================================================ */
html{height:100%;}
body{
  font-family:'Poppins',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  background-color:var(--bg);
  color:var(--text);
  line-height:1.6;
  /* desktop: top-bar 40px + nav 90px = 130px */
  padding-top:130px;
  overflow-x:hidden;
  font-weight:400;
   overflow-y:auto;
  text-rendering:optimizeLegibility;
  -webkit-font-smoothing:antialiased;
  min-height:100%;
  display:flex;
  flex-direction:column;
  transition:background .3s,color .3s;
}
input,button,textarea,select{font-family:inherit;font-size:inherit;line-height:inherit;}
a{text-decoration:none;color:inherit;transition:var(--transition);}
ul{list-style:none;}
button{cursor:pointer;border:none;outline:none;transition:var(--transition);}
img{max-width:100%;height:auto;display:block;}

/* ============================================================
   HEADER
   ============================================================ */
.header-container{position:fixed;top:0;left:0;width:100%;z-index:1000;}

.top-header{
  display:flex;justify-content:space-between;align-items:center;
  background:linear-gradient(90deg,#062a41 0%,#0a4d6e 100%);
  color:#fff;padding:0 20px;height:40px;font-size:14px;
  letter-spacing:.3px;box-shadow:0 2px 10px rgba(0,0,0,.1);
}
.web-text p{display:inline-block;font-size:.6rem;font-weight:700;}
.web-text p span{font-weight:300;}
.web-text p::after{content:"|";margin:0 10px;color:#fff;font-weight:300;}
.web-text p:last-child::after{content:"";}
.right-text{display:flex;}
.right-text a{font-size:.6rem;color:white;text-decoration:none;}
.right-text a::after{content:"|";margin:0 8px;color:#fff;font-weight:300;}
.right-text a:last-child::after{content:"";}

.main-header{
  backdrop-filter:blur(10px);
  background:rgba(255,255,255,.92);
  border-bottom:1px solid rgba(77,168,218,.3);
  box-shadow:0 2px 10px rgba(0,0,0,.1);
}
.nav{
  display:flex;justify-content:space-between;align-items:center;
  height:90px;padding:0 20px;transition:all .3s ease;
}
.logo{display:flex;align-items:center;flex:1;}
.logo img{height:80px;max-height:80px;transition:all .3s ease;}

/* Menu wrapper */
.menu{display:flex;justify-content:flex-end;align-items:flex-end;flex-direction:column;}

/* Upper nav */
.upperNav{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:nowrap;}

.nav-button{
  display:flex;justify-content:center;align-items:center;gap:5px;
  font-size:.9rem;font-weight:600;padding:8px 15px;border-radius:30px;
  transition:all .3s ease;cursor:pointer;border:none;outline:none;
  box-shadow:0 4px 10px rgba(0,53,84,.2);
}
#onlineTest1{background:linear-gradient(145deg,#dc143c,#b22222);color:#fff;}
#ebookBtn{background:#c67534;color:#fff;}
#certificate{background:linear-gradient(145deg,#0b5e0b,#0a470a);color:#fff;}
#onlineTest1:hover,#ebookBtn:hover,#certificate:hover{background:#000;transform:translateY(-2px);}

/* Login/Register toggle — NO OVERLAP FIX */
.btn-box{
  width:220px;display:flex;flex-shrink:0;
  box-shadow:0 2px 4px rgba(0,0,0,.1);
  border-radius:30px;position:relative;
  background:rgba(240,240,240,.6);
  backdrop-filter:blur(4px);
  border:1px solid rgba(8,61,93,.2);
  overflow:hidden;
}
.toggle-btn{
  padding:8px 0;position:relative;outline:none;border:none;
  background:transparent;font-size:.85rem;color:#000;
  display:flex;justify-content:center;align-items:center;gap:4px;
  z-index:1;width:50%;cursor:pointer;transition:color .3s ease;font-weight:600;
  white-space:nowrap;
}
#swap-btn{
  position:absolute;top:0;left:0;width:50%;height:100%;
  background:#083d5d;border-radius:30px;transition:all .4s ease;z-index:0;
}
#logInButton{color:white;}
#signUpBtn{color:#333;}

/* Lower nav */
.lowerNav{display:flex;gap:22px;}
.lowerNav ul{display:flex;gap:20px;}
.lowerNav li{position:relative;}
.lowerNav li a{font-size:.9rem;color:#333;font-weight:500;}
.menu-link{display:flex;align-items:center;cursor:pointer;padding:8px 0;}
.menu-link:hover{color:#083d5d;}

/* Hamburger */
.menu-icon{
  display:none;flex-direction:column;justify-content:space-between;
  width:30px;height:21px;cursor:pointer;margin-left:auto;z-index:1001;
}
.menu-icon span{display:block;height:3px;width:100%;background:var(--primary);border-radius:3px;transition:all .3s ease;}
.menu-icon.active span:nth-child(1){transform:translateY(9px) rotate(45deg);}
.menu-icon.active span:nth-child(2){opacity:0;}
.menu-icon.active span:nth-child(3){transform:translateY(-9px) rotate(-45deg);}

/* Desktop hover underline */
@media(min-width:769px){
  .menu-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:#083d5d;transition:width .3s ease;}
  .menu-link:hover::after{width:100%;}
}

/* Dropdown */
.dropdown-toggle .fa-chevron-down{margin-left:.3rem;font-size:.8rem;transition:transform .3s ease;}
.dropdown-menu{
  display:none;position:absolute;left:0;top:100%;background:#fff;
  box-shadow:0 5px 15px rgba(0,0,0,.1);border-radius:8px;padding:10px 0;
  min-width:220px;z-index:1000;
}
.dropdown.active .dropdown-menu{display:block;}
.dropdown-menu .nav-link{
  padding:12px 20px;border-bottom:1px solid #f0f0f0;display:flex;
  align-items:center;width:100%;color:#333;font-size:.9rem;transition:all .3s ease;
}
.dropdown-menu .nav-link:hover{background:#f8f9fa;color:#083d5d;padding-left:25px;}
@media(min-width:769px){.dropdown:hover .dropdown-menu{display:block;}.dropdown:hover .fa-chevron-down{transform:rotate(180deg);}}

/* ============================================================
   MAIN CONTENT WRAPPER
   ============================================================ */
.page-main{
  flex:1;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:40px 20px;
  min-height:calc(100vh - 130px);
}

/* ============================================================
   RESIZE TOOL — noise background
   ============================================================ */
body::before{
  content:'';
  position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;z-index:0;opacity:.5;
}

/* Card */
.card{
  position:relative;z-index:1;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:28px;
  box-shadow:var(--tool-shadow);
  width:100%;max-width:780px;
  padding:36px 40px 32px;
  transition:var(--tool-transition);
}

/* Topbar inside card */
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;}
.page-title{
  font-family:'Syne',sans-serif;
  font-size:1.55rem;font-weight:800;letter-spacing:-.03em;color:var(--text);
  display:flex;align-items:center;gap:10px;
}
.page-title .dot{
  width:10px;height:10px;border-radius:50%;background:var(--tool-accent);
  box-shadow:0 0 12px var(--accent-glow);display:inline-block;
}
.theme-btn{
  background:var(--surface2);border:1px solid var(--border);border-radius:50px;
  padding:7px 16px;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:500;
  color:var(--text-muted);cursor:pointer;display:flex;align-items:center;gap:7px;
  transition:var(--tool-transition);
}
.theme-btn:hover{background:var(--tool-accent);color:#fff;border-color:var(--tool-accent);}

/* Layout */
.main-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px;}

/* Upload zone */
.upload-zone{
  border:2px dashed var(--border);border-radius:var(--radius);
  background:var(--surface2);display:flex;flex-direction:column;
  align-items:center;justify-content:center;cursor:pointer;
  transition:var(--tool-transition);min-height:260px;position:relative;overflow:hidden;
}
.upload-zone:hover,.upload-zone.dragover{border-color:var(--tool-accent);background:var(--accent-glow);}
.upload-zone input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.upload-icon{
  width:56px;height:56px;background:var(--accent-glow);border-radius:16px;
  display:flex;align-items:center;justify-content:center;margin-bottom:14px;transition:var(--tool-transition);
}
.upload-zone:hover .upload-icon{transform:scale(1.08);background:var(--tool-accent);}
.upload-label{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--text);margin-bottom:5px;}
.upload-sub{font-size:.78rem;color:var(--text-muted);text-align:center;}
.upload-preview{width:100%;height:100%;position:absolute;inset:0;display:none;}
.upload-preview img{width:100%;height:100%;object-fit:cover;border-radius:calc(var(--radius) - 2px);}
.upload-preview .change-overlay{
  position:absolute;inset:0;background:rgba(0,0,0,.45);border-radius:calc(var(--radius) - 2px);
  display:flex;align-items:center;justify-content:center;opacity:0;transition:var(--tool-transition);
  font-family:'Syne',sans-serif;color:#fff;font-size:.85rem;font-weight:700;
}
.upload-preview:hover .change-overlay{opacity:1;}
.dim-badge{
  position:absolute;bottom:10px;left:10px;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);
  border-radius:8px;padding:4px 10px;font-family:'Syne',sans-serif;font-size:.72rem;font-weight:700;color:#fff;display:none;
}

/* Right panel */
.right-panel{display:flex;flex-direction:column;gap:14px;}

/* Stats */
.stats-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.stat-box{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 15px;transition:var(--tool-transition);}
.stat-label{font-size:.68rem;font-weight:500;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px;}
.stat-value{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--text);}
.stat-value.new{color:var(--tool-accent);}

/* Mode toggle */
.mode-toggle{
  display:flex;background:var(--surface2);border:1px solid var(--border);
  border-radius:50px;padding:4px;gap:4px;
}
.mode-btn{
  flex:1;border:none;border-radius:50px;padding:7px 10px;
  font-family:'Syne',sans-serif;font-size:.73rem;font-weight:700;
  color:var(--text-muted);background:transparent;cursor:pointer;
  transition:var(--tool-transition);white-space:nowrap;
}
.mode-btn.active{background:var(--tool-accent);color:#fff;box-shadow:0 2px 10px var(--accent-glow);}

/* Dimension inputs */
.dim-block{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:15px 16px;}
.dim-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.dim-row:last-of-type{margin-bottom:0;}
.dim-input-label{font-family:'Syne',sans-serif;font-size:.78rem;font-weight:700;color:var(--text-muted);width:18px;flex-shrink:0;}
.dim-input-wrap{
  flex:1;display:flex;align-items:center;background:var(--surface);
  border:1.5px solid var(--border);border-radius:9px;overflow:hidden;transition:var(--tool-transition);
}
.dim-input-wrap:focus-within{border-color:var(--tool-accent);box-shadow:0 0 0 3px var(--accent-glow);}
.dim-input{
  flex:1;border:none;background:transparent;font-family:'Syne',sans-serif;
  font-size:.95rem;font-weight:700;color:var(--text);padding:9px 12px;outline:none;min-width:0;
}
.dim-unit{padding:9px 12px 9px 0;font-size:.75rem;color:var(--text-muted);font-weight:500;}
.lock-row{display:flex;align-items:center;justify-content:center;gap:8px;margin:2px 0 10px;}
.lock-line{flex:1;height:1px;background:var(--border);}
.lock-btn{
  background:var(--surface);border:1.5px solid var(--border);border-radius:8px;padding:5px 10px;
  font-size:.75rem;color:var(--text-muted);cursor:pointer;display:flex;align-items:center;gap:5px;
  font-family:'Syne',sans-serif;font-weight:700;transition:var(--tool-transition);
}
.lock-btn.locked{border-color:var(--tool-accent);color:var(--tool-accent);background:var(--accent-glow);}
.lock-btn:hover{border-color:var(--tool-accent);color:var(--tool-accent);}

/* Percent block */
.percent-block{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:15px 16px;display:none;}
.pct-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.pct-title{font-family:'Syne',sans-serif;font-size:.85rem;font-weight:700;color:var(--text);}
.pct-badge{background:var(--tool-accent);color:#fff;font-family:'Syne',sans-serif;font-size:.8rem;font-weight:700;padding:3px 10px;border-radius:50px;min-width:50px;text-align:center;}
input[type="range"]{-webkit-appearance:none;width:100%;height:6px;border-radius:50px;background:var(--border);outline:none;cursor:pointer;}
input[type="range"]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--tool-accent);box-shadow:0 0 0 4px var(--accent-glow);cursor:pointer;transition:var(--tool-transition);}
input[type="range"]::-webkit-slider-thumb:hover{transform:scale(1.2);}
.pct-hints{display:flex;justify-content:space-between;margin-top:6px;}
.pct-hints span{font-size:.68rem;color:var(--text-muted);}

/* Preset chips */
.preset-chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;}
.chip{
  background:var(--surface);border:1.5px solid var(--border);border-radius:50px;padding:4px 11px;
  font-family:'Syne',sans-serif;font-size:.7rem;font-weight:700;
  color:var(--text-muted);cursor:pointer;transition:var(--tool-transition);
}
.chip:hover{border-color:var(--tool-accent);color:var(--tool-accent);background:var(--accent-glow);}
.chip.active{background:var(--tool-accent);border-color:var(--tool-accent);color:#fff;}

/* Format */
.format-block{display:flex;gap:6px;}
.fmt-btn{
  background:var(--surface2);border:1.5px solid var(--border);border-radius:9px;padding:8px 12px;
  font-family:'Syne',sans-serif;font-size:.75rem;font-weight:700;
  color:var(--text-muted);cursor:pointer;transition:var(--tool-transition);
}
.fmt-btn:hover{border-color:var(--tool-accent);color:var(--tool-accent);}
.fmt-btn.active{background:var(--tool-accent);border-color:var(--tool-accent);color:#fff;box-shadow:0 3px 12px var(--accent-glow);}

/* Progress */
.progress-wrap{display:none;background:var(--border);border-radius:50px;height:6px;overflow:hidden;}
.progress-bar{height:100%;background:linear-gradient(90deg,var(--tool-accent),var(--accent2));border-radius:50px;width:0%;transition:width .4s ease;}

/* Saved badge */
.saved-badge{
  display:none;align-items:center;justify-content:center;gap:6px;
  background:var(--accent-glow);border:1px solid var(--tool-accent);border-radius:50px;padding:7px 16px;
  font-family:'Syne',sans-serif;font-size:.82rem;font-weight:700;color:var(--tool-accent);
  animation:popIn .4s cubic-bezier(.4,0,.2,1);
}
@keyframes popIn{from{transform:scale(.85);opacity:0;}to{transform:scale(1);opacity:1;}}

/* Resize button */
.resize-btn{
  width:100%;background:var(--tool-accent);color:#fff;
  border:none;border-radius:var(--radius-sm);padding:15px;
  font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;
  cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px;
  transition:var(--tool-transition);letter-spacing:-.01em;position:relative;overflow:hidden;
}
.resize-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12),transparent);pointer-events:none;}
.resize-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px var(--accent-glow);}
.resize-btn:active{transform:translateY(0);}
.resize-btn:disabled{opacity:.45;cursor:not-allowed;transform:none;box-shadow:none;}

/* Download button */
.download-btn{
  width:100%;background:transparent;color:var(--tool-accent);
  border:1.5px solid var(--tool-accent);border-radius:var(--radius-sm);padding:12px;
  font-family:'Syne',sans-serif;font-size:.92rem;font-weight:700;
  cursor:pointer;display:none;align-items:center;justify-content:center;gap:8px;
  transition:var(--tool-transition);
}
.download-btn:hover{background:var(--tool-accent);color:#fff;}

/* ============================================================
   FOOTER
   ============================================================ */
footer{
  background:linear-gradient(145deg,#0a3750,#031f2f);
  color:#fff;padding:30px 0 0;position:relative;overflow:hidden;width:100%;
}
footer::before{
  content:'';position:absolute;top:0;left:0;width:100%;height:4px;
  background:linear-gradient(90deg,var(--accent),var(--secondary),var(--accent));
}
.container{width:100%;max-width:1200px;margin:0 auto;padding:0 20px;}
.footer-content{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;}
.footer-logo{display:flex;flex-direction:column;}
.footer-logo img{max-width:180px;height:auto;margin-bottom:10px;background:#fff;padding:5px;border-radius:6px;}
.footer-logo p{margin-bottom:8px;color:var(--light-gray);font-size:.8rem;line-height:1.4;}
.contact-info{margin-top:5px;}
.contact-info p{margin-bottom:4px;display:flex;align-items:center;gap:6px;font-size:.8rem;}
.contact-info i{color:var(--secondary);width:14px;font-size:.8rem;}
.footer-links h3,.footer-social h3{font-size:1rem;margin-bottom:12px;position:relative;padding-bottom:6px;font-weight:600;}
.footer-links h3::after,.footer-social h3::after{content:'';position:absolute;left:0;bottom:0;width:30px;height:2px;background:var(--secondary);border-radius:2px;}
.footer-links ul li{margin-bottom:8px;transition:transform .3s;}
.footer-links ul li:hover{transform:translateX(5px);}
.footer-links a{color:var(--light-gray);display:flex;align-items:center;gap:5px;font-size:.8rem;}
.footer-links a:hover{color:#fff;}
.footer-links a i{color:var(--secondary);font-size:.7rem;}
.footer-social ul{display:flex;flex-wrap:wrap;gap:8px;}
.footer-social a{display:flex;align-items:center;gap:5px;color:var(--light-gray);transition:all .3s;padding:5px 10px;background:rgba(255,255,255,.1);border-radius:5px;font-size:.8rem;}
.footer-social a:hover{color:#fff;background:rgba(77,168,218,.3);transform:translateY(-3px);}
.footer-bottom{border-top:1px solid rgba(255,255,255,.1);padding:15px 0;text-align:center;color:var(--light-gray);font-size:.75rem;position:relative;z-index:1;}
.footer-links-bottom{display:flex;justify-content:center;gap:12px;margin-top:8px;flex-wrap:wrap;}
.footer-links-bottom a{color:#b0d4ed;font-size:.75rem;position:relative;}
.footer-links-bottom a:not(:last-child)::after{content:'|';position:absolute;right:-8px;color:var(--secondary);}
.footer-links-bottom a:hover{color:var(--accent);}

/* ============================================================
   RESPONSIVE — MOBILE (≤ 768px)
   ============================================================ */
@media(max-width:768px){
  body{padding-top:80px;}
  .top-header{display:none;}
  .menu-icon{display:flex;}
  .nav{flex-direction:row;height:auto;padding:10px 20px;}
  .logo img{height:60px;}

  /* Fullscreen mobile menu */
  .menu{
    position:fixed;top:80px;left:0;width:100%;height:calc(100vh - 80px);
    background:rgba(255,255,255,.98);backdrop-filter:blur(15px);
    flex-direction:column;align-items:flex-start;justify-content:flex-start;
    display:none;padding:20px 16px;overflow-y:auto;z-index:999;
    transform:translateX(-100%);box-shadow:0 5px 15px rgba(0,0,0,.1);
  }
