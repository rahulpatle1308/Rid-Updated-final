<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script>
/* ── HEADER: mobile menu ── */
(function(){
  const menuIcon=document.getElementById('menuIcon');
  const menu=document.getElementById('innerCont');
  if(menuIcon){
    menuIcon.addEventListener('click',function(e){
      e.stopPropagation();
      this.classList.toggle('active');
      menu.classList.toggle('active');
    });
    document.addEventListener('click',function(e){
      if(!menu.contains(e.target)&&!menuIcon.contains(e.target)){
        menu.classList.remove('active');
        menuIcon.classList.remove('active');
      }
    });
  }
  document.querySelectorAll('.dropdown').forEach(dd=>{
    const toggle=dd.querySelector('.dropdown-toggle');
    if(toggle) toggle.addEventListener('click',function(e){
      e.preventDefault();
      if(window.innerWidth<=768) dd.classList.toggle('active');
    });
  });
})();

/* ── LOGIN/REGISTER SLIDE ── */
const loginBtn=document.getElementById('logInButton');
const registerBtn=document.getElementById('signUpBtn');
const swapBtn=document.getElementById('swap-btn');
if(loginBtn) loginBtn.addEventListener('click',()=>{
  swapBtn.style.left='0%';
  loginBtn.style.color='white';
  registerBtn.style.color='#333';
});
if(registerBtn) registerBtn.addEventListener('click',()=>{
  swapBtn.style.left='50%';
  registerBtn.style.color='white';
  loginBtn.style.color='#333';
});

/* ── RESIZE TOOL ── */
let currentFile=null,originalW=0,originalH=0;
let resizedBlob=null,selectedFormat='jpeg';
let isDark=false,resizeMode='px',aspectLocked=true;

function toggleTheme(){
  isDark=!isDark;
  document.documentElement.setAttribute('data-theme',isDark?'dark':'');
  const btn=document.querySelector('.theme-btn');
  btn.querySelector('.theme-icon').textContent=isDark?'☀️':'🌙';
  btn.querySelector('.theme-label').textContent=isDark?'Light':'Dark';
}

function switchMode(mode){
  resizeMode=mode;
  document.getElementById('modePx').classList.toggle('active',mode==='px');
  document.getElementById('modePct').classList.toggle('active',mode==='pct');
  document.getElementById('pxBlock').style.display=mode==='px'?'block':'none';
  document.getElementById('pctBlock').style.display=mode==='pct'?'block':'none';
  updateNewDimPreview();
}

function toggleLock(){
  aspectLocked=!aspectLocked;
  const btn=document.getElementById('lockBtn');
  document.getElementById('lockIcon').textContent=aspectLocked?'🔒':'🔓';
  document.getElementById('lockLabel').textContent=aspectLocked?'Ratio Locked':'Ratio Free';
  btn.classList.toggle('locked',aspectLocked);
}

function onWChange(){
  const w=parseInt(document.getElementById('inputW').value);
  if(aspectLocked&&originalW&&w) document.getElementById('inputH').value=Math.round(w*originalH/originalW);
  updateNewDimPreview();clearChips();
}
function onHChange(){
  const h=parseInt(document.getElementById('inputH').value);
  if(aspectLocked&&originalH&&h) document.getElementById('inputW').value=Math.round(h*originalW/originalH);
  updateNewDimPreview();clearChips();
}

function setPreset(w){
  document.getElementById('inputW').value=w;
  if(originalW) document.getElementById('inputH').value=Math.round(w*originalH/originalW);
  document.querySelectorAll('#presetChips .chip').forEach(c=>c.classList.toggle('active',parseInt(c.textContent)===w));
  updateNewDimPreview();
}
function clearChips(){document.querySelectorAll('#presetChips .chip').forEach(c=>c.classList.remove('active'));}

function onPctChange(val){
  document.getElementById('pctVal').textContent=val+'%';
  document.querySelectorAll('#pctBlock .chip').forEach(c=>c.classList.toggle('active',parseInt(c.textContent)===parseInt(val)));
  updateNewDimPreview();
}
function setPct(val){document.getElementById('pctSlider').value=val;onPctChange(val);}

function updateNewDimPreview(){
  if(!originalW)return;
  let nw,nh;
  if(resizeMode==='px'){
    nw=parseInt(document.getElementById('inputW').value)||0;
    nh=parseInt(document.getElementById('inputH').value)||0;
  }else{
    const pct=parseInt(document.getElementById('pctSlider').value)/100;
    nw=Math.round(originalW*pct);nh=Math.round(originalH*pct);
  }
  document.getElementById('newDim').textContent=nw&&nh?`${nw} × ${nh}`:'— × —';
}

function setFormat(fmt,el){
  selectedFormat=fmt;
  document.querySelectorAll('.fmt-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
}

function handleFile(e){const f=e.target.files[0];if(f)loadFile(f);}
function loadFile(file){
  currentFile=file;resizedBlob=null;
  const img=new Image(),reader=new FileReader();
  reader.onload=e=>{
    img.onload=()=>{
      originalW=img.width;originalH=img.height;
      document.getElementById('origDim').textContent=`${originalW} × ${originalH}`;
      document.getElementById('dimBadge').textContent=`${originalW} × ${originalH} px`;
      document.getElementById('dimBadge').style.display='block';
      const defW=Math.round(originalW*.5),defH=Math.round(originalH*.5);
      document.getElementById('inputW').value=defW;
      document.getElementById('inputH').value=defH;
      document.getElementById('newDim').textContent=`${defW} × ${defH}`;
      document.getElementById('previewImg').src=e.target.result;
      document.getElementById('uploadPreview').style.display='block';
      document.getElementById('uploadContent').style.display='none';
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(file);
  document.getElementById('resizeBtn').disabled=false;
  document.getElementById('downloadBtn').style.display='none';
  document.getElementById('savedBadge').style.display='none';
}

/* Drag & drop */
const zone=document.getElementById('uploadZone');
zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('dragover');});
zone.addEventListener('dragleave',()=>zone.classList.remove('dragover'));
zone.addEventListener('drop',e=>{
  e.preventDefault();zone.classList.remove('dragover');
  const f=e.dataTransfer.files[0];
  if(f&&f.type.startsWith('image/'))loadFile(f);
});

function resizeImage(){
  if(!currentFile||!originalW)return;
  let targetW,targetH;
  if(resizeMode==='px'){
    targetW=parseInt(document.getElementById('inputW').value);
    targetH=parseInt(document.getElementById('inputH').value);
  }else{
    const pct=parseInt(document.getElementById('pctSlider').value)/100;
    targetW=Math.round(originalW*pct);targetH=Math.round(originalH*pct);
  }
  if(!targetW||!targetH)return;
  const progressWrap=document.getElementById('progressWrap');
  const progressBar=document.getElementById('progressBar');
  progressWrap.style.display='block';progressBar.style.width='0%';
  setTimeout(()=>progressBar.style.width='50%',60);
  const img=new Image(),reader=new FileReader();
  reader.onload=e=>{
    img.onload=()=>{
      const canvas=document.createElement('canvas');
      canvas.width=targetW;canvas.height=targetH;
      const ctx=canvas.getContext('2d');
      ctx.imageSmoothingEnabled=true;ctx.imageSmoothingQuality='high';
      ctx.drawImage(img,0,0,targetW,targetH);
      progressBar.style.width='85%';
      const mimeType=selectedFormat==='png'?'image/png':`image/${selectedFormat}`;
      canvas.toBlob(blob=>{
        resizedBlob=blob;progressBar.style.width='100%';
        setTimeout(()=>{
          document.getElementById('newDim').textContent=`${targetW} × ${targetH}`;
          const badge=document.getElementById('savedBadge');
          const sizeKB=(blob.size/1024).toFixed(1);
          document.getElementById('savedText').textContent=`${targetW}×${targetH} · ${sizeKB} KB`;
          badge.style.display='flex';
          const dlBtn=document.getElementById('downloadBtn');
          dlBtn.style.display='flex';
          dlBtn.onclick=()=>{
            const a=document.createElement('a');
            a.href=URL.createObjectURL(resizedBlob);
            a.download=`resized_${targetW}x${targetH}.${selectedFormat==='jpeg'?'jpg':selectedFormat}`;
            a.click();
          };
          progressWrap.style.display='none';progressBar.style.width='0%';
        },250);
      },mimeType,.92);
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(currentFile);
}
</script>
</body>
</html>