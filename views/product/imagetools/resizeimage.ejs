  /* Upper nav stacks vertically */
  .upperNav{
    flex-direction:column;width:100%;gap:10px;margin-bottom:20px;
    align-items:stretch;
  }
  .nav-button{
    width:100%;text-align:center;height:46px;font-size:.95rem;
    justify-content:center;border-radius:12px;
  }

  /* LOGIN/REGISTER — FIXED NO OVERLAP */
  .btn-box{
    width:100%;height:44px;border-radius:12px;
    background:#f0f0f0;overflow:hidden;
    flex-direction:row;position:relative;
    border:1px solid #ddd;
  }
  .toggle-btn{
    width:50%;height:100%;font-size:.82rem;padding:0;
