<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes"/>
<title>Image to Text – RID Bharat</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<!-- NO Tesseract — using OCR.space API for high accuracy -->

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root{
  --primary:#083d5d;--primary-dark:#062a41;--secondary:#4da8da;
  --accent-rid:#ff6b35;--light-gray:#e0e0e0;--white:#ffffff;
  --bg:#f0f4f8;--surface:#ffffff;--surface2:#f4f6fb;--surface3:#e8ecf4;
  --border:#dde2ee;--border2:#c8cfe0;
  --text:#12172a;--text2:#4a5272;--text3:#8890aa;
  --tool-green:#00b87d;--tool-green-glow:rgba(0,184,125,0.12);
  --tool-blue:#2e6be6;--tool-blue-glow:rgba(46,107,230,0.10);
  --tool-red:#e03a5a;--tool-yellow:#e6a817;
  --tool-shadow:0 8px 32px rgba(18,23,42,0.10);
  --radius:14px;--mono:'JetBrains Mono',monospace;
}
[data-theme="dark"]{
  --bg:#0c0f1a;--surface:#141827;--surface2:#1a1f30;--surface3:#20263a;
  --border:#252d44;--border2:#2e3850;
  --text:#eef1ff;--text2:#8892b8;--text3:#424d6e;
  --tool-green:#00e5a0;--tool-green-glow:rgba(0,229,160,0.14);
  --tool-blue:#4f8dff;--tool-blue-glow:rgba(79,141,255,0.12);
  --tool-red:#ff4f6d;--tool-yellow:#ffd166;
  --tool-shadow:0 8px 40px rgba(0,0,0,0.5);
}

html{height:100%;}
body{
  font-family:'Poppins',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  background:var(--bg);color:var(--text);line-height:1.6;
  padding-top:130px;overflow-x:hidden;overflow-y:auto;
  font-weight:400;-webkit-font-smoothing:antialiased;
  min-height:100%;display:flex;flex-direction:column;
  transition:background .3s,color .3s;
}
input,button,textarea,select{font-family:inherit;}
a{text-decoration:none;color:inherit;}
ul{list-style:none;}
button{cursor:pointer;border:none;outline:none;}
img{max-width:100%;height:auto;display:block;}

body::before{
  content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(46,107,230,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(46,107,230,0.025) 1px,transparent 1px);
  background-size:36px 36px;pointer-events:none;z-index:0;
}

/* ── HEADER ── */
.header-container{position:fixed;top:0;left:0;width:100%;z-index:1000;}
.top-header{
  display:flex;justify-content:space-between;align-items:center;
  background:linear-gradient(90deg,#062a41,#0a4d6e);
  color:#fff;padding:0 20px;height:40px;
  letter-spacing:.3px;box-shadow:0 2px 10px rgba(0,0,0,.1);
}
.web-text p{display:inline-block;font-size:.6rem;font-weight:700;}
.web-text p span{font-weight:300;}
.web-text p::after{content:"|";margin:0 10px;color:#fff;font-weight:300;}
.web-text p:last-child::after{content:"";}
.right-text{display:flex;}
.right-text a{font-size:.6rem;color:white;}
.right-text a::after{content:"|";margin:0 8px;color:#fff;font-weight:300;}
.right-text a:last-child::after{content:"";}

.main-header{
  backdrop-filter:blur(10px);background:rgba(255,255,255,.92);
  border-bottom:1px solid rgba(77,168,218,.3);box-shadow:0 2px 10px rgba(0,0,0,.1);
}
[data-theme="dark"] .main-header{background:rgba(20,24,39,.95);border-bottom:1px solid rgba(37,45,68,.8);}
.nav{display:flex;justify-content:space-between;align-items:center;height:90px;padding:0 20px;}
.logo{display:flex;align-items:center;flex:1;}
.logo img{height:80px;max-height:80px;transition:all .3s;}
.menu{display:flex;justify-content:flex-end;align-items:flex-end;flex-direction:column;}
.upperNav{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:nowrap;}

.nav-button{
  display:flex;justify-content:center;align-items:center;gap:5px;
  font-size:.85rem;font-weight:600;padding:8px 14px;border-radius:30px;
  transition:all .3s;cursor:pointer;border:none;outline:none;box-shadow:0 4px 10px rgba(0,53,84,.2);
}
#onlineTest1{background:linear-gradient(145deg,#dc143c,#b22222);color:#fff;}
#ebookBtn{background:#c67534;color:#fff;}
#certificate{background:linear-gradient(145deg,#0b5e0b,#0a470a);color:#fff;}
#onlineTest1:hover,#ebookBtn:hover,#certificate:hover{background:#000;transform:translateY(-2px);}

.btn-box{
  width:210px;display:flex;flex-shrink:0;border-radius:30px;position:relative;
  background:rgba(240,240,240,.7);backdrop-filter:blur(4px);
  border:1px solid rgba(8,61,93,.2);overflow:hidden;
}
.toggle-btn{
  padding:8px 0;position:relative;outline:none;border:none;
  background:transparent;font-size:.8rem;color:#333;
  display:flex;justify-content:center;align-items:center;gap:4px;
  z-index:1;width:50%;cursor:pointer;font-weight:600;white-space:nowrap;transition:color .3s;
}
#swap-btn{position:absolute;top:0;left:0;width:50%;height:100%;background:#083d5d;border-radius:30px;transition:all .4s;z-index:0;}
#logInButton{color:white;}
#signUpBtn{color:#333;}

.lowerNav{display:flex;gap:22px;}
.lowerNav ul{display:flex;gap:20px;}
.lowerNav li{position:relative;}
.lowerNav li a{font-size:.88rem;color:#333;font-weight:500;}
[data-theme="dark"] .lowerNav li a{color:#ccd0e0;}
.menu-link{display:flex;align-items:center;cursor:pointer;padding:8px 0;transition:color .3s;}
.menu-link:hover{color:#083d5d;}

.menu-icon{display:none;flex-direction:column;justify-content:space-between;width:30px;height:21px;cursor:pointer;margin-left:auto;z-index:1001;}
.menu-icon span{display:block;height:3px;width:100%;background:var(--primary);border-radius:3px;transition:all .3s;}
.menu-icon.active span:nth-child(1){transform:translateY(9px) rotate(45deg);}
.menu-icon.active span:nth-child(2){opacity:0;}
.menu-icon.active span:nth-child(3){transform:translateY(-9px) rotate(-45deg);}

@media(min-width:769px){
  .menu-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:#083d5d;transition:width .3s;}
  .menu-link:hover::after{width:100%;}
  .dropdown:hover .dropdown-menu{display:block;}
}
.dropdown-menu{display:none;position:absolute;left:0;top:100%;background:#fff;box-shadow:0 5px 15px rgba(0,0,0,.1);border-radius:8px;padding:10px 0;min-width:220px;z-index:1000;}
.dropdown.active .dropdown-menu{display:block;}
.dropdown-menu .nav-link{padding:12px 20px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;width:100%;color:#333;font-size:.88rem;transition:all .3s;}
.dropdown-menu .nav-link:hover{background:#f8f9fa;color:#083d5d;padding-left:25px;}

/* ── MAIN ── */
.page-main{position:relative;z-index:1;flex:1;padding:28px 16px 40px;display:flex;flex-direction:column;align-items:center;gap:20px;}

/* API Key Banner */
.api-banner{
  width:100%;max-width:1100px;
  background:linear-gradient(135deg,rgba(46,107,230,0.08),rgba(0,184,125,0.08));
  border:1px solid var(--border2);border-radius:var(--radius);
  padding:12px 18px;
  display:flex;align-items:center;gap:12px;flex-wrap:wrap;
}
.api-banner-icon{font-size:20px;flex-shrink:0;}
.api-banner-text{flex:1;min-width:200px;}
.api-banner-title{font-size:.82rem;font-weight:700;color:var(--text);}
.api-banner-sub{font-size:.7rem;color:var(--text3);margin-top:2px;}
.api-key-input-wrap{display:flex;gap:8px;align-items:center;flex-shrink:0;flex-wrap:wrap;}
.api-key-inp{
  background:var(--surface);border:1px solid var(--border2);
  color:var(--text);font-size:.75rem;font-family:var(--mono);
  padding:7px 12px;border-radius:9px;width:220px;outline:none;
  transition:border-color .2s;
}
.api-key-inp:focus{border-color:var(--tool-blue);}
.api-save-btn{
  background:var(--tool-blue);color:#fff;
  font-size:.75rem;font-weight:700;padding:7px 14px;border-radius:9px;
  transition:all .2s;white-space:nowrap;
}
.api-save-btn:hover{opacity:.85;}
.api-link{font-size:.7rem;color:var(--tool-blue);text-decoration:underline;cursor:pointer;white-space:nowrap;}

/* Tool Header */
.tool-header{width:100%;max-width:1100px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.tool-brand{display:flex;align-items:center;gap:12px;}
.tool-icon{width:42px;height:42px;background:linear-gradient(135deg,var(--tool-green),var(--tool-blue));border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:0 4px 16px var(--tool-green-glow);flex-shrink:0;}
.tool-title{font-family:'Outfit',sans-serif;font-size:1.35rem;font-weight:800;letter-spacing:-.03em;background:linear-gradient(135deg,var(--tool-green),var(--tool-blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.tool-subtitle{font-size:.72rem;color:var(--text3);font-weight:500;margin-top:1px;}
.tool-controls{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.lang-wrap{display:flex;align-items:center;gap:6px;}
.lang-lbl{font-size:.72rem;color:var(--text3);font-weight:500;}
.lang-sel{background:var(--surface);border:1px solid var(--border2);color:var(--text);font-size:.78rem;font-weight:600;padding:7px 10px;border-radius:9px;cursor:pointer;outline:none;transition:border-color .2s;}
.lang-sel:focus{border-color:var(--tool-green);}
.theme-toggle{display:flex;align-items:center;gap:6px;background:var(--surface);border:1px solid var(--border2);border-radius:50px;padding:5px 12px;cursor:pointer;font-size:.75rem;font-weight:600;color:var(--text2);transition:all .2s;}
.theme-toggle:hover{border-color:var(--tool-blue);color:var(--text);}

/* Upload */
.upload-section{width:100%;max-width:1100px;}
.drop-zone{
  border:2px dashed var(--border2);border-radius:var(--radius);background:var(--surface);
  padding:36px 20px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;position:relative;transition:all .25s;text-align:center;gap:10px;min-height:180px;
}
.drop-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.drop-zone:hover,.drop-zone.dragover{border-color:var(--tool-green);background:var(--tool-green-glow);}
.drop-ring{position:absolute;inset:10px;border:1.5px dashed var(--border);border-radius:10px;pointer-events:none;transition:border-color .25s;}
.drop-zone:hover .drop-ring,.drop-zone.dragover .drop-ring{border-color:var(--tool-green);}
.dz-icon{width:56px;height:56px;background:linear-gradient(135deg,var(--surface2),var(--surface3));border:1px solid var(--border2);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;transition:transform .2s,box-shadow .2s;position:relative;z-index:1;}
.drop-zone:hover .dz-icon{transform:translateY(-3px);box-shadow:0 8px 20px var(--tool-green-glow);}
.dz-title{font-family:'Outfit',sans-serif;font-size:.95rem;font-weight:700;color:var(--text);position:relative;z-index:1;}
.dz-sub{font-size:.72rem;color:var(--text3);position:relative;z-index:1;}
.dz-sub span{color:var(--tool-green);font-weight:600;}
.dz-paste{font-size:.65rem;color:var(--text3);position:relative;z-index:1;}

.img-preview-row{display:none;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);padding:12px 16px;align-items:center;gap:14px;margin-top:10px;}
.img-thumb{width:72px;height:72px;border-radius:9px;overflow:hidden;border:1px solid var(--border2);flex-shrink:0;background:var(--surface2);}
.img-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.img-info{flex:1;min-width:0;}
.img-info-name{font-family:var(--mono);font-size:.75rem;color:var(--text);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.img-info-size{font-size:.68rem;color:var(--text3);margin-top:2px;}
.img-info-dim{font-family:var(--mono);font-size:.68rem;color:var(--tool-blue);margin-top:2px;}
.img-actions{display:flex;gap:6px;flex-shrink:0;}
.icon-btn{width:auto;min-width:32px;height:32px;padding:0 8px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;gap:4px;transition:all .2s;white-space:nowrap;}
.icon-btn:hover{background:var(--border);color:var(--text);border-color:var(--border2);}
.icon-btn.green{background:var(--tool-green-glow);border-color:var(--tool-green);color:var(--tool-green);}

/* Extract button */
.extract-btn{
  width:100%;max-width:1100px;height:50px;
  background:linear-gradient(135deg,var(--tool-green),#00a870);color:#fff;
  font-family:'Outfit',sans-serif;font-size:1rem;font-weight:800;
  border:none;border-radius:var(--radius);cursor:pointer;
  display:none;align-items:center;justify-content:center;gap:10px;
  transition:all .2s;box-shadow:0 4px 20px var(--tool-green-glow);
  position:relative;overflow:hidden;letter-spacing:-.01em;
}
.extract-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12),transparent);pointer-events:none;}
.extract-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,184,125,.35);}
.extract-btn:active{transform:translateY(0);}
.extract-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}

/* Progress */
.progress-section{display:none;width:100%;max-width:1100px;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);padding:16px 20px;}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.prog-label{font-size:.8rem;font-weight:600;color:var(--text2);}
.prog-pct{font-family:var(--mono);font-size:.8rem;color:var(--tool-green);font-weight:700;}
.prog-bar-bg{height:5px;background:var(--surface3);border-radius:5px;overflow:hidden;margin-bottom:6px;}
.prog-bar{height:100%;background:linear-gradient(90deg,var(--tool-green),var(--tool-blue));border-radius:5px;width:0%;transition:width .3s;}
.prog-status{font-family:var(--mono);font-size:.65rem;color:var(--text3);}

/* Output */
.output-section{display:none;width:100%;max-width:1100px;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);overflow:hidden;}
.out-head{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;background:var(--surface2);border-bottom:1px solid var(--border);flex-wrap:wrap;gap:8px;}
.out-head-left{display:flex;align-items:center;gap:10px;}
.out-title{font-size:.78rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--text2);display:flex;align-items:center;gap:7px;}
.out-dot{width:7px;height:7px;border-radius:50%;background:var(--tool-blue);box-shadow:0 0 7px var(--tool-blue);}
.conf-badge{padding:3px 10px;border-radius:20px;font-size:.65rem;font-weight:700;font-family:var(--mono);letter-spacing:.04em;}
.conf-high{background:rgba(0,184,125,.15);color:var(--tool-green);border:1px solid rgba(0,184,125,.3);}
.conf-mid{background:rgba(230,168,23,.12);color:var(--tool-yellow);border:1px solid rgba(230,168,23,.3);}
.conf-low{background:rgba(224,58,90,.12);color:var(--tool-red);border:1px solid rgba(224,58,90,.3);}
.out-head-right{display:flex;align-items:center;gap:6px;}
.out-body{padding:16px;max-height:360px;overflow-y:auto;}
.out-body::-webkit-scrollbar{width:4px;}
.out-body::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px;}
.out-text{font-family:var(--mono);font-size:.8rem;line-height:1.85;color:var(--text);white-space:pre-wrap;word-break:break-word;}
.out-stats{display:flex;align-items:center;gap:18px;flex-wrap:wrap;padding:8px 16px;border-top:1px solid var(--border);background:var(--surface2);font-size:.68rem;color:var(--text3);font-family:var(--mono);}
.stat-item strong{color:var(--text2);font-weight:700;}

/* Toast */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--surface);border:1px solid var(--tool-green);border-radius:10px;padding:10px 22px;font-size:.8rem;font-weight:600;color:var(--tool-green);box-shadow:0 8px 30px rgba(0,184,125,.2);transition:transform .3s cubic-bezier(.4,0,.2,1);z-index:9999;white-space:nowrap;}
.toast.show{transform:translateX(-50%) translateY(0);}

/* ── FOOTER ── */
footer{background:linear-gradient(145deg,#0a3750,#031f2f);color:#fff;padding:30px 0 0;position:relative;overflow:hidden;width:100%;margin-top:auto;}
footer::before{content:'';position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,var(--accent-rid),var(--secondary),var(--accent-rid));}
.container{width:100%;max-width:1200px;margin:0 auto;padding:0 20px;}
.footer-content{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;}
.footer-logo{display:flex;flex-direction:column;}
.footer-logo img{max-width:180px;height:auto;margin-bottom:10px;background:#fff;padding:5px;border-radius:6px;}
.footer-logo p{margin-bottom:8px;color:var(--light-gray);font-size:.8rem;line-height:1.4;}
.contact-info{margin-top:5px;}
.contact-info p{margin-bottom:4px;display:flex;align-items:center;gap:6px;font-size:.8rem;}
.contact-info i{color:var(--secondary);width:14px;font-size:.8rem;}
.footer-links h3,.footer-social h3{font-size:1rem;margin-bottom:12px;position:relative;padding-bottom:6px;font-weight:600;}
.footer-links h3::after,.footer-social h3::after{content:'';position:absolute;left:0;bottom:0;width:30px;height:2px;background:var(--secondary);border-radius:2px;}
.footer-links ul li{margin-bottom:8px;transition:transform .3s;}
.footer-links ul li:hover{transform:translateX(5px);}
.footer-links a{color:var(--light-gray);display:flex;align-items:center;gap:5px;font-size:.8rem;}
.footer-links a:hover{color:#fff;}
.footer-links a i{color:var(--secondary);font-size:.7rem;}
.footer-social ul{display:flex;flex-wrap:wrap;gap:8px;}
.footer-social a{display:flex;align-items:center;gap:5px;color:var(--light-gray);transition:all .3s;padding:5px 10px;background:rgba(255,255,255,.1);border-radius:5px;font-size:.8rem;}
.footer-social a:hover{color:#fff;background:rgba(77,168,218,.3);transform:translateY(-3px);}
.footer-bottom{border-top:1px solid rgba(255,255,255,.1);padding:15px 0;text-align:center;color:var(--light-gray);font-size:.75rem;}
.footer-links-bottom{display:flex;justify-content:center;gap:12px;margin-top:8px;flex-wrap:wrap;}
.footer-links-bottom a{color:#b0d4ed;font-size:.75rem;position:relative;}
.footer-links-bottom a:not(:last-child)::after{content:'|';position:absolute;right:-8px;color:var(--secondary);}
.footer-links-bottom a:hover{color:var(--accent-rid);}

/* ── RESPONSIVE ── */
@media(max-width:768px){
  body{padding-top:80px;}
  .top-header{display:none;}
  .menu-icon{display:flex;}
  .nav{flex-direction:row;height:auto;padding:10px 20px;}
  .logo img{height:60px;}
  .menu{position:fixed;top:80px;left:0;width:100%;height:calc(100vh - 80px);background:rgba(255,255,255,.98);backdrop-filter:blur(15px);flex-direction:column;align-items:flex-start;justify-content:flex-start;display:none;padding:20px 16px;overflow-y:auto;z-index:999;transform:translateX(-100%);box-shadow:0 5px 15px rgba(0,0,0,.1);}
  [data-theme="dark"] .menu{background:rgba(20,24,39,.98);}
  .menu.active{display:flex;transform:translateX(0);}
  .upperNav{flex-direction:column;width:100%;gap:10px;margin-bottom:20px;align-items:stretch;}
  .nav-button{width:100%;height:46px;font-size:.9rem;justify-content:center;border-radius:12px;}
  .btn-box{width:100%;height:44px;border-radius:12px;background:#f0f0f0;overflow:hidden;flex-direction:row;position:relative;border:1px solid #ddd;}
  .toggle-btn{width:50%;height:100%;font-size:.8rem;padding:0;z-index:1;display:flex;align-items:center;justify-content:center;gap:4px;}
  #swap-btn{position:absolute;top:0;left:0;width:50%;height:100%;border-radius:12px;z-index:0;display:block;}
  #logInButton{color:#fff;}
  #signUpBtn{color:#333;}
  .lowerNav{flex-direction:column;width:100%;gap:0;margin-top:10px;}
  .lowerNav ul{flex-direction:column;gap:0;width:100%;}
  .lowerNav li{border-bottom:1px solid #f0f0f0;}
  .menu-link{padding:14px 0;width:100%;}
  .dropdown-menu{position:static;box-shadow:none;width:100%;display:none;padding-left:20px;background:transparent;}
  .dropdown.active .dropdown-menu{display:block;}
  .page-main{padding:20px 12px 32px;}
  .tool-header{flex-direction:column;align-items:flex-start;gap:10px;}
  .tool-controls{width:100%;justify-content:space-between;}
  .img-preview-row{flex-wrap:wrap;}
