<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
// ════════════════════════════════════════════════
//  API Key — localStorage mein save hoti hai
//  Default: 'helloworld' (OCR.space demo key)
//  Free key: https://ocr.space/ocrapi
// ════════════════════════════════════════════════
const OCR_API_KEY = 'K82593712688957';

/* THEME */
let isDark = false;
function toggleTheme(){
  isDark = !isDark;
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  document.getElementById('themeIcon').textContent  = isDark ? '☀️' : '🌙';
  document.getElementById('themeLabel').textContent = isDark ? 'Light Mode' : 'Dark Mode';
}

/* HEADER */
(function(){
  const menuIcon = document.getElementById('menuIcon');
  const menu     = document.getElementById('innerCont');
  if(menuIcon){
    menuIcon.addEventListener('click', function(e){
      e.stopPropagation();
      this.classList.toggle('active');
      menu.classList.toggle('active');
    });
    document.addEventListener('click', function(e){
      if(!menu.contains(e.target) && !menuIcon.contains(e.target)){
        menu.classList.remove('active');
        menuIcon.classList.remove('active');
      }
    });
  }
})();

/* LOGIN/REGISTER */
const loginBtn    = document.getElementById('logInButton');
const registerBtn = document.getElementById('signUpBtn');
const swapBtn     = document.getElementById('swap-btn');
if(loginBtn) loginBtn.addEventListener('click', () => { swapBtn.style.left='0%'; loginBtn.style.color='white'; registerBtn.style.color='#333'; });
if(registerBtn) registerBtn.addEventListener('click', () => { swapBtn.style.left='50%'; registerBtn.style.color='white'; loginBtn.style.color='#333'; });

/* OCR TOOL */
let currentFile = null, extractedText = '';
const fileInput     = document.getElementById('fileInput');
const dropZone      = document.getElementById('dropZone');
const imgPreviewRow = document.getElementById('imgPreviewRow');
const extractBtn    = document.getElementById('extractBtn');

fileInput.addEventListener('change', e => { if(e.target.files[0]) loadFile(e.target.files[0]); });
dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('dragover');
  const f = e.dataTransfer.files[0];
  if(f && f.type.startsWith('image/')) loadFile(f);
});
document.addEventListener('paste', e => {
  const items = [...(e.clipboardData?.items||[])];
  const imgItem = items.find(i => i.type.startsWith('image/'));
  if(imgItem) loadFile(imgItem.getAsFile());
});

function loadFile(file){
  currentFile = file; extractedText = '';
  const reader = new FileReader();
  reader.onload = ev => {
    const img = new Image();
    img.onload = () => {
      document.getElementById('thumbImg').src = ev.target.result;
      document.getElementById('imgName').textContent = file.name.length>32 ? file.name.slice(0,30)+'…' : file.name;
      document.getElementById('imgSize').textContent = formatSize(file.size);
      document.getElementById('imgDim').textContent  = `${img.naturalWidth} × ${img.naturalHeight} px`;
      imgPreviewRow.style.display = 'flex';
      dropZone.querySelector('input').style.pointerEvents = 'none';
      extractBtn.style.display = 'flex';
      clearOutput();
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
}

function formatSize(b){ if(b<1024) return b+' B'; if(b<1024*1024) return (b/1024).toFixed(1)+' KB'; return (b/(1024*1024)).toFixed(1)+' MB'; }

function changeImage(){ const inp=document.getElementById('fileInput'); inp.style.pointerEvents='auto'; inp.value=''; inp.click(); }

function clearAll(){
  currentFile=null; extractedText='';
  document.getElementById('fileInput').value='';
  document.getElementById('fileInput').style.pointerEvents='auto';
  imgPreviewRow.style.display='none';
  extractBtn.style.display='none';
  clearOutput();
}

function clearOutput(){
  extractedText='';
  document.getElementById('outputSection').style.display='none';
  document.getElementById('progressSection').style.display='none';
  document.getElementById('outText').textContent='';
  document.getElementById('copyBtn').style.display='none';
  document.getElementById('dlBtn').style.display='none';
  document.getElementById('confBadge').style.display='none';
  document.getElementById('wCount').textContent='—';
  document.getElementById('cCount').textContent='—';
  document.getElementById('lCount').textContent='—';
}

/* ── OCR.space API ── */
async function runOCR(){
  if(!currentFile) return;

  const btn  = document.getElementById('extractBtn');
  const ps   = document.getElementById('progressSection');
  const pbar = document.getElementById('progBar');
  const ppct = document.getElementById('progPct');
  const plbl = document.getElementById('progLabel');
  const psts = document.getElementById('progStatus');
  const lang = document.getElementById('langSelect').value;

  btn.disabled = true;
  btn.innerHTML = `<span style="display:inline-block;animation:spin .7s linear infinite;">⟳</span>&nbsp; Extracting…`;
  ps.style.display = 'flex';
  pbar.style.width = '0%';
  document.getElementById('outputSection').style.display = 'none';

  /* animated progress while waiting for API */
  let fakeP = 0;
  const fakeTimer = setInterval(() => {
    fakeP = Math.min(fakeP + Math.random()*6, 88);
    pbar.style.width = fakeP+'%';
    ppct.textContent = Math.round(fakeP)+'%';
    if(fakeP < 25)      { plbl.textContent='Uploading image…';  psts.textContent='Image server ko bhej raha hai'; }
    else if(fakeP < 55) { plbl.textContent='Analyzing image…';  psts.textContent='Text regions detect ho rahe hain'; }
    else                { plbl.textContent='Extracting text…';  psts.textContent='Almost done…'; }
  }, 350);

  try {
    const formData = new FormData();
    formData.append('file', currentFile, currentFile.name || 'image.jpg');
    formData.append('apikey', OCR_API_KEY);
    formData.append('language', lang);
    formData.append('isOverlayRequired', 'false');
    formData.append('detectOrientation', 'true');
    formData.append('scale', 'true');
    formData.append('OCREngine', '2');  /* Engine 2 = highest accuracy */
    formData.append('isTable', 'false');

    const response = await fetch('https://api.ocr.space/parse/image', {
      method: 'POST',
      body: formData
    });

    const data = await response.json();

    clearInterval(fakeTimer);
    pbar.style.width='100%'; ppct.textContent='100%';
    plbl.textContent='Done!'; psts.textContent='Text extracted successfully';

    setTimeout(() => {
      ps.style.display='none'; pbar.style.width='0%';
      const os = document.getElementById('outputSection');
      os.style.display = 'block';

      /* API error check */
      if(data.IsErroredOnProcessing || data.OCRExitCode === 99){
        const errMsg = data.ErrorMessage?.[0] || data.ErrorDetails || 'Unknown error';
        document.getElementById('outText').textContent =
          `❌ OCR Error: ${errMsg}\n\n` +
          (errMsg.includes('API key') || errMsg.includes('Unauthorized')
            ? '👆 Apni free API key daalo:\n1. ocr.space/ocrapi pe jao\n2. Free signup karo\n3. Email mein key aayegi\n4. Upar "API Key" field mein paste karo'
            : 'Dobara try karein ya dusri image use karein.');
        showResult(os, btn); return;
      }

      /* Collect text from all pages */
      const allText = (data.ParsedResults || [])
        .map(r => (r.ParsedText || '').trim())
        .filter(Boolean)
        .join('\n\n')
        .trim();

      extractedText = allText;

      if(allText){
        document.getElementById('outText').textContent = allText;

        const words = allText.split(/\s+/).filter(Boolean).length;
        document.getElementById('wCount').textContent = words;
        document.getElementById('cCount').textContent = allText.length;
        document.getElementById('lCount').textContent = allText.split('\n').filter(Boolean).length;

        /* Confidence from exit code */
        const exitCode = data.ParsedResults?.[0]?.FileParseExitCode;
        const badge    = document.getElementById('confBadge');
        badge.style.display = 'inline-flex';
        if(exitCode === 1){
          badge.className='conf-badge conf-high'; badge.textContent='✓ High Accuracy';
        } else if(exitCode === 2){
          badge.className='conf-badge conf-mid';  badge.textContent='~ Medium Accuracy';
        } else {
          badge.className='conf-badge conf-low';  badge.textContent='⚠ Low Accuracy';
        }

        document.getElementById('copyBtn').style.display='flex';
        document.getElementById('dlBtn').style.display='flex';
      } else {
        document.getElementById('outText').textContent =
          '⚠️  Koi text nahi mila.\n\nTips:\n• High resolution clear image use karein\n• Text blurry ya rotate nahi hona chahiye\n• Dusri language select karein\n• Alag image try karein';
      }

      showResult(os, btn);
    }, 400);

  } catch(err){
    clearInterval(fakeTimer);
    ps.style.display='none';
    const os = document.getElementById('outputSection');
    os.style.display='block';
    document.getElementById('outText').textContent =
      err.message.includes('fetch') || err.message.includes('Failed')
        ? '🌐 Network Error!\n\nInternet connection check karein.\nBhi try karein:\n• Page refresh karein\n• VPN off karein agar on hai'
        : `❌ Error: ${err.message}`;
    showResult(os, btn);
  }
}

function showResult(os, btn){
  os.scrollIntoView({ behavior:'smooth', block:'start' });
  btn.disabled = false;
  btn.innerHTML = `<svg width="18" height="18" fill="none" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="2.2"/><path d="M7 8h10M7 12h6M7 16h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Extract Text from Image`;
}

async function copyText(){
  if(!extractedText) return;
  await navigator.clipboard.writeText(extractedText);
  const btn = document.getElementById('copyBtn');
  btn.classList.add('green'); btn.textContent='✓ Copied';
  showToast('✓ Text copy ho gaya!');
  setTimeout(()=>{ btn.classList.remove('green'); btn.textContent='⎘ Copy'; }, 2000);
}

function downloadTxt(){
  if(!extractedText) return;
  const blob = new Blob([extractedText],{type:'text/plain'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'extracted-text.txt';
  a.click();
  showToast('📄 File download ho gayi!');
}

function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2400);
}
</script>
</body>
</html>