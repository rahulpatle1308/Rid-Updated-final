  <!-- JavaScript -->
  <script>
    (function () {
      // ===== HEADER FUNCTIONALITY =====
      const menuIcon = document.getElementById('menuIcon');
      const menu = document.getElementById('innerCont');
      if (menuIcon) {
        menuIcon.addEventListener('click', function (e) {
          e.stopPropagation();
          this.classList.toggle('active');
          menu.classList.toggle('active');
        });
      }

      // ===== LOGIN REGISTER SLIDE EFFECT =====
      const loginBtn = document.getElementById("logInButton");
      const registerBtn = document.getElementById("signUpBtn");
      const swapBtn = document.getElementById("swap-btn");

      if (loginBtn && registerBtn && swapBtn) {
        loginBtn.addEventListener("click", function () {
          swapBtn.style.left = "0%";
          loginBtn.style.color = "white";
          registerBtn.style.color = "#000";
        });

        registerBtn.addEventListener("click", function () {
          swapBtn.style.left = "50%";
          registerBtn.style.color = "white";
          loginBtn.style.color = "#000";
        });
      }

      // ===== IMAGE CONVERTER FUNCTIONALITY =====
      const fileInput = document.getElementById('fileInput');
      const uploadBox = document.getElementById('uploadBox');
      const originalPreview = document.getElementById('originalPreview');
      const jpgPreview = document.getElementById('jpgPreview');
      const originalInfo = document.getElementById('originalInfo');
      const jpgInfo = document.getElementById('jpgInfo');
      const convertBtn = document.getElementById('convertBtn');
      const downloadBtn = document.getElementById('downloadBtn');
      const formatSelect = document.getElementById('formatSelect');
      const qualitySelect = document.getElementById('jpgQuality');
      const qualityWrapper = document.getElementById('qualityWrapper');
      const stars = [...document.getElementById('starWidget').children];
      const rateBtn = document.getElementById('rateSubmit');
      const themeToggle = document.getElementById('themeToggle');
      const themeIcon = document.getElementById('themeIcon');
      const themeText = document.getElementById('themeText');

      let currentFile = null;
      let convertedBlob = null;
      let convertedUrl = null;

      // ========== THEME TOGGLE ==========
      function setTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        if (theme === 'dark') {
          themeIcon.className = 'fas fa-moon';
          themeText.innerText = 'Dark';
        } else {
          themeIcon.className = 'fas fa-sun';
          themeText.innerText = 'Light';
        }
      }

      const savedTheme = localStorage.getItem('theme') || 'light';
      setTheme(savedTheme);

      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme') || 'light';
          const newTheme = current === 'light' ? 'dark' : 'light';
          setTheme(newTheme);
          localStorage.setItem('theme', newTheme);
        });
      }

      // ========== STAR RATING ==========
      stars.forEach(s => s.addEventListener('click', function(e) {
        let v = parseInt(this.dataset.value);
        stars.forEach((x, i) => {
          if (i < v) {
            x.classList.remove('fa-regular');
            x.classList.add('fa-solid');
          } else {
            x.classList.remove('fa-solid');
            x.classList.add('fa-regular');
          }
        });
      }));

      if (rateBtn) {
        rateBtn.addEventListener('click', () => {
          let f = stars.filter(s => s.classList.contains('fa-solid')).length;
          f ? alert(f + ' star' + (f > 1 ? 's' : '') + '! 🌟') : alert('select stars');
        });
      }

      // ========== FORMAT CHANGE HANDLER ==========
      if (formatSelect) {
        formatSelect.addEventListener('change', function() {
          if (this.value === 'png' || this.value === 'bmp' || this.value === 'gif') {
            qualityWrapper.style.display = 'none';
          } else {
            qualityWrapper.style.display = 'flex';
          }
        });
      }

      // ========== UPLOAD HANDLERS ==========
      if (uploadBox) {
        uploadBox.addEventListener('click', () => fileInput.click());

        uploadBox.addEventListener('dragover', e => {
          e.preventDefault();
          uploadBox.style.borderColor = '#f59e0b';
        });

        uploadBox.addEventListener('dragleave', () => {
          uploadBox.style.borderColor = 'var(--border-light)';
        });

        uploadBox.addEventListener('drop', e => {
          e.preventDefault();
          uploadBox.style.borderColor = 'var(--border-light)';
          if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
        });
      }

      if (fileInput) {
        fileInput.addEventListener('change', e => {
          if (fileInput.files.length) handleFile(fileInput.files[0]);
        });
      }

      function handleFile(f) {
        if (!f.type.startsWith('image/')) return alert('Please select an image file');
        
        currentFile = f;
        if (convertedUrl) URL.revokeObjectURL(convertedUrl);
        convertedBlob = null;
        convertedUrl = null;
        downloadBtn.disabled = true;
        
        jpgPreview.innerHTML = '<i class="fas fa-magic" style="font-size:2.2rem; color:var(--accent);"></i>';
        jpgInfo.innerText = 'ready';
        
        const reader = new FileReader();
        reader.onload = e => {
          originalPreview.innerHTML = `<img src="${e.target.result}" alt="original">`;
          originalInfo.innerText = (f.size / 1024).toFixed(1) + ' KB';
        };
        reader.readAsDataURL(f);
      }

      // ========== CONVERT ==========
      if (convertBtn) {
        convertBtn.addEventListener('click', () => {
          if (!currentFile) return alert('Select an image first');

          const img = new Image();
          const reader = new FileReader();
          reader.onload = e => { img.src = e.target.result; };
          reader.readAsDataURL(currentFile);

          img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            const ctx = canvas.getContext('2d');
            
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.drawImage(img, 0, 0);

            const format = formatSelect.value;
            let mimeType = 'image/jpeg';
            let quality = parseFloat(qualitySelect.value);
            let fileExtension = 'jpg';

            switch(format) {
              case 'png':
                mimeType = 'image/png';
                fileExtension = 'png';
                quality = undefined;
                break;
              case 'webp':
                mimeType = 'image/webp';
                fileExtension = 'webp';
                break;
              case 'bmp':
                mimeType = 'image/bmp';
                fileExtension = 'bmp';
                quality = undefined;
                break;
              case 'gif':
                mimeType = 'image/gif';
                fileExtension = 'gif';
                quality = undefined;
                break;
              default:
                mimeType = 'image/jpeg';
                fileExtension = 'jpg';
            }

            canvas.toBlob(b => {
              if (!b) return alert('Conversion failed');
              
              if (convertedUrl) URL.revokeObjectURL(convertedUrl);
              convertedBlob = b;
              convertedUrl = URL.createObjectURL(b);

              const previewImg = document.createElement('img');
              previewImg.src = convertedUrl;
              jpgPreview.innerHTML = '';
              jpgPreview.appendChild(previewImg);
              jpgInfo.innerText = (b.size / 1024).toFixed(1) + ' KB · ' + fileExtension.toUpperCase();
              
              downloadBtn.disabled = false;
            }, mimeType, quality);
          };
        });
      }

      // ========== DOWNLOAD ==========
      if (downloadBtn) {
        downloadBtn.addEventListener('click', () => {
          if (!convertedBlob || !convertedUrl) return;
          
          const a = document.createElement('a');
          a.href = convertedUrl;
          const baseName = currentFile ? currentFile.name.replace(/\.[^/.]+$/, '') : 'image';
          const ext = formatSelect.value;
          a.download = baseName + '_converted.' + ext;
          a.click();
        });
      }

      // ========== CLEANUP ==========
      window.addEventListener('beforeunload', () => {
        if (convertedUrl) URL.revokeObjectURL(convertedUrl);
      });

      window.workshop = function() {
        window.open("workshop/form.html", "_self");
      }
      
      window.typingsoftware = function() {
        window.location.href = "/typing-software";
      }
      
      window.compress = function() {
        window.location.href = "/com";
      }
    })();
  </script>
