<script>
/* Theme */
function toggleTheme(){
  const root=document.documentElement,isDark=root.dataset.theme==='dark';
  root.dataset.theme=isDark?'light':'dark';
  document.getElementById('themeToggle').textContent=isDark?'🌙':'☀️';
}

/* Mobile menu */
(function(){
  const icon=document.getElementById('menuIcon');
  const menu=document.getElementById('innerCont');
  if(!icon)return;
  icon.addEventListener('click',function(e){
    e.stopPropagation();
    this.classList.toggle('active');
    menu.classList.toggle('active');
  });
  document.addEventListener('click',function(e){
    if(!menu.contains(e.target)&&!icon.contains(e.target)){
      icon.classList.remove('active');
      menu.classList.remove('active');
    }
  });
})();

/* Login/Register */
const loginBtn=document.getElementById('logInButton');
const regBtn=document.getElementById('signUpBtn');
const swapEl=document.getElementById('swap-btn');
if(loginBtn){
  loginBtn.addEventListener('click',()=>{swapEl.style.left='0%';loginBtn.style.color='white';regBtn.style.color='#333';});
}
if(regBtn){
  regBtn.addEventListener('click',()=>{swapEl.style.left='50%';regBtn.style.color='white';loginBtn.style.color='#333';});
}

/* ===== CROP TOOL ===== */
const S={
  img:null,fname:'',rotation:0,flipH:false,flipV:false,
  ratio:'free',fmt:'image/jpeg',
  crop:{x:0,y:0,w:0,h:0},
  drag:false,dragMode:null,dragStart:null,cropSnap:null,_cropResult:null
};

/* File upload */
const fileInput=document.getElementById('fileInput');
const dropzone=document.getElementById('dropzone');
fileInput.addEventListener('change',e=>loadFile(e.target.files[0]));
dropzone.addEventListener('dragover',e=>{e.preventDefault();dropzone.classList.add('over');});
dropzone.addEventListener('dragleave',()=>dropzone.classList.remove('over'));
dropzone.addEventListener('drop',e=>{e.preventDefault();dropzone.classList.remove('over');loadFile(e.dataTransfer.files[0]);});

function loadFile(file){
  if(!file||!file.type.startsWith('image/'))return;
  S.fname=file.name;
  const reader=new FileReader();
  reader.onload=ev=>{
    const img=new Image();
    img.onload=()=>{
      S.img=img;S.rotation=0;S.flipH=false;S.flipV=false;
      document.getElementById('thumbImg').src=ev.target.result;
      openEditor();
      requestAnimationFrame(()=>requestAnimationFrame(renderEditor));
    };
    img.src=ev.target.result;
  };
  reader.readAsDataURL(file);
}

function openEditor(){
  document.getElementById('uploadPage').classList.add('hidden');
  document.getElementById('editorPage').classList.add('show');
}
function goBack(){
  document.getElementById('editorPage').classList.remove('show');
  document.getElementById('uploadPage').classList.remove('hidden');
  fileInput.value='';
  setBtns(true);
}
function setBtns(d){
  document.getElementById('cropBtn').disabled=d;
  document.getElementById('cropBtnToolbar').disabled=d;
}

/* Render */
function renderEditor(){
  if(!S.img)return;
  const wrap=document.getElementById('canvasWrap');
  const r=wrap.getBoundingClientRect();
  const aw=Math.max(r.width-40,80),ah=Math.max(r.height-40,80);
  const ang=((S.rotation%360)+360)%360,swapped=ang===90||ang===270;
  const nw=swapped?S.img.naturalHeight:S.img.naturalWidth;
  const nh=swapped?S.img.naturalWidth:S.img.naturalHeight;
  const sc=Math.min(aw/nw,ah/nh,1);
  const dw=Math.max(Math.round(nw*sc),20),dh=Math.max(Math.round(nh*sc),20);
  const si=document.getElementById('srcImg');
  si.src=S.img.src;si.style.width=dw+'px';si.style.height=dh+'px';
  si.style.transform=`rotate(${S.rotation}deg) scaleX(${S.flipH?-1:1}) scaleY(${S.flipV?-1:1})`;
  const cw=document.getElementById('cropWrap');
  cw.style.display='block';cw.style.width=dw+'px';cw.style.height=dh+'px';
  document.getElementById('toolbarFile').textContent=S.fname;
  document.getElementById('chipImg').textContent=`${S.img.naturalWidth} × ${S.img.naturalHeight} px`;
  setBtns(false);initCrop(dw,dh);
}

function getScale(){return document.getElementById('srcImg').clientWidth/S.img.naturalWidth;}
function initCrop(dw,dh){const p=Math.min(dw,dh)*.1;S.crop={x:p,y:p,w:dw-p*2,h:dh-p*2};applyRatio();clamp();drawBox();}
function resetCrop(){if(!S.img)return;const cw=document.getElementById('cropWrap');initCrop(parseInt(cw.style.width)||200,parseInt(cw.style.height)||200);}
function setRatio(el,r){document.querySelectorAll('.ratio-pill').forEach(b=>b.classList.remove('active'));el.classList.add('active');S.ratio=r;applyRatio();clamp();drawBox();}
function applyRatio(){
  if(S.ratio==='free')return;
  const[rw,rh]=S.ratio.split(':').map(Number);
  const maxH=parseInt(document.getElementById('cropWrap').style.height)||400;
  const nh=S.crop.w*rh/rw;
  if(nh<=maxH)S.crop.h=nh;else S.crop.w=S.crop.h*rw/rh;
}
function clamp(){
  const cw=document.getElementById('cropWrap');
  const W=parseInt(cw.style.width)||400,H=parseInt(cw.style.height)||400;
  S.crop.w=Math.max(20,Math.min(S.crop.w,W));S.crop.h=Math.max(20,Math.min(S.crop.h,H));
  S.crop.x=Math.max(0,Math.min(S.crop.x,W-S.crop.w));S.crop.y=Math.max(0,Math.min(S.crop.y,H-S.crop.h));
}
function drawBox(){
  const b=document.getElementById('cropBox'),c=S.crop;
  b.style.left=c.x+'px';b.style.top=c.y+'px';b.style.width=c.w+'px';b.style.height=c.h+'px';
  updateShades();updateBadge();updateInputs();
}
function updateShades(){
  const cw=document.getElementById('cropWrap');if(cw.style.display==='none')return;
  const W=parseInt(cw.style.width)||0,H=parseInt(cw.style.height)||0,c=S.crop;
  function s(id,t,l,w,h){const el=document.getElementById(id);el.style.cssText=`top:${t}px;left:${l}px;width:${w}px;height:${h}px;`;}
  s('sTop',0,0,W,c.y);s('sBot',c.y+c.h,0,W,H-c.y-c.h);
  s('sLft',c.y,0,c.x,c.h);s('sRgt',c.y,c.x+c.w,W-c.x-c.w,c.h);
}
function updateBadge(){
  if(!S.img)return;const sc=getScale();
  const rw=Math.round(S.crop.w/sc),rh=Math.round(S.crop.h/sc);
  document.getElementById('cropBadge').textContent=`${rw} × ${rh}`;
  document.getElementById('chipCrop').textContent=`${rw} × ${rh} px`;
  document.getElementById('chipCropWrap').style.display='flex';
}
function updateInputs(){
  if(!S.img)return;const sc=getScale();
  document.getElementById('cropW').value=Math.round(S.crop.w/sc);
  document.getElementById('cropH').value=Math.round(S.crop.h/sc);
  document.getElementById('cropX').value=Math.round(S.crop.x/sc);
  document.getElementById('cropY').value=Math.round(S.crop.y/sc);
}
function onDimInput(axis){
  const sc=getScale();
  if(axis==='w'){S.crop.w=(parseInt(document.getElementById('cropW').value)||0)*sc;if(S.ratio!=='free'){const[a,b]=S.ratio.split(':').map(Number);S.crop.h=S.crop.w*b/a;}}
  else{S.crop.h=(parseInt(document.getElementById('cropH').value)||0)*sc;if(S.ratio!=='free'){const[a,b]=S.ratio.split(':').map(Number);S.crop.w=S.crop.h*a/b;}}
  clamp();drawBox();
}
function onPosInput(){
  const sc=getScale();
  S.crop.x=(parseInt(document.getElementById('cropX').value)||0)*sc;
  S.crop.y=(parseInt(document.getElementById('cropY').value)||0)*sc;
  clamp();drawBox();
}

/* Drag */
function wrapPos(e){const r=document.getElementById('cropWrap').getBoundingClientRect();return{x:e.clientX-r.left,y:e.clientY-r.top};}
document.getElementById('cropWrap').addEventListener('mousedown',e=>{
  const t=e.target;
  if(t!==document.getElementById('cropWrap')&&t!==document.getElementById('srcImg'))return;
  const p=wrapPos(e);S.drag=true;S.dragMode='draw';S.dragStart=p;S.crop={x:p.x,y:p.y,w:1,h:1};bindDrag();
});
document.getElementById('cropBox').addEventListener('mousedown',e=>{
  e.stopPropagation();S.drag=true;S.dragMode='move';S.dragStart=wrapPos(e);S.cropSnap={...S.crop};bindDrag();
});
document.querySelectorAll('.handle').forEach(h=>{
  h.addEventListener('mousedown',e=>{e.stopPropagation();S.drag=true;S.dragMode=h.dataset.d;S.dragStart=wrapPos(e);S.cropSnap={...S.crop};bindDrag();});
  h.addEventListener('touchstart',e=>{e.stopPropagation();S.drag=true;S.dragMode=h.dataset.d;S.dragStart=wrapPos(e.touches[0]);S.cropSnap={...S.crop};bindDrag();},{passive:true});
});
document.getElementById('cropWrap').addEventListener('touchstart',e=>{
  const t=e.target;if(t!==document.getElementById('cropWrap')&&t!==document.getElementById('srcImg'))return;
  const p=wrapPos(e.touches[0]);S.drag=true;S.dragMode='draw';S.dragStart=p;S.crop={x:p.x,y:p.y,w:1,h:1};bindDrag();
},{passive:true});
document.getElementById('cropBox').addEventListener('touchstart',e=>{
  e.stopPropagation();S.drag=true;S.dragMode='move';S.dragStart=wrapPos(e.touches[0]);S.cropSnap={...S.crop};bindDrag();
},{passive:true});
function bindDrag(){
  document.addEventListener('mousemove',onMove);document.addEventListener('mouseup',onUp);
  document.addEventListener('touchmove',t=>onMove(t.touches[0]),{passive:true});document.addEventListener('touchend',onUp,{passive:true});
}
function onMove(e){
  if(!S.drag)return;
  const p=wrapPos(e),dx=p.x-S.dragStart.x,dy=p.y-S.dragStart.y,sc=S.cropSnap;
  if(S.dragMode==='draw'){S.crop.x=Math.min(p.x,S.dragStart.x);S.crop.y=Math.min(p.y,S.dragStart.y);S.crop.w=Math.abs(dx);S.crop.h=Math.abs(dy);}
  else if(S.dragMode==='move'){S.crop.x=sc.x+dx;S.crop.y=sc.y+dy;}
  else{
    let{x,y,w,h}=sc,d=S.dragMode;
    if(d.includes('e'))w=Math.max(20,sc.w+dx);if(d.includes('s'))h=Math.max(20,sc.h+dy);
    if(d.includes('w')){x=sc.x+dx;w=Math.max(20,sc.w-dx);}if(d.includes('n')){y=sc.y+dy;h=Math.max(20,sc.h-dy);}
    S.crop={x,y,w,h};
  }
  if(S.ratio!=='free')applyRatio();clamp();drawBox();
}
function onUp(){
  S.drag=false;
  document.removeEventListener('mousemove',onMove);document.removeEventListener('mouseup',onUp);
  document.removeEventListener('touchmove',onMove);document.removeEventListener('touchend',onUp);
}
function doRotate(d){if(!S.img)return;S.rotation=(S.rotation+d+360)%360;renderEditor();}
function doFlip(ax){if(!S.img)return;if(ax==='h')S.flipH=!S.flipH;else S.flipV=!S.flipV;renderEditor();}

/* Crop */
function doCrop(){
  if(!S.img)return;
  const sc=getScale();
  const rx=Math.max(0,Math.min(Math.round(S.crop.x/sc),S.img.naturalWidth-1));
  const ry=Math.max(0,Math.min(Math.round(S.crop.y/sc),S.img.naturalHeight-1));
  const rw=Math.max(1,Math.min(Math.round(S.crop.w/sc),S.img.naturalWidth-rx));
  const rh=Math.max(1,Math.min(Math.round(S.crop.h/sc),S.img.naturalHeight-ry));
  const outW=parseInt(document.getElementById('outW').value)||rw;
  const outH=parseInt(document.getElementById('outH').value)||rh;
  const q=parseInt(document.getElementById('qSlider').value)/100;
  const off=document.getElementById('offscreen');
  off.width=outW;off.height=outH;
  const ctx=off.getContext('2d');
  ctx.clearRect(0,0,outW,outH);ctx.save();
  ctx.translate(outW/2,outH/2);ctx.rotate(S.rotation*Math.PI/180);
  ctx.scale(S.flipH?-1:1,S.flipV?-1:1);
  ctx.drawImage(S.img,rx,ry,rw,rh,-outW/2,-outH/2,outW,outH);
  ctx.restore();
  const prev=document.getElementById('previewCanvas');
  const maxW=430,maxH=Math.round(Math.min(window.innerHeight*.38,380));
  const asp=outW/outH;let pw=Math.min(maxW,outW),ph=pw/asp;
  if(ph>maxH){ph=maxH;pw=ph*asp;}
  pw=Math.max(1,Math.round(pw));ph=Math.max(1,Math.round(ph));
  prev.width=pw;prev.height=ph;prev.getContext('2d').drawImage(off,0,0,pw,ph);
  document.getElementById('previewMeta').textContent=`${outW} × ${outH} px · ${S.fmt.split('/')[1].toUpperCase()} · Q${Math.round(q*100)}`;
  S._cropResult={off,outW,outH,q};
  document.getElementById('modalOverlay').classList.add('open');
}
function setFmt(el,fmt){S.fmt=fmt;document.querySelectorAll('.fmt-btn').forEach(b=>b.classList.remove('active'));el.classList.add('active');}
function downloadCrop(){
  const{off,outW,outH,q}=S._cropResult;
  const ext=S.fmt==='image/jpeg'?'jpg':S.fmt==='image/png'?'png':'webp';
  const a=document.createElement('a');
  a.href=off.toDataURL(S.fmt,q);
  a.download=`cropped-${outW}x${outH}.${ext}`;
  a.click();
}
function maybeCloseModal(e){if(e.target===document.getElementById('modalOverlay'))closeModal();}
function closeModal(){document.getElementById('modalOverlay').classList.remove('open');}

/* Resize handler */
let _rt=null;
window.addEventListener('resize',()=>{
  clearTimeout(_rt);
  _rt=setTimeout(()=>{
    if(S.img&&document.getElementById('editorPage').classList.contains('show'))
      renderEditor();
  },100);
});
</script>
</body>
</html>