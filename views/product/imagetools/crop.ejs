<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Crop Image – RID Bharat</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root{
  --primary:#083d5d;
  --primary-dark:#062a41;
  --secondary:#4da8da;
  --accent:#ff6b35;
  --light-gray:#e0e0e0;
  --bg:#f4f4f8;
  --surface:#ffffff;
  --surface2:#f0f0f6;
  --border:#e2e2ec;
  --border2:#d0d0de;
  --text:#1a1a2e;
  --text2:#666680;
  --text3:#aaaabc;
  --red:#ff4757;
  --red-s:#ff6b78;
  --green:#2ed573;
  --shadow-sm:0 1px 4px rgba(0,0,0,.07);
  --shadow:0 5px 15px rgba(0,0,0,.08);
  --shadow-lg:0 12px 40px rgba(0,0,0,.15);
  --radius:14px;
  --mono:'JetBrains Mono',monospace;
  --header-h:130px;
}
[data-theme="dark"]{
  --bg:#111116;
  --surface:#1c1c24;
  --surface2:#25252f;
  --border:#2e2e3e;
  --border2:#3a3a4e;
  --text:#eeeef8;
  --text2:#8888a8;
  --text3:#44445a;
  --shadow-sm:0 1px 4px rgba(0,0,0,.4);
  --shadow:0 4px 20px rgba(0,0,0,.5);
  --shadow-lg:0 12px 40px rgba(0,0,0,.6);
}

html{height:100%;}
body{
  font-family:'Poppins',-apple-system,BlinkMacSystemFont,sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
  /* No height:100% on body — let it grow naturally so footer shows */
  min-height:100vh;
  display:flex;
  flex-direction:column;
}
input,button,textarea,select{font-family:inherit;font-size:inherit;}
a{text-decoration:none;color:inherit;}
ul{list-style:none;}
button{cursor:pointer;border:none;outline:none;}
img{max-width:100%;height:auto;display:block;}

/* ===========================================
   HEADER
   =========================================== */
.header-container{
  position:fixed;top:0;left:0;width:100%;z-index:1000;
}
.top-header{
  display:flex;justify-content:space-between;align-items:center;
  background:linear-gradient(90deg,#062a41,#0a4d6e);
  color:#fff;padding:0 20px;height:40px;
  box-shadow:0 2px 10px rgba(0,0,0,.1);
}
.web-text p{display:inline-block;font-size:.6rem;font-weight:700;}
.web-text p span{font-weight:300;}
.web-text p::after{content:"|";margin:0 10px;color:#fff;font-weight:300;}
.web-text p:last-child::after{content:"";}
.right-text{display:flex;}
.right-text a{font-size:.6rem;color:#fff;}
.right-text a::after{content:"|";margin:0 8px;color:#fff;font-weight:300;}
.right-text a:last-child::after{content:"";}

.main-header{
  backdrop-filter:blur(10px);
  background:rgba(255,255,255,.97);
  border-bottom:1px solid rgba(77,168,218,.3);
  box-shadow:0 2px 10px rgba(0,0,0,.1);
}
.nav{display:flex;justify-content:space-between;align-items:center;height:90px;padding:0 20px;}
.logo{display:flex;align-items:center;flex:1;}
.logo img{height:80px;max-height:80px;}
.menu{display:flex;justify-content:flex-end;align-items:flex-end;flex-direction:column;}
.upperNav{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:nowrap;}
.nav-button{
  display:inline-flex;justify-content:center;align-items:center;gap:5px;
  font-size:.85rem;font-weight:600;padding:8px 15px;border-radius:30px;
  cursor:pointer;border:none;white-space:nowrap;transition:all .3s;
}
#onlineTest1{background:linear-gradient(145deg,#dc143c,#b22222);color:#fff;}
#ebookBtn{background:#c67534;color:#fff;}
#certificate{background:linear-gradient(145deg,#0b5e0b,#0a470a);color:#fff;}
#onlineTest1:hover,#ebookBtn:hover,#certificate:hover{background:#000;transform:translateY(-2px);}

/* Login Register pill */
.btn-box{
  width:220px;min-width:200px;flex-shrink:0;
  display:flex;border-radius:30px;position:relative;
  background:rgba(240,240,240,.7);border:1px solid rgba(8,61,93,.2);
  overflow:hidden;height:38px;
}
.toggle-btn{
  width:50%;height:100%;position:relative;z-index:1;
  background:transparent;border:none;font-size:.82rem;font-weight:600;color:#000;
  display:inline-flex;justify-content:center;align-items:center;gap:4px;
  cursor:pointer;white-space:nowrap;padding:0 6px;transition:color .3s;
}
#swap-btn{
  position:absolute;top:0;left:0;width:50%;height:100%;
  background:var(--primary);border-radius:30px;transition:left .4s;z-index:0;
}
#logInButton{color:#fff;}

/* Lower nav */
.lowerNav{display:flex;gap:22px;}
.lowerNav ul{display:flex;gap:20px;}
.lowerNav li{position:relative;}
.lowerNav li a{font-size:.9rem;color:#333;font-weight:500;display:flex;align-items:center;}
.menu-link{cursor:pointer;padding:8px 0;transition:color .3s;}
.menu-link:hover,.menu-link.active{color:var(--primary);}

.menu-icon{
  display:none;flex-direction:column;justify-content:space-between;
  width:30px;height:21px;cursor:pointer;margin-left:auto;z-index:1001;
}
.menu-icon span{display:block;height:3px;width:100%;background:var(--primary);border-radius:3px;transition:all .3s;}
.menu-icon.active span:nth-child(1){transform:translateY(9px) rotate(45deg);}
.menu-icon.active span:nth-child(2){opacity:0;}
.menu-icon.active span:nth-child(3){transform:translateY(-9px) rotate(-45deg);}

@media(min-width:769px){
  .menu-link{position:relative;}
  .menu-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:var(--primary);transition:width .3s;}
  .menu-link:hover::after{width:100%;}
}
.dropdown-menu{
  display:none;position:absolute;left:0;top:100%;background:#fff;
  box-shadow:0 5px 15px rgba(0,0,0,.1);border-radius:8px;padding:10px 0;
  min-width:220px;z-index:1000;
}
.dropdown:hover .dropdown-menu{display:block;}
.dropdown.active .dropdown-menu{display:block;}
.dropdown-menu li a{padding:12px 20px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;width:100%;font-size:.9rem;color:#333;}
.dropdown-menu li a:hover{background:#f8f9fa;color:var(--primary);padding-left:25px;}

/* ===========================================
   THEME TOGGLE
   =========================================== */
#themeToggle{
  position:fixed;top:148px;right:16px;z-index:999;
  width:36px;height:36px;border-radius:50%;
  background:var(--surface);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;box-shadow:var(--shadow-sm);transition:all .2s;
}
#themeToggle:hover{transform:scale(1.1);}

/* ===========================================
   UPLOAD PAGE — normal page, scrollable
   Shows: header space + upload area + footer
   =========================================== */
#uploadPage{
  display:flex;
  flex-direction:column;
  padding-top:var(--header-h); /* push below fixed header */
  flex:1; /* fill body so footer goes to bottom */
}
#uploadPage.hidden{display:none !important;}

.upload-area{
  flex:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:22px;padding:50px 20px;
}
.upload-title{text-align:center;}
.upload-title h1{font-size:clamp(22px,4vw,32px);font-weight:800;letter-spacing:-.6px;margin-bottom:6px;color:var(--text);}
.upload-title p{font-size:13px;color:var(--text2);}

.dropzone{
  width:min(460px,92vw);background:var(--surface);
  border:2px dashed var(--border2);border-radius:var(--radius);
  padding:38px 28px;text-align:center;cursor:pointer;position:relative;
  transition:border-color .25s,background .25s,box-shadow .25s;box-shadow:var(--shadow-sm);
}
.dropzone:hover,.dropzone.over{
  border-color:var(--red);background:rgba(255,71,87,.04);
  box-shadow:0 0 0 4px rgba(255,71,87,.08),var(--shadow);
}
.dropzone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.dz-icon{width:58px;height:58px;margin:0 auto 13px;background:linear-gradient(135deg,#ff4757,#ff8fa3);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:26px;box-shadow:0 8px 24px rgba(255,71,87,.3);}
.dz-main{font-size:15px;font-weight:700;margin-bottom:5px;color:var(--text);}
.dz-sub{font-size:12px;color:var(--text2);}
.dz-sub span{color:var(--red);font-weight:600;}
.dz-divider{display:flex;align-items:center;gap:10px;margin:18px 0 0;color:var(--text3);font-size:12px;}
.dz-divider::before,.dz-divider::after{content:'';flex:1;height:1px;background:var(--border);}
.btn-upload{
  margin-top:12px;width:100%;height:42px;
  background:linear-gradient(135deg,#ff4757,#ff6b6b);border-radius:10px;
  color:#fff;font-size:14px;font-weight:700;
  box-shadow:0 6px 20px rgba(255,71,87,.35);
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:transform .18s,box-shadow .18s;
}
.btn-upload:hover{transform:translateY(-1px);box-shadow:0 10px 26px rgba(255,71,87,.45);}
.upload-note{font-size:11px;color:var(--text3);text-align:center;}

/* ===========================================
   FOOTER — inside #uploadPage
   =========================================== */
.site-footer{
  background:linear-gradient(145deg,#0a3750,#031f2f);
  color:#fff;
  padding:40px 0 0;
  position:relative;
  overflow:hidden;
  width:100%;
  margin-top:auto; /* pushes footer to bottom */
}
.site-footer::before{
  content:'';position:absolute;top:0;left:0;width:100%;height:4px;
  background:linear-gradient(90deg,#ff6b35,#4da8da,#ff6b35);
}
.footer-inner{
  max-width:1200px;margin:0 auto;padding:0 24px;
}
.footer-grid{
  display:grid;
  grid-template-columns:1.5fr 1fr 1fr 1fr;
  gap:36px;
  margin-bottom:0;
}
.footer-brand{}
.footer-brand .brand-logo{
  display:flex;align-items:center;gap:10px;margin-bottom:14px;
}
.footer-brand .brand-logo img{
  height:60px;background:#fff;padding:4px 8px;border-radius:8px;
}
.footer-brand p{
  font-size:.8rem;color:#94a3b8;line-height:1.7;margin-bottom:12px;
}
.footer-contact p{
  display:flex;align-items:center;gap:8px;
  font-size:.8rem;color:#94a3b8;margin-bottom:6px;
}
.footer-contact i{color:#4da8da;width:14px;}
.footer-contact a{color:#94a3b8;}
.footer-contact a:hover{color:#fff;}

.footer-col h4{
  font-size:.85rem;font-weight:700;color:#fff;
  margin-bottom:16px;position:relative;padding-bottom:8px;
}
.footer-col h4::after{
  content:'';position:absolute;bottom:0;left:0;
  width:28px;height:2px;background:#4da8da;border-radius:2px;
}
.footer-col ul{display:flex;flex-direction:column;gap:9px;}
.footer-col ul li a{
  font-size:.8rem;color:#94a3b8;
  display:flex;align-items:center;gap:7px;
  transition:all .2s;
}
.footer-col ul li a:hover{color:#fff;padding-left:4px;}
.footer-col ul li a i{font-size:.65rem;color:#4da8da;}

.social-links{display:flex;flex-wrap:wrap;gap:8px;margin-top:4px;}
.social-links a{
  display:flex;align-items:center;gap:6px;
  color:#94a3b8;font-size:.78rem;
  padding:6px 12px;
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.08);
  border-radius:8px;transition:all .2s;
}
.social-links a:hover{
  color:#fff;background:rgba(77,168,218,.2);
  border-color:rgba(77,168,218,.4);
  transform:translateY(-2px);
}
.social-links a i{font-size:.8rem;}

.footer-bottom-bar{
  margin-top:32px;
  border-top:1px solid rgba(255,255,255,.08);
  padding:18px 0;
  display:flex;align-items:center;justify-content:space-between;
  gap:12px;flex-wrap:wrap;
}
.footer-bottom-bar p{font-size:.75rem;color:#475569;}
.footer-bottom-links{display:flex;gap:16px;flex-wrap:wrap;}
.footer-bottom-links a{
  font-size:.72rem;color:#475569;
  transition:color .2s;position:relative;
}
.footer-bottom-links a:hover{color:#94a3b8;}
.footer-bottom-links a:not(:last-child)::after{
  content:'|';position:absolute;right:-9px;color:#334155;
}

/* ===========================================
   EDITOR PAGE — fixed overlay, no scroll
   =========================================== */
#editorPage{
  display:none; /* hidden by default */
  position:fixed;
  top:var(--header-h);
  left:0;
  width:100%;
  height:calc(100vh - var(--header-h));
  flex-direction:row;
  overflow:hidden;
  background:var(--bg);
  z-index:500;
}
#editorPage.show{display:flex;}

/* Sidebar */
.sidebar{
  width:258px;min-width:220px;max-width:258px;flex-shrink:0;
  background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow-y:auto;overflow-x:hidden;height:100%;
}
.sidebar::-webkit-scrollbar{width:3px;}
.sidebar::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
.sb-top{padding:13px 14px 0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.sb-logo{font-size:14px;font-weight:800;background:linear-gradient(135deg,#ff4757,#ff8fa3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.sb-back{height:26px;padding:0 10px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--text2);font-size:11px;font-weight:600;display:flex;align-items:center;gap:4px;transition:all .2s;}
.sb-back:hover{border-color:var(--red);color:var(--red);}
.sb-thumb{margin:11px 14px;border-radius:9px;overflow:hidden;background:var(--surface2);border:1px solid var(--border);aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sb-thumb img{max-width:100%;max-height:100%;object-fit:contain;}
.sb-section{padding:10px 14px;border-top:1px solid var(--border);flex-shrink:0;}
.sb-label{font-size:9.5px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:var(--text3);margin-bottom:8px;}
.ratio-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;}
.ratio-pill{border:1px solid var(--border);background:transparent;border-radius:7px;padding:5px 3px;font-size:10px;font-weight:600;color:var(--text2);text-align:center;line-height:1.3;transition:all .2s;cursor:pointer;}
.ratio-pill:hover{border-color:var(--red-s);color:var(--red-s);}
.ratio-pill.active{border-color:var(--red);background:rgba(255,71,87,.1);color:var(--red);}
.input-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.input-group{display:flex;flex-direction:column;gap:3px;}
.input-group label{font-size:9.5px;font-weight:600;color:var(--text3);letter-spacing:.5px;}
.num-input{height:30px;width:100%;padding:0 8px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;color:var(--text);font-size:11.5px;font-weight:500;font-family:var(--mono);transition:border-color .2s;}
.num-input:focus{outline:none;border-color:var(--red);}
.transform-row{display:flex;gap:5px;}
.t-btn{flex:1;height:30px;border-radius:7px;border:1px solid var(--border);background:var(--surface2);color:var(--text2);font-size:15px;transition:all .2s;}
.t-btn:hover{border-color:var(--red-s);color:var(--red-s);}
.q-row{display:flex;flex-direction:column;gap:5px;}
.q-header{display:flex;justify-content:space-between;align-items:center;}
.q-name{font-size:11px;color:var(--text2);}
.q-val{font-family:var(--mono);font-size:10.5px;color:var(--red);font-weight:500;}
input[type=range]{-webkit-appearance:none;width:100%;height:3px;border-radius:3px;background:var(--border);cursor:pointer;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:12px;height:12px;border-radius:50%;background:var(--red);border:2px solid var(--surface);box-shadow:0 0 0 2px rgba(255,71,87,.3);transition:transform .15s;}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.25);}
.sb-actions{padding:12px 14px;margin-top:auto;border-top:1px solid var(--border);flex-shrink:0;}
.btn-reset{width:100%;height:34px;border-radius:9px;background:transparent;border:1px solid var(--border);color:var(--text2);font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .2s;}
.btn-reset:hover{border-color:var(--border2);color:var(--text);}

/* Canvas column */
.canvas-col{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;min-height:0;}
.editor-toolbar{height:48px;min-height:48px;flex-shrink:0;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:10px;}
.toolbar-file{font-size:11.5px;color:var(--text2);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;flex-shrink:1;}
.toolbar-sep{flex:1;}
.info-chip{height:24px;padding:0 9px;border-radius:6px;background:var(--surface2);border:1px solid var(--border);font-family:var(--mono);font-size:10px;color:var(--text2);display:flex;align-items:center;gap:4px;white-space:nowrap;flex-shrink:0;}
.info-chip .dot{width:5px;height:5px;border-radius:50%;background:var(--green);box-shadow:0 0 5px var(--green);}
.btn-crop-now{height:38px;padding:0 16px;flex-shrink:0;background:linear-gradient(135deg,#ff4757,#ff6b6b);border-radius:9px;color:#fff;font-size:13px;font-weight:700;box-shadow:0 4px 14px rgba(255,71,87,.35);display:flex;align-items:center;justify-content:center;gap:6px;transition:all .2s;}
.btn-crop-now:hover{transform:translateY(-1px);box-shadow:0 7px 20px rgba(255,71,87,.45);}
.btn-crop-now:active{transform:translateY(0);}
.btn-crop-now:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}
.canvas-wrap{flex:1;min-height:0;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:20px;background:var(--bg);position:relative;}
.canvas-wrap::before{content:'';position:absolute;inset:0;background-image:linear-gradient(45deg,var(--surface2) 25%,transparent 25%),linear-gradient(-45deg,var(--surface2) 25%,transparent 25%),linear-gradient(45deg,transparent 75%,var(--surface2) 75%),linear-gradient(-45deg,transparent 75%,var(--surface2) 75%);background-size:20px 20px;background-position:0 0,0 10px,10px -10px,-10px 0;opacity:.25;pointer-events:none;}

/* Crop elements */
#cropWrap{position:relative;display:none;user-select:none;flex-shrink:0;}
#srcImg{display:block;border-radius:4px;box-shadow:var(--shadow-lg);pointer-events:none;}
.shade{position:absolute;background:rgba(0,0,0,.5);pointer-events:none;}
#cropBox{position:absolute;border:2px solid #fff;cursor:move;box-shadow:0 0 0 1px rgba(0,0,0,.4),inset 0 0 0 1px rgba(255,255,255,.15);}
.rof{position:absolute;pointer-events:none;}
.rof-h{width:100%;height:1px;background:rgba(255,255,255,.22);}
.rof-v{height:100%;width:1px;background:rgba(255,255,255,.22);}
.handle{position:absolute;pointer-events:all;width:16px;height:16px;}
.handle::before{content:'';position:absolute;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.5);}
.handle.nw::before{top:0;left:0;width:16px;height:3px;}
.handle.nw::after{content:'';position:absolute;top:0;left:0;width:3px;height:16px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.5);}
.handle.ne::before{top:0;right:0;left:auto;width:16px;height:3px;}
.handle.ne::after{content:'';position:absolute;top:0;right:0;width:3px;height:16px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.5);}
.handle.sw::before{bottom:0;top:auto;left:0;width:16px;height:3px;}
.handle.sw::after{content:'';position:absolute;bottom:0;left:0;width:3px;height:16px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.5);}
.handle.se::before{bottom:0;top:auto;right:0;left:auto;width:16px;height:3px;}
.handle.se::after{content:'';position:absolute;bottom:0;right:0;width:3px;height:16px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.5);}
.handle.n,.handle.s{width:24px;height:10px;left:50%;transform:translateX(-50%);}
.handle.n{top:-5px;cursor:n-resize;}
.handle.s{bottom:-5px;cursor:s-resize;}
.handle.n::before,.handle.s::before{width:24px;height:3px;top:50%;transform:translateY(-50%);}
.handle.e,.handle.w{height:24px;width:10px;top:50%;transform:translateY(-50%);}
.handle.e{right:-5px;cursor:e-resize;}
.handle.w{left:-5px;cursor:w-resize;}
.handle.e::before,.handle.w::before{height:24px;width:3px;left:50%;transform:translateX(-50%);}
.handle.nw{top:-8px;left:-8px;cursor:nw-resize;}
.handle.ne{top:-8px;right:-8px;cursor:ne-resize;}
.handle.sw{bottom:-8px;left:-8px;cursor:sw-resize;}
.handle.se{bottom:-8px;right:-8px;cursor:se-resize;}
#cropBadge{position:absolute;bottom:-28px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.72);backdrop-filter:blur(6px);color:#fff;font-family:var(--mono);font-size:10.5px;padding:3px 10px;border-radius:5px;white-space:nowrap;pointer-events:none;}

/* ===========================================
   MODAL
   =========================================== */
.modal-overlay{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:24px;width:min(480px,100%);max-height:calc(100vh - 32px);overflow-y:auto;display:flex;flex-direction:column;box-shadow:var(--shadow-lg);animation:slideUp .25s ease;}
.modal::-webkit-scrollbar{width:3px;}
.modal::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
.modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.modal-head h2{font-size:16px;font-weight:800;color:var(--text);}
.modal-x{background:none;border:none;color:var(--text3);font-size:22px;line-height:1;padding:2px 6px;border-radius:6px;}
.modal-x:hover{color:var(--text);}
.prev-img-wrap{display:flex;align-items:center;justify-content:center;margin-bottom:12px;border-radius:10px;overflow:hidden;background:var(--surface2);border:1px solid var(--border);max-height:min(380px,40vh);}
#previewCanvas{display:block;max-width:100%;max-height:min(380px,40vh);}
.modal-meta{font-family:var(--mono);font-size:11px;color:var(--text2);text-align:center;margin-bottom:14px;}
.fmt-row{display:flex;gap:7px;margin-bottom:12px;}
.fmt-btn{flex:1;height:30px;border-radius:7px;border:1px solid var(--border);background:transparent;font-family:var(--mono);font-size:11px;font-weight:500;color:var(--text2);transition:all .2s;}
.fmt-btn.active{border-color:var(--red);background:rgba(255,71,87,.1);color:var(--red);}
.btn-download{width:100%;height:44px;border-radius:10px;background:linear-gradient(135deg,#ff4757,#ff6b6b);color:#fff;font-size:14px;font-weight:700;box-shadow:0 5px 18px rgba(255,71,87,.35);display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;}
.btn-download:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(255,71,87,.45);}
@keyframes slideUp{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}

/* ===========================================
   RESPONSIVE
   =========================================== */
