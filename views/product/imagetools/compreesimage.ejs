<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
  <title>PixelPress | RID Bharat – Image Compressor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&family=Space+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    /* ===== RESET ===== */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    :root {
      --primary:      #083d5d;
      --primary-dark: #062a41;
      --secondary:    #4da8da;
      --accent:       #ff6b35;
      --light-gray:   #e0e0e0;
      --white:        #ffffff;
      --transition:   all 0.3s ease;
    }

    body {
      font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f2f2f2;
      color: #333;
      line-height: 1.6;
      padding-top: 130px;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    input,button,textarea,select { font-family:inherit; font-size:inherit; }
    a    { text-decoration:none; color:inherit; transition:var(--transition); }
    ul   { list-style:none; }
    button { cursor:pointer; border:none; outline:none; transition:var(--transition); }
    img  { max-width:100%; height:auto; display:block; }
    .container { width:100%; max-width:1200px; margin:0 auto; padding:0 20px; }

    /* ==========================================================
       HEADER
    ========================================================== */
    .header-container { position:fixed; top:0; left:0; width:100%; z-index:1000; }

    .top-header {
      display:flex; justify-content:space-between; align-items:center;
      background:linear-gradient(90deg,#062a41,#0a4d6e);
      color:#fff; padding:0 20px; height:40px; font-size:14px;
      letter-spacing:0.3px; box-shadow:0 2px 10px rgba(0,0,0,.1);
    }
    .web-text p { display:inline-block; font-size:.6rem; font-weight:700; }
    .web-text p span { font-weight:300; }
    .web-text p::after { content:"|"; margin:0 10px; color:#fff; font-weight:300; }
    .web-text p:last-child::after { content:""; }
    .right-text { display:flex; }
    .right-text a { font-size:.6rem; color:white; }
    .right-text a::after { content:"|"; margin:0 8px; color:#fff; font-weight:300; }
    .right-text a:last-child::after { content:""; }

    .main-header {
      backdrop-filter:blur(10px);
      background:rgba(255,255,255,.95);
      border-bottom:1px solid rgba(77,168,218,.3);
      box-shadow:0 2px 10px rgba(0,0,0,.1);
    }
    .nav {
      display:flex; justify-content:space-between; align-items:center;
      height:90px; padding:0 20px; transition:var(--transition);
    }
    .logo { display:flex; align-items:center; flex:1; }
    .logo img { height:80px; transition:var(--transition); }

    .menu { display:flex; justify-content:flex-end; align-items:flex-end; flex-direction:column; }
    .upperNav { display:flex; align-items:center; gap:8px; margin-bottom:10px; }

    .nav-button {
      display:inline-flex; justify-content:center; align-items:center; gap:5px;
      font-size:.9rem; font-weight:600; padding:8px 15px;
      border-radius:30px; cursor:pointer; border:none; outline:none; transition:var(--transition);
    }
    #onlineTest1 { background:linear-gradient(145deg,#dc143c,#b22222); color:#fff; }
    #certificate  { background:linear-gradient(145deg,#0b5e0b,#0a470a); color:#fff; }
    #onlineTest1:hover,#certificate:hover { background:#000; transform:translateY(-2px); }

    .btn-box {
      width: 230px;
      height: 38px;
      display: flex;
      flex-direction: row;
      position: relative;
      border-radius: 30px;
      background: #f0f0f0;
      border: 1px solid rgba(8,61,93,.2);
      box-shadow: 0 2px 4px rgba(0,0,0,.08);
      overflow: hidden;
    }
    #swap-btn {
      position: absolute;
      top: 0; left: 0;
      width: 50%; height: 100%;
      background: #083d5d;
      border-radius: 30px;
      transition: left .35s ease;
      z-index: 0;
      pointer-events: none;
    }
    .toggle-btn {
      position: relative;
      z-index: 1;
      width: 50%; height: 100%;
      background: transparent;
      border: none; outline: none;
      font-size: .82rem; font-weight: 600;
      color: #333;
      display: flex; align-items: center; justify-content: center; gap: 4px;
      cursor: pointer;
      transition: color .3s ease;
      padding: 0 4px;
      white-space: nowrap;
    }
    #logInButton { color:#fff; }

    .lowerNav { display:flex; gap:22px; }
    .lowerNav ul { display:flex; gap:20px; }
    .lowerNav li { position:relative; list-style:none; }
    .lowerNav li a { font-size:.9rem; display:flex; align-items:center; color:#333; font-weight:500; }
    .menu-link { display:flex; align-items:center; cursor:pointer; padding:8px 0; gap:6px; }
    .menu-link:hover { color:var(--primary); }

    @media (min-width:769px) {
      .menu-link { position:relative; }
      .menu-link::after { content:''; position:absolute; bottom:0; left:0; width:0; height:2px; background:var(--primary); transition:width .3s; }
      .menu-link:hover::after { width:100%; }
    }

    .menu-icon {
      display:none; flex-direction:column; justify-content:space-between;
      width:30px; height:21px; cursor:pointer; margin-left:auto; z-index:1001;
    }
    .menu-icon span { display:block; height:3px; width:100%; background:var(--primary); border-radius:3px; transition:var(--transition); }
    .menu-icon.active span:nth-child(1) { transform:translateY(9px) rotate(45deg); }
    .menu-icon.active span:nth-child(2) { opacity:0; }
    .menu-icon.active span:nth-child(3) { transform:translateY(-9px) rotate(-45deg); }

    /* ==========================================================
       IMAGE COMPRESSOR SECTION
       FIX: removed min-height:calc(100vh - 130px) — that was
       causing the huge empty space above/below the card.
       Now uses auto height with just enough padding.
    ========================================================== */
    #compressor-section {
      width: 100%;
      /* ✅ FIXED: was min-height:calc(100vh - 130px) which forced
         giant empty space. Now just padding top/bottom. */
      padding: 36px 16px 48px;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      background: linear-gradient(145deg,#eef2fb 0%,#e4eaf6 100%);
      font-family: 'Inter', sans-serif;
    }

    .comp-wrap { width:100%; max-width:1020px; }

    .glass-card {
      width: 100%;
      background: #fff;
      border-radius: 28px;
      box-shadow: 0 10px 48px rgba(8,61,93,.10), 0 1px 3px rgba(0,0,0,.04);
      padding: 48px 56px;
      border: 1px solid rgba(77,168,218,.18);
    }

    .title-row {
      display:flex; align-items:center; justify-content:space-between;
      flex-wrap:wrap; gap:8px; margin-bottom:30px;
    }
    .comp-title {
      font-size: clamp(1.55rem,2.5vw,2.1rem);
      font-weight:800; letter-spacing:-.03em;
      background:linear-gradient(135deg,#083d5d,#2b79a8);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
    }
    .badge-mono {
      font-family:'Space Mono',monospace; font-size:.65rem;
      background:#eef6ff; padding:4px 12px; border-radius:60px; color:#2c3e66; font-weight:600;
    }

    .drop-compact {
      border:2px dashed #c4d6ea;
      border-radius:20px; background:#fafcff;
      padding:36px 24px; text-align:center;
      cursor:pointer; transition:all .2s ease;
      margin-bottom:30px; position:relative;
    }
    .drop-compact:hover,
    .drop-compact.dragover { border-color:#3b82f6; background:#f0f7ff; }
    .drop-compact input[type="file"] {
      position:absolute; inset:0;
      width:100%; height:100%;
      opacity:0; cursor:pointer; z-index:5;
    }
    .drop-icon { font-size:2.6rem; display:block; margin:0 auto 10px; }
    .drop-label { font-weight:600; font-size:1rem; color:#1e293b; }
    .drop-hint {
      font-family:'Space Mono',monospace; font-size:.65rem; color:#5b6e8c;
      background:#eef2fa; display:inline-block; padding:3px 14px; border-radius:20px; margin-top:8px;
    }

    .controls-row { display:flex; gap:28px; flex-wrap:wrap; margin-bottom:28px; align-items:flex-end; }
    .quality-box { flex:2; min-width:200px; }
    .format-box  { flex:1; min-width:180px; }
    .ctrl-label {
      font-size:.72rem; font-weight:700; text-transform:uppercase;
      letter-spacing:.06em; color:#4a5b7a; margin-bottom:8px;
      display:flex; justify-content:space-between; align-items:center;
    }
    #quality-val {
      font-family:'Space Mono',monospace; background:#e8f0fe;
      padding:2px 10px; border-radius:30px; font-size:.72rem; font-weight:700; color:#2563eb;
    }
    input[type="range"] {
      width:100%; height:5px; -webkit-appearance:none;
      background:#dde6f0; border-radius:10px; cursor:pointer; outline:none;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance:none; width:18px; height:18px;
      background:#2563eb; border-radius:50%;
      border:2px solid white; box-shadow:0 1px 6px rgba(37,99,235,.3); cursor:pointer;
    }
    .pill-group { display:flex; gap:8px; flex-wrap:wrap; }
    .fmt-pill {
      font-family:'Space Mono',monospace; font-size:.72rem;
      padding:6px 18px; border-radius:40px; background:white;
      border:1.5px solid #cddcee; font-weight:600; color:#475569; cursor:pointer; transition:.15s;
    }
    .fmt-pill.active,.fmt-pill:hover { background:#2563eb; border-color:#2563eb; color:white; }

    .btn-go {
      width:100%;
      background:linear-gradient(98deg,#1d4ed8,#3b82f6);
      border:none; padding:15px; border-radius:50px;
      font-weight:700; font-size:1rem; color:white;
      display:flex; align-items:center; justify-content:center; gap:8px;
      cursor:pointer; margin-bottom:22px; transition:all .2s;
      box-shadow:0 6px 20px rgba(37,99,235,.25); letter-spacing:.02em;
    }
    .btn-go:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 12px 28px rgba(37,99,235,.3); }
    .btn-go:disabled { opacity:.45; cursor:not-allowed; transform:none !important; }
    .btn-go:active:not(:disabled) { transform:scale(.98); }

    .progress-micro { margin-bottom:18px; display:none; }
    .progress-micro.show { display:block; }
    .track { height:5px; background:#e2e8f0; border-radius:20px; overflow:hidden; }
    .fill  { width:0%; height:100%; background:linear-gradient(90deg,#3b82f6,#8b5cf6); border-radius:20px; transition:width .25s; }
    .progress-status { font-size:.65rem; font-family:monospace; text-align:right; margin-top:5px; color:#5b6e8c; }

    .result-micro { display:none; border-radius:20px; border:1px solid #deeaf8; background:#fff; overflow:hidden; margin-top:8px; }
    .result-micro.show { display:block; animation:fadePop .3s ease; }
    @keyframes fadePop { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

    .preview-duo { display:flex; gap:1px; background:#deeaf8; }
    .preview-item { flex:1; background:white; padding:18px 14px; text-align:center; }
    .preview-item img { max-width:100%; max-height:150px; object-fit:contain; border-radius:10px; background:#f5f9ff; margin:0 auto; display:block; }
    .preview-label { font-size:.65rem; font-weight:700; font-family:monospace; text-transform:uppercase; color:#6c7a91; margin-top:8px; }
    .file-size-num { font-size:.82rem; font-weight:700; margin-top:4px; }
    .orig-size { color:#dc2626; }
    .comp-size { color:#059669; }

    .action-bar {
      display:flex; align-items:center; justify-content:space-between;
      padding:14px 22px; background:#f8fcff; border-top:1px solid #deeaf8;
      flex-wrap:wrap; gap:10px;
    }
    .save-chip {
      font-family:monospace; font-size:.76rem; font-weight:700;
      background:#dcfce7; padding:5px 16px; border-radius:50px; color:#166534;
    }
    .dl-micro {
      background:#059669; border:none; padding:9px 24px; border-radius:40px;
      font-weight:700; font-size:.82rem; color:white; cursor:pointer;
      display:flex; gap:6px; align-items:center; transition:all .2s;
    }
    .dl-micro:hover { background:#047857; transform:translateY(-1px); }

    .error-mini {
      display:none; background:#fff1f2; border-radius:12px;
      padding:10px 14px; font-size:.76rem; font-family:monospace;
      color:#be123c; margin-top:12px; border-left:3px solid #f43f5e;
    }
    .error-mini.show { display:block; }

    /* ==========================================================
       FOOTER
    ========================================================== */
    footer {
      background:linear-gradient(145deg,#0a3750,#031f2f);
      color:#fff; padding:30px 0 0; position:relative; width:100%; overflow:hidden;
    }
    footer::before {
      content:''; position:absolute; top:0; left:0; width:100%; height:4px;
      background:linear-gradient(90deg,var(--accent),var(--secondary),var(--accent));
    }
    .footer-content { display:grid; grid-template-columns:repeat(4,1fr); gap:30px; }
    .footer-logo { display:flex; flex-direction:column; }
    .footer-logo img { max-width:180px; margin-bottom:10px; background:#fff; padding:5px; border-radius:6px; }
    .footer-logo p { margin-bottom:8px; color:var(--light-gray); font-size:.8rem; line-height:1.4; }
    .contact-info { margin-top:5px; }
    .contact-info p { margin-bottom:4px; display:flex; align-items:center; gap:6px; font-size:.8rem; }
    .contact-info i { color:var(--secondary); width:14px; font-size:.8rem; }
    .footer-links h3,.footer-social h3 { font-size:1rem; margin-bottom:12px; position:relative; padding-bottom:6px; font-weight:600; }
    .footer-links h3:after,.footer-social h3:after { content:''; position:absolute; left:0; bottom:0; width:30px; height:2px; background:var(--secondary); border-radius:2px; }
    .footer-links ul li { margin-bottom:8px; transition:transform .3s; }
    .footer-links ul li:hover { transform:translateX(5px); }
    .footer-links a { color:var(--light-gray); display:flex; align-items:center; gap:5px; font-size:.8rem; transition:color .3s; }
    .footer-links a:hover { color:#fff; }
    .footer-links a i { color:var(--secondary); font-size:.7rem; }
    .footer-social ul { display:flex; flex-wrap:wrap; gap:8px; }
    .footer-social a { display:flex; align-items:center; gap:5px; color:var(--light-gray); padding:5px 10px; background:rgba(255,255,255,.1); border-radius:5px; font-size:.8rem; transition:all .3s; }
    .footer-social a:hover { color:#fff; background:rgba(77,168,218,.3); transform:translateY(-3px); }
    .footer-bottom { border-top:1px solid rgba(255,255,255,.1); padding:15px 0; text-align:center; color:var(--light-gray); font-size:.75rem; }
    .footer-links-bottom { display:flex; justify-content:center; gap:12px; margin-top:8px; flex-wrap:wrap; }
    .footer-links-bottom a { color:#b0d4ed; font-size:.75rem; position:relative; transition:color .3s; }
    .footer-links-bottom a:not(:last-child)::after { content:'|'; position:absolute; right:-8px; color:var(--secondary); }
    .footer-links-bottom a:hover { color:var(--accent); }
    .back-to-top { position:absolute; right:15px; top:0; background:var(--secondary); color:#fff; width:35px; height:35px; border-radius:50%; display:flex; align-items:center; justify-content:center; opacity:0; visibility:hidden; pointer-events:none; transition:var(--transition); }

    ::-webkit-scrollbar { width:8px; }
    ::-webkit-scrollbar-track { background:#e2ecf5; }
    ::-webkit-scrollbar-thumb { background:linear-gradient(145deg,#083d5d,#1f6991); border-radius:10px; }
    ::-webkit-scrollbar-thumb:hover { background:var(--accent); }

    /* ==========================================================
       RESPONSIVE
    ========================================================== */
    @media (max-width:768px) {
      body { padding-top:90px; }
      .top-header { display:none; }
      .menu-icon { display:flex; }
      .nav { height:auto; padding:10px 20px; }
      .logo img { height:60px; }

      .menu {
        position:fixed; top:90px; left:0;
        width:100%; height:calc(100vh - 90px);
        background:rgba(255,255,255,.98); backdrop-filter:blur(12px);
        flex-direction:column; align-items:flex-start; justify-content:flex-start;
        display:none; padding:24px 20px 30px; overflow-y:auto;
        z-index:999; transform:translateX(-100%); transition:transform .3s ease;
        box-shadow:4px 0 20px rgba(0,0,0,.08);
      }
      .menu.active { display:flex; transform:translateX(0); }

      .upperNav { flex-direction:column; width:100%; gap:10px; margin-bottom:18px; }
      .upperNav .nav-button { width:100%; height:44px; font-size:.95rem; justify-content:center; }
      #certificate { width:100%; }
      .btn-box { width:100%; height:42px; }
      .toggle-btn { font-size:.8rem; }

      .lowerNav { flex-direction:column; width:100%; gap:0; margin-top:6px; }
      .lowerNav ul { flex-direction:column; gap:0; width:100%; }
      .lowerNav li { border-bottom:1px solid #f0f0f0; }
      .menu-link { padding:13px 0; width:100%; font-size:.95rem; }

      /* compressor on mobile */
      #compressor-section { padding:16px 6px 24px; }
      .comp-wrap { max-width:100%; }
      .glass-card { padding:20px 14px; border-radius:16px; }
      .comp-title { font-size:1.35rem; }
      .controls-row { flex-direction:column; gap:16px; }
      .quality-box,.format-box { min-width:100%; }
      .preview-duo { flex-direction:column; }
      .preview-item img { max-height:120px; }
      .drop-compact { padding:22px 12px; }
      .drop-icon { font-size:2rem; }

      /* footer mobile */
      .footer-content { grid-template-columns:repeat(2,1fr); }
    }

    @media (max-width:480px) {
      #compressor-section { padding:10px 4px 20px; }
      .glass-card { padding:16px 12px; }
      .comp-title { font-size:1.15rem; }
      .btn-go { font-size:.88rem; padding:12px; }
      .preview-item img { max-height:90px; }
      .action-bar { flex-direction:column; align-items:stretch; }
      .dl-micro { justify-content:center; }
    }

    @media (max-width:600px) {
      .footer-content { grid-template-columns:1fr; text-align:center; }
      .footer-logo { align-items:center; }
      .footer-logo img { margin:0 auto 10px; }
      .contact-info p { justify-content:center; }
      .footer-links ul,.footer-social ul { justify-content:center; }
      .footer-links h3::after,.footer-social h3::after { left:50%; transform:translateX(-50%); }
      .footer-links a { justify-content:center; }
    }
  </style>
</head>

<body>

  <!-- ===== HEADER ===== -->
  <div class="header-container">
    <div class="top-header">
      <div class="web-text">
        <p><span>RID Bharat Run by TWF</span></p>
        <p>Helpline: <span>+91-9202707903</span></p>
        <p>Email: <span>ridorg.in@gmail.com</span></p>
      </div>
      <div class="right-text">
        <a href="#">ISO:9001:2015 Certified</a>
        <a href="#">TWF</a>
        <a href="#">Reg.No:048884</a>
        <a href="#">ESTD:2020</a>
      </div>
    </div>

    <div class="main-header">
      <div class="nav">
        <div class="logo">
          <img src="./assets/final_logo.svg" alt="RID Bharat Logo"
            onerror="this.src='https://via.placeholder.com/260x70/083d5d/FFFFFF?text=RID+Bharat'">
          <div class="menu-icon" id="menuIcon">
            <span></span><span></span><span></span>
          </div>
        </div>

        <div class="menu" id="innerCont">
          <div class="upperNav">
            <a href="/RTS/public/main.html">
              <button class="nav-button" id="onlineTest1">
                <i class="fa-brands fa-servicestack"></i> Test Series
              </button>
            </a>
            <button class="nav-button" style="background:linear-gradient(145deg,#c67534,#a05a20);color:#fff;">
              <i class="fa-solid fa-book"></i> Service
            </button>
            <a href="/Certificate-Verification/verify.html">
              <button class="nav-button" id="certificate">
                <i class="fa-solid fa-certificate"></i> Certificate
              </button>
            </a>
            <div class="btn-box">
              <div id="swap-btn"></div>
              <button class="toggle-btn" id="logInButton"
                      onclick="window.location.href='/login'">
                <i class="fa-solid fa-right-to-bracket"></i> Login
              </button>
              <button class="toggle-btn" id="signUpBtn"
                      onclick="window.location.href='/form'">
                <i class="fa-solid fa-user-plus"></i> Register
              </button>
            </div>
          </div>

          <ul class="lowerNav">
            <li><a class="menu-link" href="index.html"><i class="fa-solid fa-house"></i> Home</a></li>
            <li><a class="menu-link" href="about/about.html"><i class="fa-solid fa-circle-info"></i> About Us</a></li>
            <li><a class="menu-link" href="#"><i class="fa-solid fa-file-lines"></i> Research Papers</a></li>
            <li><a class="menu-link" href="#"><i class="fa-solid fa-file-lines"></i> Internship</a></li>
            <li><a class="menu-link" href="#"><i class="fa-solid fa-file-lines"></i> E-Book</a></li>
            <li><a class="menu-link" href="/contact/contact.html"><i class="fa-solid fa-headset"></i> Tech Interview</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== IMAGE COMPRESSOR ===== -->
  <section id="compressor-section">
    <div class="comp-wrap">
      <div class="glass-card">

        <div class="title-row">
          <h2 class="comp-title" style="text-align: center;">Compress Image</h2>
        </div>

        <div class="drop-compact" id="dropZone">
          <input type="file" id="fileInput" accept="image/*">
          <span class="drop-icon">🖼️</span>
          <p class="drop-label" id="dropLabel">Drop your image here or <u>click to browse</u></p>
          <p class="drop-hint" id="dropHint">JPEG · PNG · WEBP · max 20 MB</p>
        </div>

        <div class="controls-row">
          <div class="quality-box">
            <div class="ctrl-label">
              <span>Quality</span>
              <span id="quality-val">80%</span>
            </div>
            <input type="range" id="qualityRange" min="5" max="100" value="80">
          </div>
          <div class="format-box">
            <div class="ctrl-label">Output Format</div>
            <div class="pill-group">
              <button class="fmt-pill active" data-fmt="image/jpeg">JPEG</button>
              <button class="fmt-pill"        data-fmt="image/png">PNG</button>
              <button class="fmt-pill"        data-fmt="image/webp">WEBP</button>
            </div>
          </div>
        </div>

        <button class="btn-go" id="compressBtn" disabled>
          <i class="fa-solid fa-bolt"></i> Compress Now
        </button>

        <div class="progress-micro" id="progressBlock">
          <div class="track"><div class="fill" id="fillBar"></div></div>
          <div class="progress-status" id="progressMsg">Processing…</div>
        </div>

        <div class="error-mini" id="errorBox"></div>

        <div class="result-micro" id="resultPanel">
          <div class="preview-duo">
            <div class="preview-item">
              <img id="origImg" src="" alt="Original">
              <p class="preview-label">Original</p>
              <p class="file-size-num orig-size" id="origSize">—</p>
            </div>
            <div class="preview-item">
              <img id="compImg" src="" alt="Compressed">
              <p class="preview-label">Compressed</p>
              <p class="file-size-num comp-size" id="compSize">—</p>
            </div>
          </div>
          <div class="action-bar">
            <span class="save-chip" id="savedChip">📊 Savings</span>
            <button class="dl-micro" id="downloadBtn">⬇ Download</button>
          </div>
        </div>

      </div>
    </div>
  </section>

