  <!-- ===== SCRIPTS ===== -->
  <script>
  /* Hamburger */
  (function(){
    var icon = document.getElementById('menuIcon');
    var menu = document.getElementById('innerCont');
    if(!icon) return;
    icon.addEventListener('click', function(e){
      e.stopPropagation();
      icon.classList.toggle('active');
      menu.classList.toggle('active');
    });
    document.addEventListener('click', function(e){
      if(!menu.contains(e.target) && !icon.contains(e.target)){
        icon.classList.remove('active');
        menu.classList.remove('active');
      }
    });
  })();

  /* Login / Register pill */
  (function(){
    var loginBtn = document.getElementById('logInButton');
    var regBtn   = document.getElementById('signUpBtn');
    var slider   = document.getElementById('swap-btn');
    if(!loginBtn||!regBtn||!slider) return;
    loginBtn.addEventListener('mousedown', function(){
      slider.style.left    = '0%';
      loginBtn.style.color = '#fff';
      regBtn.style.color   = '#333';
    });
    regBtn.addEventListener('mousedown', function(){
      slider.style.left    = '50%';
      regBtn.style.color   = '#fff';
      loginBtn.style.color = '#333';
    });
  })();

  /* Image Compressor */
  (function(){
    var dropZone    = document.getElementById('dropZone');
    var fileInput   = document.getElementById('fileInput');
    var qualSlider  = document.getElementById('qualityRange');
    var qualVal     = document.getElementById('quality-val');
    var compressBtn = document.getElementById('compressBtn');
    var progBlock   = document.getElementById('progressBlock');
    var fillBar     = document.getElementById('fillBar');
    var progMsg     = document.getElementById('progressMsg');
    var resultPanel = document.getElementById('resultPanel');
    var origImg     = document.getElementById('origImg');
    var compImg     = document.getElementById('compImg');
    var origSizeEl  = document.getElementById('origSize');
    var compSizeEl  = document.getElementById('compSize');
    var savedChip   = document.getElementById('savedChip');
    var downloadBtn = document.getElementById('downloadBtn');
    var errorBox    = document.getElementById('errorBox');
    var dropLabel   = document.getElementById('dropLabel');
    var dropHint    = document.getElementById('dropHint');
    var fmtPills    = document.querySelectorAll('.fmt-pill');

    var currentFile = null;
    var outputBlob  = null;
    var outputUrl   = null;
    var activeMime  = 'image/jpeg';

    function fmtBytes(b){
      if(b<1024) return b+' B';
      if(b<1048576) return (b/1024).toFixed(1)+' KB';
      return (b/1048576).toFixed(2)+' MB';
    }
    function showErr(m){ errorBox.textContent='⚠️ '+m; errorBox.classList.add('show'); }
    function hideErr() { errorBox.classList.remove('show'); errorBox.textContent=''; }
    function resetResult(){
      resultPanel.classList.remove('show');
      if(outputUrl){ URL.revokeObjectURL(outputUrl); outputUrl=null; }
      outputBlob=null; compImg.src='';
    }

    function loadFile(file){
      hideErr(); resetResult();
      if(!file) return;
      if(!file.type.startsWith('image/')){
        showErr('Please choose a valid image (JPEG, PNG, WEBP, etc.)');
        compressBtn.disabled=true; currentFile=null; return;
      }
      if(file.size > 20*1024*1024){
        showErr('File too large — max 20 MB allowed.');
        compressBtn.disabled=true; currentFile=null; return;
      }
      currentFile = file;
      compressBtn.disabled = false;
      var name = file.name.length>30 ? file.name.slice(0,26)+'…' : file.name;
      dropLabel.textContent = '✅ '+name;
      dropHint.textContent  = fmtBytes(file.size)+' · ready to compress';
      var reader = new FileReader();
      reader.onload = function(e){
        origImg.src = e.target.result;
        origSizeEl.textContent = fmtBytes(file.size);
      };
      reader.readAsDataURL(file);
    }

    function doCompress(){
      if(!currentFile){ showErr('No image selected.'); return; }
      hideErr(); resetResult();
      progBlock.classList.add('show');
      fillBar.style.width='0%';
      progMsg.textContent='Starting…';
      var w = 0;
      var iv = setInterval(function(){
        w += Math.random()*16;
        if(w>=85){ w=85; clearInterval(iv); }
        fillBar.style.width = Math.round(w)+'%';
        progMsg.textContent = 'Compressing… '+Math.round(w)+'%';
      }, 60);
      var quality = parseInt(qualSlider.value,10)/100;
      var mime    = activeMime;
      var reader  = new FileReader();
      reader.onload = function(ev){
        var img = new Image();
        img.onload = function(){
          var canvas = document.createElement('canvas');
          canvas.width  = img.naturalWidth;
          canvas.height = img.naturalHeight;
          canvas.getContext('2d').drawImage(img,0,0);
          canvas.toBlob(function(blob){
            clearInterval(iv);
            fillBar.style.width='100%';
            progMsg.textContent='Done! 100%';
            setTimeout(function(){
              progBlock.classList.remove('show');
              if(!blob){ showErr('Compression failed — try a different format.'); return; }
              showResult(blob);
            }, 280);
          }, mime, quality);
        };
        img.onerror = function(){
          clearInterval(iv); progBlock.classList.remove('show');
          showErr('Could not read the image — try another file.');
        };
        img.src = ev.target.result;
      };
      reader.onerror = function(){
        clearInterval(iv); progBlock.classList.remove('show');
        showErr('File read error — please try again.');
      };
      reader.readAsDataURL(currentFile);
    }

    function showResult(blob){
      outputBlob = blob;
      outputUrl  = URL.createObjectURL(blob);
      compImg.src = outputUrl;
      compSizeEl.textContent = fmtBytes(blob.size);
      var saved = ((currentFile.size - blob.size)/currentFile.size)*100;
      if(saved>0){
        savedChip.textContent    = '✅ Saved '+saved.toFixed(1)+'% ('+fmtBytes(currentFile.size-blob.size)+')';
        savedChip.style.background='#dcfce7'; savedChip.style.color='#166534';
      } else {
        savedChip.textContent    = '⚠️ No reduction — try lower quality or a different format';
        savedChip.style.background='#fef9c3'; savedChip.style.color='#854d0e';
      }
      resultPanel.classList.add('show');
      setTimeout(function(){ resultPanel.scrollIntoView({behavior:'smooth',block:'nearest'}); },80);
    }

    downloadBtn.addEventListener('click', function(){
      if(!outputBlob) return;
      var ext  = activeMime==='image/png'?'png': activeMime==='image/webp'?'webp':'jpg';
      var base = (currentFile.name.replace(/\.[^/.]+$/,'')||'image').slice(0,40);
      var a    = document.createElement('a');
      var url  = URL.createObjectURL(outputBlob);
      a.href=url; a.download=base+'_compressed.'+ext;
      document.body.appendChild(a); a.click();
      document.body.removeChild(a);
      setTimeout(function(){ URL.revokeObjectURL(url); },400);
    });

    qualSlider.addEventListener('input', function(){ qualVal.textContent=this.value+'%'; });

    fmtPills.forEach(function(btn){
      btn.addEventListener('click', function(){
        fmtPills.forEach(function(b){ b.classList.remove('active'); });
        this.classList.add('active');
        activeMime = this.dataset.fmt;
      });
    });

    compressBtn.addEventListener('click', doCompress);

    dropZone.addEventListener('dragover', function(e){ e.preventDefault(); this.classList.add('dragover'); });
    dropZone.addEventListener('dragleave', function(){ this.classList.remove('dragover'); });
    dropZone.addEventListener('drop', function(e){
      e.preventDefault(); this.classList.remove('dragover');
      if(e.dataTransfer.files.length) loadFile(e.dataTransfer.files[0]);
    });

    fileInput.addEventListener('change', function(){
      if(this.files && this.files.length>0) loadFile(this.files[0]);
    });
  })();
  </script>
