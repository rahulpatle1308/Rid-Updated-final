<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
  <title>Image Merger Pro | RID Bharat</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    :root {
      --primary:      #083d5d;
      --primary-dark: #062a41;
      --secondary:    #4da8da;
      --accent:       #ff6b35;
      --light-gray:   #e0e0e0;
      --white:        #ffffff;
      --transition:   all 0.3s ease;
    }

    body {
      font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f2f2f2;
      color: #333;
      line-height: 1.6;
      padding-top: 130px;  /* top-bar 40 + nav 90 */
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    a    { text-decoration:none; color:inherit; transition:var(--transition); }
    ul   { list-style:none; }
    button { cursor:pointer; border:none; outline:none; transition:var(--transition); }
    img  { max-width:100%; height:auto; display:block; }
    input,button,textarea,select { font-family:inherit; font-size:inherit; }
    .container { width:100%; max-width:1200px; margin:0 auto; padding:0 20px; }

    /* ══════════════════════════════════════
       HEADER
    ══════════════════════════════════════ */
    .header-container { position:fixed; top:0; left:0; width:100%; z-index:1000; }

    /* top bar */
    .top-header {
      display:flex; justify-content:space-between; align-items:center;
      background:linear-gradient(90deg,#062a41,#0a4d6e);
      color:#fff; padding:0 20px; height:40px; font-size:14px;
      letter-spacing:.3px; box-shadow:0 2px 10px rgba(0,0,0,.1);
    }
    .web-text p { display:inline-block; font-size:.6rem; font-weight:700; }
    .web-text p span { font-weight:300; }
    .web-text p::after { content:"|"; margin:0 10px; color:#fff; font-weight:300; }
    .web-text p:last-child::after { content:""; }
    .right-text { display:flex; }
    .right-text a { font-size:.6rem; color:white; }
    .right-text a::after { content:"|"; margin:0 8px; color:#fff; font-weight:300; }
    .right-text a:last-child::after { content:""; }

    /* main nav */
    .main-header {
      backdrop-filter:blur(10px);
      background:rgba(255,255,255,.95);
      border-bottom:1px solid rgba(77,168,218,.3);
      box-shadow:0 2px 10px rgba(0,0,0,.1);
    }
    .nav {
      display:flex; justify-content:space-between; align-items:center;
      height:90px; padding:0 20px; transition:var(--transition);
    }
    .logo { display:flex; align-items:center; flex:1; }
    .logo img { height:80px; transition:var(--transition); }

    .menu { display:flex; justify-content:flex-end; align-items:flex-end; flex-direction:column; }
    .upperNav { display:flex; align-items:center; gap:8px; margin-bottom:10px; }

    .nav-button {
      display:inline-flex; justify-content:center; align-items:center; gap:5px;
      font-size:.9rem; font-weight:600; padding:8px 15px;
      border-radius:30px; cursor:pointer; border:none; outline:none;
      transition:var(--transition);
      background:linear-gradient(135deg,var(--primary),#1e5a7a); color:#fff;
    }
    #onlineTest1 { background:linear-gradient(145deg,#dc143c,#b22222); color:#fff; }
    #certificate  { background:linear-gradient(145deg,#0b5e0b,#0a470a); color:#fff; }
    #onlineTest1:hover,#certificate:hover { background:#000; transform:translateY(-2px); }

    /* ── Login / Register pill ──
       KEY: buttons are DIRECT flex children of .btn-box (no <a> wrappers inside)
       #swap-btn is absolute z-index:0, buttons are z-index:1                    */
    .btn-box {
      width: 230px;
      height: 38px;
      display: flex;
      flex-direction: row;
      position: relative;
      border-radius: 30px;
      background: #f0f0f0;
      border: 1px solid rgba(8,61,93,.2);
      box-shadow: 0 2px 4px rgba(0,0,0,.08);
      overflow: hidden;
    }
    #swap-btn {
      position: absolute;
      top: 0; left: 0;
      width: 50%; height: 100%;
      background: var(--primary);
      border-radius: 30px;
      transition: left .35s ease;
      z-index: 0;
      pointer-events: none;
    }
    .toggle-btn {
      position: relative; z-index: 1;
      width: 50%; height: 100%;
      background: transparent; border: none; outline: none;
      font-size: .82rem; font-weight: 600; color: #333;
      display: flex; align-items: center; justify-content: center; gap: 4px;
      cursor: pointer; transition: color .3s ease;
      padding: 0 4px; white-space: nowrap;
    }
    #logInButton { color: #fff; }

    /* lower nav */
    .lowerNav { display:flex; gap:22px; }
    .lowerNav ul { display:flex; gap:20px; }
    .lowerNav li { position:relative; list-style:none; }
    .lowerNav li a { font-size:.9rem; display:flex; align-items:center; color:#333; font-weight:500; }
    .menu-link { display:flex; align-items:center; cursor:pointer; padding:8px 0; gap:6px; }
    .menu-link:hover { color:var(--primary); }

    @media (min-width:769px) {
      .menu-link { position:relative; }
      .menu-link::after { content:''; position:absolute; bottom:0; left:0; width:0; height:2px; background:var(--primary); transition:width .3s; }
      .menu-link:hover::after { width:100%; }
    }

    /* hamburger */
    .menu-icon {
      display:none; flex-direction:column; justify-content:space-between;
      width:30px; height:21px; cursor:pointer; margin-left:auto; z-index:1001;
    }
    .menu-icon span { display:block; height:3px; width:100%; background:var(--primary); border-radius:3px; transition:var(--transition); }
    .menu-icon.active span:nth-child(1) { transform:translateY(9px) rotate(45deg); }
    .menu-icon.active span:nth-child(2) { opacity:0; }
    .menu-icon.active span:nth-child(3) { transform:translateY(-9px) rotate(-45deg); }

    /* ══════════════════════════════════════
       CENTER — IMAGE MERGER
       Goal: wide card, compact height, NO USER SCROLL
    ══════════════════════════════════════ */
    .merger-section {
      width: 100%;
      min-height: calc(100vh - 130px);  /* fills space between header and footer */
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 20px 32px;
      background: linear-gradient(135deg,#f0f4fb 0%,#e4eaf6 100%);
    }

    /* Wide card — matches compressor page style */
    .merger-card {
      width: 100%;
      max-width: 1000px;          /* wide, not the old 560px */
      background: #fff;
      border-radius: 24px;
      box-shadow: 0 10px 48px rgba(8,61,93,.10), 0 1px 3px rgba(0,0,0,.04);
      border: 1px solid rgba(77,168,218,.18);
      overflow: hidden;
    }

    .merger-header {
      padding: 16px 32px 14px;
      border-bottom: 1px solid #e9ecef;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 8px;
    }
    .merger-header h2 {
      font-size: 1.5rem; font-weight: 700; color: var(--primary);
      display: flex; align-items: center; gap: 8px;
    }
    .merger-header p { color:#718096; font-size:.72rem; }

    /* Two-column layout inside card */
    .merger-body {
      display: grid;
      grid-template-columns: 360px 1fr;
      min-height: 0;
    }

    /* LEFT: controls */
    .merger-left {
      padding: 18px 20px;
      border-right: 1px solid #e9ecef;
      display: flex; flex-direction: column; gap: 12px;
    }

    /* RIGHT: preview */
    .merger-right {
      padding: 18px 20px;
      display: flex; flex-direction: column; gap: 10px;
    }

    /* section label */
    .sec-lbl {
      font-size: .62rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .08em; color: #718096; margin-bottom: 2px;
    }

    /* Upload zone */
    .upload-zone {
      background: #f7fafc; border: 2px dashed #cbd5e0;
      border-radius: 14px; padding: 14px 12px; text-align: center;
      cursor: pointer; transition: all .2s; position: relative;
    }
    .upload-zone:hover, .upload-zone.dragover { border-color:var(--primary); background:#f0f6fc; }
    .upload-zone input[type="file"] {
      position:absolute; inset:0; width:100%; height:100%; opacity:0; cursor:pointer; z-index:3;
    }
    .upload-icon { font-size:24px; margin-bottom:4px; }
    .upload-btn-face {
      display:inline-block; background:var(--primary); color:#fff;
      padding:5px 16px; border-radius:40px; font-size:.72rem; font-weight:600; margin:4px 0;
    }
    .upload-hint { color:#a0aec0; font-size:.6rem; }

    /* Add more */
    .add-more-wrap { position:relative; }
    .add-more-wrap input[type="file"] {
      position:absolute; inset:0; width:100%; height:100%; opacity:0; cursor:pointer; z-index:3;
    }
    .add-more-face {
      width:100%; background:transparent; border:1.5px dashed #cbd5e0;
      border-radius:10px; padding:7px; display:flex;
      align-items:center; justify-content:center; gap:5px;
      color:var(--primary); font-size:.72rem; font-weight:600;
      transition:all .2s; pointer-events:none;
    }
    .add-more-wrap:hover .add-more-face { border-color:var(--primary); background:#f0f6fc; }

    /* File list */
    .files-header {
      display:flex; align-items:center; justify-content:space-between; margin-bottom:6px;
    }
    .file-badge {
      background:var(--primary); color:#fff;
      padding:2px 8px; border-radius:20px; font-size:.6rem; font-weight:600;
    }
    .clear-all-btn {
      background:#edf2f7; border:none; color:#718096;
      padding:2px 8px; border-radius:20px; font-size:.6rem; cursor:pointer;
    }
    .clear-all-btn:hover { background:#e2e8f0; }
    .files-grid {
      max-height: 120px; overflow-y:auto;
      display:flex; flex-direction:column; gap:5px;
      scrollbar-width:thin; scrollbar-color:#cbd5e0 transparent;
    }
    .files-grid::-webkit-scrollbar { width:3px; }
    .files-grid::-webkit-scrollbar-thumb { background:#cbd5e0; border-radius:3px; }
    .empty-message { text-align:center; padding:10px; color:#a0aec0; font-size:.7rem; }

    .file-item-card {
      background:#fff; border:1px solid #e2e8f0; border-radius:8px;
      padding:5px 8px; display:flex; align-items:center; gap:8px;
    }
    .file-icon-small {
      width:28px; height:28px; background:#f7fafc; border-radius:5px;
      display:flex; align-items:center; justify-content:center; overflow:hidden; flex-shrink:0;
    }
    .file-icon-small img { width:100%; height:100%; object-fit:cover; }
    .file-info-text { flex:1; min-width:0; }
    .file-name-text { font-size:.68rem; font-weight:500; color:#2d3748; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .file-size-text { font-size:.58rem; color:#a0aec0; }
    .remove-single-btn {
      background:#edf2f7; border:none; width:22px; height:22px;
      border-radius:5px; color:#a0aec0; cursor:pointer; font-size:.75rem;
      display:flex; align-items:center; justify-content:center; flex-shrink:0;
    }
    .remove-single-btn:hover { background:#fed7d7; color:#e53e3e; }

    /* Settings */
    .controls-wrapper { display:flex; gap:10px; }
    .control-box { flex:1; background:#f7fafc; border-radius:10px; padding:10px; }
    .control-title { font-size:.6rem; color:#718096; font-weight:700; margin-bottom:6px; text-transform:uppercase; letter-spacing:.06em; }
    .radio-options { display:flex; gap:10px; flex-wrap:wrap; }
    .radio-options label { font-size:.72rem; color:#4a5568; display:flex; align-items:center; gap:4px; cursor:pointer; }
    .radio-options input { accent-color:var(--primary); width:12px; height:12px; }

    /* Action buttons */
    .action-buttons { display:flex; gap:10px; }
    .action-btn {
      flex:1; padding:10px; border:none; border-radius:40px;
      font-weight:700; font-size:.8rem; cursor:pointer;
      display:flex; align-items:center; justify-content:center; gap:5px;
      transition:all .2s;
    }
    .merge-btn { background:var(--primary); color:#fff; }
    .merge-btn:hover:not(:disabled) { background:var(--primary-dark); transform:translateY(-1px); }
    .download-btn { background:#edf2f7; color:#4a5568; border:1px solid #e2e8f0; }
    .download-btn:hover:not(:disabled) { background:#e2e8f0; }
    .action-btn:disabled { opacity:.45; cursor:not-allowed; transform:none !important; }

    /* Spinner */
    .spinner-small {
      width:13px; height:13px; border:2px solid rgba(255,255,255,.3);
      border-top-color:#fff; border-radius:50%; animation:spin .6s linear infinite; display:none;
    }
    @keyframes spin { to { transform:rotate(360deg); } }

    /* Preview (right side) */
    .preview-header { display:flex; justify-content:space-between; align-items:center; }
    .preview-header span:first-child { font-size:.75rem; font-weight:600; color:#4a5568; }
    .preview-dimension {
      background:#edf2f7; padding:2px 8px; border-radius:20px;
      font-size:.6rem; color:var(--primary); font-weight:600;
    }
    .canvas-container {
      flex:1; background:#f7fafc; border-radius:12px; border:1px solid #e2e8f0;
      display:flex; align-items:center; justify-content:center;
      min-height: 200px; overflow:hidden; position:relative;
    }
    /* grid bg */
    .canvas-container::before {
      content:''; position:absolute; inset:0;
      background-image: linear-gradient(#e2e8f0 1px,transparent 1px),linear-gradient(90deg,#e2e8f0 1px,transparent 1px);
      background-size:20px 20px; opacity:.5;
    }
    #mergedCanvas {
      max-width:100%; max-height:320px;
      display:block; position:relative; z-index:1;
      border-radius:6px;
    }
    .preview-placeholder {
      text-align:center; color:#a0aec0; position:relative; z-index:1;
    }
    .preview-placeholder .ph-icon { font-size:2.5rem; opacity:.3; margin-bottom:8px; }
    .preview-placeholder p { font-size:.75rem; }
    .preview-placeholder small { font-size:.62rem; }
    .hidden { display:none !important; }

    /* Toast */
    .success-toast {
      position:fixed; bottom:24px; left:50%;
      transform:translateX(-50%) translateY(20px);
      background:#38a169; color:#fff; padding:6px 16px; border-radius:40px;
      font-size:.72rem; font-weight:600; z-index:2000; opacity:0;
      transition:all .3s; pointer-events:none;
    }
    .success-toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

    /* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ */
    footer {
      background:linear-gradient(135deg,var(--primary),var(--primary-dark));
      color:#fff; padding:30px 0 0; position:relative; overflow:hidden;
    }
    footer::before {
      content:''; position:absolute; top:0; left:0; width:100%; height:4px;
      background:linear-gradient(90deg,var(--accent),var(--secondary),var(--accent));
    }
    .footer-content { display:grid; grid-template-columns:repeat(4,1fr); gap:30px; }
    .footer-logo { display:flex; flex-direction:column; }
    .footer-logo img { max-width:180px; margin-bottom:10px; background:#fff; padding:5px; border-radius:6px; }
    .footer-logo p { color:var(--light-gray); font-size:.8rem; line-height:1.4; margin-bottom:8px; }
    .contact-info p { margin-bottom:4px; display:flex; align-items:center; gap:6px; font-size:.8rem; }
    .contact-info i { color:var(--secondary); width:14px; font-size:.8rem; }
    .footer-links h3,.footer-social h3 { font-size:1rem; margin-bottom:12px; position:relative; padding-bottom:6px; font-weight:600; }
    .footer-links h3:after,.footer-social h3:after { content:''; position:absolute; left:0; bottom:0; width:30px; height:2px; background:var(--secondary); border-radius:2px; }
    .footer-links ul li { margin-bottom:8px; transition:transform .3s; }
    .footer-links ul li:hover { transform:translateX(5px); }
    .footer-links a { color:var(--light-gray); display:flex; align-items:center; gap:5px; font-size:.8rem; transition:color .3s; }
    .footer-links a:hover { color:#fff; }
    .footer-links a i { color:var(--secondary); font-size:.7rem; }
    .footer-social ul { display:flex; flex-wrap:wrap; gap:8px; }
    .footer-social a { display:flex; align-items:center; gap:5px; color:var(--light-gray); padding:5px 10px; background:rgba(255,255,255,.1); border-radius:5px; font-size:.8rem; transition:all .3s; }
    .footer-social a:hover { color:#fff; background:rgba(77,168,218,.3); transform:translateY(-3px); }
    .footer-bottom { border-top:1px solid rgba(255,255,255,.1); padding:15px 0; text-align:center; color:var(--light-gray); font-size:.75rem; margin-top:30px; }
    .footer-links-bottom { display:flex; justify-content:center; gap:12px; margin-top:8px; flex-wrap:wrap; }
    .footer-links-bottom a { color:var(--light-gray); font-size:.75rem; transition:color .3s; }
    .footer-links-bottom a:hover { color:var(--accent); }

    /* scrollbar */
    ::-webkit-scrollbar { width:8px; }
    ::-webkit-scrollbar-track { background:#e2ecf5; }
    ::-webkit-scrollbar-thumb { background:linear-gradient(145deg,#083d5d,#1f6991); border-radius:10px; }
    ::-webkit-scrollbar-thumb:hover { background:var(--accent); }

    /* ══════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════ */
    @media (max-width:768px) {
      body { padding-top:90px; }
      .top-header { display:none; }
      .menu-icon { display:flex; }
      .nav { height:auto; padding:10px 20px; }
      .logo img { height:60px; }

      .menu {
        position:fixed; top:90px; left:0;
        width:100%; height:calc(100vh - 90px);
        background:rgba(255,255,255,.98); backdrop-filter:blur(12px);
        flex-direction:column; align-items:flex-start; justify-content:flex-start;
        display:none; padding:24px 20px 30px; overflow-y:auto;
        z-index:999; transform:translateX(-100%); transition:transform .3s ease;
      }
      .menu.active { display:flex; transform:translateX(0); }
      .upperNav { flex-direction:column; width:100%; gap:10px; margin-bottom:18px; }
      .upperNav .nav-button { width:100%; height:44px; font-size:.95rem; justify-content:center; }
      #certificate { width:100%; }
      .btn-box { width:100%; height:42px; }
      .toggle-btn { font-size:.8rem; }
      .lowerNav { flex-direction:column; width:100%; gap:0; margin-top:6px; }
      .lowerNav ul { flex-direction:column; gap:0; width:100%; }
      .lowerNav li { border-bottom:1px solid #f0f0f0; }
      .menu-link { padding:13px 0; width:100%; font-size:.95rem; }

      /* merger on mobile */
      .merger-section { padding:14px 8px 24px; align-items:flex-start; padding-top:20px; }
      .merger-card { border-radius:16px; }
      .merger-header { padding:14px 16px 12px; }
      .merger-header h2 { font-size:1.2rem; }
      .merger-body { grid-template-columns:1fr; }
      .merger-left { border-right:none; border-bottom:1px solid #e9ecef; padding:14px 16px; }
      .merger-right { padding:14px 16px; }
      .controls-wrapper { flex-direction:column; gap:8px; }
      .canvas-container { min-height:140px; }
      #mergedCanvas { max-height:180px; }
    }

    @media (max-width:480px) {
      .merger-header h2 { font-size:1rem; }
      .action-buttons { flex-direction:column; }
    }

    @media (max-width:992px) { .footer-content { grid-template-columns:repeat(2,1fr); } }
    @media (max-width:600px) {
      .footer-content { grid-template-columns:1fr; text-align:center; }
      .footer-logo { align-items:center; }
      .footer-logo img { margin:0 auto 10px; }
      .contact-info p { justify-content:center; }
      .footer-links ul,.footer-social ul { justify-content:center; }
      .footer-links h3::after,.footer-social h3::after { left:50%; transform:translateX(-50%); }
      .footer-links a { justify-content:center; }
    }
  </style>
</head>

<body>

  <!-- ===== HEADER ===== -->
  <div class="header-container">
    <div class="top-header">
      <div class="web-text">
        <p><span>RID Bharat Run by TWF</span></p>
        <p>Helpline: <span>+91-9202707903</span></p>
        <p>Email: <span>ridorg.in@gmail.com</span></p>
      </div>
      <div class="right-text">
        <a href="#">ISO:9001:2015 Certified</a>
        <a href="#">TWF</a>
        <a href="#">Reg.No:048884</a>
        <a href="#">ESTD:2020</a>
      </div>
    </div>

    <div class="main-header">
      <div class="nav">
        <div class="logo">
          <img src="./assets/final_logo.svg" alt="RID Bharat Logo"
            onerror="this.src='https://via.placeholder.com/260x70/083d5d/FFFFFF?text=RID+Bharat'">
          <div class="menu-icon" id="menuIcon">
            <span></span><span></span><span></span>
          </div>
        </div>

        <div class="menu" id="innerCont">
          <div class="upperNav">
            <a href="/RTS/public/main.html">
              <button class="nav-button" id="onlineTest1">
                <i class="fa-brands fa-servicestack"></i> Test Series
              </button>
            </a>
            <button class="nav-button" style="background:linear-gradient(145deg,#c67534,#a05a20);color:#fff;">
              <i class="fa-solid fa-book"></i> Service
            </button>
            <a href="/Certificate-Verification/verify.html">
              <button class="nav-button" id="certificate">
                <i class="fa-solid fa-certificate"></i> Certificate
              </button>
            </a>
            <!-- FIX: buttons are DIRECT children of .btn-box — no <a> wrappers inside -->
            <div class="btn-box">
              <div id="swap-btn"></div>
              <button class="toggle-btn" id="logInButton" onclick="window.location.href='/login'">
                <i class="fa-solid fa-right-to-bracket"></i> Login
              </button>
              <button class="toggle-btn" id="signUpBtn" onclick="window.location.href='/form'">
                <i class="fa-solid fa-user-plus"></i> Register
              </button>
            </div>
          </div>

