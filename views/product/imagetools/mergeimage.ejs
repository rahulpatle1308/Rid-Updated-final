  <!-- ===== SCRIPTS ===== -->
  <script>
  /* ── Hamburger ── */
  (function(){
    var icon = document.getElementById('menuIcon');
    var menu = document.getElementById('innerCont');
    if(!icon) return;
    icon.addEventListener('click', function(e){
      e.stopPropagation();
      icon.classList.toggle('active');
      menu.classList.toggle('active');
    });
    document.addEventListener('click', function(e){
      if(!menu.contains(e.target) && !icon.contains(e.target)){
        icon.classList.remove('active');
        menu.classList.remove('active');
      }
    });
  })();

  /* ── Login / Register pill ── */
  (function(){
    var loginBtn = document.getElementById('logInButton');
    var regBtn   = document.getElementById('signUpBtn');
    var slider   = document.getElementById('swap-btn');
    if(!loginBtn||!regBtn||!slider) return;
    loginBtn.addEventListener('mousedown', function(){
      slider.style.left    = '0%';
      loginBtn.style.color = '#fff';
      regBtn.style.color   = '#333';
    });
    regBtn.addEventListener('mousedown', function(){
      slider.style.left   = '50%';
      regBtn.style.color  = '#fff';
      loginBtn.style.color = '#333';
    });
  })();

  /* ── Image Merger ── */
  (function(){
    var fileInput    = document.getElementById('fileInput');
    var addMoreInput = document.getElementById('addMoreInput');
    var uploadZone   = document.getElementById('uploadZone');
    var filesGrid    = document.getElementById('filesGridContainer');
    var fileCount    = document.getElementById('fileCountDisplay');
    var clearBtn     = document.getElementById('clearAllButton');
    var mergeBtn     = document.getElementById('mergeButton');
    var mergeSpinner = document.getElementById('mergeSpinner');
    var mergeBtnText = document.getElementById('mergeBtnText');
    var dlBtn        = document.getElementById('downloadButton');
    var canvas       = document.getElementById('mergedCanvas');
    var placeholder  = document.getElementById('previewPlaceholder');
    var dimLabel     = document.getElementById('dimensionLabel');
    var dirRadios    = document.getElementsByName('direction');
    var fmtRadios    = document.getElementsByName('format');

    var files = [];
    var mergedBlob = null;
    var toastTimer = null;

    /* toast */
    function toast(msg){
      var el = document.querySelector('.success-toast');
      if(!el){ el = document.createElement('div'); el.className='success-toast'; document.body.appendChild(el); }
      el.textContent = msg; el.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function(){ el.classList.remove('show'); }, 2000);
    }

    function fmtBytes(b){
      if(b<1024) return b+' B';
      if(b<1048576) return (b/1024).toFixed(1)+' KB';
      return (b/1048576).toFixed(2)+' MB';
    }

    function render(){
      fileCount.textContent = files.length;
      mergeBtn.disabled = files.length < 2;
      if(!files.length){
        filesGrid.innerHTML = '<div class="empty-message">No images selected. Add 2 or more.</div>';
        return;
      }
      filesGrid.innerHTML = '';
      files.forEach(function(f,i){
        var item = document.createElement('div');
        item.className = 'file-item-card';
        var thumb = document.createElement('div'); thumb.className='file-icon-small';
        var img = document.createElement('img');
        var url = URL.createObjectURL(f);
        img.src = url; img.onload = function(){ URL.revokeObjectURL(url); };
        thumb.appendChild(img);
        var info = document.createElement('div'); info.className='file-info-text';
        info.innerHTML='<div class="file-name-text">'+(f.name.length>22?f.name.slice(0,19)+'…':f.name)+'</div><div class="file-size-text">'+fmtBytes(f.size)+'</div>';
        var del = document.createElement('button'); del.className='remove-single-btn'; del.textContent='✕';
        del.addEventListener('click',(function(idx){ return function(){ removeAt(idx); }; })(i));
        item.appendChild(thumb); item.appendChild(info); item.appendChild(del);
        filesGrid.appendChild(item);
      });
    }

    function removeAt(i){
      files.splice(i,1); mergedBlob=null; dlBtn.disabled=true; resetPreview(); render();
      if(files.length) toast('Image removed');
    }

    function resetPreview(){
      var ctx = canvas.getContext('2d');
      ctx.clearRect(0,0,canvas.width,canvas.height);
      canvas.width=0; canvas.height=0;
      placeholder.classList.remove('hidden');
      dimLabel.textContent='—'; mergedBlob=null; dlBtn.disabled=true;
    }

    function addFiles(incoming){
      var arr = Array.from(incoming).filter(function(f){ return f.type.startsWith('image/'); });
      if(!arr.length) return;
      var added=0;
      arr.forEach(function(f){
        if(!files.some(function(e){ return e.name===f.name&&e.size===f.size; })){ files.push(f); added++; }
      });
      if(added){ render(); resetPreview(); toast(added+' image'+(added>1?'s':'')+' added'); }
    }

    /* file inputs */
    fileInput.addEventListener('change',function(){ if(this.files.length) addFiles(this.files); this.value=''; });
    addMoreInput.addEventListener('change',function(){ if(this.files.length) addFiles(this.files); this.value=''; });

    /* drag & drop */
    ['dragover','dragenter'].forEach(function(ev){
      uploadZone.addEventListener(ev,function(e){ e.preventDefault(); uploadZone.classList.add('dragover'); });
    });
    ['dragleave','drop'].forEach(function(ev){
      uploadZone.addEventListener(ev,function(e){
        e.preventDefault(); uploadZone.classList.remove('dragover');
        if(ev==='drop'&&e.dataTransfer.files.length) addFiles(e.dataTransfer.files);
      });
    });

    /* clear */
    clearBtn.addEventListener('click',function(){
      if(!files.length) return;
      files=[]; mergedBlob=null; render(); resetPreview(); toast('All cleared');
    });

    /* merge */
    mergeBtn.addEventListener('click',async function(){
      if(files.length<2){ toast('Need at least 2 images!'); return; }
      mergeBtn.disabled=true;
      mergeSpinner.style.display='inline-block';
      mergeBtnText.textContent='Merging…';
      try {
        var dir = Array.from(dirRadios).find(function(r){ return r.checked; }).value;
        var fmt = Array.from(fmtRadios).find(function(r){ return r.checked; }).value;
        var imgs = await Promise.all(files.map(function(f){
          return new Promise(function(res,rej){
            var r=new FileReader();
            r.onload=function(ev){ var im=new Image(); im.onload=function(){ res(im); }; im.onerror=rej; im.src=ev.target.result; };
            r.onerror=rej; r.readAsDataURL(f);
          });
        }));
        var ctx = canvas.getContext('2d');
        if(dir==='horizontal'){
          var maxH=Math.max.apply(null,imgs.map(function(im){ return im.height; }));
          var sc=imgs.map(function(im){ var s=maxH/im.height; return {im:im,w:Math.round(im.width*s),h:maxH}; });
          canvas.width=sc.reduce(function(a,b){ return a+b.w; },0); canvas.height=maxH;
          ctx.fillStyle='#fff'; ctx.fillRect(0,0,canvas.width,canvas.height);
          var x=0; sc.forEach(function(s){ ctx.drawImage(s.im,x,0,s.w,s.h); x+=s.w; });
        } else {
          var maxW=Math.max.apply(null,imgs.map(function(im){ return im.width; }));
          var scv=imgs.map(function(im){ var s=maxW/im.width; return {im:im,w:maxW,h:Math.round(im.height*s)}; });
          canvas.height=scv.reduce(function(a,b){ return a+b.h; },0); canvas.width=maxW;
          ctx.fillStyle='#fff'; ctx.fillRect(0,0,canvas.width,canvas.height);
          var y=0; scv.forEach(function(s){ ctx.drawImage(s.im,0,y,s.w,s.h); y+=s.h; });
        }
        dimLabel.textContent=canvas.width+'×'+canvas.height;
        placeholder.classList.add('hidden');
        canvas.toBlob(function(blob){
          mergedBlob=blob; dlBtn.disabled=false; toast('✅ Merged successfully!');
        },'image/'+fmt,0.92);
      } catch(err){ toast('Error: '+err.message); }
      finally {
        mergeBtn.disabled=files.length<2;
        mergeSpinner.style.display='none';
        mergeBtnText.textContent='🔄 Merge Images';
      }
    });

    /* download */
    dlBtn.addEventListener('click',function(){
      if(!mergedBlob) return;
      var fmt=Array.from(fmtRadios).find(function(r){ return r.checked; }).value;
      var a=document.createElement('a'); var url=URL.createObjectURL(mergedBlob);
      a.href=url; a.download='merged-'+Date.now()+'.'+(fmt==='png'?'png':'jpg');
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      setTimeout(function(){ URL.revokeObjectURL(url); },400);
      toast('⬇ Download started!');
    });

    render(); resetPreview();
  })();
  </script>
