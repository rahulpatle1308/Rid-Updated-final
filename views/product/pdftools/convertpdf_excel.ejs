    // ========== PDF TO EXCEL LOGIC (unchanged) ==========
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
    
    let currentFile = null;
    let extractedData = [];
    let isProcessing = false;
    
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('fileInput');
    const fileInfo = document.getElementById('fileInfo');
    const fileName = document.getElementById('fileName');
    const convertBtn = document.getElementById('convertBtn');
    const previewContainer = document.getElementById('previewContainer');
    const rowCountSpan = document.getElementById('rowCount');
    const colCountSpan = document.getElementById('colCount');
    const errorMsg = document.getElementById('errorMsg');
    
    function showError(message) {
      errorMsg.textContent = message;
      errorMsg.style.display = 'block';
      setTimeout(() => {
        errorMsg.style.display = 'none';
      }, 4000);
    }
    
    // Exact line by line extraction
    async function extractPDFLineByLine(file) {
      try {
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        const totalPages = pdf.numPages;
        let allLines = [];
        
        for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
          const page = await pdf.getPage(pageNum);
          const textContent = await page.getTextContent();
          
          const rowsMap = new Map();
          
          for (let item of textContent.items) {
            if (!item.str || item.str.trim() === '') continue;
            
            let y = item.transform ? item.transform[5] : 0;
            let roundedY = Math.round(y / 3) * 3;
            
            if (!rowsMap.has(roundedY)) {
              rowsMap.set(roundedY, []);
            }
            
            rowsMap.get(roundedY).push({
              text: item.str,
              x: item.transform ? item.transform[4] : 0
            });
          }
          
          const sortedRows = Array.from(rowsMap.keys()).sort((a, b) => b - a);
          
          for (let rowY of sortedRows) {
            const items = rowsMap.get(rowY);
            items.sort((a, b) => a.x - b.x);
            
            const columns = [];
            let currentColumn = [];
            let lastX = null;
            
            for (let item of items) {
              if (lastX === null || (item.x - lastX) < 25) {
                currentColumn.push(item.text);
              } else {
                columns.push(currentColumn.join(' '));
                currentColumn = [item.text];
              }
              lastX = item.x;
            }
            
            if (currentColumn.length > 0) {
              columns.push(currentColumn.join(' '));
            }
            
            if (columns.length > 0 && columns.some(c => c.trim().length > 0)) {
              allLines.push(columns);
            }
          }
        }
        
        // Fallback if no structured lines
        if (allLines.length < 3) {
          let rawText = '';
          for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
            const page = await pdf.getPage(pageNum);
            const textContent = await page.getTextContent();
            const pageText = textContent.items.map(item => item.str).join(' ');
            rawText += pageText + '\n';
          }
          
          const textLines = rawText.split(/\r?\n/);
          for (let line of textLines) {
            if (line.trim().length > 0) {
              allLines.push([line.trim()]);
            }
          }
        }
        
        const maxCols = Math.max(...allLines.map(row => row.length), 1);
        const normalizedData = allLines.map(row => {
          const newRow = [...row];
          while (newRow.length < maxCols) newRow.push('');
          return newRow;
        });
        
        return normalizedData;
        
      } catch (error) {
        console.error('PDF parsing error:', error);
        throw new Error('Failed to parse PDF');
      }
    }
    
    function renderPreview(data) {
      if (!data || data.length === 0) {
        previewContainer.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-exclamation-circle"></i>
            <p style="font-size: 12px;">No data extracted</p>
          </div>
        `;
        rowCountSpan.textContent = 'Rows: 0';
        colCountSpan.textContent = 'Cols: 0';
        return;
      }
      
      const maxPreviewRows = 70;
      const previewRows = data.slice(0, maxPreviewRows);
      const maxCols = Math.max(...data.map(row => row.length), 1);
      
      rowCountSpan.textContent = `Rows: ${data.length}`;
      colCountSpan.textContent = `Cols: ${maxCols}`;
      
      let html = '<table class="data-table"><thead> transduction';
      for (let i = 0; i < Math.min(maxCols, 10); i++) {
        html += `<th>${getColumnLetter(i)}</th>`;
      }
      if (maxCols > 10) html += `<th>...</th>`;
      html += '</thead><tbody>';
      
      for (let i = 0; i < previewRows.length; i++) {
        html += ' transduction';
        for (let j = 0; j < Math.min(maxCols, 10); j++) {
          let cellValue = previewRows[i][j] || '';
          let displayValue = cellValue.length > 60 ? cellValue.substring(0, 57) + '...' : cellValue;
          html += `<td title="${escapeHtml(cellValue)}">${escapeHtml(displayValue)}</td>`;
        }
        if (maxCols > 10) html += '<td>...</td>';
        html += '</tr>';
      }
      
      html += '</tbody></table>';
      
      if (data.length > maxPreviewRows) {
        html += `<div style="text-align: center; padding: 8px; background: #f8fafc; margin-top: 10px; border-radius: 10px; font-size: 10px; color: #64748b;">
          <i class="fas fa-eye"></i> Showing ${maxPreviewRows} of ${data.length} rows
        </div>`;
      }
      
      previewContainer.innerHTML = html;
    }
    
    function getColumnLetter(index) {
      let letter = '';
      while (index >= 0) {
        letter = String.fromCharCode(65 + (index % 26)) + letter;
        index = Math.floor(index / 26) - 1;
      }
      return letter;
    }
    
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }
    
    function exportToExcel(data, filename) {
      if (!data || data.length === 0) {
        showError('No data to export');
        return false;
      }
      
      const maxCols = Math.max(...data.map(row => row.length), 1);
      const wsData = [];
      
      for (let row of data) {
        const excelRow = [];
        for (let i = 0; i < maxCols; i++) {
          excelRow.push(i < row.length ? row[i] : '');
        }
        wsData.push(excelRow);
      }
      
      const worksheet = XLSX.utils.aoa_to_sheet(wsData);
      
      const colWidths = [];
      for (let i = 0; i < maxCols; i++) {
        let maxLen = 8;
        for (let j = 0; j < Math.min(wsData.length, 300); j++) {
          let cellValue = wsData[j][i] || '';
          let cellLen = String(cellValue).length;
          if (cellLen > maxLen && cellLen < 80) {
            maxLen = Math.min(cellLen + 2, 50);
          }
        }
        colWidths.push({ wch: maxLen });
      }
      worksheet['!cols'] = colWidths;
      
      const workbook = XLSX.utils.book_new();
      const sheetName = (filename.replace(/\.pdf$/i, '').substring(0, 31) || 'PDF_Data');
      XLSX.utils.book_append_sheet(workbook, worksheet, sheetName);
      
      const outputName = filename.replace(/\.pdf$/i, '') + '_extract.xlsx';
      XLSX.writeFile(workbook, outputName);
      
      return true;
    }
    
    async function convertPDF() {
      if (!currentFile) {
        showError('Please select a PDF file');
        return;
      }
      
      if (isProcessing) return;
      isProcessing = true;
      
      const originalText = convertBtn.innerHTML;
      convertBtn.innerHTML = '<span class="loading-spinner"></span> Processing...';
      convertBtn.disabled = true;
      
      try {
        const data = await extractPDFLineByLine(currentFile);
        extractedData = data;
        renderPreview(extractedData);
        
        const success = exportToExcel(extractedData, currentFile.name);
        
        if (success) {
          convertBtn.innerHTML = '<i class="fas fa-check"></i> Done!';
          setTimeout(() => {
            if (convertBtn) convertBtn.innerHTML = originalText;
          }, 1500);
        }
        
      } catch (error) {
        console.error('Conversion error:', error);
        showError(error.message || 'Conversion failed');
        renderPreview([]);
      } finally {
        isProcessing = false;
        convertBtn.innerHTML = originalText;
        convertBtn.disabled = false;
      }
    }
    
    async function handleFile(file) {
      if (!file || file.type !== 'application/pdf') {
        showError('Please select a PDF file');
        return false;
      }
      
      currentFile = file;
      fileName.textContent = file.name.length > 42 ? file.name.substring(0, 39) + '...' : file.name;
      fileInfo.style.display = 'block';
      
      previewContainer.innerHTML = `
        <div class="empty-state">
          <div class="loading-spinner" style="border-color: #6366f1; border-top-color: transparent; width: 28px; height: 28px; margin: 0 auto 10px;"></div>
          <p style="font-size: 12px;">Extracting lines...</p>
        </div>
      `;
      
      try {
        const data = await extractPDFLineByLine(file);
        extractedData = data;
        renderPreview(extractedData);
        return true;
      } catch (error) {
        console.error('Preview error:', error);
        showError('Preview failed, but you can convert');
        previewContainer.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-file-pdf"></i>
            <p style="font-size: 12px;">Ready to convert</p>
          </div>
        `;
        return false;
      }
    }
    
    dropzone.addEventListener('click', () => fileInput.click());
    
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.style.borderColor = '#6366f1';
      dropzone.style.background = '#f5f3ff';
    });
    
    dropzone.addEventListener('dragleave', () => {
      dropzone.style.borderColor = '#cbd5e1';
      dropzone.style.background = '#fefefe';
    });
    
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.style.borderColor = '#cbd5e1';
      dropzone.style.background = '#fefefe';
      const files = e.dataTransfer.files;
      if (files.length > 0) handleFile(files[0]);
    });
    
    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) handleFile(e.target.files[0]);
    });
    
    convertBtn.addEventListener('click', convertPDF);
  </script>
