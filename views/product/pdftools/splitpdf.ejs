  <script>
    // ========== HEADER MENU TOGGLE (mobile) ==========
    (function () {
      const menuIcon = document.getElementById('menuIcon');
      const menu = document.getElementById('innerCont');
      if (menuIcon) {
        menuIcon.addEventListener('click', function (e) {
          e.stopPropagation();
          this.classList.toggle('active');
          menu.classList.toggle('active');
        });
      }

      const loginBtn = document.getElementById("logInButton");
      const registerBtn = document.getElementById("signUpBtn");
      const swapBtn = document.getElementById("swap-btn");
      if (loginBtn && registerBtn && swapBtn) {
        loginBtn.addEventListener("click", function () {
          swapBtn.style.left = "0%";
          loginBtn.style.color = "white";
          registerBtn.style.color = "#000";
        });
        registerBtn.addEventListener("click", function () {
          swapBtn.style.left = "50%";
          registerBtn.style.color = "white";
          loginBtn.style.color = "#000";
        });
      }
    })();

    // ========== SPLIT PDF LOGIC ==========
    const fileInput = document.getElementById('pdfFile');
    const fileInfo = document.getElementById('fileInfo');
    const pageCountDisplay = document.getElementById('pageCountDisplay');
    const controlsDiv = document.getElementById('controls');
    const startPageInput = document.getElementById('startPage');
    const endPageInput = document.getElementById('endPage');
    const extractBtn = document.getElementById('extractBtn');
    const splitAllBtn = document.getElementById('splitAllBtn');
    const clearBtn = document.getElementById('clearBtn');
    const statusMsg = document.getElementById('statusMsg');

    let pdfBytes = null;          // store original PDF bytes
    let totalPages = 0;
    let fileName = '';

    // Helper: load PDF from file
    async function loadPDF(file) {
      const arrayBuffer = await file.arrayBuffer();
      const pdfDoc = await PDFLib.PDFDocument.load(arrayBuffer);
      totalPages = pdfDoc.getPageCount();
      return { pdfDoc, arrayBuffer };
    }

    // Extract a range of pages
    async function extractPages(start, end) {
      if (!pdfBytes) throw new Error('No PDF loaded');
      const srcDoc = await PDFLib.PDFDocument.load(pdfBytes);
      const newDoc = await PDFLib.PDFDocument.create();
      const pageIndices = [];
      for (let i = start - 1; i < end; i++) {
        pageIndices.push(i);
      }
      const pages = await newDoc.copyPages(srcDoc, pageIndices);
      pages.forEach(page => newDoc.addPage(page));
      const newPdfBytes = await newDoc.save();
      return newPdfBytes;
    }

    // Split all pages: returns array of { blob, name }
    async function splitAllPages() {
      if (!pdfBytes) throw new Error('No PDF loaded');
      const srcDoc = await PDFLib.PDFDocument.load(pdfBytes);
      const results = [];
      for (let i = 0; i < totalPages; i++) {
        const newDoc = await PDFLib.PDFDocument.create();
        const [page] = await newDoc.copyPages(srcDoc, [i]);
        newDoc.addPage(page);
        const pageBytes = await newDoc.save();
        const blob = new Blob([pageBytes], { type: 'application/pdf' });
        results.push({
          blob,
          name: `${fileName.replace(/\.pdf$/i, '')}_page_${i+1}.pdf`
        });
      }
      return results;
    }

    // Download a single PDF blob
    function downloadPDF(blob, filename) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }

    // Download zip of multiple PDFs
    async function downloadZip(files) {
      const zip = new JSZip();
      for (const file of files) {
        zip.file(file.name, file.blob);
      }
      const zipBlob = await zip.generateAsync({ type: 'blob' });
      const url = URL.createObjectURL(zipBlob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${fileName.replace(/\.pdf$/i, '')}_split_pages.zip`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }

    // Handle file selection
    fileInput.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      if (file.type !== 'application/pdf') {
        statusMsg.innerText = 'Please select a valid PDF file.';
        resetUI();
        return;
      }
      fileName = file.name;
      fileInfo.innerHTML = `<i class="fas fa-file-pdf"></i> ${file.name} (${(file.size/1024).toFixed(2)} KB)`;
      statusMsg.innerText = 'Loading PDF...';
      try {
        const arrayBuffer = await file.arrayBuffer();
        pdfBytes = arrayBuffer;
        const pdfDoc = await PDFLib.PDFDocument.load(pdfBytes);
        totalPages = pdfDoc.getPageCount();
        pageCountDisplay.innerText = `Total pages: ${totalPages}`;
        startPageInput.max = totalPages;
        endPageInput.max = totalPages;
        startPageInput.value = 1;
        endPageInput.value = totalPages;
        controlsDiv.style.display = 'block';
        statusMsg.innerText = `PDF loaded (${totalPages} pages). Ready to split.`;
      } catch (err) {
        console.error(err);
        statusMsg.innerText = 'Error loading PDF. File may be corrupted.';
        resetUI();
      }
    });

    function resetUI() {
      pdfBytes = null;
      totalPages = 0;
      fileInfo.innerHTML = '';
      pageCountDisplay.innerText = '';
      controlsDiv.style.display = 'none';
      statusMsg.innerText = 'Ready. Select a PDF file.';
    }

    // Extract range
    extractBtn.addEventListener('click', async () => {
      if (!pdfBytes) {
        statusMsg.innerText = 'No PDF loaded.';
        return;
      }
      let start = parseInt(startPageInput.value);
      let end = parseInt(endPageInput.value);
      if (isNaN(start)) start = 1;
      if (isNaN(end)) end = totalPages;
      if (start < 1) start = 1;
      if (end > totalPages) end = totalPages;
      if (start > end) [start, end] = [end, start];
      if (start < 1 || end > totalPages) {
        statusMsg.innerText = `Please enter a valid range (1-${totalPages}).`;
        return;
      }
      statusMsg.innerText = `Extracting pages ${start} to ${end}...`;
      extractBtn.disabled = true;
      try {
        const newPdfBytes = await extractPages(start, end);
        const blob = new Blob([newPdfBytes], { type: 'application/pdf' });
        downloadPDF(blob, `${fileName.replace(/\.pdf$/i, '')}_pages_${start}-${end}.pdf`);
        statusMsg.innerText = `Extracted pages ${start}-${end} and downloaded.`;
      } catch (err) {
        console.error(err);
        statusMsg.innerText = 'Error extracting pages.';
      } finally {
        extractBtn.disabled = false;
      }
    });

    // Split all pages
    splitAllBtn.addEventListener('click', async () => {
      if (!pdfBytes) {
        statusMsg.innerText = 'No PDF loaded.';
        return;
      }
      statusMsg.innerText = `Splitting ${totalPages} pages... This may take a moment.`;
      splitAllBtn.disabled = true;
      try {
        const files = await splitAllPages();
        if (files.length === 1) {
          // Single page: download directly
          downloadPDF(files[0].blob, files[0].name);
          statusMsg.innerText = 'Single page PDF downloaded.';
        } else {
          await downloadZip(files);
          statusMsg.innerText = `Split into ${files.length} pages and downloaded as ZIP.`;
        }
      } catch (err) {
        console.error(err);
        statusMsg.innerText = 'Error splitting PDF.';
      } finally {
        splitAllBtn.disabled = false;
      }
    });

    clearBtn.addEventListener('click', () => {
      fileInput.value = '';
      resetUI();
    });

    // Drag & drop
    const uploadArea = document.getElementById('uploadArea');
    uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); uploadArea.style.borderColor = '#4da8da'; });
    uploadArea.addEventListener('dragleave', () => { uploadArea.style.borderColor = '#d1dbe8'; });
    uploadArea.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea.style.borderColor = '#d1dbe8';
      const file = e.dataTransfer.files[0];
      if (file && file.type === 'application/pdf') {
        fileInput.files = e.dataTransfer.files;
        fileInput.dispatchEvent(new Event('change'));
      } else {
        statusMsg.innerText = 'Please drop a valid PDF file.';
      }
    });
  </script>
