  color: white;
  text-decoration: none;
  transition: opacity 0.3s;
}

.right-text a:hover {
  opacity: 0.8;
}

.right-text a:not(:last-child)::after {
  content: "|";
  margin: 0 8px;
  color: rgba(255,255,255,0.6);
}

.main-header {
