  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.nav-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(8, 61, 93, 0.3);
}

#certificate {
  background: linear-gradient(135deg, #2e7d32 0%, #1b5e20 100%);
}

.btn-box {
  width: 220px;
  display: flex;
  border-radius: 40px;
  position: relative;
  background: #f0f0f0;
  overflow: hidden;
}

#swap-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: linear-gradient(135deg, var(--primary) 0%, #1e5a7a 100%);
  border-radius: 40px;
  transition: left 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.toggle-btn {
  flex: 1;
  padding: 8px 0;
  border: none;
  background: transparent;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  z-index: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

#logInButton { color: white; }
#signUpBtn { color: #555; }

.lowerNav ul {
  display: flex;
  gap: 28px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.lowerNav li a {
