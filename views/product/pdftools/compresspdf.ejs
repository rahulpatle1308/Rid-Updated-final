<script>
// DOM Elements
const uploadBox = document.getElementById("uploadBox");
const pdfInput = document.getElementById("pdfInput");
const fileInfo = document.getElementById("fileInfo");
const originalSizeSpan = document.getElementById("originalSize");
const statusEl = document.getElementById("status");
const compressedInfo = document.getElementById("compressedInfo");
const compressBtn = document.getElementById("compressBtn");
const qualitySlider = document.getElementById("qualitySlider");
const qualityValue = document.getElementById("qualityValue");

let selectedPdfFile = null;
let originalFileSize = 0;

// Quality slider handler
qualitySlider.addEventListener("input", () => {
  const val = parseInt(qualitySlider.value);
  if (val <= 30) qualityValue.innerText = "Low (Small Size)";
  else if (val <= 70) qualityValue.innerText = "Medium (Balanced)";
  else qualityValue.innerText = "High (Better Quality)";
  
  // Update active badge
  document.querySelectorAll(".compression-badge").forEach(badge => {
    const badgeVal = parseInt(badge.getAttribute("data-value"));
    if (Math.abs(badgeVal - val) <= 20) {
      badge.classList.add("active");
    } else {
      badge.classList.remove("active");
    }
  });
});

// Badge click handlers
document.querySelectorAll(".compression-badge").forEach(badge => {
  badge.addEventListener("click", () => {
    const val = parseInt(badge.getAttribute("data-value"));
    qualitySlider.value = val;
    if (val <= 30) qualityValue.innerText = "Low (Small Size)";
    else if (val <= 70) qualityValue.innerText = "Medium (Balanced)";
    else qualityValue.innerText = "High (Better Quality)";
    
    document.querySelectorAll(".compression-badge").forEach(b => b.classList.remove("active"));
    badge.classList.add("active");
  });
});

// Upload handlers
uploadBox.addEventListener("click", () => pdfInput.click());

uploadBox.addEventListener("dragover", (e) => {
  e.preventDefault();
  uploadBox.style.borderColor = "#4da8da";
  uploadBox.style.background = "#f0f9ff";
});

uploadBox.addEventListener("dragleave", () => {
  uploadBox.style.borderColor = "#cbd5e1";
  uploadBox.style.background = "#fafcff";
});

uploadBox.addEventListener("drop", (e) => {
  e.preventDefault();
  uploadBox.style.borderColor = "#cbd5e1";
  uploadBox.style.background = "#fafcff";
  const files = e.dataTransfer.files;
  if (files.length > 0 && files[0].type === "application/pdf") {
    handleFileSelect(files[0]);
  } else {
    alert("Please drop a valid PDF file");
  }
});

pdfInput.addEventListener("change", (e) => {
  if (pdfInput.files.length > 0) {
    handleFileSelect(pdfInput.files[0]);
  }
});

function handleFileSelect(file) {
  if (file.type !== "application/pdf") {
    alert("Please select a valid PDF file");
    return;
  }
  if (file.size > 50 * 1024 * 1024) {
    alert("File size exceeds 50MB limit");
    return;
  }
  
  selectedPdfFile = file;
  originalFileSize = file.size;
  fileInfo.innerText = file.name;
  const sizeInMB = (file.size / (1024 * 1024)).toFixed(2);
  const sizeInKB = (file.size / 1024).toFixed(1);
  originalSizeSpan.innerText = sizeInMB > 1 ? `${sizeInMB} MB` : `${sizeInKB} KB`;
  statusEl.innerHTML = '<i class="fa-regular fa-circle-check" style="color:#22c55e;"></i> Ready to compress';
  compressedInfo.innerText = "";
}

// Compress PDF function
async function compressPdf(pdfBytes, qualityLevel) {
  // Load the PDF
  const pdfDoc = await PDFLib.PDFDocument.load(pdfBytes);
  
  // Create a new PDF for optimized output
  const newPdf = await PDFLib.PDFDocument.create();
  
  // Copy all pages
  const pages = await newPdf.copyPages(pdfDoc, pdfDoc.getPageIndices());
  pages.forEach(page => newPdf.addPage(page));
  
  // Save with compression options
  // useObjectStreams helps reduce file size
  const compressedBytes = await newPdf.save({
    useObjectStreams: true,
    addDefaultPage: false
  });
  
  return compressedBytes;
}

// Compress button click
compressBtn.addEventListener("click", async () => {
  if (!selectedPdfFile) {
    alert("📄 Please select a PDF file first");
    return;
  }
  
  const originalText = compressBtn.innerHTML;
  compressBtn.innerHTML = '<i class="fa-solid fa-spinner fa-pulse"></i> Compressing PDF...';
  compressBtn.disabled = true;
  statusEl.innerHTML = '<i class="fa-solid fa-spinner fa-pulse"></i> Optimizing PDF structure...';
  
  try {
    const fileArrayBuffer = await selectedPdfFile.arrayBuffer();
    const quality = parseInt(qualitySlider.value);
    
    // Compress the PDF
    const compressedBytes = await compressPdf(fileArrayBuffer, quality);
    
    const compressedSize = compressedBytes.length;
    const sizeReduction = ((originalFileSize - compressedSize) / originalFileSize * 100).toFixed(1);
    const originalMB = (originalFileSize / (1024 * 1024)).toFixed(2);
    const compressedMB = (compressedSize / (1024 * 1024)).toFixed(2);
    
    // Create and download compressed PDF
    const blob = new Blob([compressedBytes], { type: "application/pdf" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    const originalName = selectedPdfFile.name.replace(/\.pdf$/i, "");
    link.download = `${originalName}_compressed.pdf`;
    link.href = url;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    
    // Update status with size reduction info
    let reductionText = "";
    if (sizeReduction > 0) {
      reductionText = `Reduced by ${sizeReduction}% (${originalMB}MB → ${compressedMB}MB)`;
    } else if (sizeReduction < 0) {
      reductionText = `Size increased by ${Math.abs(sizeReduction)}% (already optimized)`;
    } else {
      reductionText = `Size unchanged (${originalMB}MB)`;
    }
    
    statusEl.innerHTML = `<i class="fa-solid fa-check-circle" style="color:#22c55e;"></i> Compressed! ${reductionText}`;
    compressedInfo.innerText = reductionText;
    compressBtn.innerHTML = '<i class="fa-solid fa-check"></i> Compressed Successfully';
    
    setTimeout(() => {
      compressBtn.innerHTML = originalText;
    }, 2500);
    
  } catch (error) {
    console.error("Compression error:", error);
    statusEl.innerHTML = '<i class="fa-solid fa-circle-exclamation" style="color:#ef4444;"></i> Error compressing PDF';
    compressedInfo.innerText = "";
    alert("Failed to compress PDF: " + error.message);
    compressBtn.innerHTML = originalText;
  } finally {
    compressBtn.disabled = false;
  }
});

