}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  text-align: center;
  padding: 20px 0;
  font-size: 0.7rem;
}

.footer-links-bottom {
  display: flex;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
  margin-top: 12px;
}

@media (max-width: 900px) {
  .menu-icon {
