}

/* ===== HEADER STYLES ===== */
.header-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 1000;
  background: transparent;
}

.top-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #062a41 0%, #0a4d6e 100%);
  color: #fff;
  padding: 0 5%;
  height: 38px;
  font-size: 12px;
  flex-wrap: wrap;
}

.web-text {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}

.web-text p {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 500;
  margin: 0;
}

.web-text p span {
  font-weight: 400;
}

.web-text p:not(:last-child)::after {
  content: "|";
  margin: 0 8px;
  color: rgba(255,255,255,0.6);
}

.right-text {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}

.right-text a {
