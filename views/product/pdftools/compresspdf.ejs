}

.menu-icon.active span:nth-child(1) {
  transform: translateY(9px) rotate(45deg);
}
.menu-icon.active span:nth-child(2) {
  opacity: 0;
}
.menu-icon.active span:nth-child(3) {
  transform: translateY(-9px) rotate(-45deg);
}

/* ===== MAIN SECTION - COMPRESS PDF ===== */
.converter-section {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: calc(100vh - 280px);
  margin-top: 135px;
  margin-bottom: 50px;
  padding: 0 20px;
}

.card {
  width: 100%;
  max-width: 750px;
  background: white;
  border-radius: 28px;
  padding: 40px;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.12);
  transition: transform 0.3s;
}

.card-header {
  text-align: center;
  margin-bottom: 30px;
}

.card-header .icon {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}

.card-header .icon i {
  font-size: 40px;
  color: var(--primary);
}

.card-header h2 {
  color: var(--primary);
  font-size: 1.8rem;
  font-weight: 700;
  margin-bottom: 10px;
}

.card-header p {
