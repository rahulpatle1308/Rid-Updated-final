}

@media (max-width: 768px) {
  .top-header {
    display: none;
  }
  .converter-section {
    margin-top: 100px;
  }
  .card {
    padding: 25px;
  }
  .preview-row {
    flex-direction: column;
  }
  .footer-content {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .footer-links h3:after {
    left: 50%;
    transform: translateX(-50%);
  }
  .card-header h2 {
    font-size: 1.4rem;
  }
}
</style>
