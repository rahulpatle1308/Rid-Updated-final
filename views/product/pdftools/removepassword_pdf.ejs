<script>
// DOM Elements
const uploadBox = document.getElementById("uploadBox");
const pdfInput = document.getElementById("pdfInput");
const fileInfo = document.getElementById("fileInfo");
const fileSizeInfo = document.getElementById("fileSizeInfo");
const statusEl = document.getElementById("status");
const removeBtn = document.getElementById("removeBtn");
const passwordInput = document.getElementById("pdfPassword");
const togglePasswordBtn = document.getElementById("togglePasswordBtn");

let selectedPdfFile = null;

// Toggle password visibility
togglePasswordBtn.addEventListener("click", () => {
  const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
  passwordInput.setAttribute("type", type);
  togglePasswordBtn.innerHTML = type === "password" ? '<i class="fa-regular fa-eye"></i>' : '<i class="fa-regular fa-eye-slash"></i>';
});

// Upload box click
uploadBox.addEventListener("click", () => pdfInput.click());

// Drag & drop handlers
uploadBox.addEventListener("dragover", (e) => {
  e.preventDefault();
  uploadBox.style.borderColor = "#4da8da";
  uploadBox.style.background = "#f0f9ff";
});

uploadBox.addEventListener("dragleave", () => {
  uploadBox.style.borderColor = "#cbd5e1";
  uploadBox.style.background = "#fafcff";
});

uploadBox.addEventListener("drop", (e) => {
  e.preventDefault();
  uploadBox.style.borderColor = "#cbd5e1";
  uploadBox.style.background = "#fafcff";
  const files = e.dataTransfer.files;
  if (files.length > 0 && files[0].type === "application/pdf") {
    handleFileSelect(files[0]);
  } else {
    alert("Please drop a valid PDF file");
  }
});

pdfInput.addEventListener("change", (e) => {
  if (pdfInput.files.length > 0) {
    handleFileSelect(pdfInput.files[0]);
  }
});

function handleFileSelect(file) {
  if (file.type !== "application/pdf") {
    alert("Please select a valid PDF file");
    return;
  }
  if (file.size > 50 * 1024 * 1024) {
    alert("File size exceeds 50MB limit");
    return;
  }
  selectedPdfFile = file;
  fileInfo.innerText = file.name;
  const sizeInMB = (file.size / (1024 * 1024)).toFixed(2);
  fileSizeInfo.innerText = `${sizeInMB} MB`;
  statusEl.innerHTML = '<i class="fa-regular fa-circle-check" style="color:#22c55e;"></i> Ready to remove password';
  statusEl.style.color = "#16a34a";
}

// Function to remove password from PDF
async function removePasswordFromPdf(pdfBytes, password) {
  // Load the PDF with the provided password
  const pdfDoc = await PDFLib.PDFDocument.load(pdfBytes, { password: password });
  // Save without encryption - this removes the password protection
  const decryptedBytes = await pdfDoc.save();
  return decryptedBytes;
}

// Remove password button click
removeBtn.addEventListener("click", async () => {
  if (!selectedPdfFile) {
    alert("📄 Please select a PDF file first");
    return;
  }
  
  const password = passwordInput.value.trim();
  if (!password) {
    alert("🔑 Please enter the PDF password to remove protection");
    passwordInput.focus();
    return;
  }
  
  const originalText = removeBtn.innerHTML;
  removeBtn.innerHTML = '<i class="fa-solid fa-spinner fa-pulse"></i> Decrypting PDF...';
  removeBtn.disabled = true;
  statusEl.innerHTML = '<i class="fa-solid fa-spinner fa-pulse"></i> Attempting to remove password...';
  statusEl.style.color = "#f59e0b";
  
  try {
    const fileArrayBuffer = await selectedPdfFile.arrayBuffer();
    
    // Try to decrypt the PDF with the provided password
    const decryptedPdfBytes = await removePasswordFromPdf(fileArrayBuffer, password);
    
    // Create and download the decrypted PDF
    const blob = new Blob([decryptedPdfBytes], { type: "application/pdf" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    const originalName = selectedPdfFile.name.replace(/\.pdf$/i, "");
    link.download = `${originalName}_unlocked.pdf`;
    link.href = url;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    
    statusEl.innerHTML = '<i class="fa-solid fa-circle-check" style="color:#22c55e;"></i> Password removed! File downloaded.';
    statusEl.style.color = "#16a34a";
    removeBtn.innerHTML = '<i class="fa-solid fa-check"></i> Unlocked Successfully';
    
    setTimeout(() => {
      removeBtn.innerHTML = originalText;
    }, 2500);
    
  } catch (error) {
    console.error("Decryption error:", error);
    statusEl.innerHTML = '<i class="fa-solid fa-circle-exclamation" style="color:#ef4444;"></i> Wrong password or file is not password-protected';
    statusEl.style.color = "#dc2626";
    alert("❌ Failed to remove password.\n\nPossible reasons:\n• Incorrect password\n• The PDF is not password-protected\n• The PDF uses unsupported encryption");
    removeBtn.innerHTML = originalText;
  } finally {
    removeBtn.disabled = false;
  }
});

