  <script>
    // ========== HEADER MENU TOGGLE (mobile) ==========
    (function () {
      const menuIcon = document.getElementById('menuIcon');
      const menu = document.getElementById('innerCont');
      if (menuIcon) {
        menuIcon.addEventListener('click', function (e) {
          e.stopPropagation();
          this.classList.toggle('active');
          menu.classList.toggle('active');
        });
      }

      const loginBtn = document.getElementById("logInButton");
      const registerBtn = document.getElementById("signUpBtn");
      const swapBtn = document.getElementById("swap-btn");
      if (loginBtn && registerBtn && swapBtn) {
        loginBtn.addEventListener("click", function () {
          swapBtn.style.left = "0%";
          loginBtn.style.color = "white";
          registerBtn.style.color = "#000";
        });
        registerBtn.addEventListener("click", function () {
          swapBtn.style.left = "50%";
          registerBtn.style.color = "white";
          loginBtn.style.color = "#000";
        });
      }
    })();

    // ========== PDF MERGER LOGIC ==========
    const fileInput = document.getElementById('pdfFiles');
    const fileListArea = document.getElementById('fileListArea');
    const fileItemsContainer = document.getElementById('fileItems');
    const mergeBtn = document.getElementById('mergeBtn');
    const clearBtn = document.getElementById('clearBtn');
    const statusMsg = document.getElementById('statusMsg');
    let selectedFiles = [];

    function updateFileList() {
      if (selectedFiles.length === 0) {
        fileListArea.style.display = 'none';
        mergeBtn.disabled = true;
        statusMsg.innerText = 'Ready. Select PDF files to merge.';
        return;
      }
      fileListArea.style.display = 'block';
      fileItemsContainer.innerHTML = '';
      selectedFiles.forEach((file, index) => {
        const div = document.createElement('div');
        div.className = 'file-item';
        div.innerHTML = `
          <span><i class="fas fa-file-pdf"></i> ${file.name} (${(file.size/1024).toFixed(2)} KB)</span>
          <span class="remove-file" data-index="${index}"><i class="fas fa-times-circle"></i></span>
        `;
        fileItemsContainer.appendChild(div);
      });
      mergeBtn.disabled = false;
      statusMsg.innerText = `${selectedFiles.length} file(s) selected. Click "Merge & Download".`;
      document.querySelectorAll('.remove-file').forEach(el => {
        el.addEventListener('click', (e) => {
          const idx = parseInt(el.dataset.index);
          if (!isNaN(idx)) {
            selectedFiles.splice(idx, 1);
            updateFileList();
          }
        });
      });
    }

    fileInput.addEventListener('change', (e) => {
      const files = Array.from(e.target.files);
      if (files.length === 0) return;
      const invalid = files.filter(f => f.type !== 'application/pdf');
      if (invalid.length > 0) {
        statusMsg.innerText = `Invalid file(s): ${invalid.map(f => f.name).join(', ')}. Only PDF allowed.`;
        return;
      }
      selectedFiles = [...selectedFiles, ...files];
      updateFileList();
      fileInput.value = '';
    });

    clearBtn.addEventListener('click', () => {
      selectedFiles = [];
      updateFileList();
      fileInput.value = '';
      statusMsg.innerText = 'Cleared all files.';
    });

    async function mergePDFs() {
      if (selectedFiles.length === 0) {
        statusMsg.innerText = 'No files to merge.';
        return;
      }
      statusMsg.innerText = 'Merging PDFs... Please wait.';
      mergeBtn.disabled = true;
      try {
        const { PDFDocument } = PDFLib;
        const mergedPdf = await PDFDocument.create();
        for (const file of selectedFiles) {
          const arrayBuffer = await file.arrayBuffer();
          const pdf = await PDFDocument.load(arrayBuffer);
          const pages = await mergedPdf.copyPages(pdf, pdf.getPageIndices());
          pages.forEach(page => mergedPdf.addPage(page));
        }
        const mergedBytes = await mergedPdf.save();
        const blob = new Blob([mergedBytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'merged_document.pdf';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        statusMsg.innerText = 'Merge successful! PDF downloaded.';
      } catch (err) {
        console.error(err);
        statusMsg.innerText = 'Error merging PDFs. Make sure files are valid and not corrupted.';
      } finally {
        mergeBtn.disabled = false;
      }
    }

    mergeBtn.addEventListener('click', mergePDFs);

    // Drag & drop
    const uploadArea = document.getElementById('uploadArea');
    uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); uploadArea.style.borderColor = '#4da8da'; });
    uploadArea.addEventListener('dragleave', () => { uploadArea.style.borderColor = '#d1dbe8'; });
    uploadArea.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea.style.borderColor = '#d1dbe8';
      const files = Array.from(e.dataTransfer.files);
      const pdfFiles = files.filter(f => f.type === 'application/pdf');
      if (pdfFiles.length === 0) {
        statusMsg.innerText = 'Please drop valid PDF files.';
        return;
      }
      selectedFiles = [...selectedFiles, ...pdfFiles];
      updateFileList();
    });
  </script>
