  <script>
    // ========== HEADER / FOOTER INTERACTIONS ==========
    (function () {
      const menuIcon = document.getElementById('menuIcon');
      const menu = document.getElementById('innerCont');
      if (menuIcon) {
        menuIcon.addEventListener('click', function (e) {
          e.stopPropagation();
          this.classList.toggle('active');
          if (menu) menu.classList.toggle('active');
        });
      }

      const loginBtn = document.getElementById("logInButton");
      const registerBtn = document.getElementById("signUpBtn");
      const swapBtn = document.getElementById("swap-btn");
      if (loginBtn && registerBtn && swapBtn) {
        loginBtn.addEventListener("click", function () {
          swapBtn.style.left = "0%";
          loginBtn.style.color = "white";
          registerBtn.style.color = "#000";
        });
        registerBtn.addEventListener("click", function () {
          swapBtn.style.left = "50%";
          registerBtn.style.color = "white";
          loginBtn.style.color = "#000";
        });
      }

      const backToTop = document.querySelector('.back-to-top');
      if (backToTop) {
        backToTop.addEventListener('click', (e) => {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    })();

    // ========== CONVERTER LOGIC ==========
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const browseBtn = document.getElementById('browseBtn');
    const filePreviewCard = document.getElementById('filePreviewCard');
    const fileNameSpan = document.getElementById('fileNameDisplay');
    const fileSizeSpan = document.getElementById('fileSizeDisplay');
    const clearFileBtn = document.getElementById('clearFileBtn');
    const convertBtn = document.getElementById('convertBtn');
    const downloadBtn = document.getElementById('downloadBtn');
    const statusMsgDiv = document.getElementById('statusMsg');

    let selectedFile = null;
    let generatedPdfBlob = null;
    let isConverting = false;

    function updateStatus(message, isError = false, isLoading = false) {
      statusMsgDiv.innerHTML = '';
      if (isLoading) {
        statusMsgDiv.innerHTML = `<div class="spinner"></div><span>${message}</span>`;
      } else {
        const icon = isError ? '<i class="fas fa-exclamation-triangle" style="color:#e53e3e"></i>' : '<i class="fas fa-check-circle" style="color:#10b981"></i>';
        if (!isError && !message.includes('Ready') && !message.includes('success')) {
          statusMsgDiv.innerHTML = `${icon}<span>${message}</span>`;
        } else if (isError) {
          statusMsgDiv.innerHTML = `${icon}<span style="color:#b91c1c">${message}</span>`;
        } else {
          statusMsgDiv.innerHTML = `<i class="fas fa-info-circle" style="color:#3b82f6"></i><span>${message}</span>`;
        }
      }
    }

    function formatFileSize(bytes) {
      if (bytes === 0) return '0 Bytes';
      const k = 1024;
      const sizes = ['Bytes', 'KB', 'MB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
    }

    function resetFileSelection() {
      selectedFile = null;
      generatedPdfBlob = null;
      filePreviewCard.style.display = 'none';
      convertBtn.disabled = true;
      downloadBtn.disabled = true;
      if (fileInput) fileInput.value = '';
      updateStatus('Ready. Upload a .docx file.', false);
    }

    function handleFile(file) {
      if (!file) return;
      if (!file.name.toLowerCase().endsWith('.docx')) {
        updateStatus('Invalid file type. Please select a .docx (Word) document.', true);
        resetFileSelection();
        return;
      }
      if (file.size > 30 * 1024 * 1024) {
        updateStatus('File exceeds 30MB limit. Please choose a smaller document.', true);
        resetFileSelection();
        return;
      }
      selectedFile = file;
      fileNameSpan.innerText = file.name;
      fileSizeSpan.innerText = formatFileSize(file.size);
      filePreviewCard.style.display = 'flex';
      convertBtn.disabled = false;
      downloadBtn.disabled = true;
      generatedPdfBlob = null;
      updateStatus(`File loaded: ${file.name}. Ready to convert.`, false);
    }

    browseBtn.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', (e) => {
      if (e.target.files && e.target.files.length > 0) handleFile(e.target.files[0]);
    });

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });
    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('drag-over');
    });
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      const files = e.dataTransfer.files;
      if (files.length > 0) handleFile(files[0]);
    });
    dropZone.addEventListener('click', (e) => {
      if (e.target === browseBtn || browseBtn.contains(e.target)) return;
      fileInput.click();
    });

    clearFileBtn.addEventListener('click', () => {
      resetFileSelection();
      selectedFile = null;
      generatedPdfBlob = null;
      updateStatus('File cleared. Upload a new .docx', false);
    });

    async function convertDocxToPdf(file) {
      const arrayBuffer = await file.arrayBuffer();
      const mammothOptions = {
        styleMap: [
          "p => p:fresh",
          "strong => b",
          "em => i",
          "u => u",
          "underline => u"
        ]
      };
      let result;
      try {
        result = await mammoth.convertToHtml({ arrayBuffer }, mammothOptions);
      } catch (err) {
        throw new Error(`Mammoth parsing error: ${err.message}`);
      }
      const htmlContent = result.value;
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = htmlContent;

      function extractSegments(node) {
        let segments = [];
        if (node.nodeType === Node.TEXT_NODE) {
          segments.push({ text: node.textContent, bold: false, italic: false, underline: false });
          return segments;
        }
        if (node.nodeType !== Node.ELEMENT_NODE) return segments;
        const isBold = node.tagName === 'B' || node.tagName === 'STRONG';
        const isItalic = node.tagName === 'I' || node.tagName === 'EM';
        const isUnderline = node.tagName === 'U';
        let childSegments = [];
        node.childNodes.forEach(child => {
          childSegments.push(...extractSegments(child));
        });
        if (isBold || isItalic || isUnderline) {
          childSegments = childSegments.map(seg => ({
            ...seg,
            bold: seg.bold || isBold,
            italic: seg.italic || isItalic,
            underline: seg.underline || isUnderline
          }));
        }
        if (node.tagName === 'P' || node.tagName === 'DIV' || node.tagName === 'H1' || node.tagName === 'H2' || node.tagName === 'H3') {
          childSegments.push({ text: '\n', bold: false, italic: false, underline: false });
        } else if (node.tagName === 'BR') {
          childSegments.push({ text: '\n', bold: false, italic: false, underline: false });
        }
        return childSegments;
      }

      let allSegments = [];
      tempDiv.childNodes.forEach(child => {
        allSegments.push(...extractSegments(child));
      });

      let paragraphs = [];
      let currentPara = [];
      for (let seg of allSegments) {
        if (seg.text === '\n') {
          if (currentPara.length > 0) {
            paragraphs.push([...currentPara]);
            currentPara = [];
          }
        } else if (seg.text.trim() !== '' || seg.text === ' ') {
          currentPara.push(seg);
        } else if (seg.text.length > 0 && seg.text.trim() === '' && seg.text.includes(' ')) {
          currentPara.push(seg);
        }
      }
      if (currentPara.length > 0) paragraphs.push(currentPara);
      if (paragraphs.length === 0) {
        const plainText = result.value.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
        paragraphs = [[{ text: plainText, bold: false, italic: false, underline: false }]];
      }

      const { PDFDocument, rgb, StandardFonts } = PDFLib;
      const pdfDoc = await PDFDocument.create();
      let page = pdfDoc.addPage([595.28, 841.89]);
      const { width, height } = page.getSize();
      const fontRegular = await pdfDoc.embedFont(StandardFonts.Helvetica);
      const fontBold = await pdfDoc.embedFont(StandardFonts.HelveticaBold);
      const fontItalic = await pdfDoc.embedFont(StandardFonts.HelveticaOblique);
      const fontBoldItalic = await pdfDoc.embedFont(StandardFonts.HelveticaBoldOblique);
      let yCursor = height - 50;
      const leftMargin = 50;
      const maxWidth = width - 100;
      const lineHeight = 14;
      const fontSize = 11;

      function getFontForSegment(seg) {
        if (seg.bold && seg.italic) return fontBoldItalic;
        if (seg.bold) return fontBold;
        if (seg.italic) return fontItalic;
        return fontRegular;
      }

      function drawParagraph(paragraphSegments, startY) {
        let currentY = startY;
        let currentX = leftMargin;
        let lineSegments = [];
        let lineWidth = 0;
        const flushLine = () => {
          if (lineSegments.length === 0) return false;
          let xOffset = leftMargin;
          for (let seg of lineSegments) {
            const font = getFontForSegment(seg);
            page.drawText(seg.text, { x: xOffset, y: currentY, size: fontSize, font });
            xOffset += font.widthOfTextAtSize(seg.text, fontSize);
          }
          currentY -= lineHeight;
          lineSegments = [];
          lineWidth = 0;
          return true;
        };
        for (let seg of paragraphSegments) {
          let text = seg.text;
          if (!text) continue;
          const font = getFontForSegment(seg);
          let words = text.split(/(\s+)/);
          for (let token of words) {
            if (token === '') continue;
            const tokenWidth = font.widthOfTextAtSize(token, fontSize);
            if (lineWidth + tokenWidth <= maxWidth) {
              lineSegments.push({ ...seg, text: token });
              lineWidth += tokenWidth;
            } else {
              flushLine();
              if (font.widthOfTextAtSize(token, fontSize) > maxWidth) {
                let chars = token.split('');
                let partial = '';
                for (let ch of chars) {
                  let testWidth = font.widthOfTextAtSize(partial + ch, fontSize);
                  if (testWidth <= maxWidth) {
                    partial += ch;
                  } else {
                    if (partial) {
                      lineSegments.push({ ...seg, text: partial });
                      flushLine();
                    }
                    partial = ch;
                  }
                }
                if (partial) {
                  lineSegments.push({ ...seg, text: partial });
                  flushLine();
                }
              } else {
                lineSegments.push({ ...seg, text: token });
                lineWidth = tokenWidth;
              }
            }
          }
        }
        if (lineSegments.length > 0) flushLine();
        return currentY;
      }

      for (let para of paragraphs) {
        if (yCursor < 50) {
          page = pdfDoc.addPage([595.28, 841.89]);
          yCursor = height - 50;
        }
        yCursor = drawParagraph(para, yCursor);
        yCursor -= 6;
        if (yCursor < 40) {
          page = pdfDoc.addPage([595.28, 841.89]);
          yCursor = height - 50;
        }
      }
      const pdfBytes = await pdfDoc.save();
      return new Blob([pdfBytes], { type: 'application/pdf' });
    }

    convertBtn.addEventListener('click', async () => {
      if (!selectedFile) {
        updateStatus('No file selected. Please upload a .docx file.', true);
        return;
      }
      if (isConverting) {
        updateStatus('Conversion already in progress...', false);
        return;
      }
      isConverting = true;
      convertBtn.disabled = true;
      downloadBtn.disabled = true;
      updateStatus('Converting document, please wait...', false, true);
      try {
        const pdfBlob = await convertDocxToPdf(selectedFile);
        generatedPdfBlob = pdfBlob;
        downloadBtn.disabled = false;
        updateStatus(`Conversion successful! PDF ready (${(pdfBlob.size / 1024).toFixed(1)} KB). Click download.`, false);
      } catch (error) {
        console.error(error);
        updateStatus(`Conversion failed: ${error.message || 'Unknown error'}`, true);
        generatedPdfBlob = null;
        downloadBtn.disabled = true;
      } finally {
        isConverting = false;
        convertBtn.disabled = !selectedFile;
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (!generatedPdfBlob) {
        updateStatus('No PDF generated. Please convert first.', true);
        return;
      }
      const originalName = selectedFile ? selectedFile.name.replace(/\.docx$/i, '') : 'document';
      const fileName = `${originalName}_converted.pdf`;
      saveAs(generatedPdfBlob, fileName);
      updateStatus(`Download started: ${fileName}`, false);
    });

    resetFileSelection();
  </script>
