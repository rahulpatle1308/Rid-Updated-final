  <script>
    // ========== HEADER FUNCTIONALITY (mobile menu & toggle) ==========
    (function () {
      const menuIcon = document.getElementById('menuIcon');
      const menu = document.getElementById('innerCont');
      if (menuIcon) {
        menuIcon.addEventListener('click', function (e) {
          e.stopPropagation();
          this.classList.toggle('active');
          menu.classList.toggle('active');
        });
      }

      const loginBtn = document.getElementById("logInButton");
      const registerBtn = document.getElementById("signUpBtn");
      const swapBtn = document.getElementById("swap-btn");
      if (loginBtn && registerBtn && swapBtn) {
        loginBtn.addEventListener("click", function () {
          swapBtn.style.left = "0%";
          loginBtn.style.color = "white";
          registerBtn.style.color = "#000";
        });
        registerBtn.addEventListener("click", function () {
          swapBtn.style.left = "50%";
          registerBtn.style.color = "white";
          loginBtn.style.color = "#000";
        });
      }
    })();

    // ========== WORD COUNTER FUNCTIONALITY ==========
    (function() {
      const textarea = document.getElementById('textInput');
      const wordSpan = document.getElementById('wordCount');
      const charWithSpaceSpan = document.getElementById('charWithSpace');
      const charNoSpaceSpan = document.getElementById('charNoSpace');
      const sentenceSpan = document.getElementById('sentenceCount');
      const paragraphSpan = document.getElementById('paragraphCount');

      function countWords(str) {
        if (!str || str.trim() === '') return 0;
        return str.trim().split(/\s+/).filter(word => word.length > 0).length;
      }

      function countCharactersWithSpaces(str) {
        return str.length;
      }

      function countCharactersWithoutSpaces(str) {
        return str.replace(/\s/g, '').length;
      }

      function countSentences(str) {
        if (!str || str.trim() === '') return 0;
        const rawSentences = str.split(/[.!?]+/);
        return rawSentences.filter(sentence => sentence.trim().length > 0).length;
      }

      function countParagraphs(str) {
        if (!str || str.trim() === '') return 0;
        const blocks = str.split(/\n\s*\n/);
        const valid = blocks.filter(block => block.trim().length > 0);
        return valid.length === 0 && str.trim().length > 0 ? 1 : valid.length;
      }

      function updateAllCounters() {
        const rawText = textarea.value;
        wordSpan.innerText = countWords(rawText);
        charWithSpaceSpan.innerText = countCharactersWithSpaces(rawText);
        charNoSpaceSpan.innerText = countCharactersWithoutSpaces(rawText);
        sentenceSpan.innerText = countSentences(rawText);
        paragraphSpan.innerText = countParagraphs(rawText);
      }

      textarea.addEventListener('input', updateAllCounters);

      document.getElementById('clearBtn').addEventListener('click', () => {
        textarea.value = '';
        updateAllCounters();
        textarea.focus();
      });

      document.getElementById('sampleBtn').addEventListener('click', () => {
        const sample = `✨ Welcome to WordWise — your modern word companion.

This sample shows how the counter works in real-time. It tracks words, characters (with and without spaces), sentences, and paragraphs.

✍️ Did you know? Professional writers often aim for clarity over word count. But it's always fun to see the numbers rise!

Try adding more lines:
- Bullet points count as words.
- Multiple sentences? Yes! They increase sentence count.

Another paragraph begins here. Notice how blank lines separate paragraphs. This is the third paragraph.

Go ahead, edit this text and watch every metric update instantly — no delay, no fuss. Enjoy the modern UI! 🌟`;
        textarea.value = sample;
        updateAllCounters();
        textarea.focus();
      });

      updateAllCounters();
    })();
  </script>
