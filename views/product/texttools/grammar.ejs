<script>
  // ======================== HEADER FIXES + RESPONSIVE MENU ========================
  (function() {
    const menuIcon = document.getElementById('menuIcon');
    const menuPanel = document.getElementById('innerCont');
    const allMenuLinks = document.querySelectorAll('#innerCont a, #innerCont button');
    
    function closeMenu() {
      if (menuPanel && menuIcon) {
        menuPanel.classList.remove('active');
        menuIcon.classList.remove('active');
        document.body.style.overflow = '';
      }
    }
    
    function toggleMenu(e) {
      e.stopPropagation();
      menuPanel.classList.toggle('active');
      menuIcon.classList.toggle('active');
      if (menuPanel.classList.contains('active')) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    }
    
    if (menuIcon) menuIcon.addEventListener('click', toggleMenu);
    
    allMenuLinks.forEach(link => {
      link.addEventListener('click', () => {
        setTimeout(() => closeMenu(), 100);
      });
    });
    
    window.addEventListener('resize', function() {
      if (window.innerWidth > 768 && menuPanel && menuPanel.classList.contains('active')) {
        closeMenu();
      }
    });
  })();

  // Login/Register toggle slider
  const loginBtn = document.getElementById("logInButton");
  const registerBtn = document.getElementById("signUpBtn");
  const swapBtn = document.getElementById("swap-btn");
  if (loginBtn && registerBtn && swapBtn) {
    loginBtn.addEventListener("click", function() {
      swapBtn.style.left = "0%";
      loginBtn.style.color = "white";
      registerBtn.style.color = "#333";
    });
    registerBtn.addEventListener("click", function() {
      swapBtn.style.left = "50%";
      registerBtn.style.color = "white";
      loginBtn.style.color = "#333";
    });
  }

  // ======================== GRAMMAR CHECKER LOGIC ========================
  const inputTextarea = document.getElementById('inputText');
  function updateStats() {
    let text = inputTextarea.value;
    let words = text.trim() ? text.trim().split(/\s+/).length : 0;
    let chars = text.length;
    let sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0).length;
    document.getElementById('wordCount').textContent = words;
    document.getElementById('charCount').textContent = chars;
    document.getElementById('sentenceCount').textContent = sentences;
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function copyToClipboard(text) {
    if (!text || text.trim() === '') { alert('⚠️ Nothing to copy.'); return; }
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(text).then(() => {
        alert('✅ Corrected text copied!');
      }).catch(() => fallbackCopy(text));
    } else { fallbackCopy(text); }
  }
  
  function fallbackCopy(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed'; textarea.style.top = '-9999px';
    document.body.appendChild(textarea);
    textarea.select();
    let success = false;
    try { success = document.execCommand('copy'); } catch(e) { console.warn(e); }
    document.body.removeChild(textarea);
    alert(success ? '✅ Copied to clipboard!' : '❌ Manual copy needed');
  }

  async function checkGrammar() {
    let text = inputTextarea.value;
    if (!text.trim()) {
      document.getElementById('mistakesList').innerHTML = '<div class="no-issues"><i class="fas fa-info-circle"></i><p>Please enter text to analyze</p></div>';
      document.getElementById('correctedSentence').innerHTML = '';
      return;
    }
    document.getElementById('mistakesList').innerHTML = '<div class="no-issues"><i class="fas fa-spinner fa-spin"></i><p>AI is proofreading...</p></div>';
    document.getElementById('correctedSentence').innerHTML = '';
    try {
      const response = await fetch('https://api.languagetool.org/v2/check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ text: text, language: 'en-US', enabledOnly: 'false' })
      });
      const data = await response.json();
      const matches = data.matches || [];
      document.getElementById('liveMistakeCount').textContent = matches.length;
      const mistakesDiv = document.getElementById('mistakesList');
      const correctedDiv = document.getElementById('correctedSentence');
      if (matches.length === 0) {
        mistakesDiv.innerHTML = '<div class="no-issues"><i class="fas fa-check-circle"></i><p>✨ Perfect! No grammar or spelling issues found.</p></div>';
        correctedDiv.innerHTML = '';
      } else {
        let correctedText = text;
        const sortedMatches = [...matches].sort((a, b) => b.offset - a.offset);
        for (let match of sortedMatches) {
          const original = text.substring(match.offset, match.offset + match.length);
          const bestSuggestion = (match.replacements && match.replacements[0]) ? match.replacements[0].value : original;
          if (bestSuggestion !== original) {
            const before = correctedText.substring(0, match.offset);
            const after = correctedText.substring(match.offset + match.length);
            correctedText = before + bestSuggestion + after;
          }
        }
        let mistakesHtml = '';
        matches.forEach(match => {
          const original = text.substring(match.offset, match.offset + match.length);
          const bestSuggestion = (match.replacements && match.replacements[0]) ? match.replacements[0].value : original;
          const message = match.message || 'Grammar suggestion';
          mistakesHtml += `<div class="mistake-card" onclick="applyCorrection('${escapeHtml(bestSuggestion)}', '${escapeHtml(original)}')">
            <div class="mistake-text">❌ ${escapeHtml(original)}</div>
            <div class="correction-text">✅ ${escapeHtml(bestSuggestion)}</div>
            <div class="suggestion">💡 ${escapeHtml(message)} <i class="fas fa-mouse-pointer"></i> Click to apply</div>
          </div>`;
        });
        mistakesDiv.innerHTML = mistakesHtml;
        const finalCorrected = correctedText;
        correctedDiv.innerHTML = `<div class="corrected-sentence"><h4><i class="fas fa-magic"></i> ✨ Corrected Version:</h4><div class="corrected-text">${escapeHtml(finalCorrected)}</div><button class="copy-btn" id="dynamicCopyBtn"><i class="fas fa-copy"></i> Copy Corrected Text</button></div>`;
        const copyBtnElem = document.getElementById('dynamicCopyBtn');
        if (copyBtnElem) copyBtnElem.addEventListener('click', () => copyToClipboard(finalCorrected));
      }
      document.getElementById('resultsBox').scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (error) {
      console.error(error);
      document.getElementById('mistakesList').innerHTML = '<div class="no-issues"><i class="fas fa-exclamation-triangle"></i><p>⚠️ Network error. Please try again later.</p></div>';
    }
  }

  window.applyCorrection = function(correctWord, wrongWord) {
    let current = inputTextarea.value;
    let regex = new RegExp('\\b' + escapeRegex(wrongWord) + '\\b', 'gi');
    let updated = current.replace(regex, correctWord);
    inputTextarea.value = updated;
    updateStats();
    checkGrammar();
  };
  
  function escapeRegex(str) { return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
  
  function clearText() { 
    inputTextarea.value = ''; 
    updateStats(); 
    document.getElementById('mistakesList').innerHTML = '<div class="no-issues"><i class="fas fa-lightbulb"></i><p>Enter text and click "Check Grammar & Spelling"</p></div>'; 
    document.getElementById('correctedSentence').innerHTML = ''; 
    document.getElementById('liveMistakeCount').textContent = '0'; 
  }

  // Voice
  let recognition = null, isListening = false;
  const voiceBtn = document.getElementById('voiceBtn');
  if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    recognition = new SpeechRecognition();
    recognition.lang = 'en-US'; 
    recognition.interimResults = false;
    recognition.onstart = () => { 
      isListening = true; 
      voiceBtn.classList.add('listening'); 
      voiceBtn.innerHTML = '<i class="fas fa-microphone-slash"></i> 🎙️ Listening... Stop'; 
    };
    recognition.onresult = (event) => {
      const transcript = event.results[0][0].transcript;
      inputTextarea.value = inputTextarea.value ? inputTextarea.value + ' ' + transcript : transcript;
      updateStats();
      voiceBtn.classList.remove('listening');
      voiceBtn.innerHTML = '<i class="fas fa-microphone"></i> 🎤 Voice Input';
      isListening = false;
    };
    recognition.onerror = () => { 
      alert('Voice error. Check mic.'); 
      voiceBtn.classList.remove('listening'); 
      voiceBtn.innerHTML = '<i class="fas fa-microphone"></i> 🎤 Voice Input'; 
      isListening = false; 
    };
    recognition.onend = () => { 
      if (isListening) { 
        voiceBtn.classList.remove('listening'); 
        voiceBtn.innerHTML = '<i class="fas fa-microphone"></i> 🎤 Voice Input'; 
        isListening = false; 
      } 
    };
    voiceBtn.addEventListener('click', () => { 
      if (isListening) recognition.stop(); 
      else try { recognition.start(); } catch(e){} 
    });
  } else { 
    voiceBtn.disabled = true; 
    voiceBtn.style.opacity = '0.5'; 
    voiceBtn.title = 'Voice not supported'; 
  }

  document.getElementById('checkBtn').addEventListener('click', checkGrammar);
  document.getElementById('clearBtn').addEventListener('click', clearText);
  inputTextarea.addEventListener('input', updateStats);
  inputTextarea.addEventListener('keydown', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); checkGrammar(); } });
  updateStats();
  document.getElementById('mistakesList').innerHTML = '<div class="no-issues"><i class="fas fa-lightbulb"></i><p>Ready. Type or paste text and click "Check Grammar & Spelling".</p></div>';
</script>
</body>
