  <script>
    // ========== HEADER FUNCTIONALITY (mobile menu & toggle) ==========
    (function () {
      const menuIcon = document.getElementById('menuIcon');
      const menu = document.getElementById('innerCont');
      if (menuIcon) {
        menuIcon.addEventListener('click', function (e) {
          e.stopPropagation();
          this.classList.toggle('active');
          menu.classList.toggle('active');
        });
      }

      const loginBtn = document.getElementById("logInButton");
      const registerBtn = document.getElementById("signUpBtn");
      const swapBtn = document.getElementById("swap-btn");
      if (loginBtn && registerBtn && swapBtn) {
        loginBtn.addEventListener("click", function () {
          swapBtn.style.left = "0%";
          loginBtn.style.color = "white";
          registerBtn.style.color = "#000";
        });
        registerBtn.addEventListener("click", function () {
          swapBtn.style.left = "50%";
          registerBtn.style.color = "white";
          loginBtn.style.color = "#000";
        });
      }
    })();

    // ========== HANDWRITING TO TEXT LOGIC ==========
    const canvas = document.getElementById('drawCanvas');
    const ctx = canvas.getContext('2d');
    const brushSize = document.getElementById('brushSize');
    const brushColor = document.getElementById('brushColor');
    const clearCanvasBtn = document.getElementById('clearCanvasBtn');
    const recognizeBtn = document.getElementById('recognizeBtn');
    const outputTextDiv = document.getElementById('outputText');
    const copyTextBtn = document.getElementById('copyTextBtn');
    const statusMsg = document.getElementById('statusMsg');

    // Set canvas dimensions properly (match CSS size but maintain actual pixel resolution)
    function resizeCanvas() {
      const container = canvas.parentElement;
      const maxWidth = Math.min(700, container.clientWidth);
      canvas.style.width = '100%';
      canvas.style.height = 'auto';
      // Set actual canvas dimensions to a fixed size for consistent OCR (500x300)
      canvas.width = 700;
      canvas.height = 300;
      // Re-apply background and stroke style
      ctx.fillStyle = 'white';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.strokeStyle = brushColor.value;
      ctx.lineWidth = brushSize.value;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
    }

    window.addEventListener('resize', () => {
      // Save current drawing before resize? We'll just reinitialize the canvas content (white)
      // Better to redraw from saved image data, but for simplicity we just clear on resize.
      // We'll store drawing data when needed? Actually resize might lose drawing.
      // We'll keep current drawing by converting to image and restoring? But complex.
      // For simplicity, we'll just preserve drawing by saving and restoring image data.
      const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
      resizeCanvas();
      ctx.putImageData(imageData, 0, 0);
    });

    resizeCanvas();

    // Drawing variables
    let drawing = false;

    function getCanvasCoords(e) {
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      let clientX, clientY;
      if (e.touches) {
        clientX = e.touches[0].clientX;
        clientY = e.touches[0].clientY;
      } else {
        clientX = e.clientX;
        clientY = e.clientY;
      }
      let x = (clientX - rect.left) * scaleX;
      let y = (clientY - rect.top) * scaleY;
      x = Math.min(Math.max(0, x), canvas.width);
      y = Math.min(Math.max(0, y), canvas.height);
      return { x, y };
    }

    function startDrawing(e) {
      drawing = true;
      const { x, y } = getCanvasCoords(e);
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(x, y);
      ctx.stroke();
      e.preventDefault();
    }

    function draw(e) {
      if (!drawing) return;
      const { x, y } = getCanvasCoords(e);
      ctx.lineTo(x, y);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(x, y);
      e.preventDefault();
    }

    function stopDrawing() {
      drawing = false;
      ctx.beginPath();
    }

    canvas.addEventListener('mousedown', startDrawing);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDrawing);
    canvas.addEventListener('mouseleave', stopDrawing);
    // Touch events
    canvas.addEventListener('touchstart', startDrawing);
    canvas.addEventListener('touchmove', draw);
    canvas.addEventListener('touchend', stopDrawing);

    // Brush settings
    function updateBrush() {
      ctx.strokeStyle = brushColor.value;
      ctx.lineWidth = brushSize.value;
    }
    brushSize.addEventListener('input', () => {
      ctx.lineWidth = brushSize.value;
    });
    brushColor.addEventListener('input', () => {
      ctx.strokeStyle = brushColor.value;
    });

    // Clear canvas
    clearCanvasBtn.addEventListener('click', () => {
      ctx.fillStyle = 'white';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = 'white'; // reset fill
      outputTextDiv.innerText = 'Click "Convert to Text" after drawing...';
      statusMsg.innerText = 'Canvas cleared. Draw something then click Convert.';
    });

    // Recognize using Tesseract
    recognizeBtn.addEventListener('click', async () => {
      statusMsg.innerText = '🔄 Processing... Please wait (OCR may take a few seconds).';
      outputTextDiv.innerText = 'Recognizing...';
      try {
        // Get image data from canvas
        const imageData = canvas.toDataURL('image/png');
        // Use Tesseract
        const worker = await Tesseract.createWorker('eng');
        await worker.loadLanguage('eng');
        await worker.initialize('eng');
        const { data: { text } } = await worker.recognize(imageData);
        await worker.terminate();
        if (text.trim() === '') {
          outputTextDiv.innerText = 'No text recognized. Try writing clearer, larger letters.';
          statusMsg.innerText = 'No text detected. Please draw clearly and try again.';
        } else {
          outputTextDiv.innerText = text;
          statusMsg.innerText = '✅ Text recognized successfully!';
        }
      } catch (error) {
        console.error(error);
        outputTextDiv.innerText = 'Error during recognition. Check console.';
        statusMsg.innerText = '❌ OCR failed. Make sure you are connected to the internet (Tesseract loads models).';
      }
    });

    // Copy recognized text
    copyTextBtn.addEventListener('click', async () => {
      const text = outputTextDiv.innerText;
      if (text === 'Click "Convert to Text" after drawing...' || text === 'Recognizing...' || text.includes('No text recognized')) {
        statusMsg.innerText = 'Nothing to copy. Convert text first.';
        setTimeout(() => {
          if (statusMsg.innerText === 'Nothing to copy. Convert text first.') {
            statusMsg.innerText = 'Ready. Draw something then click Convert.';
          }
        }, 2000);
        return;
      }
      try {
        await navigator.clipboard.writeText(text);
        statusMsg.innerText = '✅ Copied to clipboard!';
        setTimeout(() => {
          if (statusMsg.innerText === '✅ Copied to clipboard!') {
            statusMsg.innerText = 'Ready. Draw something then click Convert.';
          }
        }, 2000);
      } catch (err) {
        statusMsg.innerText = '❌ Failed to copy.';
      }
    });

    // Initial brush style
    updateBrush();
  </script>
