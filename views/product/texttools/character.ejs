  <script>
    (function() {
      // Mobile menu toggle
      const menuIcon = document.getElementById('menuIcon');
      const menu = document.getElementById('innerCont');
      if (menuIcon && menu) {
        menuIcon.addEventListener('click', function(e) {
          e.stopPropagation();
          this.classList.toggle('active');
          menu.classList.toggle('active');
        });
        // Close menu when clicking on any menu link
        const allLinks = menu.querySelectorAll('a');
        allLinks.forEach(link => {
          link.addEventListener('click', () => {
            menuIcon.classList.remove('active');
            menu.classList.remove('active');
          });
        });
      }

      // Login/Register slide effect
      const loginBtn = document.getElementById("logInButton");
      const registerBtn = document.getElementById("signUpBtn");
      const swapBtn = document.getElementById("swap-btn");
      if (loginBtn && registerBtn && swapBtn) {
        loginBtn.addEventListener("click", function() {
          swapBtn.style.left = "0%";
          loginBtn.style.color = "white";
          registerBtn.style.color = "#000";
        });
        registerBtn.addEventListener("click", function() {
          swapBtn.style.left = "50%";
          registerBtn.style.color = "white";
          loginBtn.style.color = "#000";
        });
      }

      // Adjust main content spacing based on header height
      const mainArea = document.getElementById('mainContentArea');
      const headerContainer = document.querySelector('.header-container');
      function adjustSpacing() {
        if (!headerContainer || !mainArea) return;
        const headerHeight = headerContainer.offsetHeight;
        mainArea.style.marginTop = headerHeight + 'px';
      }
      window.addEventListener('load', adjustSpacing);
      window.addEventListener('resize', adjustSpacing);

      // Character Counter logic
      const textarea = document.getElementById('textInput');
      const totalCharsSpan = document.getElementById('totalChars');
      const charsNoSpaceSpan = document.getElementById('charsNoSpace');
      const wordCountSpan = document.getElementById('wordCount');
      const lineBreaksSpan = document.getElementById('lineBreaks');
      const spaceCountSpan = document.getElementById('spaceCountDisplay');
      const extraNoteSpan = document.getElementById('extraNote');
      const clearBtn = document.getElementById('clearTextBtn');
      const demoBtn = document.getElementById('demoBtn');

      function animateNumber(element, newValue) {
        const current = parseInt(element.innerText);
        if (current === newValue) return;
        element.style.transform = 'scale(1.07)';
        element.innerText = newValue;
        setTimeout(() => element.style.transform = '', 110);
      }

      function updateCounters() {
        const rawText = textarea.value;
        const totalChars = rawText.length;
        let spaceCount = 0, lineBreakCount = 0;
        for (let ch of rawText) {
          if (ch === ' ') spaceCount++;
          else if (ch === '\n') lineBreakCount++;
        }
        const charsWithoutSpace = totalChars - spaceCount;
        let wordCount = 0;
        if (rawText.trim().length > 0) wordCount = rawText.trim().split(/\s+/).length;
        
        animateNumber(totalCharsSpan, totalChars);
        animateNumber(charsNoSpaceSpan, charsWithoutSpace);
        animateNumber(wordCountSpan, wordCount);
        animateNumber(lineBreaksSpan, lineBreakCount);
        animateNumber(spaceCountSpan, spaceCount);
        
        if (totalChars === 0) extraNoteSpan.innerHTML = '<i class="fas fa-crown"></i> start typing · center mode';
        else if (wordCount === 0 && totalChars > 0) extraNoteSpan.innerHTML = '<i class="fas fa-star-of-life"></i> symbols only · still magic';
        else if (totalChars > 280) extraNoteSpan.innerHTML = '<i class="fas fa-dragon"></i> legendary length!';
        else if (totalChars > 120) extraNoteSpan.innerHTML = '<i class="fas fa-fire"></i> flourishing text!';
        else if (totalChars > 30) extraNoteSpan.innerHTML = '<i class="fas fa-chart-line"></i> realtime analyzer';
        else extraNoteSpan.innerHTML = '<i class="fas fa-feather"></i> crisp & centered';
      }

      function clearText() { textarea.value = ""; updateCounters(); textarea.focus(); }
      function insertSample() {
        textarea.value = `✦ Center Character Counter ✦\n\n• Emojis 🎯✨💎 & special symbols\n• Spaces & line breaks tracked\n• Real-time metrics in compact style\n→ Total chars, words & spaces update live.`;
        updateCounters();
        textarea.focus();
      }

      let updateScheduled = false;
      function scheduleUpdate() {
        if (updateScheduled) return;
        updateScheduled = true;
        requestAnimationFrame(() => { updateCounters(); updateScheduled = false; });
      }
      textarea.addEventListener('input', scheduleUpdate);
      clearBtn.addEventListener('click', clearText);
      demoBtn.addEventListener('click', insertSample);
      
      updateCounters();
      textarea.focus();
    })();
  </script>
