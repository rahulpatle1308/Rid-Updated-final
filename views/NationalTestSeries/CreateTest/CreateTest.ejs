<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>RIDTECH • Create Test Questions</title>
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/Allindiatestserice/CreateTest.css">

</head>

<body>

  <div class="header">
    <div class="header-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" />
      </svg>
    </div>
    <h1>Create Test Questions</h1>
  </div>

  <div class="container">
    <div class="grid">

      <!-- LEFT: Added Questions panel (dark) -->
      <div class="panel">
        <div class="panel-header">
          <div class="panel-header-left">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <line x1="8" y1="6" x2="21" y2="6" />
              <line x1="8" y1="12" x2="21" y2="12" />
              <line x1="8" y1="18" x2="21" y2="18" />
              <line x1="3" y1="6" x2="3.01" y2="6" />
              <line x1="3" y1="12" x2="3.01" y2="12" />
              <line x1="3" y1="18" x2="3.01" y2="18" />
            </svg>
            Added Questions
          </div>
          <span class="count-badge" id="q-count">0</span>
        </div>
        <div class="panel-body">
          <div id="q-list">
            <div class="empty-state" id="empty-msg">
              <div class="empty-icon">?</div>
              No questions added yet. Add your first question below.
            </div>
          </div>
        </div>
        <div class="bottom-bar">
          <button class="btn btn-cancel" id="cancelBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
            Cancel
          </button>
          <button class="btn btn-save" id="saveBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" />
              <polyline points="17 21 17 13 7 13 7 21" />
              <polyline points="7 3 7 8 15 8" />
            </svg>
            Save All
          </button>
        </div>
      </div>

      <!-- RIGHT: Add New Question panel (MCQ + True/False) dark version -->
      <div class="panel">
        <div class="panel-header">
          <div class="panel-header-left" style="color: var(--blue);">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round">
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="16" />
              <line x1="8" y1="12" x2="16" y2="12" />
            </svg>
            Add New Question
          </div>
        </div>

        <div class="panel-body">
          <!-- Type + Marks row -->
          <div class="form-section">
            <div class="field-row">
              <div>
                <label class="field-label">Question Type</label>
                <select class="form-control" id="q-type">
                  <option value="MCQ">Multiple Choice (MCQ)</option>
                  <option value="TF">True / False</option>
                </select>
              </div>
              <div>
                <label class="field-label">Marks</label>
                <input type="number" class="form-control" id="marks" value="1" min="1" max="100">
              </div>
            </div>
          </div>

          <!-- Question Text -->
          <div class="form-section">
            <label class="field-label">Write Your Question</label>
            <textarea class="form-control" id="q-text" placeholder="Type your question here..."></textarea>
          </div>

          <!-- MCQ OPTIONS SECTION -->
          <div id="mcq-section" class="form-section">
            <div class="options-title">Options (MCQ) <span style="font-size:11px;color:var(--text3);">— select radio to
                mark correct</span></div>
            <div class="options-grid" id="options-grid">
              <div class="option-item">
                <input type="radio" name="correct" value="0">
                <input class="opt-input" type="text" placeholder="Option A" id="opt0">
              </div>
              <div class="option-item">
                <input type="radio" name="correct" value="1">
                <input class="opt-input" type="text" placeholder="Option B" id="opt1">
              </div>
              <div class="option-item">
                <input type="radio" name="correct" value="2">
                <input class="opt-input" type="text" placeholder="Option C" id="opt2">
              </div>
              <div class="option-item">
                <input type="radio" name="correct" value="3">
                <input class="opt-input" type="text" placeholder="Option D" id="opt3">
              </div>
            </div>
            <button class="add-more-btn" id="addMoreOptBtn">+ Add More Options</button>
          </div>

          <!-- TRUE/FALSE SECTION -->
          <div id="tf-section" class="form-section" style="display: none;">
            <div class="tf-group">
              <div class="tf-title">Select the correct answer (True / False)</div>
              <div class="tf-options">
                <div class="tf-radio-item">
                  <input type="radio" name="tfCorrect" value="True" id="tfTrue">
                  <label for="tfTrue">✅ True</label>
                </div>
                <div class="tf-radio-item">
                  <input type="radio" name="tfCorrect" value="False" id="tfFalse">
                  <label for="tfFalse">❌ False</label>
                </div>
              </div>
            </div>
          </div>

          <!-- Translate button row -->
          <div class="form-section">
            <div class="translate-row">
              <button class="translate-btn" id="translateBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round">
                  <path d="M5 8l6 6" />
                  <path d="M4 14l6-6 2-3" />
                  <path d="M2 5h12" />
                  <path d="M7 2h1" />
                  <path d="M22 22l-5-10-5 10" />
                  <path d="M14 18h6" />
                </svg>
                Auto Translate
              </button>
            </div>
          </div>

          <!-- Add Question CTA -->
          <button class="add-question-btn" id="addQuestionBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add Question to Test
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    // ---------- STATE ----------
    let questions = [];
    let optCount = 4;

    // DOM elements
    const qTypeSelect = document.getElementById('q-type');
    const mcqSection = document.getElementById('mcq-section');
    const tfSection = document.getElementById('tf-section');
    const optionsGrid = document.getElementById('options-grid');
    const qTextArea = document.getElementById('q-text');
    const marksInput = document.getElementById('marks');
    const addMoreBtn = document.getElementById('addMoreOptBtn');
    const addQuestionBtn = document.getElementById('addQuestionBtn');
    const qListContainer = document.getElementById('q-list');
    const qCountSpan = document.getElementById('q-count');
    const cancelBtn = document.getElementById('cancelBtn');
    const saveBtn = document.getElementById('saveBtn');
    const toastEl = document.getElementById('toast');

    function showToast(msg) {
      toastEl.textContent = msg;
      toastEl.classList.add('show');
      setTimeout(() => toastEl.classList.remove('show'), 2600);
    }

    function toggleQuestionTypeUI() {
      const selectedType = qTypeSelect.value;
      if (selectedType === 'MCQ') {
        mcqSection.style.display = 'block';
        tfSection.style.display = 'none';
      } else {
        mcqSection.style.display = 'none';
        tfSection.style.display = 'block';
      }
    }

    function addMoreOption() {
      if (optCount >= 12) {
        showToast("Maximum 12 options allowed");
        return;
      }
      optCount++;
      const letter = String.fromCharCode(65 + (optCount - 1));
      const div = document.createElement('div');
      div.className = 'option-item';
      div.innerHTML = `
      <input type="radio" name="correct" value="${optCount - 1}">
      <input class="opt-input" type="text" placeholder="Option ${letter}" id="opt${optCount - 1}">
    `;
      optionsGrid.appendChild(div);
    }

    function resetFormFields() {
      qTextArea.value = '';
      document.querySelectorAll('.opt-input').forEach(inp => inp.value = '');
      document.querySelectorAll('input[name="correct"]').forEach(radio => radio.checked = false);
      document.getElementById('tfTrue').checked = false;
      document.getElementById('tfFalse').checked = false;
      marksInput.value = '1';
      qTypeSelect.value = 'MCQ';
      toggleQuestionTypeUI();
      resetOptionsGridToDefault();
    }

    function resetOptionsGridToDefault() {
      while (optionsGrid.children.length > 4) {
        optionsGrid.removeChild(optionsGrid.lastChild);
      }
      optCount = 4;
      const allOptInputs = optionsGrid.querySelectorAll('.opt-input');
      allOptInputs.forEach(inp => inp.value = '');
      const allRadios = optionsGrid.querySelectorAll('input[name="correct"]');
      allRadios.forEach(radio => radio.checked = false);
    }

    function addQuestionHandler() {
      const qText = qTextArea.value.trim();
      if (!qText) { showToast("⚠️ Please write your question first"); return; }
      const type = qTypeSelect.value;
      const marks = parseInt(marksInput.value);
      if (isNaN(marks) || marks < 1) { showToast("Marks must be at least 1"); return; }
      let typeLabel = type === 'MCQ' ? 'MCQ' : 'True/False';

      if (type === 'MCQ') {
        const optionInputs = optionsGrid.querySelectorAll('.opt-input');
        let optionTexts = [];
        optionInputs.forEach(inp => { let val = inp.value.trim(); if (val !== "") optionTexts.push(val); });
        if (optionTexts.length < 2) { showToast("⚠️ At least two non-empty options required for MCQ"); return; }
        const selectedRadio = optionsGrid.querySelector('input[name="correct"]:checked');
        if (!selectedRadio) { showToast("⚠️ Please select the correct answer (radio button) for MCQ"); return; }
        const correctIdx = parseInt(selectedRadio.value);
        if (correctIdx >= optionTexts.length || !optionTexts[correctIdx]) { showToast("⚠️ Correct option must have valid text"); return; }
        const correctAnswerText = optionTexts[correctIdx];
        questions.push({
          q: qText,
          type: 'TF',
          typeLabel: 'True/False',
          marks,
          correctAnswer: correctValue,
          options: ["True", "False"] // 🔥 FIX
        });
        showToast(`✅ MCQ added: "${qText.substring(0, 40)}..."`);
      } else {
        const tfTrueRadio = document.getElementById('tfTrue');
        const tfFalseRadio = document.getElementById('tfFalse');
        if (!tfTrueRadio.checked && !tfFalseRadio.checked) { showToast("⚠️ Please select the correct answer: True or False"); return; }
        const correctValue = tfTrueRadio.checked ? "True" : "False";
        questions.push({ q: qText, type: 'TF', typeLabel: 'True/False', marks, correctAnswer: correctValue });
        showToast(`✅ True/False added: "${qText.substring(0, 40)}..."`);
      }
      renderQuestionList();
      resetFormFields();
    }

    function renderQuestionList() {
      qCountSpan.textContent = questions.length;
      if (questions.length === 0) {
        qListContainer.innerHTML = `<div class="empty-state"><div class="empty-icon">?</div>No questions added yet. Add your first question below.</div>`;
        return;
      }
      let html = '';
      questions.forEach((q, idx) => {
        let correctMeta = '';
        if (q.type === 'TF') correctMeta = `<span class="tag tag-correct">✔️ Correct: ${escapeHtml(q.correctAnswer)}</span>`;
        else if (q.type === 'MCQ' && q.correctAnswer) {
          let shortAns = q.correctAnswer.length > 25 ? q.correctAnswer.slice(0, 22) + '...' : q.correctAnswer;
          correctMeta = `<span class="tag tag-correct">✓ ${escapeHtml(shortAns)}</span>`;
        }
        html += `<div class="q-item"><div class="q-num">${idx + 1}</div><div class="q-content"><div class="q-text">${escapeHtml(q.q)}</div><div class="q-meta"><span class="tag tag-type">${escapeHtml(q.typeLabel)}</span><span class="tag tag-mark">${q.marks} mark${q.marks > 1 ? 's' : ''}</span>${correctMeta}</div></div><button class="q-delete" data-index="${idx}" title="Remove">✕</button></div>`;
      });
      qListContainer.innerHTML = html;
      document.querySelectorAll('.q-delete').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const index = parseInt(btn.getAttribute('data-index'));
          if (!isNaN(index)) { questions.splice(index, 1); renderQuestionList(); showToast("🗑️ Question removed"); }
        });
      });
      // Scroll control logic
      if (questions.length > 4) {
        qListContainer.style.maxHeight = "300px";
        qListContainer.style.overflowY = "auto";
      } else {
        qListContainer.style.maxHeight = "none";
        qListContainer.style.overflowY = "visible";
      }
    }

    function escapeHtml(str) { if (!str) return ''; return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
    function cancelAllHandler() { if (questions.length > 0 && !confirm('Cancel will delete all added questions. Are you sure?')) return; questions = []; renderQuestionList(); resetFormFields(); showToast("All questions cleared."); }
    async function saveAllHandler() {
      try {
        if (questions.length === 0) {
          alert("No questions!");
          return;
        }

        console.log("Sending Questions:", questions);

        const res = await fetch("/National-Test-Series/save-temp-questions", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ questions })
        });

        const data = await res.json();

        if (data.success) {
          window.location.href = "/test-details";
        } else {
          alert("❌ Failed to save questions");
        }

      } catch (err) {
        console.error("Save Error:", err);
        alert("❌ Server error");
      }
    }
    function translatePlaceholder() { showToast("✨ Auto-translate feature coming soon!"); }

    function init() {
      qTypeSelect.addEventListener('change', toggleQuestionTypeUI);
      addMoreBtn.addEventListener('click', addMoreOption);
      addQuestionBtn.addEventListener('click', addQuestionHandler);
      cancelBtn.addEventListener('click', cancelAllHandler);
      saveBtn.addEventListener('click', saveAllHandler);
      document.getElementById('translateBtn').addEventListener('click', translatePlaceholder);
      toggleQuestionTypeUI();
      resetOptionsGridToDefault();
      renderQuestionList();
    }
    init();
  </script>
</body>

</html>