    function openSchedule(pre) {
      if (pre) document.querySelectorAll('.scb').forEach(b => { if (b.textContent.toLowerCase().includes((pre || '').toLowerCase().slice(0, 5))) b.classList.add('on'); });
      openModal('schedModal');
    }

    function openQuickLead() {
      document.getElementById("quickLeadPopup").style.display = "flex";
    }

    function closeQuickLead() {
      document.getElementById("quickLeadPopup").style.display = "none";
    }

    async function submitQuickLead() {

      const data = {
        name: document.getElementById("ql_name").value,
        phone: document.getElementById("ql_phone").value,
        page: window.location.href
      }

      const res = await fetch("/api/save-lead", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(data)
      })

      const result = await res.json()

      if (result.success) {

        alert("Thanks! We will contact you.");

        closeQuickLead();

      }

    }
    setTimeout(() => {
      openQuickLead();
    }, 6000);
    function showToast(icon, title, sub) {
      clearTimeout(toastTm);
      document.getElementById('toastIcon').textContent = icon;
      document.getElementById('toastTitle').textContent = title;
      document.getElementById('toastSub').textContent = sub;
      const t = document.getElementById('toast');
      t.classList.add('show');
      toastTm = setTimeout(() => t.classList.remove('show'), 3500);
    }
    let userLocation = "";

    fetch("https://ipapi.co/json/")
      .then(res => res.json())
      .then(data => {
        userLocation = data.city + ", " + data.region
      })

    // COUNTERS
    function initCounters() {
      const els = document.querySelectorAll('.hstat-num');
      const t = [120, 80, 15, 5], s = ['+', '+', '+', 'yr'];
      const obs = new IntersectionObserver(e => {
        e.forEach(x => {
          if (x.isIntersecting) {
            const el = x.target, i = [...els].indexOf(el), end = t[i], sf = s[i];
            let c = 0, st = end / 60;
            const ti = setInterval(() => {
              c += st;
              if (c >= end) { el.innerHTML = end + '<span>' + sf + '</span>'; clearInterval(ti); }
              else el.innerHTML = Math.floor(c) + '<span>' + sf + '</span>';
            }, 22);
            obs.unobserve(el);
          }
        });
      }, { threshold: .5 });
      els.forEach(el => obs.observe(el));
    }

    // MODALS
    function openModal(id) { document.getElementById(id).classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeModal(id) {
      document.getElementById(id).classList.remove('open'); document.body.style.overflow = '';
      if (id === 'schedModal') {
        document.getElementById('schedContent').style.display = 'block';
        document.getElementById('schedSuccess').style.display = 'none';
        const b = document.getElementById('submitBtn'); b.disabled = false; b.innerHTML = '<i class="fas fa-paper-plane"></i> Submit My Requirements';
      }
    }
    document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', function (e) { if (e.target === this) closeModal(this.id); }));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeModal('svcModal'); closeModal('schedModal'); } });

    // TOAST
    let toastTm;
    function showToast(icon, title, sub) {
      clearTimeout(toastTm);
      document.getElementById('toastIcon').textContent = icon;
      document.getElementById('toastTitle').textContent = title;
      document.getElementById('toastSub').textContent = sub;
      const t = document.getElementById('toast'); t.classList.add('show');
      toastTm = setTimeout(() => t.classList.remove('show'), 3500);
    }

