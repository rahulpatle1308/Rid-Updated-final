  // FORCE FIX FOR SAMSUNG S10/S24 (360px x 760px / 780px)
  (function() {
    function isSmallDevice() {
      return window.innerWidth <= 380 && window.innerHeight >= 700;
    }
    
    function fixToggleButton() {
      var menuIcon = document.getElementById('menuIcon');
      var menu = document.getElementById('innerCont');
      
      if (!menuIcon || !menu) return;
      
      // Force remove any existing styles
      if (isSmallDevice()) {
        // Force menu icon visible
        menuIcon.style.setProperty('display', 'flex', 'important');
        menuIcon.style.setProperty('z-index', '999999', 'important');
        menuIcon.style.setProperty('position', 'fixed', 'important');
        menuIcon.style.setProperty('top', '18px', 'important');
        menuIcon.style.setProperty('right', '18px', 'important');
        
        // Menu style
        menu.style.setProperty('position', 'fixed', 'important');
        menu.style.setProperty('top', '-100%', 'important');
        menu.style.setProperty('left', '0', 'important');
        menu.style.setProperty('width', '100%', 'important');
        menu.style.setProperty('height', '100vh', 'important');
        menu.style.setProperty('background', 'white', 'important');
        menu.style.setProperty('transition', 'top 0.3s ease', 'important');
        menu.style.setProperty('z-index', '99998', 'important');
        menu.style.setProperty('padding', '80px 20px 30px', 'important');
        menu.style.setProperty('overflow-y', 'auto', 'important');
        
        // Fix button box
        var btnBox = document.querySelector('.btn-box');
        if (btnBox) {
          btnBox.style.setProperty('position', 'fixed', 'important');
          btnBox.style.setProperty('top', '12px', 'important');
          btnBox.style.setProperty('right', '70px', 'important');
          btnBox.style.setProperty('z-index', '999999', 'important');
          btnBox.style.setProperty('background', 'white', 'important');
        }
      }
      
      // Fix menu active class
      menuIcon.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        this.classList.toggle('active');
        menu.classList.toggle('active');
        
        if (menu.classList.contains('active')) {
          if (isSmallDevice()) {
            menu.style.setProperty('top', '0', 'important');
          } else {
            menu.style.setProperty('left', '0', 'important');
          }
          document.body.style.overflow = 'hidden';
        } else {
          if (isSmallDevice()) {
            menu.style.setProperty('top', '-100%', 'important');
          } else {
            menu.style.setProperty('left', '-100%', 'important');
          }
          document.body.style.overflow = '';
        }
      });
      
      // Close menu on outside click
      document.addEventListener('click', function(e) {
        if (menu.classList.contains('active')) {
          if (!menu.contains(e.target) && !menuIcon.contains(e.target)) {
            menu.classList.remove('active');
            menuIcon.classList.remove('active');
            if (isSmallDevice()) {
              menu.style.setProperty('top', '-100%', 'important');
            } else {
              menu.style.setProperty('left', '-100%', 'important');
            }
            document.body.style.overflow = '';
          }
        }
      });
    }
    
    // Run on load and resize
    window.addEventListener('DOMContentLoaded', fixToggleButton);
    window.addEventListener('resize', fixToggleButton);
  })();

  
  // FORCE FIX - TOGGLE BUTTON CLICK
  (function() {
    // Wait for page to load completely
    window.addEventListener('load', function() {
      console.log('Page loaded - fixing toggle button');
      
      var menuIcon = document.getElementById('menuIcon');
      var menu = document.getElementById('innerCont');
      
      if (!menuIcon) {
        console.log('Menu icon not found!');
        return;
      }
      
      if (!menu) {
        console.log('Menu container not found!');
        return;
      }
      
      console.log('Found menu icon and menu container');
      
      // Remove all existing click handlers
      var newMenuIcon = menuIcon.cloneNode(true);
      menuIcon.parentNode.replaceChild(newMenuIcon, menuIcon);
      menuIcon = document.getElementById('menuIcon');
      
      // Add new click handler
      menuIcon.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        console.log('Toggle button clicked');
        
        // Toggle classes
        this.classList.toggle('active');
        menu.classList.toggle('active');
        
        // Check if menu is open
        if (menu.classList.contains('active')) {
          console.log('Menu opened');
          // Force menu visible
          menu.style.display = 'flex';
          menu.style.left = '0';
          document.body.style.overflow = 'hidden';
        } else {
          console.log('Menu closed');
          // Force menu hidden
          if (window.innerWidth <= 768) {
            menu.style.left = '-100%';
          } else {
            menu.style.display = '';
          }
          document.body.style.overflow = '';
        }
      });
      
      // Also try direct style toggle as backup
      menuIcon.addEventListener('touchstart', function(e) {
        // For touch devices
        setTimeout(function() {
          if (menu.classList.contains('active')) {
            menu.style.display = 'flex';
            menu.style.left = '0';
          } else {
            if (window.innerWidth <= 768) {
              menu.style.left = '-100%';
            }
          }
        }, 10);
      });
    });
  })();

  // ========== COMPLETE TOGGLE BUTTON WITH SCROLL FIX ==========
(function() {
  const menuIcon = document.getElementById('menuIcon');
  const menu = document.getElementById('innerCont');
  
  if (menuIcon && menu) {
    // Clean existing listeners
    const newIcon = menuIcon.cloneNode(true);
    menuIcon.parentNode.replaceChild(newIcon, menuIcon);
    const finalIcon = document.getElementById('menuIcon');
    const finalMenu = document.getElementById('innerCont');
    
    finalIcon.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      this.classList.toggle('active');
      finalMenu.classList.toggle('active');
      
      if (finalMenu.classList.contains('active')) {
        // Menu open
        document.body.style.overflow = 'hidden';
        finalMenu.style.overflowY = 'auto';
        finalMenu.style.height = '100%';
      } else {
        // Menu closed
        document.body.style.overflow = '';
        finalMenu.style.overflowY = '';
      }
    });
    
    // Close menu on outside click
    document.addEventListener('click', function(e) {
      if (finalMenu.classList.contains('active')) {
        if (!finalMenu.contains(e.target) && !finalIcon.contains(e.target)) {
          finalMenu.classList.remove('active');
          finalIcon.classList.remove('active');
          document.body.style.overflow = '';
        }
      }
    });
    
    // Fix for window resize
    window.addEventListener('resize', function() {
      if (window.innerWidth > 768 && finalMenu.classList.contains('active')) {
        finalMenu.classList.remove('active');
        finalIcon.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  }
})();
