    // 3-BOX BUILDER
    function buildThreeBoxes() {
      renderBoxList('appList', 'appDetail', 'appDetailInner', APP_SERVICES, 'app', 'sbd-tag-app');
      renderBoxList('webList', 'webDetail', 'webDetailInner', WEB_SERVICES, 'web', 'sbd-tag-web');
      renderBoxList('otherList', 'otherDetail', 'otherDetailInner', OTHER_SERVICES, 'other', 'sbd-tag-other');
    }

    function renderBoxList(listId, detailId, innerId, data, prefix, tagClass) {
      const wrap = document.getElementById(listId);
      if (!wrap) return;
      data.forEach((svc, i) => {
        const key = prefix + '-' + i;
        const div = document.createElement('div');
        div.className = 'svc-box-item';
        div.id = 'sbi-' + key;
        div.style.animationDelay = (i * 0.05) + 's';
        div.innerHTML = `<div class="sbi-bar"></div><div class="sbi-body"><div class="sbi-icon">${svc.icon}</div><div style="flex:1"><div class="sbi-title">${svc.title}</div><div class="sbi-note">${svc.note}</div></div><div class="sbi-arr"><i class="fas fa-chevron-down"></i></div></div>`;
        div.onclick = () => selectBoxItem(key, svc, listId, detailId, innerId, tagClass);
        wrap.appendChild(div);
      });
    }

    function selectBoxItem(key, svc, listId, detailId, innerId, tagClass) {
      const item = document.getElementById('sbi-' + key);
      const detail = document.getElementById(detailId);
      const isActive = item.classList.contains('active');
      document.getElementById(listId).querySelectorAll('.svc-box-item').forEach(el => {
        el.classList.remove('active');
        el.querySelector('.sbi-arr i').className = 'fas fa-chevron-down';
      });
      if (isActive) { detail.classList.remove('open'); return; }
      item.classList.add('active');
      item.querySelector('.sbi-arr i').className = 'fas fa-chevron-up';

      const featuresHTML = (svc.features || []).map(f => `<div class="sbd-feat-row"><div class="sbd-feat-dot">✓</div>${f}</div>`).join('');
      const chipsHTML = (svc.chips || []).map(c => `<span class="sbd-chip">${c}</span>`).join('');
      const subHTML = (svc.subServices || []).map(s => `<div class="sbd-sub-chip"><div class="ssc-icon">${s.icon}</div><div><div class="ssc-label">${s.label}</div><div class="ssc-note">${s.note}</div></div></div>`).join('');

      document.getElementById(innerId).innerHTML = `
        <span class="sbd-tag ${tagClass}">${svc.partTag}</span>
        <div class="sbd-icon">${svc.icon}</div>
        <div class="sbd-title">${svc.title}</div>
        <div class="sbd-desc">${svc.desc}</div>
        ${subHTML ? `<div class="sbd-feat-label">What's Covered</div><div class="sbd-sub-grid">${subHTML}</div>` : ''}
        <div class="sbd-feat-label">What's Included</div>
        <div class="sbd-feat-list">${featuresHTML}</div>
        ${chipsHTML ? `<div class="sbd-chips">${chipsHTML}</div>` : ''}
        <div class="sbd-footer">
          <div class="sbd-price"><small>Starting from</small>${svc.price}</div>
          <button class="sbd-btn-quote" onclick="openSchedule('${svc.title}')"><i class="fas fa-calendar-check"></i> Get Quote</button>
          <button class="sbd-btn-more" onclick="openDetailModal('${key}')"><i class="fas fa-expand-alt"></i> Explore</button>
        </div>`;
      detail.classList.add('open');
      setTimeout(() => item.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 60);
    }

    function openDetailModal(key) {
      const parts = key.split('-');
      const prefix = parts[0], i = parseInt(parts[1]);
      let svc;
      if (prefix === 'app') svc = APP_SERVICES[i];
      else if (prefix === 'web') svc = WEB_SERVICES[i];
      else svc = OTHER_SERVICES[i];
      const subHTML = (svc.subServices || []).map(s => `<div style="display:flex;align-items:center;gap:8px;background:#f2f7fc;border-radius:8px;padding:8px 12px;font-size:.8rem;"><span>${s.icon}</span><strong style="color:var(--primary)">${s.label}</strong><span style="color:var(--gray);margin-left:4px;">${s.note}</span></div>`).join('');
      document.getElementById('svcModalContent').innerHTML = `
        <div class="sdm-icon">${svc.icon}</div>
        <div class="sdm-tag">${svc.partTag}</div>
        <div class="modal-title">${svc.title}</div>
        <p class="sdm-desc">${svc.desc}</p>
        ${subHTML ? `<div class="sdm-features"><h4>What's Covered</h4><div style="display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:18px;">${subHTML}</div></div>` : ''}
        <div class="sdm-features"><h4>What's Included</h4>
        <div class="sdm-feat-list">${(svc.features || []).map(f => `<div class="sdm-feat"><div class="sdm-feat-dot">✓</div>${f}</div>`).join('')}</div></div>
        <div class="sdm-footer"><div><div class="sdm-price-from">Starting from</div><div class="sdm-price-val">${svc.price}</div></div>
        <button class="sdm-quote-btn" onclick="closeModal('svcModal');openSchedule('${svc.title}')"><i class="fas fa-calendar-check"></i> Get a Quote</button></div>`;
      openModal('svcModal');
    }

    // DOMAINS
    function buildDomains() {
      const g = document.getElementById('domainsGrid');
      if (!g) return;
      DOMAINS.forEach(d => { g.innerHTML += `<div class="domain-card" onclick="openSchedule()"><div class="domain-icon">${d.icon}</div><h3>${d.title}</h3><p>${d.desc}</p><span class="domain-count">${d.count}</span></div>`; });
    }

    // TESTIMONIALS
    function buildTestimonials() { renderFeatured(); buildDots(); buildMiniGrid(); }
    function renderFeatured() {
      const t = TESTIMONIALS[testiIdx];
      document.getElementById('testiFeatured').innerHTML = `<div class="testi-stars">${[...Array(t.rating)].map(() => '<i class="fas fa-star"></i>').join('')}${[...Array(5 - t.rating)].map(() => '<i class="far fa-star"></i>').join('')}</div><p class="testi-text">${t.review}</p><div class="testi-author"><div class="tav ${t.ac}">${t.av}</div><div><div class="tauth-name">${t.name}</div><div class="tauth-co">${t.company}</div></div><span class="tauth-tag">${t.project}</span></div>`;
    }
    function buildDots() {
      document.getElementById('testiDots').innerHTML = TESTIMONIALS.map((_, i) => `<button class="tdot${i === testiIdx ? ' active' : ''}" onclick="setTesti(${i})"></button>`).join('');
    }
    function buildMiniGrid() {
      document.getElementById('testiMiniGrid').innerHTML = TESTIMONIALS.map((t, i) => `<div class="testi-mini${i === testiIdx ? ' active' : ''}" onclick="setTesti(${i})"><div class="tm-top"><div class="tav ${t.ac}" style="width:33px;height:33px;font-size:.7rem">${t.av}</div><div><div class="tm-name">${t.name}</div><div class="tm-co">${t.company}</div></div><div class="tm-stars">${'★'.repeat(t.rating)}</div></div><p class="tm-text">${t.review.slice(0, 86)}…</p></div>`).join('');
    }
    function setTesti(i) { testiIdx = i; clearInterval(testiTimer); renderFeatured(); buildDots(); buildMiniGrid(); startTestiTimer(); }
    function startTestiTimer() { testiTimer = setInterval(() => { testiIdx = (testiIdx + 1) % TESTIMONIALS.length; renderFeatured(); buildDots(); buildMiniGrid(); }, 5000); }

    // CASES
    function buildCases() {
      const g = document.getElementById('casesGrid');
      if (!g) return;
      CASES.forEach(c => { g.innerHTML += `<div class="case-card"><div class="case-thumb ${c.thumb}"><span>${c.emoji}</span><span class="case-badge">${c.badge}</span></div><div class="case-body"><div class="case-type ${c.typeClass}">${c.type}</div><div class="case-title">${c.title}</div><div class="case-desc">${c.desc}</div><div class="case-metrics">${c.metrics.map(m => `<span class="cmetric">${m}</span>`).join('')}</div></div></div>`; });
    }

    // SCHEDULE
    function buildSvcCheckboxes() {
      const wrap = document.getElementById('svcCheckboxes');
      if (!wrap) return;
      ['📱 Mobile App', '🌐 Website', '🎨 UI/UX Design', '⚙️ Backend/API', '🚀 DevOps', '🤖 AI/ML', '🛒 E-Commerce', '👨‍💻 Hire Developer', '🔧 Maintenance'].forEach(s => {
        const btn = document.createElement('button'); btn.type = 'button'; btn.className = 'scb'; btn.textContent = s;
        btn.onclick = () => btn.classList.toggle('on'); wrap.appendChild(btn);
      });
    }
    function openSchedule(pre) {
      if (pre) document.querySelectorAll('.scb').forEach(b => { if (b.textContent.toLowerCase().includes((pre || '').toLowerCase().slice(0, 5))) b.classList.add('on'); });
      openModal('schedModal');
    }
 
