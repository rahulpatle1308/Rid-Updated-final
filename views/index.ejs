/* ===== HERO SECTION ===== */
.hero {
  position: relative;
  height: 60vh;
  width: 100%;
  overflow: hidden;
}

/* ===== VIDEO ===== */
.bg-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  z-index: -1;
}

/* ===== OVERLAY ===== */
.overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.25);

  display: flex;
  align-items: center;
  justify-content: flex-start;
  text-align: left;

  padding: 0 80px;
}

/* ===== CONTENT ===== */
.content {
  color: #fff;
  max-width: 600px;
  width: 100%;
}

/* ===== TEXT ===== */
.site-name {
  font-size: 48px;
  font-weight: 700;
  margin-bottom: 10px;
}

.tagline {
  font-size: 22px;
  margin-bottom: 20px;
}

/* ===== LIST ===== */
.content ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.content ul li {
  margin: 8px 0;
  font-size: 18px;
}

/* ===== BUTTON ===== */
.btn {
  display: inline-block;
  margin-top: 20px;
  padding: 12px 25px;
  background: #ff6600;
  color: #fff;
  text-decoration: none;
  border-radius: 6px;
  transition: 0.3s;
}

.btn:hover {
  background: #e65c00;
}

