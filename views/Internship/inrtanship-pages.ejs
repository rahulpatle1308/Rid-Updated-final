                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> About RID</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Research Papers</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Innovation Hub</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Join Community</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Events</a></li>
                    </ul>
                </div>

                <div class="footer-social">
                    <h3>Follow Us</h3>
                    <ul>
                        <li><a href="#"><i class="fab fa-facebook-f"></i> FB</a></li>
                        <li><a href="https://www.linkedin.com/in/rid-bharat-9a4517324" target="_blank"><i
                                    class="fab fa-linkedin-in"></i> IN</a></li>
                        <li><a href="https://youtube.com/@ridbharat" target="_blank"><i class="fab fa-youtube"></i>
                                YT</a></li>
                        <li><a href="https://github.com/RID-bharat25" target="_blank"><i class="fab fa-github"></i>
                                GH</a></li>
                        <li><a href="https://www.instagram.com/ridbharat" target="_blank"><i
                                    class="fab fa-instagram"></i> IG</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <p>©2024 RID | TWF. All Rights Reserved.</p>
                <div class="footer-links-bottom">
                    <a href="#">About</a>
                    <a href="#">Terms</a>
                    <a href="#">Privacy</a>
                    <a href="#">Disclaimer</a>
                    <a href="#">Contact</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize AOS
        AOS.init({
            duration: 800,
            once: true
        });

        // Main Application
        (function () {
            // Storage Keys
            const STORAGE_INTERNSHIPS = 'ridInternHubInternships';
            const STORAGE_APPLICATIONS = 'ridInternHubApplications';

            // Initial Data
            const defaultInternships = [
                {
                    id: '1',
                    title: 'Frontend Developer',
                    company: 'RidTech',
                    location: 'Bhopal',
                    stipend: '5000/mo',
                    category: 'Technology',
                    tags: ['HTML', 'CSS', 'JS', 'React'],
                    daysLeft: '3d',
                    icon: 'fa-code',
                    desc: 'Looking for passionate Frontend Developer.',
                    type: 'Full Time',
                    openings: 3,
                    website: 'https://ridtech.com',
                    email: 'careers@ridtech.com',
                    experience: '0-1 years',
                    duration: '6 months'
                },
                {
                    id: '2',
                    title: 'Digital Marketing',
                    company: 'RidTech',
                    location: 'Bhopal',
                    stipend: '5000/mo',
                    category: 'Marketing',
                    tags: ['SEO', 'Social', 'Content'],
                    daysLeft: '2d',
                    icon: 'fa-chart-line',
                    desc: 'Join marketing team.',
                    type: 'Part Time',
                    openings: 2,
                    website: 'https://ridtech.com',
                    email: 'marketing@ridtech.com',
                    experience: '0-1 years',
                    duration: '3 months'
                },
                {
                    id: '3',
                    title: 'UI/UX Designer',
                    company: 'RidTech',
                    location: 'Hybrid',
                    stipend: '5000/mo',
                    category: 'Design',
                    tags: ['Figma', 'Prototype'],
                    daysLeft: '7d',
                    icon: 'fa-pencil-ruler',
                    desc: 'Create intuitive interfaces.',
                    type: 'Full Time',
                    openings: 1,
                    website: 'https://ridtech.com',
                    email: 'design@ridtech.com',
                    experience: '0-2 years',
                    duration: '6 months'
                }
            ];

            // Initialize storage
            let internships = JSON.parse(localStorage.getItem(STORAGE_INTERNSHIPS));
            if (!internships || internships.length === 0) {
                internships = defaultInternships.map((item, index) => ({
                    ...item,
                    id: Date.now() + index + ''
                }));
                localStorage.setItem(STORAGE_INTERNSHIPS, JSON.stringify(internships));
            }

            // Initialize applications storage
            let applications = JSON.parse(localStorage.getItem(STORAGE_APPLICATIONS)) || [];

            // DOM Elements
            const cardsContainer = document.getElementById('cardsContainer');
            const searchInput = document.getElementById('searchInput');
            const filterCategory = document.getElementById('filterCategory');
            const filterLocation = document.getElementById('filterLocation');
            const filterStipendMin = document.getElementById('filterStipendMin');
            const filterStipendMax = document.getElementById('filterStipendMax');
            const applyFilters = document.getElementById('applyFilters');
            const clearFiltersBtn = document.getElementById('clearFilters');
            const filterItems = document.querySelectorAll('.filter-item');
            const noResultMsg = document.getElementById('noResultMsg');
            const resultCountSpan = document.getElementById('resultCount');
            const filterPanel = document.getElementById('filterPanel');
            const filterToggleBtn = document.getElementById('filterToggleBtn');
            const clearFiltersNoResult = document.getElementById('clearFiltersNoResult');

            // Post Modal elements
            const postModal = document.getElementById('postModal');
            const closePostModal = document.getElementById('closePostModal');
            const cancelPostBtn = document.getElementById('cancelPostBtn');
            const postForm = document.getElementById('postForm');

            // Details Modal elements
            const detailsModal = document.getElementById('detailsModal');
            const closeDetailsModal = document.getElementById('closeDetailsModal');
            const closeDetailsBtn = document.getElementById('closeDetailsBtn');
            const detailsContent = document.getElementById('detailsContent');
            const applyFromDetailsBtn = document.getElementById('applyFromDetailsBtn');

            // Application Modal elements
            const applicationModal = document.getElementById('applicationModal');
            const closeApplicationModal = document.getElementById('closeApplicationModal');
            const cancelApplicationBtn = document.getElementById('cancelApplicationBtn');
            const applicationForm = document.getElementById('applicationForm');
            const applyInternshipId = document.getElementById('applyInternshipId');
            const applyJobTitle = document.getElementById('applyJobTitle');
            const applyCompanyName = document.getElementById('applyCompanyName');

            // Form fields
            const applicantName = document.getElementById('applicantName');
            const applicantEmail = document.getElementById('applicantEmail');
            const applicantPhone = document.getElementById('applicantPhone');
            const applicantCollege = document.getElementById('applicantCollege');
            const applicantYear = document.getElementById('applicantYear');
            const applicantSkills = document.getElementById('applicantSkills');

            // Buttons
            const headerPostBtn = document.getElementById('headerPostBtn');
            const mobilePostBtn = document.getElementById('mobilePostBtn');

            // Mobile Menu
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            const mobileMenu = document.getElementById('mobileMenu');
            const menuOverlay = document.getElementById('menuOverlay');
            const closeMobileMenu = document.getElementById('closeMobileMenu');

            // Stats
            const totalInternshipsSpan = document.getElementById('totalInternships');
            const totalCompaniesSpan = document.getElementById('totalCompanies');

            // Currently selected internship
            let currentInternshipId = null;

            // Mobile Menu Functions
            function openMobileMenu() {
                mobileMenu.classList.add('open');
                menuOverlay.classList.add('open');
                document.body.style.overflow = 'hidden';
            }

            function closeMobileMenuFunc() {
                mobileMenu.classList.remove('open');
                menuOverlay.classList.remove('open');
                document.body.style.overflow = '';
            }

            if (hamburgerBtn) {
                hamburgerBtn.addEventListener('click', openMobileMenu);
            }

            if (closeMobileMenu) {
                closeMobileMenu.addEventListener('click', closeMobileMenuFunc);
            }

            if (menuOverlay) {
                menuOverlay.addEventListener('click', closeMobileMenuFunc);
            }

            // Helper Functions
            function showNotification(msg) {
                alert(msg);
            }

            function saveInternships() {
                localStorage.setItem(STORAGE_INTERNSHIPS, JSON.stringify(internships));
                updateStats();
            }

            function saveApplications() {
                localStorage.setItem(STORAGE_APPLICATIONS, JSON.stringify(applications));
            }

            function updateStats() {
                totalInternshipsSpan.textContent = internships.length;
                const uniqueCompanies = [...new Set(internships.map(i => i.company))].length;
                totalCompaniesSpan.textContent = uniqueCompanies;
            }

       // Render Cards
            function renderCards() {
                let filtered = [...internships];
                const searchTerm = searchInput ? searchInput.value.trim().toLowerCase() : '';

                if (searchTerm) {
                    filtered = filtered.filter(intern =>
                        intern.title.toLowerCase().includes(searchTerm) ||
                        intern.company.toLowerCase().includes(searchTerm) ||
                        (intern.tags && intern.tags.some(t => t.toLowerCase().includes(searchTerm)))
                    );
                }

                const activeItem = document.querySelector('.filter-item.active');
                const cat = activeItem ? activeItem.getAttribute('data-cat') : 'All';
                if (cat !== 'All') {
                    filtered = filtered.filter(intern => intern.category === cat);
                }

                const loc = filterLocation ? filterLocation.value.trim().toLowerCase() : '';
                if (loc) {
                    filtered = filtered.filter(intern => intern.location.toLowerCase().includes(loc));
                }

                const min = parseInt(filterStipendMin ? filterStipendMin.value : '0') || 0;
                const max = parseInt(filterStipendMax ? filterStipendMax.value : '9999') || 9999;
                filtered = filtered.filter(intern => {
                    const num = parseInt(intern.stipend.replace(/[^0-9]/g, '')) || 0;
                    return num >= min && num <= max;
                });

                if (filtered.length === 0) {
                    cardsContainer.innerHTML = '';
                    noResultMsg.classList.remove('hidden');
                    resultCountSpan.textContent = '0 internships';
                } else {
                    noResultMsg.classList.add('hidden');
                    resultCountSpan.textContent = filtered.length + ' internships';

                    let html = '';
                    filtered.forEach(intern => {
                        html += `
                            <div class="glass-card rounded-3xl p-4 sm:p-6 flex flex-col gap-2 sm:gap-3" data-id="${intern.id}" data-aos="fade-up">
                                <div class="flex items-start gap-2 sm:gap-3">
                                    <div class="w-10 h-10 sm:w-14 sm:h-14 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center text-white text-lg sm:text-2xl flex-shrink-0">
                                        <i class="fas ${intern.icon || 'fa-briefcase'}"></i>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-xs sm:text-sm font-medium text-purple-600 truncate">${intern.company}</p>
                                        <h3 class="font-bold text-gray-800 text-base sm:text-xl truncate">${intern.title}</h3>
                                    </div>
                                </div>
                                
                                <div class="flex flex-wrap gap-1 sm:gap-2 text-xs sm:text-sm text-gray-600">
                                    <span><i class="fas fa-map-pin text-purple-400 mr-1"></i>${intern.location}</span>
                                    <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
                                    <span><i class="fas fa-money-bill-wave text-purple-400 mr-1"></i>${intern.stipend}</span>
                                </div>
                                
                                <div class="flex flex-wrap gap-1 mt-1">
                                    ${intern.tags ? intern.tags.slice(0, 3).map(t => `
                                        <span class="px-2 sm:px-3 py-1 bg-purple-100 text-purple-700 text-xs rounded-full font-medium">${t}</span>
                                    `).join('') : ''}
                                    ${intern.tags && intern.tags.length > 3 ? `<span class="px-2 sm:px-3 py-1 bg-purple-100 text-purple-700 text-xs rounded-full font-medium">+${intern.tags.length - 3}</span>` : ''}
                                </div>
                                
                                <div class="flex justify-between items-center mt-2">
                                    <span class="text-xs text-gray-400 bg-gray-100 px-2 sm:px-3 py-1 rounded-full">
                                        <i class="far fa-clock mr-1"></i>${intern.daysLeft || 'new'}
                                    </span>
                                    <div class="flex gap-1 sm:gap-2">
                                        <button class="details-btn details-btn-click px-3 sm:px-4 py-1 sm:py-2 text-xs sm:text-sm" data-id="${intern.id}">
                                            <i class="fas fa-info-circle"></i> Details
                                        </button>
                                        <button class="apply-btn bg-gradient-to-r from-purple-600 to-pink-600 text-white px-3 sm:px-4 py-1 sm:py-2 rounded-full text-xs sm:text-sm hover:shadow-lg transition-all transform hover:scale-105"
                                                data-id="${intern.id}"
                                                data-title="${intern.title}"
                                                data-company="${intern.company}">
                                            Apply
                                        </button>
                                    </div>
                                </div>
                            </div>
                        `;
                    });

                    cardsContainer.innerHTML = html;
                }
            }

            // Event Listeners
            filterItems.forEach(item => {
                item.addEventListener('click', function () {
                    filterItems.forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                    if (filterCategory) {
                        filterCategory.value = this.getAttribute('data-cat');
                    }
                    renderCards();
                });
            });

            if (searchInput) {
                searchInput.addEventListener('input', renderCards);
            }

            if (applyFilters) {
                applyFilters.addEventListener('click', renderCards);
            }

            if (clearFiltersBtn) {
                clearFiltersBtn.addEventListener('click', () => {
                    if (filterLocation) filterLocation.value = '';
                    if (filterStipendMin) filterStipendMin.value = '';
                    if (filterStipendMax) filterStipendMax.value = '';
                    if (filterCategory) filterCategory.value = 'All';
                    filterItems.forEach(i => i.classList.remove('active'));
                    const allItem = document.querySelector('.filter-item[data-cat="All"]');
                    if (allItem) allItem.classList.add('active');
                    renderCards();
                });
            }

            if (clearFiltersNoResult) {
                clearFiltersNoResult.addEventListener('click', () => {
                    if (clearFiltersBtn) clearFiltersBtn.click();
                });
            }

            if (filterToggleBtn) {
                filterToggleBtn.addEventListener('click', () => {
                    if (filterPanel) filterPanel.classList.toggle('hidden');
                });
            }

            if (filterCategory) {
                filterCategory.addEventListener('change', function () {
                    const val = this.value;
                    filterItems.forEach(i => i.classList.remove('active'));
                    const selectedItem = document.querySelector(`.filter-item[data-cat="${val}"]`);
                    if (selectedItem) selectedItem.classList.add('active');
                    renderCards();
                });
            }

            // Post Modal Functions
            function openPostModal() {
                postModal.classList.remove('hidden');
                document.body.classList.add('modal-open');
            }

            function closePostModalFunc() {
                postModal.classList.add('hidden');
                document.body.classList.remove('modal-open');
                if (postForm) postForm.reset();
            }

            if (headerPostBtn) {
                headerPostBtn.addEventListener('click', openPostModal);
            }

            if (mobilePostBtn) {
                mobilePostBtn.addEventListener('click', function () {
                    closeMobileMenuFunc();
                    openPostModal();
                });
            }

            if (closePostModal) {
                closePostModal.addEventListener('click', closePostModalFunc);
            }

            if (cancelPostBtn) {
                cancelPostBtn.addEventListener('click', closePostModalFunc);
            }

            // Post Form Submit
            if (postForm) {
                postForm.addEventListener('submit', (e) => {
                    e.preventDefault();

                    const title = document.getElementById('postTitle').value.trim();
                    const company = document.getElementById('postCompany').value.trim();
                    const location = document.getElementById('postLocation').value.trim();
                    const stipend = document.getElementById('postStipend').value.trim();
                    const category = document.getElementById('postCategory').value;
                    const type = document.getElementById('postType').value.trim() || 'Internship';
                    const openings = parseInt(document.getElementById('postOpenings').value) || 1;
                    const tags = document.getElementById('postTags').value.split(',').map(t => t.trim()).filter(t => t);
                    const desc = document.getElementById('postDesc').value.trim();
                    const website = document.getElementById('postWebsite').value.trim();
                    const email = document.getElementById('postEmail').value.trim();
                    const experience = document.getElementById('postExperience').value.trim();
                    const duration = document.getElementById('postDuration').value.trim();

                    if (!title || !company || !location || !stipend || !category || !desc) {
                        showNotification('Please fill all required fields');
                        return;
                    }

                    const newIntern = {
                        id: Date.now() + '-' + Math.random().toString(36).substr(2, 9),
                        title,
                        company,
                        location,
                        stipend,
                        category,
                        type,
                        openings,
                        tags: tags.length ? tags : ['internship'],
                        daysLeft: 'new',
                        icon: 'fa-bolt',
                        desc,
                        website,
                        email,
                        experience,
                        duration
                    };

                    internships.push(newIntern);
                    saveInternships();
                    postForm.reset();
                    closePostModalFunc();
                    renderCards();
                    showNotification('✅ Internship posted successfully!');
                });
            }

            // Modal Backdrop Close
            window.addEventListener('click', (e) => {
                if (e.target === postModal) {
                    closePostModalFunc();
                }
                if (e.target === detailsModal) {
                    closeDetailsModalFunc();
                }
                if (e.target === applicationModal) {
                    closeApplicationModalFunc();
                }
            });

            // Details Modal Functions
            function openDetailsModal(internshipId) {
                const internship = internships.find(i => i.id === internshipId);
                if (!internship) return;

                currentInternshipId = internshipId;

                detailsContent.innerHTML = `
                    <div class="flex items-center gap-3 sm:gap-4 mb-4 sm:mb-6">
                        <div class="w-16 h-16 sm:w-20 sm:h-20 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center text-white text-2xl sm:text-3xl">
                            <i class="fas ${internship.icon || 'fa-briefcase'}"></i>
                        </div>
                        <div>
                            <h4 class="text-xl sm:text-2xl font-bold text-gray-800">${internship.title}</h4>
                            <p class="text-base sm:text-lg text-gray-600">${internship.company}</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-2 sm:gap-3 mb-4">
                        <div class="job-detail-item">
                            <div class="job-detail-icon"><i class="fas fa-map-pin"></i></div>
                            <div>
                                <p class="text-xs text-gray-500">Location</p>
                                <p class="font-semibold text-gray-800 text-sm sm:text-base">${internship.location}</p>
                            </div>
                        </div>
                        <div class="job-detail-item">
                            <div class="job-detail-icon"><i class="fas fa-money-bill-wave"></i></div>
                            <div>
                                <p class="text-xs text-gray-500">Stipend</p>
                                <p class="font-semibold text-gray-800 text-sm sm:text-base">${internship.stipend}</p>
                            </div>
                        </div>
                        <div class="job-detail-item">
                            <div class="job-detail-icon"><i class="fas fa-briefcase"></i></div>
                            <div>
                                <p class="text-xs text-gray-500">Type</p>
                                <p class="font-semibold text-gray-800 text-sm sm:text-base">${internship.type || 'Not specified'}</p>
                            </div>
                        </div>
                        <div class="job-detail-item">
                            <div class="job-detail-icon"><i class="fas fa-users"></i></div>
                            <div>
                                <p class="text-xs text-gray-500">Openings</p>
                                <p class="font-semibold text-gray-800 text-sm sm:text-base">${internship.openings || 1}</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <p class="text-sm font-semibold text-gray-700 mb-2">Skills</p>
                        <div class="flex flex-wrap gap-2">
                            ${internship.tags ? internship.tags.map(tag =>
                    `<span class="tag">${tag}</span>`
                ).join('') : '<span class="text-gray-500">No skills specified</span>'}
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <p class="text-sm font-semibold text-gray-700 mb-2">Description</p>
                        <p class="text-gray-600 leading-relaxed text-sm sm:text-base">${internship.desc || 'No description provided.'}</p>
                    </div>
                `;

                detailsModal.classList.remove('hidden');
                document.body.classList.add('modal-open');
            }

            function closeDetailsModalFunc() {
                detailsModal.classList.add('hidden');
                document.body.classList.remove('modal-open');
                currentInternshipId = null;
            }

            if (closeDetailsModal) {
                closeDetailsModal.addEventListener('click', closeDetailsModalFunc);
            }

            if (closeDetailsBtn) {
                closeDetailsBtn.addEventListener('click', closeDetailsModalFunc);
            }

            // Apply from details button
            if (applyFromDetailsBtn) {
                applyFromDetailsBtn.addEventListener('click', function () {
                    if (currentInternshipId) {
                        const internship = internships.find(i => i.id === currentInternshipId);
                        if (internship) {
                            closeDetailsModalFunc();
                            openApplicationModal(currentInternshipId, internship.title, internship.company);
                        }
                    }
                });
            }

            // Application Modal Functions
            function openApplicationModal(jobId, jobTitle, companyName) {
                applyInternshipId.value = jobId;
                applyJobTitle.textContent = jobTitle;
                applyCompanyName.textContent = companyName;
                applicationModal.classList.remove('hidden');
                document.body.classList.add('modal-open');
            }

            function closeApplicationModalFunc() {
                applicationModal.classList.add('hidden');
                document.body.classList.remove('modal-open');
                if (applicationForm) applicationForm.reset();
            }

            if (closeApplicationModal) {
                closeApplicationModal.addEventListener('click', closeApplicationModalFunc);
            }

            if (cancelApplicationBtn) {
                cancelApplicationBtn.addEventListener('click', closeApplicationModalFunc);
            }

            // Application Form Submit
            if (applicationForm) {
                applicationForm.addEventListener('submit', (e) => {
                    e.preventDefault();

                    const name = applicantName.value.trim();
                    const email = applicantEmail.value.trim();
                    const phone = applicantPhone.value.trim();
                    const college = applicantCollege.value.trim();
                    const year = applicantYear.value;
                    const skills = applicantSkills.value.split(',').map(s => s.trim()).filter(s => s);

                    if (!name || !email || !phone || !college || !year || skills.length === 0) {
                        showNotification('Please fill all required fields');
                        return;
                    }

                    const internship = internships.find(i => i.id === applyInternshipId.value);

                    const application = {
                        id: Date.now() + '-' + Math.random().toString(36).substr(2, 9),
                        internshipId: applyInternshipId.value,
                        internshipTitle: internship.title,
                        companyName: internship.company,
                        applicantName: name,
                        applicantEmail: email,
                        applicantPhone: phone,
                        applicantCollege: college,
                        applicantYear: year,
                        applicantSkills: skills,
                        appliedAt: new Date().toISOString(),
                        status: 'pending'
                    };

                    applications.push(application);
                    saveApplications();

                    closeApplicationModalFunc();
                    showNotification('✅ Application submitted successfully!');
                });
            }

            // Card button clicks
            if (cardsContainer) {
                cardsContainer.addEventListener('click', (e) => {
                    const detailsBtn = e.target.closest('.details-btn-click');
                    if (detailsBtn) {
                        e.preventDefault();
                        openDetailsModal(detailsBtn.getAttribute('data-id'));
                    }

                    const applyBtn = e.target.closest('.apply-btn');
                    if (applyBtn) {
                        e.preventDefault();
                        openApplicationModal(
                            applyBtn.getAttribute('data-id'),
                            applyBtn.getAttribute('data-title'),
                            applyBtn.getAttribute('data-company')
                        );
                    }
                });
            }

            // Initialize
            updateStats();
            renderCards();
// set defalrt
            // Set default active item if none
            const allItem = document.querySelector('.filter-item[data-cat="All"]');
            if (allItem && !document.querySelector('.filter-item.active')) {
                allItem.classList.add('active');
            }
        })();
    </script>
</body>

</html>