<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <title>Rid InternHub ✦ Where Dreams Take Flight</title>

    <!-- Modern Logo - Favicon for browser tab -->
    <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cdefs%3E%3ClinearGradient id='grad' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' style='stop-color:%23667eea;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23764ba2;stop-opacity:1' /%3E%3C/linearGradient%3E%3C/defs%3E%3Ccircle cx='50' cy='50' r='45' fill='url(%23grad)'/%3E%3Cpath d='M35 35 L65 35 L55 50 L65 65 L35 65 L45 50 L35 35' fill='white' stroke='white' stroke-width='2'/%3E%3Ccircle cx='50' cy='50' r='6' fill='%23667eea'/%3E%3C/svg%3E">
    <link rel="apple-touch-icon"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cdefs%3E%3ClinearGradient id='grad' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' style='stop-color:%23667eea;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23764ba2;stop-opacity:1' /%3E%3C/linearGradient%3E%3C/defs%3E%3Ccircle cx='50' cy='50' r='45' fill='url(%23grad)'/%3E%3Cpath d='M35 35 L65 35 L55 50 L65 65 L35 65 L45 50 L35 35' fill='white' stroke='white' stroke-width='2'/%3E%3Ccircle cx='50' cy='50' r='6' fill='%23667eea'/%3E%3C/svg%3E">

    <!-- Fonts & Libraries -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        :root {
            --primary: #083d5d;
            --primary-dark: #062a41;
            --secondary: #4da8da;
            --accent: #ff6b35;
            --light: #f2f7fc;
            --dark: #333;
            --gray: #555;
            --light-gray: #e0e0e0;
            --white: #ffffff;
            --shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Plus Jakarta Sans', 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
            width: 100%;
        }

        body.modal-open {
            overflow: hidden;
        }

        /* Animated Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background:
                radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* Floating Particles - Responsive */
        .particle {
            position: fixed;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            pointer-events: none;
            z-index: 0;
            animation: float 20s infinite;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0) rotate(0deg);
            }

            25% {
                transform: translateY(-100px) rotate(90deg);
            }

            75% {
                transform: translateY(100px) rotate(-90deg);
            }
        }

        /* Modern Glass Effect */
        .glass-modern {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.2);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .glass-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 30px 60px -15px rgba(102, 126, 234, 0.5);
        }

        /* Gradient Buttons */
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-weight: 600;
            padding: 0.75rem 2rem;
            border-radius: 50px;
            transition: all 0.3s;
            box-shadow: 0 10px 20px -8px rgba(102, 126, 234, 0.4);
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            min-height: 48px;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 30px -8px rgba(102, 126, 234, 0.6);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid rgba(255, 255, 255, 0.3);
            color: white;
            font-weight: 600;
            padding: 0.75rem 2rem;
            border-radius: 50px;
            transition: all 0.3s;
            backdrop-filter: blur(5px);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            min-height: 48px;
        }

        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: white;
            transform: translateY(-2px);
        }

        /* Post Button in Header */
        .btn-post {
            background: linear-gradient(135deg, #ff6b6b, #ff8e53);
            color: white;
            font-weight: 700;
            padding: 0.6rem 1.8rem;
            border-radius: 50px;
            transition: all 0.3s;
            box-shadow: 0 10px 20px -8px rgba(255, 107, 107, 0.4);
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            min-height: 44px;
            font-size: 1rem;
            letter-spacing: 0.3px;
        }

        .btn-post:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 20px 30px -8px rgba(255, 107, 107, 0.6);
        }

        .btn-post i {
            font-size: 1.1rem;
        }

        /* Filter Bar - Fully Responsive */
        .filter-bar {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: clamp(5px, 1vw, 10px);
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 60px;
            padding: clamp(6px, 1.5vw, 8px) clamp(10px, 2vw, 16px);
        }

        .filter-item {
            padding: clamp(5px, 1vw, 8px) clamp(12px, 2vw, 20px);
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            backdrop-filter: blur(5px);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: clamp(4px, 1vw, 8px);
            font-size: clamp(0.7rem, 2vw, 0.95rem);
            white-space: nowrap;
            min-width: clamp(70px, 15vw, 90px);
        }

        .filter-item:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .filter-item.active {
            background: white;
            color: #667eea;
            border: none;
            box-shadow: 0 10px 20px -8px rgba(255, 255, 255, 0.5);
        }

        .stat-item {
            padding: clamp(5px, 1vw, 8px) clamp(12px, 2vw, 20px);
            border-radius: 50px;
            font-weight: 600;
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: clamp(4px, 1vw, 8px);
            font-size: clamp(0.7rem, 2vw, 0.95rem);
            white-space: nowrap;
            min-width: clamp(80px, 16vw, 110px);
        }

        .stat-item i {
            font-size: clamp(0.8rem, 2vw, 1rem);
            color: rgba(255, 255, 255, 0.8);
        }

        /* Mobile Responsive - Enhanced */
        @media (max-width: 768px) {
            .filter-bar {
                border-radius: 30px;
                padding: 10px;
                gap: 6px;
                justify-content: flex-start;
                overflow-x: auto;
                flex-wrap: nowrap;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
            }

            .filter-bar::-webkit-scrollbar {
                display: none;
            }

            .filter-item,
            .stat-item {
                padding: 6px 12px;
                font-size: 0.75rem;
                min-width: auto;
                flex-shrink: 0;
            }

            .btn-post {
                padding: 0.4rem 1rem;
                font-size: 0.8rem;
                min-height: 36px;
            }
        }

        @media (max-width: 480px) {

            .filter-item,
            .stat-item {
                padding: 5px 10px;
                font-size: 0.7rem;
                gap: 4px;
            }

            .btn-post {
                padding: 0.35rem 0.8rem;
                font-size: 0.75rem;
            }
        }

        /* Input Fields - Responsive */
        .input-modern {
            width: 100%;
            padding: clamp(0.5rem, 2vw, 0.6rem) clamp(1rem, 3vw, 1.2rem) clamp(0.5rem, 2vw, 0.6rem) clamp(2rem, 5vw, 2.5rem);
            border-radius: 50px;
            border: 2px solid rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.15);
            color: white;
            transition: all 0.3s;
            backdrop-filter: blur(5px);
            font-size: clamp(12px, 3vw, 14px);
        }

        .input-modern:focus {
            outline: none;
            border-color: white;
            background: rgba(255, 255, 255, 0.25);
            box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.1);
        }

        .input-modern::placeholder {
            color: rgba(255, 255, 255, 0.7);
            font-size: clamp(12px, 3vw, 14px);
        }

        /* Mobile Menu - Improved */
        .mobile-menu {
            position: fixed;
            top: 0;
            right: -100%;
            width: min(80%, 320px);
            height: 100vh;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(20px);
            border-left: 1px solid rgba(255, 255, 255, 0.3);
            transition: right 0.3s ease;
            z-index: 100;
            padding: 2rem 1.5rem;
        }

        .mobile-menu.open {
            right: 0;
        }

        .menu-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
            z-index: 99;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
        }

        .menu-overlay.open {
            opacity: 1;
            visibility: visible;
        }

        .hamburger-btn {
            display: none;
            background: rgba(255, 255, 255, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 12px;
            width: clamp(40px, 8vw, 48px);
            height: clamp(40px, 8vw, 48px);
            align-items: center;
            justify-content: center;
            color: white;
            font-size: clamp(1.2rem, 4vw, 1.5rem);
            cursor: pointer;
        }

        @media (max-width: 768px) {
            .hamburger-btn {
                display: flex;
            }
        }

        /* Modern Logo - Responsive */
        .logo-container {
            display: flex;
            align-items: center;
            gap: clamp(0.3rem, 2vw, 0.5rem);
        }

        .modern-logo {
            width: clamp(32px, 6vw, 40px);
            height: clamp(32px, 6vw, 40px);
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 20px -5px rgba(102, 126, 234, 0.5);
        }

        .modern-logo::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.4), transparent);
            transform: rotate(45deg);
            animation: logoShine 3s infinite;
        }

        @keyframes logoShine {
            0% {
                transform: translateX(-100%) rotate(45deg);
            }

            20%,
            100% {
                transform: translateX(100%) rotate(45deg);
            }
        }

        .modern-logo svg {
            width: clamp(20px, 4vw, 24px);
            height: clamp(20px, 4vw, 24px);
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
            z-index: 2;
        }

        .brand-name {
            font-size: clamp(1rem, 4vw, 1.3rem);
            font-weight: 700;
            color: white;
        }

        .brand-name span {
            color: #e0e7ff;
        }

        /* Header Search - Responsive */
        .header-search {
            flex: 2;
            max-width: min(600px, 40vw);
            margin: 0 clamp(0.3rem, 2vw, 1rem);
            position: relative;
        }

        .header-search i {
            position: absolute;
            left: clamp(8px, 2vw, 12px);
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.6);
            font-size: clamp(0.8rem, 2vw, 0.9rem);
            z-index: 1;
        }

        /* Right side buttons container */
        .right-buttons {
            display: flex;
            align-items: center;
            gap: clamp(0.3rem, 1vw, 0.5rem);
            flex-shrink: 0;
        }

        /* Responsive Breakpoints */
        @media (max-width: 1024px) {
            .header-search {
                max-width: 350px;
            }
        }

        @media (max-width: 768px) {
            .header-search {
                display: none;
            }

            .brand-name {
                font-size: 1.1rem;
            }
        }

        @media (max-width: 640px) {
            .right-buttons {
                gap: 0.25rem;
            }

            .filter-toggle-btn {
                padding: 0.4rem 0.8rem;
                font-size: 0.75rem;
            }
        }

        /* Modal Styles - Responsive */
        .modal-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .modal-modern {
            background: white;
            border-radius: clamp(1rem, 3vw, 2rem);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            width: 100%;
            max-width: min(600px, 90vw);
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            z-index: 10000;
            animation: modalPop 0.3s ease-out;
        }

        @keyframes modalPop {
            0% {
                opacity: 0;
                transform: scale(0.9);
            }

            100% {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* Form Inputs in Modal - Responsive */
        .modal-modern input,
        .modal-modern select,
        .modal-modern textarea {
            background: #f8f9fa;
            border: 1px solid #e2e8f0;
            color: #1a202c;
            font-size: clamp(14px, 3vw, 16px);
            padding: clamp(0.6rem, 2vw, 0.75rem) clamp(0.8rem, 2.5vw, 1rem);
        }

        /* Details Button - Responsive */
        .details-btn {
            background: rgba(102, 126, 234, 0.1);
            color: #667eea;
            border: 1px solid rgba(102, 126, 234, 0.3);
            padding: clamp(0.4rem, 1.5vw, 0.5rem) clamp(0.8rem, 2vw, 1rem);
            border-radius: 50px;
            font-size: clamp(0.75rem, 2vw, 0.9rem);
            font-weight: 600;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Job Details in Modal - Responsive */
        .job-detail-item {
            display: flex;
            align-items: center;
            gap: clamp(0.5rem, 2vw, 1rem);
            padding: clamp(0.5rem, 1.5vw, 0.75rem);
            background: rgba(102, 126, 234, 0.05);
            border-radius: 1rem;
            border: 1px solid rgba(102, 126, 234, 0.1);
        }

        .job-detail-icon {
            width: clamp(32px, 6vw, 40px);
            height: clamp(32px, 6vw, 40px);
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .tag {
            padding: 0.25rem clamp(0.6rem, 2vw, 1rem);
            background: rgba(102, 126, 234, 0.1);
            color: #667eea;
            border-radius: 50px;
            font-size: clamp(0.7rem, 2vw, 0.85rem);
            font-weight: 500;
        }

        /* Filter Toggle Button - Responsive */
        .filter-toggle-btn {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: white;
            padding: clamp(0.4rem, 1.5vw, 0.5rem) clamp(0.8rem, 2vw, 1.2rem);
            border-radius: 50px;
            font-size: clamp(0.75rem, 2vw, 0.9rem);
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        /* ===== RID BHARAT FOOTER STYLES - FULLY RESPONSIVE ===== */
        footer {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: var(--white);
            padding: clamp(20px, 5vw, 30px) 0 0;
            position: relative;
            overflow: hidden;
            margin-top: 50px;
            width: 100%;
        }

        .footer-content {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: clamp(15px, 3vw, 30px);
        }

        .footer-logo {
            display: flex;
            flex-direction: column;
        }

        .footer-logo img {
            max-width: min(180px, 40vw);
            height: auto;
            margin-bottom: 10px;
            background: #fff;
            padding: 5px;
            border-radius: 6px;
        }

        .footer-logo p {
            margin-bottom: 8px;
            color: var(--light-gray);
            font-size: clamp(0.7rem, 2vw, 0.8rem);
            line-height: 1.4;
        }

        .contact-info p {
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: clamp(0.7rem, 2vw, 0.8rem);
            flex-wrap: wrap;
        }

        .contact-info i {
            color: var(--secondary);
            width: 14px;
            font-size: 0.8rem;
        }

        .footer-links h3,
        .footer-social h3 {
            font-size: clamp(0.85rem, 2.5vw, 1rem);
            margin-bottom: 12px;
            position: relative;
            padding-bottom: 6px;
            font-weight: 600;
            color: white;
        }

        .footer-links h3:after,
        .footer-social h3:after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 30px;
            height: 2px;
            background: var(--secondary);
            border-radius: 2px;
        }

        .footer-links ul li {
            margin-bottom: 8px;
            transition: transform 0.3s;
        }

        .footer-links a {
            color: var(--light-gray);
            transition: color 0.3s;
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: clamp(0.7rem, 2vw, 0.8rem);
            text-decoration: none;
            flex-wrap: wrap;
        }

        .footer-links a:hover {
            color: var(--white);
        }

        .footer-links a i {
            color: var(--secondary);
            font-size: 0.7rem;
        }

        .footer-social ul {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .footer-social a {
            display: flex;
            align-items: center;
            gap: 5px;
            color: var(--light-gray);
            transition: all 0.3s;
            padding: clamp(4px, 1.5vw, 5px) clamp(6px, 2vw, 10px);
            background: rgba(255, 255, 255, 0.1);
            border-radius: 5px;
            font-size: clamp(0.7rem, 2vw, 0.8rem);
            text-decoration: none;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding: 15px 0;
            text-align: center;
            color: var(--light-gray);
            font-size: clamp(0.65rem, 2vw, 0.75rem);
            margin-top: 30px;
        }

        .footer-links-bottom {
            display: flex;
            justify-content: center;
            gap: clamp(8px, 2vw, 12px);
            margin-top: 8px;
            flex-wrap: wrap;
        }

        .footer-links-bottom a {
            color: var(--light-gray);
            transition: color 0.3s;
            position: relative;
            font-size: clamp(0.65rem, 2vw, 0.75rem);
            text-decoration: none;
        }

        .footer-links-bottom a:not(:last-child)::after {
            content: '|';
            position: absolute;
            right: -8px;
            color: var(--secondary);
        }

        /* Responsive Footer Breakpoints */
        @media (max-width: 992px) {
            .footer-content {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 600px) {
            .footer-content {
                grid-template-columns: 1fr;
                text-align: center;
