                transform: translateX(-50%);
            }

            .footer-links a {
                justify-content: center;
            }

            .footer-social a {
                justify-content: center;
            }
        }

        /* Cards Grid - Fully Responsive */
        #cardsContainer {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
            gap: clamp(1rem, 3vw, 1.5rem);
        }

        /* Filter Panel - Responsive */
        #filterPanel {
            padding: clamp(1rem, 3vw, 1.5rem);
        }

        #filterPanel .grid {
            gap: clamp(0.8rem, 2vw, 1rem);
        }

        /* Typography Responsive */
        h2 {
            font-size: clamp(1.5rem, 5vw, 2rem);
        }

        .text-sm {
            font-size: clamp(0.7rem, 2vw, 0.875rem);
        }

        .text-xs {
            font-size: clamp(0.6rem, 1.8vw, 0.75rem);
        }

        /* Container Padding Responsive */
        .container,
        .max-w-7xl {
            padding-left: clamp(0.8rem, 3vw, 1rem);
            padding-right: clamp(0.8rem, 3vw, 1rem);
        }

        /* Spacing Responsive */
        .py-4 {
            padding-top: clamp(0.8rem, 2.5vw, 1rem);
            padding-bottom: clamp(0.8rem, 2.5vw, 1rem);
        }

        .py-6 {
            padding-top: clamp(1.2rem, 3vw, 1.5rem);
            padding-bottom: clamp(1.2rem, 3vw, 1.5rem);
        }

        .px-4 {
            padding-left: clamp(0.8rem, 2.5vw, 1rem);
            padding-right: clamp(0.8rem, 2.5vw, 1rem);
        }

        .gap-6 {
            gap: clamp(1rem, 3vw, 1.5rem);
        }

        .mb-6 {
            margin-bottom: clamp(1rem, 3vw, 1.5rem);
        }

        .mt-2 {
            margin-top: clamp(0.3rem, 1.5vw, 0.5rem);
        }

        .h-16 {
            height: clamp(3.5rem, 10vw, 4rem);
        }

        /* Ensure touch targets are large enough on mobile */
        @media (max-width: 768px) {

            button,
            .filter-item,
            .stat-item,
            .details-btn,
            .apply-btn,
            .btn-post,
            .filter-toggle-btn {
                min-height: 40px;
            }

            .filter-item,
            .stat-item {
                min-height: 36px;
            }
        }

        /* Landscape mode optimization */
        @media (max-height: 500px) and (orientation: landscape) {
            .modal-modern {
                max-height: 85vh;
            }

            .mobile-menu {
                padding: 1rem;
